                        if Length(syllables_local) <= 4 then
                        begin
                            Inc(candidate.score, c_prefix_short_query_phrase_bonus);
                        end;
                    end;
                    Dec(candidate.score, (Length(syllables_local) - prefix_count) *
                        c_prefix_remaining_penalty);

                    SetLength(out_candidates, Length(out_candidates) + 1);
                    out_candidates[High(out_candidates)] := candidate;
                    seen.AddOrSetValue(seen_key, 1);
                    Inc(accepted_total);
                    Inc(accepted_for_prefix);
                end;
            end;
        finally
            seen.Free;
        end;

        sort_candidates_lightweight(out_candidates);
        Result := Length(out_candidates) > 0;
    end;

    function build_exact_head_modal_tail_complete_candidates(const query_text: string;
        out out_candidates: TncCandidateList): Boolean;
    const
        c_head_modal_complete_limit = 3;
        c_head_modal_complete_bonus = 1280;
    var
        normalized_query: string;
        syllables_local: TncPinyinParseResult;
        head_key: string;
        tail_key: string;
        tail_text: string;
        tail_units: TArray<string>;
        tail_syllable_count: Integer;
        idx: Integer;
        head_results: TncCandidateList;
        candidate: TncCandidate;
        accepted_count: Integer;
        score_value: Integer;
        path_hint: Integer;
        tail_path: string;
    begin
        SetLength(out_candidates, 0);
        Result := False;
        if m_dictionary = nil then
        begin
            Exit;
        end;

        normalized_query := normalize_pinyin_text(query_text);
        if normalized_query = '' then
        begin
            Exit;
        end;

        syllables_local := get_effective_compact_pinyin_syllables(normalized_query);
        if Length(syllables_local) < 3 then
        begin
            Exit;
        end;

        tail_key := normalize_pinyin_text(syllables_local[High(syllables_local)].text);
        tail_text := '';
        SetLength(tail_units, 0);
        tail_syllable_count := 0;
        if tail_key = 'ba' then
        begin
            tail_text := string(Char($5427));
        end
        else if tail_key = 'ma' then
        begin
            tail_text := string(Char($5417));
        end
        else if tail_key = 'ne' then
        begin
            tail_text := string(Char($5462));
        end
        else if tail_key = 'a' then
        begin
            tail_text := string(Char($554A));
        end
        else if tail_key = 'ya' then
        begin
            tail_text := string(Char($5440));
        end
        else if tail_key = 'la' then
        begin
            tail_text := string(Char($5566));
        end
        else if tail_key = 'le' then
        begin
            tail_text := string(Char($4E86));
        end
        else if tail_key = 'wa' then
        begin
            tail_text := string(Char($54C7));
        end;
        if tail_key = 'le' then
        begin
            tail_units := TArray<string>.Create(tail_text);
            tail_syllable_count := 1;
        end
        else if tail_text <> '' then
        begin
            if (Length(syllables_local) >= 2) and
                SameText(normalize_pinyin_text(
                syllables_local[High(syllables_local) - 1].text), 'le') then
            begin
                tail_units := TArray<string>.Create(string(Char($4E86)), tail_text);
                tail_syllable_count := 2;
            end
            else
            begin
                tail_units := TArray<string>.Create(tail_text);
                tail_syllable_count := 1;
            end;
        end;
        if tail_syllable_count <= 0 then
        begin
            Exit;
        end;

        head_key := '';
        for idx := 0 to High(syllables_local) - tail_syllable_count do
        begin
            head_key := head_key + normalize_pinyin_text(syllables_local[idx].text);
        end;
        if head_key = '' then
        begin
            Exit;
        end;

        if not dictionary_exact_lookup_cached(head_key, head_results) then
        begin
            Exit;
        end;

        accepted_count := 0;
        for idx := 0 to High(head_results) do
        begin
            if accepted_count >= c_head_modal_complete_limit then
            begin
                Break;
            end;
            if Trim(head_results[idx].comment) <> '' then
            begin
                Continue;
            end;
            if get_candidate_text_unit_count(Trim(head_results[idx].text)) <>
                (Length(syllables_local) - tail_syllable_count) then
            begin
                Continue;
            end;

            candidate := head_results[idx];
            score_value := candidate.score;
            if candidate.has_dict_weight and (candidate.dict_weight > score_value) then
            begin
                score_value := candidate.dict_weight;
            end;

            candidate.text := Trim(candidate.text) + String.Join('', tail_units);
            candidate.comment := '';
            candidate.source := cs_rule;
            candidate.has_dict_weight := False;
            candidate.dict_weight := 0;
            candidate.score := score_value + c_head_modal_complete_bonus;
            path_hint := score_value + c_head_modal_complete_bonus;
            tail_path := String.Join(c_segment_path_separator, tail_units);
            remember_segment_path_for_candidate(candidate.text, '',
                Trim(head_results[idx].text) + c_segment_path_separator + tail_path,
                path_hint);

            SetLength(out_candidates, Length(out_candidates) + 1);
            out_candidates[High(out_candidates)] := candidate;
            Inc(accepted_count);
        end;

        sort_candidates_lightweight(out_candidates);
        Result := Length(out_candidates) > 0;
    end;

    procedure finalize_le_plus_modal_particle_sentence_candidate(
        var candidates: TncCandidateList);
    const
        c_le_modal_finalize_bonus = 1180;
    var
        syllables_local: TncPinyinParseResult;
        tail_key: string;
        expected_units: TArray<string>;
        expected_tail_text: string;
        expected_first_tail_text: string;
        idx: Integer;
        candidate_units: Integer;
        best_index: Integer;
        best_score: Integer;
        existing_index: Integer;
        preferred_existing_index: Integer;
        preferred_existing_score: Integer;
        preferred_partial_index: Integer;
        preferred_partial_score: Integer;
        segment_path: string;
        segment_parts: TArray<string>;
        corrected_candidate: TncCandidate;
        corrected_text: string;
        corrected_path: string;
        text_units: TArray<string>;
        part_idx: Integer;
        tail_idx: Integer;
        tail_ok: Boolean;
    begin
        if (Length(candidates) = 0) or (input_syllable_count < 5) or
            (not is_full_pinyin_key(lookup_text)) then
        begin
            Exit;
        end;

        syllables_local := get_effective_compact_pinyin_syllables(lookup_text);
        if Length(syllables_local) <> input_syllable_count then
        begin
            Exit;
        end;

        tail_key := normalize_pinyin_text(syllables_local[High(syllables_local)].text);
        expected_tail_text := '';
        if tail_key = 'ba' then
        begin
            expected_tail_text := string(Char($5427));
        end
        else if tail_key = 'ma' then
        begin
            expected_tail_text := string(Char($5417));
        end
        else if tail_key = 'ne' then
        begin
            expected_tail_text := string(Char($5462));
        end
        else if tail_key = 'a' then
        begin
            expected_tail_text := string(Char($554A));
        end
        else if tail_key = 'ya' then
        begin
            expected_tail_text := string(Char($5440));
        end
        else if tail_key = 'la' then
        begin
            expected_tail_text := string(Char($5566));
        end
        else if tail_key = 'wa' then
        begin
            expected_tail_text := string(Char($54C7));
        end;

        if (expected_tail_text = '') or
            (not SameText(normalize_pinyin_text(
            syllables_local[High(syllables_local) - 1].text), 'le')) then
        begin
            Exit;
        end;

        expected_units := TArray<string>.Create(string(Char($4E86)), expected_tail_text);
        expected_first_tail_text := expected_units[0];
        preferred_existing_index := -1;
        preferred_existing_score := Low(Integer);
        preferred_partial_index := -1;
        preferred_partial_score := Low(Integer);
        best_index := -1;
        best_score := Low(Integer);
        existing_index := -1;

        for idx := 0 to High(candidates) do
        begin
            if SameText(Trim(candidates[idx].comment), tail_key) then
            begin
                candidate_units := get_candidate_text_unit_count(Trim(candidates[idx].text));
                if candidate_units = input_syllable_count - 1 then
                begin
                    text_units := split_text_units(Trim(candidates[idx].text));
                    if (Length(text_units) > 0) and
                        SameText(Trim(text_units[High(text_units)]), expected_first_tail_text) and
                        (candidates[idx].score > preferred_partial_score) then
                    begin
                        preferred_partial_score := candidates[idx].score;
                        preferred_partial_index := idx;
                    end;
                end;
            end;

            if Trim(candidates[idx].comment) <> '' then
            begin
                Continue;
            end;

            candidate_units := get_candidate_text_unit_count(Trim(candidates[idx].text));
            if candidate_units = input_syllable_count then
            begin
                text_units := split_text_units(Trim(candidates[idx].text));
                if Length(text_units) >= 2 then
                begin
                    if SameText(Trim(text_units[High(text_units) - 1]), expected_units[0]) and
                        SameText(Trim(text_units[High(text_units)]), expected_units[1]) and
                        (candidates[idx].score > preferred_existing_score) then
                    begin
                        preferred_existing_score := candidates[idx].score;
                        preferred_existing_index := idx;
                    end;
                end;
            end;

            if candidate_units <> input_syllable_count then
            begin
                Continue;
            end;

            segment_path := get_segment_path_for_candidate(candidates[idx]);
            if get_encoded_path_segment_count_local(segment_path) <= 2 then
            begin
                Continue;
            end;
            segment_parts := segment_path.Split([c_segment_path_separator]);
            if Length(segment_parts) <= 2 then
            begin
                Continue;
            end;

            tail_ok := True;
            for tail_idx := 0 to 1 do
            begin
                if get_candidate_text_unit_count(
                    Trim(segment_parts[High(segment_parts) - 1 + tail_idx])) <> 1 then
                begin
                    tail_ok := False;
                    Break;
                end;
            end;
            if not tail_ok then
            begin
                Continue;
            end;

            corrected_text := '';
            corrected_path := '';
            for part_idx := 0 to High(segment_parts) - 2 do
            begin
                corrected_text := corrected_text + Trim(segment_parts[part_idx]);
                if corrected_path = '' then
                begin
                    corrected_path := Trim(segment_parts[part_idx]);
                end
                else
                begin
                    corrected_path := corrected_path + c_segment_path_separator +
                        Trim(segment_parts[part_idx]);
                end;
            end;
            for tail_idx := 0 to High(expected_units) do
            begin
                corrected_text := corrected_text + expected_units[tail_idx];
                if corrected_path = '' then
                begin
                    corrected_path := expected_units[tail_idx];
                end
                else
                begin
                    corrected_path := corrected_path + c_segment_path_separator +
                        expected_units[tail_idx];
                end;
            end;

            if SameText(corrected_text, Trim(candidates[idx].text)) then
            begin
                if (preferred_existing_index < 0) and
                    (candidates[idx].score > preferred_existing_score) then
                begin
                    preferred_existing_score := candidates[idx].score;
                    preferred_existing_index := idx;
                end;
                Continue;
            end;

            if existing_index < 0 then
            begin
                for part_idx := 0 to High(candidates) do
                begin
                    if (Trim(candidates[part_idx].comment) = '') and
                        SameText(Trim(candidates[part_idx].text), corrected_text) then
                    begin
                        existing_index := part_idx;
                        Break;
                    end;
                end;
            end;

            if candidates[idx].score > best_score then
            begin
                best_score := candidates[idx].score;
                best_index := idx;
            end;
        end;

        if preferred_partial_index >= 0 then
        begin
            corrected_candidate := candidates[preferred_partial_index];
            corrected_candidate.text := Trim(corrected_candidate.text) + expected_units[1];
            corrected_candidate.comment := '';
            corrected_candidate.source := cs_rule;
            corrected_candidate.has_dict_weight := False;
            corrected_candidate.dict_weight := 0;
            corrected_candidate.score := Max(corrected_candidate.score +
                c_le_modal_finalize_bonus, candidates[0].score + c_le_modal_finalize_bonus);
            segment_path := get_segment_path_for_candidate(candidates[preferred_partial_index]);
            if segment_path = '' then
            begin
                corrected_path := Trim(candidates[preferred_partial_index].text) +
                    c_segment_path_separator + expected_units[1];
            end
            else
            begin
                corrected_path := segment_path + c_segment_path_separator + expected_units[1];
            end;
            remember_segment_path_for_candidate(corrected_candidate.text, '',
                corrected_path, corrected_candidate.score);
            for idx := Length(candidates) - 1 downto 1 do
            begin
                candidates[idx] := candidates[idx - 1];
            end;
            candidates[0] := corrected_candidate;
            Exit;
        end;

        if preferred_existing_index > 0 then
        begin
            corrected_candidate := candidates[preferred_existing_index];
            corrected_candidate.comment := '';
            corrected_candidate.source := cs_rule;
            Inc(corrected_candidate.score, c_le_modal_finalize_bonus);
            for idx := preferred_existing_index downto 1 do
            begin
                candidates[idx] := candidates[idx - 1];
            end;
            candidates[0] := corrected_candidate;
            Exit;
        end;

        if best_index < 0 then
        begin
            Exit;
        end;

        if existing_index >= 0 then
        begin
            corrected_candidate := candidates[existing_index];
            Inc(corrected_candidate.score, c_le_modal_finalize_bonus);
            corrected_candidate.source := cs_rule;
            corrected_candidate.comment := '';
        end
        else
        begin
            corrected_candidate := candidates[best_index];
            segment_path := get_segment_path_for_candidate(candidates[best_index]);
            segment_parts := segment_path.Split([c_segment_path_separator]);
            corrected_text := '';
            corrected_path := '';
            for part_idx := 0 to High(segment_parts) - 2 do
            begin
                corrected_text := corrected_text + Trim(segment_parts[part_idx]);
                if corrected_path = '' then
                begin
                    corrected_path := Trim(segment_parts[part_idx]);
                end
                else
                begin
                    corrected_path := corrected_path + c_segment_path_separator +
                        Trim(segment_parts[part_idx]);
                end;
            end;
            for tail_idx := 0 to High(expected_units) do
            begin
                corrected_text := corrected_text + expected_units[tail_idx];
                if corrected_path = '' then
                begin
                    corrected_path := expected_units[tail_idx];
                end
                else
                begin
                    corrected_path := corrected_path + c_segment_path_separator +
                        expected_units[tail_idx];
                end;
            end;

            corrected_candidate.text := corrected_text;
            corrected_candidate.comment := '';
            corrected_candidate.source := cs_rule;
            corrected_candidate.has_dict_weight := False;
            corrected_candidate.dict_weight := 0;
            Inc(corrected_candidate.score, c_le_modal_finalize_bonus);
            remember_segment_path_for_candidate(corrected_candidate.text, '',
                corrected_path, corrected_candidate.score);
        end;

        for idx := Length(candidates) - 1 downto 1 do
        begin
            candidates[idx] := candidates[idx - 1];
        end;
        candidates[0] := corrected_candidate;
    end;

    function build_dangling_exact_head_chain_sentence_candidates(
        const query_text: string; out out_candidates: TncCandidateList): Boolean;
    const
        c_chain_max_depth = 8;
        c_chain_min_prefix_len = 3;
        c_chain_max_prefix_len = 14;
        c_chain_max_prefix_hits_per_depth = 6;
        c_chain_max_results_per_prefix = 2;
        c_chain_completion_bonus = 1200;
        c_chain_segment_penalty = 280;
        c_chain_prefix_len_bonus = 90;
    var
        normalized_query: string;
        best_scores: TDictionary<string, Integer>;

        procedure remember_complete_chain(const text_value: string;
            const path_value: string; const score_value: Integer);
        var
            previous_score: Integer;
            candidate: TncCandidate;
            idx: Integer;
            encoded_path: string;
        begin
            if (Trim(text_value) = '') or
                (get_candidate_text_unit_count(Trim(text_value)) <> input_syllable_count) then
            begin
                Exit;
            end;

            if best_scores.TryGetValue(text_value, previous_score) and
                (previous_score >= score_value) then
            begin
                Exit;
            end;
            best_scores.AddOrSetValue(text_value, score_value);

            encoded_path := path_value;
            if (encoded_path <> '') and (encoded_path[1] = c_segment_path_separator) then
            begin
                Delete(encoded_path, 1, 1);
            end;

            for idx := 0 to High(out_candidates) do
            begin
                if SameText(Trim(out_candidates[idx].text), Trim(text_value)) then
                begin
                    out_candidates[idx].score := score_value;
                    out_candidates[idx].comment := '';
                    out_candidates[idx].source := cs_rule;
                    out_candidates[idx].has_dict_weight := False;
                    out_candidates[idx].dict_weight := 0;
                    remember_segment_path_for_candidate(out_candidates[idx].text, '',
                        encoded_path, score_value);
                    Exit;
                end;
            end;

            candidate.text := text_value;
            candidate.comment := '';
            candidate.score := score_value;
            candidate.source := cs_rule;
            candidate.has_dict_weight := False;
            candidate.dict_weight := 0;
            SetLength(out_candidates, Length(out_candidates) + 1);
            out_candidates[High(out_candidates)] := candidate;
            remember_segment_path_for_candidate(candidate.text, '', encoded_path,
                score_value);
        end;

        procedure build_chain_recursive(const remaining_query: string;
            const composed_text: string; const composed_path: string;
            const accumulated_score: Integer; const depth: Integer);
        var
            prefix_len: Integer;
            prefix_key: string;
            allow_nonfull_tail: Boolean;
            exact_results: TncCandidateList;
            result_idx: Integer;
            prefix_hit_count: Integer;
            accepted_count: Integer;
            piece_text: string;
            piece_score: Integer;
            piece_units: Integer;
            next_text: string;
            next_path: string;
            next_remaining: string;
        begin
            if remaining_query = '' then
            begin
                remember_complete_chain(composed_text, composed_path,
                    accumulated_score + c_chain_completion_bonus -
                    (depth * c_chain_segment_penalty));
                Exit;
            end;
            if depth >= c_chain_max_depth then
            begin
                Exit;
            end;

            prefix_hit_count := 0;
            for prefix_len := Min(c_chain_max_prefix_len, Length(remaining_query)) downto
                c_chain_min_prefix_len do
            begin
                prefix_key := Copy(remaining_query, 1, prefix_len);
                allow_nonfull_tail := prefix_len = Length(remaining_query);
                if (not is_full_pinyin_key(prefix_key)) and (not allow_nonfull_tail) then
                begin
                    Continue;
                end;
                if not dictionary_exact_lookup_cached(prefix_key, exact_results) then
                begin
                    Continue;
                end;

                accepted_count := 0;
                for result_idx := 0 to High(exact_results) do
                begin
                    if accepted_count >= c_chain_max_results_per_prefix then
                    begin
                        Break;
                    end;
                    if Trim(exact_results[result_idx].comment) <> '' then
                    begin
                        Continue;
                    end;
                    if is_runtime_chain_candidate(exact_results[result_idx]) or
                        is_runtime_common_pattern_candidate(exact_results[result_idx]) or
                        is_runtime_redup_candidate(exact_results[result_idx]) then
                    begin
                        Continue;
                    end;

                    piece_text := Trim(exact_results[result_idx].text);
                    if piece_text = '' then
                    begin
                        Continue;
                    end;
                    piece_units := get_candidate_text_unit_count(piece_text);
                    if (depth = 0) and (piece_units = 1) and
                        (prefix_len < Length(remaining_query)) then
                    begin
                        Continue;
                    end;

                    next_remaining := Copy(remaining_query, prefix_len + 1, MaxInt);
                    piece_score := exact_results[result_idx].score;
                    if exact_results[result_idx].has_dict_weight and
                        (exact_results[result_idx].dict_weight > piece_score) then
                    begin
                        piece_score := exact_results[result_idx].dict_weight;
                    end;
                    if piece_score <= 0 then
                    begin
                        piece_score := 1;
                    end;

                    next_text := composed_text + piece_text;
                    next_path := composed_path + c_segment_path_separator + piece_text;
                    build_chain_recursive(next_remaining, next_text, next_path,
                        accumulated_score + piece_score +
                        (prefix_len * c_chain_prefix_len_bonus), depth + 1);
                    Inc(accepted_count);
                end;

                if accepted_count > 0 then
                begin
                    Inc(prefix_hit_count);
                    if prefix_hit_count >= c_chain_max_prefix_hits_per_depth then
                    begin
                        Break;
                    end;
                end;
            end;
        end;
    begin
        SetLength(out_candidates, 0);
        Result := False;
        if m_dictionary = nil then
        begin
            Exit;
        end;

        normalized_query := normalize_pinyin_text(query_text);
        if (normalized_query = '') or (Length(normalized_query) < 8) then
        begin
            Exit;
        end;

        best_scores := TDictionary<string, Integer>.Create;
        try
            build_chain_recursive(normalized_query, '', '', 0, 0);
        finally
            best_scores.Free;
        end;

        if Length(out_candidates) = 0 then
        begin
            Exit(False);
        end;

        sort_candidates_lightweight(out_candidates);
        Result := True;
    end;

    procedure apply_shifted_boundary_longer_exact_penalty(
        var candidates: TncCandidateList);
    const
        c_exact_probe_limit = 8;
        c_shifted_boundary_penalty = 3600;
        c_min_shifted_left_weight = 520;
        c_min_shifted_follow_weight = 520;
    var
        syllables_local: TncPinyinParseResult;
        idx: Integer;
        segment_path: string;
        segment_parts: TArray<string>;
        segment_idx: Integer;
        syllable_idx: Integer;
        left_units: Integer;
        right_units: Integer;
        adjustment: Integer;
        shifted_left_weight: Integer;
        shifted_follow_weight: Integer;

        function build_query_key_local(const start_idx: Integer;
            const syllable_count_local: Integer): string;
        var
            local_idx: Integer;
        begin
            Result := '';
            if (start_idx < 0) or (syllable_count_local <= 0) or
                (start_idx + syllable_count_local - 1 > High(syllables_local)) then
            begin
                Exit;
            end;

            for local_idx := start_idx to start_idx + syllable_count_local - 1 do
            begin
                Result := Result + normalize_pinyin_text(syllables_local[local_idx].text);
            end;
        end;

        function get_exact_candidate_rank_weight(
            const candidate: TncCandidate): Integer;
        begin
            Result := candidate.score;
            if candidate.has_dict_weight and (candidate.dict_weight > Result) then
            begin
                Result := candidate.dict_weight;
            end;
        end;

        function try_get_best_exact_phrase_weight_local(const start_idx: Integer;
            const syllable_count_local: Integer; out out_weight: Integer): Boolean;
        var
            query_key: string;
            exact_results: TncCandidateList;
            exact_idx: Integer;
            candidate_text: string;
            candidate_units: Integer;
            weight_value: Integer;
        begin
            Result := False;
            out_weight := 0;
            if (m_dictionary = nil) or
                (start_idx < 0) or (syllable_count_local <= 0) or
                (start_idx + syllable_count_local - 1 > High(syllables_local)) then
            begin
                Exit;
            end;

            query_key := build_query_key_local(start_idx, syllable_count_local);
            if (query_key = '') or
                (not m_dictionary.lookup_exact_full_pinyin(query_key, exact_results)) then
            begin
                Exit;
            end;

            for exact_idx := 0 to High(exact_results) do
            begin
                if exact_idx >= c_exact_probe_limit then
                begin
                    Break;
                end;
                if Trim(exact_results[exact_idx].comment) <> '' then
                begin
                    Continue;
                end;
                if is_runtime_chain_candidate(exact_results[exact_idx]) or
                    is_runtime_common_pattern_candidate(exact_results[exact_idx]) or
                    is_runtime_redup_candidate(exact_results[exact_idx]) then
                begin
                    Continue;
                end;

                candidate_text := Trim(exact_results[exact_idx].text);
                candidate_units := get_candidate_text_unit_count(candidate_text);
                if candidate_units <> syllable_count_local then
                begin
                    Continue;
                end;

                weight_value := get_exact_candidate_rank_weight(exact_results[exact_idx]);
                if weight_value > out_weight then
                begin
                    out_weight := weight_value;
                    Result := True;
                end;
            end;
        end;

        function try_get_best_shifted_follow_weight_local(
            const start_idx: Integer; out out_weight: Integer): Boolean;
        var
            probe_len: Integer;
            weight_value: Integer;
        begin
            Result := False;
            out_weight := 0;
            if (start_idx < 0) or (start_idx > High(syllables_local)) then
            begin
                Exit;
            end;

            for probe_len := 1 to Min(3, Length(syllables_local) - start_idx) do
            begin
                if not try_get_best_exact_phrase_weight_local(start_idx,
                    probe_len, weight_value) then
                begin
                    Continue;
                end;
                if weight_value > out_weight then
                begin
                    out_weight := weight_value;
                    Result := True;
                end;
            end;
        end;

    begin
        if (Length(candidates) = 0) or
            (input_syllable_count < c_long_sentence_exact_min_syllables) then
        begin
            Exit;
        end;

        syllables_local := get_effective_compact_pinyin_syllables(
            normalize_pinyin_text(m_last_lookup_key));
        if Length(syllables_local) <> m_last_lookup_syllable_count then
        begin
            Exit;
        end;

        for idx := 0 to High(candidates) do
        begin
            if Trim(candidates[idx].comment) <> '' then
            begin
                Continue;
            end;

            segment_path := get_segment_path_for_candidate(candidates[idx]);
            if get_encoded_path_segment_count_local(segment_path) <= 1 then
            begin
                Continue;
            end;

            segment_parts := segment_path.Split([c_segment_path_separator]);
            syllable_idx := 0;
            adjustment := 0;
            for segment_idx := 0 to High(segment_parts) - 1 do
            begin
                left_units := get_candidate_text_unit_count(Trim(segment_parts[segment_idx]));
                right_units := get_candidate_text_unit_count(Trim(segment_parts[segment_idx + 1]));

                if (left_units >= 2) and (right_units >= 2) and
                    (syllable_idx + left_units + right_units - 1 <= High(syllables_local)) and
                    try_get_best_exact_phrase_weight_local(syllable_idx,
                    left_units + 1, shifted_left_weight) and
                    (shifted_left_weight >= c_min_shifted_left_weight) and
                    try_get_best_shifted_follow_weight_local(
                    syllable_idx + left_units + 1, shifted_follow_weight) and
                    (shifted_follow_weight >= c_min_shifted_follow_weight) then
                begin
                    Dec(adjustment, c_shifted_boundary_penalty);
                end;

                Inc(syllable_idx, left_units);
            end;

            if adjustment <> 0 then
            begin
                Inc(candidates[idx].score, adjustment);
            end;
        end;
    end;

    procedure apply_compact_long_phrase_bonus(var candidates: TncCandidateList);
    const
        c_compact_long_phrase_bonus = 760;
        c_compact_long_phrase_extra_per_unit = 120;
    var
        idx: Integer;
        encoded_path: string;
        segment_parts: TArray<string>;
        part_idx: Integer;
        segment_units: Integer;
        max_segment_units: Integer;
        path_segment_count: Integer;
    begin
        if (Length(candidates) = 0) or
            (input_syllable_count < c_long_sentence_exact_min_syllables) then
        begin
            Exit;
        end;

        for idx := 0 to High(candidates) do
        begin
            if (Trim(candidates[idx].comment) <> '') or
                (get_candidate_text_unit_count(Trim(candidates[idx].text)) <>
                input_syllable_count) or
                is_runtime_chain_candidate(candidates[idx]) or
                is_runtime_common_pattern_candidate(candidates[idx]) or
                is_runtime_redup_candidate(candidates[idx]) then
            begin
                Continue;
            end;

            encoded_path := get_segment_path_for_candidate(candidates[idx]);
            path_segment_count := get_encoded_path_segment_count_local(encoded_path);
            if path_segment_count <= 1 then
            begin
                Continue;
            end;

            max_segment_units := 0;
            segment_parts := encoded_path.Split([c_segment_path_separator]);
            for part_idx := 0 to High(segment_parts) do
            begin
                if Trim(segment_parts[part_idx]) = '' then
                begin
                    Continue;
                end;
                segment_units := get_candidate_text_unit_count(Trim(segment_parts[part_idx]));
                if segment_units > max_segment_units then
                begin
                    max_segment_units := segment_units;
                end;
            end;

            if max_segment_units < 3 then
            begin
                Continue;
            end;

            Inc(candidates[idx].score,
                c_compact_long_phrase_bonus +
                Max(0, max_segment_units - 3) * c_compact_long_phrase_extra_per_unit);
        end;
    end;

    procedure apply_preferred_sentence_phrase_bonus(
        var candidates: TncCandidateList);
    begin
        // Phrase preference is intentionally dictionary-driven. Avoid hard-coded
        // sentence substring bonuses here; short phrases should be represented in
        // the lexicon and resolved through exact chunk lookup.
    end;
    procedure ensure_modal_tail_sentence_candidate_visible(var candidates: TncCandidateList);
    const
        c_modal_tail_correction_bonus = 980;
    var
        syllables_local: TncPinyinParseResult;
        tail_key: string;
        expected_text: string;
        idx: Integer;
        best_index: Integer;
        best_score: Integer;
        existing_index: Integer;
        segment_path: string;
        corrected_path: string;
        corrected_text: string;
        segment_parts: TArray<string>;
        corrected_candidate: TncCandidate;
        part_idx: Integer;
    begin
        if (Length(candidates) = 0) or (input_syllable_count < 4) or
            (not is_full_pinyin_key(lookup_text)) then
        begin
            Exit;
        end;

        syllables_local := get_effective_compact_pinyin_syllables(lookup_text);
        if Length(syllables_local) <> input_syllable_count then
        begin
            Exit;
        end;

        tail_key := normalize_pinyin_text(syllables_local[High(syllables_local)].text);
        expected_text := '';
        if tail_key = 'ba' then
        begin
            expected_text := string(Char($5427));
        end
        else if tail_key = 'ma' then
        begin
            expected_text := string(Char($5417));
        end
        else if tail_key = 'ne' then
        begin
            expected_text := string(Char($5462));
        end
        else if tail_key = 'a' then
        begin
            expected_text := string(Char($554A));
        end
        else if tail_key = 'ya' then
        begin
            expected_text := string(Char($5440));
        end
        else if tail_key = 'la' then
        begin
            expected_text := string(Char($5566));
        end
        else if tail_key = 'le' then
        begin
            expected_text := string(Char($4E86));
        end
        else if tail_key = 'wa' then
        begin
            expected_text := string(Char($54C7));
        end;
        if expected_text = '' then
        begin
            Exit;
        end;

        best_index := -1;
        best_score := Low(Integer);
        existing_index := -1;
        for idx := 0 to High(candidates) do
        begin
            if (Trim(candidates[idx].comment) <> '') or
                (get_candidate_text_unit_count(Trim(candidates[idx].text)) <> input_syllable_count) then
            begin
                Continue;
            end;

            segment_path := get_segment_path_for_candidate(candidates[idx]);
            if get_encoded_path_segment_count_local(segment_path) <= 1 then
            begin
                Continue;
            end;

            segment_parts := segment_path.Split([c_segment_path_separator]);
            if Length(segment_parts) <= 1 then
            begin
                Continue;
            end;
            if get_candidate_text_unit_count(Trim(segment_parts[High(segment_parts)])) <> 1 then
            begin
                Continue;
            end;

            corrected_text := '';
            corrected_path := '';
            for part_idx := 0 to High(segment_parts) - 1 do
            begin
                corrected_text := corrected_text + Trim(segment_parts[part_idx]);
                if corrected_path = '' then
                begin
                    corrected_path := Trim(segment_parts[part_idx]);
                end
                else
                begin
                    corrected_path := corrected_path + c_segment_path_separator +
                        Trim(segment_parts[part_idx]);
                end;
            end;
            corrected_text := corrected_text + expected_text;
            if corrected_path = '' then
            begin
                corrected_path := expected_text;
            end
            else
            begin
                corrected_path := corrected_path + c_segment_path_separator + expected_text;
            end;

            if SameText(corrected_text, Trim(candidates[idx].text)) then
            begin
                if existing_index < 0 then
                begin
                    existing_index := idx;
                end;
                Continue;
            end;

            if existing_index < 0 then
            begin
                for part_idx := 0 to High(candidates) do
                begin
                    if (Trim(candidates[part_idx].comment) = '') and
                        SameText(Trim(candidates[part_idx].text), corrected_text) then
                    begin
                        existing_index := part_idx;
                        Break;
                    end;
                end;
            end;

            if candidates[idx].score > best_score then
            begin
                best_score := candidates[idx].score;
                best_index := idx;
            end;
        end;

        if best_index < 0 then
        begin
            Exit;
        end;

        segment_path := get_segment_path_for_candidate(candidates[best_index]);
        segment_parts := segment_path.Split([c_segment_path_separator]);
        corrected_text := '';
        corrected_path := '';
        for part_idx := 0 to High(segment_parts) - 1 do
        begin
            corrected_text := corrected_text + Trim(segment_parts[part_idx]);
            if corrected_path = '' then
            begin
                corrected_path := Trim(segment_parts[part_idx]);
            end
            else
            begin
                corrected_path := corrected_path + c_segment_path_separator +
                    Trim(segment_parts[part_idx]);
            end;
        end;
        corrected_text := corrected_text + expected_text;
        if corrected_path = '' then
        begin
            corrected_path := expected_text;
        end
        else
        begin
            corrected_path := corrected_path + c_segment_path_separator + expected_text;
        end;

        if existing_index >= 0 then
        begin
            Inc(candidates[existing_index].score, c_modal_tail_correction_bonus);
            candidates[existing_index].source := cs_rule;
            remember_segment_path_for_candidate(corrected_text, '',
                corrected_path, candidates[existing_index].score);
            Exit;
        end;

        corrected_candidate := candidates[best_index];
        corrected_candidate.text := corrected_text;
        corrected_candidate.comment := '';
        corrected_candidate.source := cs_rule;
        corrected_candidate.has_dict_weight := False;
        corrected_candidate.dict_weight := 0;
        Inc(corrected_candidate.score, c_modal_tail_correction_bonus);
        SetLength(candidates, Length(candidates) + 1);
        candidates[High(candidates)] := corrected_candidate;
        remember_segment_path_for_candidate(corrected_candidate.text, '',
            corrected_path, corrected_candidate.score);
    end;

    procedure finalize_modal_tail_sentence_candidate(var candidates: TncCandidateList);
    const
        c_modal_tail_finalize_bonus = 960;
    var
        syllables_local: TncPinyinParseResult;
        tail_key: string;
        expected_text: string;
        idx: Integer;
        candidate_units: Integer;
        best_index: Integer;
        best_score: Integer;
        existing_index: Integer;
        preferred_existing_index: Integer;
        preferred_existing_score: Integer;
        segment_path: string;
        segment_parts: TArray<string>;
        corrected_candidate: TncCandidate;
        corrected_text: string;
        corrected_path: string;
        part_idx: Integer;
        last_units: TArray<string>;
        candidate_modal_score: Integer;

        function is_quantity_tail_unit_local(const unit_text: string): Boolean;
        begin
            Result :=
                SameText(unit_text, string(Char($6B21))) or
                SameText(unit_text, string(Char($4E2A))) or
                SameText(unit_text, string(Char($5929))) or
                SameText(unit_text, string(Char($65E5))) or
                SameText(unit_text, string(Char($8F6E))) or
                SameText(unit_text, string(Char($6B65))) or
                SameText(unit_text, string(Char($6761))) or
                SameText(unit_text, string(Char($6839))) or
                SameText(unit_text, string(Char($6279))) or
                SameText(unit_text, string(Char($5339))) or
                SameText(unit_text, string(Char($53F0))) or
                SameText(unit_text, string(Char($628A))) or
                SameText(unit_text, string(Char($526F))) or
                SameText(unit_text, string(Char($5BF9))) or
                SameText(unit_text, string(Char($53CC))) or
                SameText(unit_text, string(Char($74F6))) or
                SameText(unit_text, string(Char($6876))) or
                SameText(unit_text, string(Char($680B))) or
                SameText(unit_text, string(Char($5E62))) or
                SameText(unit_text, string(Char($7247))) or
                SameText(unit_text, string(Char($76D8))) or
                SameText(unit_text, string(Char($53EA)));
        end;

        function has_one_quantity_modal_tail_local(
            const units: TArray<string>): Boolean;
        begin
            Result := (Length(units) >= 3) and
                SameText(Trim(units[High(units)]), expected_text) and
                SameText(Trim(units[High(units) - 2]), string(Char($4E00))) and
                is_quantity_tail_unit_local(Trim(units[High(units) - 1]));
        end;
    begin
        if (Length(candidates) = 0) or (input_syllable_count < 4) or
            (not is_full_pinyin_key(lookup_text)) then
        begin
            Exit;
        end;

        syllables_local := get_effective_compact_pinyin_syllables(lookup_text);
        if Length(syllables_local) <> input_syllable_count then
        begin
            Exit;
        end;

        tail_key := normalize_pinyin_text(syllables_local[High(syllables_local)].text);
        expected_text := '';
        if tail_key = 'ba' then
        begin
            expected_text := string(Char($5427));
        end
        else if tail_key = 'ma' then
        begin
            expected_text := string(Char($5417));
        end
        else if tail_key = 'ne' then
        begin
            expected_text := string(Char($5462));
        end
        else if tail_key = 'a' then
        begin
            expected_text := string(Char($554A));
        end
        else if tail_key = 'ya' then
        begin
            expected_text := string(Char($5440));
        end
        else if tail_key = 'la' then
        begin
            expected_text := string(Char($5566));
        end
        else if tail_key = 'le' then
        begin
            expected_text := string(Char($4E86));
        end
        else if tail_key = 'wa' then
        begin
            expected_text := string(Char($54C7));
        end;
        if expected_text = '' then
        begin
            Exit;
        end;

        best_index := -1;
        best_score := Low(Integer);
        existing_index := -1;
        preferred_existing_index := -1;
        preferred_existing_score := Low(Integer);
        for idx := 0 to High(candidates) do
        begin
            if Trim(candidates[idx].comment) <> '' then
            begin
                Continue;
            end;

            candidate_units := get_candidate_text_unit_count(Trim(candidates[idx].text));
            if candidate_units = input_syllable_count then
            begin
                last_units := split_text_units(Trim(candidates[idx].text));
                if (Length(last_units) > 0) and
                    SameText(Trim(last_units[High(last_units)]), expected_text) then
                begin
                    candidate_modal_score := candidates[idx].score;
                    if has_one_quantity_modal_tail_local(last_units) then
                    begin
                        Inc(candidate_modal_score, 60000);
                    end;
                    if candidate_modal_score > preferred_existing_score then
                    begin
                        preferred_existing_score := candidate_modal_score;
                        preferred_existing_index := idx;
                    end;
                end;
            end;

            if candidate_units <> input_syllable_count then
            begin
                Continue;
            end;

            segment_path := get_segment_path_for_candidate(candidates[idx]);
            if get_encoded_path_segment_count_local(segment_path) <= 1 then
            begin
                Continue;
            end;
            segment_parts := segment_path.Split([c_segment_path_separator]);
            if Length(segment_parts) <= 1 then
            begin
                Continue;
            end;
            if get_candidate_text_unit_count(Trim(segment_parts[High(segment_parts)])) <> 1 then
            begin
                Continue;
            end;

            corrected_text := '';
            corrected_path := '';
            for part_idx := 0 to High(segment_parts) - 1 do
            begin
                corrected_text := corrected_text + Trim(segment_parts[part_idx]);
                if corrected_path = '' then
                begin
                    corrected_path := Trim(segment_parts[part_idx]);
                end
                else
                begin
                    corrected_path := corrected_path + c_segment_path_separator +
                        Trim(segment_parts[part_idx]);
                end;
            end;
            corrected_text := corrected_text + expected_text;

            if SameText(corrected_text, Trim(candidates[idx].text)) then
            begin
                if existing_index < 0 then
                begin
                    existing_index := idx;
                end;
                Continue;
            end;

            if existing_index < 0 then
            begin
                for part_idx := 0 to High(candidates) do
                begin
                    if (Trim(candidates[part_idx].comment) = '') and
                        SameText(Trim(candidates[part_idx].text), corrected_text) then
                    begin
                        existing_index := part_idx;
                        Break;
                    end;
                end;
            end;

            if candidates[idx].score > best_score then
            begin
                best_score := candidates[idx].score;
                best_index := idx;
            end;
        end;

        if preferred_existing_index > 0 then
        begin
            corrected_candidate := candidates[preferred_existing_index];
            corrected_candidate.comment := '';
            corrected_candidate.source := cs_rule;
            Inc(corrected_candidate.score, c_modal_tail_finalize_bonus);
            for idx := preferred_existing_index downto 1 do
            begin
                candidates[idx] := candidates[idx - 1];
            end;
            candidates[0] := corrected_candidate;
            Exit;
        end;

        if best_index < 0 then
        begin
            Exit;
        end;

        if existing_index >= 0 then
        begin
            corrected_candidate := candidates[existing_index];
            Inc(corrected_candidate.score, c_modal_tail_finalize_bonus);
            corrected_candidate.source := cs_rule;
            corrected_candidate.comment := '';
        end
        else
        begin
            corrected_candidate := candidates[best_index];
            segment_path := get_segment_path_for_candidate(candidates[best_index]);
            segment_parts := segment_path.Split([c_segment_path_separator]);
            corrected_text := '';
            corrected_path := '';
            for part_idx := 0 to High(segment_parts) - 1 do
            begin
                corrected_text := corrected_text + Trim(segment_parts[part_idx]);
                if corrected_path = '' then
                begin
                    corrected_path := Trim(segment_parts[part_idx]);
                end
                else
                begin
                    corrected_path := corrected_path + c_segment_path_separator +
                        Trim(segment_parts[part_idx]);
                end;
            end;
            corrected_text := corrected_text + expected_text;
            if corrected_path = '' then
            begin
                corrected_path := expected_text;
            end
            else
            begin
                corrected_path := corrected_path + c_segment_path_separator + expected_text;
            end;

            corrected_candidate.text := corrected_text;
            corrected_candidate.comment := '';
            corrected_candidate.source := cs_rule;
            corrected_candidate.has_dict_weight := False;
            corrected_candidate.dict_weight := 0;
            Inc(corrected_candidate.score, c_modal_tail_finalize_bonus);
            corrected_candidate.comment := '';
            remember_segment_path_for_candidate(corrected_candidate.text, '',
                corrected_path, corrected_candidate.score);
        end;

        for idx := Length(candidates) - 1 downto 1 do
        begin
            candidates[idx] := candidates[idx - 1];
        end;
        candidates[0] := corrected_candidate;
    end;

    function build_segment_candidates_timed(out out_candidates: TncCandidateList;
        const include_full_path: Boolean = True;
        const allow_relaxed_split: Boolean = False): Boolean;
    var
        phase_start_tick: UInt64;
        local_path_search_elapsed_ms: Int64;
    begin
        phase_start_tick := GetTickCount64;
        local_path_search_elapsed_ms := 0;
        Result := build_segment_candidates(out_candidates, include_full_path, local_path_search_elapsed_ms,
            allow_relaxed_split);
        Inc(segment_elapsed_ms, Int64(GetTickCount64 - phase_start_tick));
        Inc(path_search_elapsed_ms, local_path_search_elapsed_ms);
    end;

    procedure sort_candidates_timed(var candidates: TncCandidateList);
    var
        phase_start_tick: UInt64;
    begin
        phase_start_tick := GetTickCount64;
        sort_candidates(candidates);
        Inc(sort_elapsed_ms, Int64(GetTickCount64 - phase_start_tick));
    end;

    procedure note_post_phase_elapsed(const phase_start_tick: UInt64);
    begin
        Inc(post_elapsed_ms, Int64(GetTickCount64 - phase_start_tick));
    end;

    procedure note_debug_helper_elapsed(const phase_name: string;
        const phase_start_tick: UInt64);
    var
        elapsed_ms: UInt64;
    begin
        if not m_config.debug_mode then
        begin
            Exit;
        end;

        elapsed_ms := GetTickCount64 - phase_start_tick;
        m_last_full_path_debug_info := m_last_full_path_debug_info +
            Format(' %s=%d', [phase_name, elapsed_ms]);
    end;

    function has_complete_phrase_candidate_for_syllable_count(
        const candidates: TncCandidateList; const expected_syllables: Integer): Boolean;
    var
        candidate_idx: Integer;
    begin
        Result := False;
        if expected_syllables <= 0 then
        begin
            Exit;
        end;

        for candidate_idx := 0 to High(candidates) do
        begin
            if candidates[candidate_idx].comment <> '' then
            begin
                Continue;
            end;
            if (get_candidate_text_unit_count(Trim(candidates[candidate_idx].text)) <
                expected_syllables) or
                (get_candidate_text_unit_count(Trim(candidates[candidate_idx].text)) >
                expected_syllables + 1) then
            begin
                Continue;
            end;
            Exit(True);
        end;
    end;

    function has_reliable_complete_phrase_candidate_for_syllable_count(
        const candidates: TncCandidateList; const expected_syllables: Integer): Boolean;
    var
        candidate_idx: Integer;
        candidate_units: Integer;
    begin
        Result := False;
        if expected_syllables <= 0 then
        begin
            Exit;
        end;

        for candidate_idx := 0 to High(candidates) do
        begin
            if candidates[candidate_idx].comment <> '' then
            begin
                Continue;
            end;
            candidate_units := get_candidate_text_unit_count(Trim(candidates[candidate_idx].text));
            if (candidate_units < expected_syllables) or
                (candidate_units > expected_syllables + 1) then
            begin
                Continue;
            end;

            if candidates[candidate_idx].source <> cs_user then
            begin
                Exit(True);
            end;
        end;
    end;

    function has_weak_user_complete_phrase_candidate_for_syllable_count(
        const candidates: TncCandidateList; const expected_syllables: Integer): Boolean;
    const
        c_max_weak_user_weight = 1200;
    var
        candidate_idx: Integer;
        candidate_weight: Integer;
    begin
        Result := False;
        if expected_syllables <= 0 then
        begin
            Exit;
        end;

        for candidate_idx := 0 to High(candidates) do
        begin
            if (candidates[candidate_idx].source <> cs_user) or
                (candidates[candidate_idx].comment <> '') then
            begin
                Continue;
            end;
            if get_candidate_text_unit_count(Trim(candidates[candidate_idx].text)) <>
                expected_syllables then
            begin
                Continue;
            end;

            candidate_weight := candidates[candidate_idx].score;
            if candidates[candidate_idx].has_dict_weight then
            begin
                candidate_weight := candidates[candidate_idx].dict_weight;
            end;
            if candidate_weight <= c_max_weak_user_weight then
            begin
                Exit(True);
            end;
        end;
    end;

    function has_exact_complete_phrase_candidate_for_syllable_count(
        const candidates: TncCandidateList; const expected_syllables: Integer): Boolean;
    var
        candidate_idx: Integer;
    begin
        Result := False;
        if expected_syllables <= 0 then
        begin
            Exit;
        end;

        for candidate_idx := 0 to High(candidates) do
        begin
            if candidates[candidate_idx].comment <> '' then
            begin
                Continue;
            end;
            if get_candidate_text_unit_count(Trim(candidates[candidate_idx].text)) <>
                expected_syllables then
            begin
                Continue;
            end;
            if candidates[candidate_idx].has_dict_weight or
                (candidates[candidate_idx].source = cs_user) then
            begin
                Exit(True);
            end;
        end;
    end;

    function has_natural_complete_segment_path_candidate_for_syllable_count(
        const candidates: TncCandidateList; const expected_syllables: Integer): Boolean;
    var
        candidate_idx: Integer;
        encoded_path: string;
    begin
        Result := False;
        if expected_syllables <= 0 then
        begin
            Exit;
        end;

        for candidate_idx := 0 to High(candidates) do
        begin
            if candidates[candidate_idx].comment <> '' then
            begin
                Continue;
            end;
            if get_candidate_text_unit_count(Trim(candidates[candidate_idx].text)) <>
                expected_syllables then
            begin
                Continue;
            end;

            encoded_path := get_segment_path_for_candidate(candidates[candidate_idx]);
            if (Trim(encoded_path) = '') or
                (get_encoded_path_segment_count_local(encoded_path) <= 1) or
                (not is_natural_predictive_segment_path_local(encoded_path)) then
            begin
                Continue;
            end;

            Exit(True);
        end;
    end;

    function is_trusted_top_complete_candidate_for_early_exit(
        const candidates: TncCandidateList): Boolean;
    const
        c_tail_min_syllables = 2;
        c_tail_max_syllables = 5;
        c_min_support_score = 8192;
    var
        candidate: TncCandidate;
        candidate_text: string;
        candidate_units: TArray<string>;
        start_idx: Integer;
        span_syllables: Integer;
        candidate_chunk_text: string;
        resolved_text: string;
        resolved_path: string;
        resolved_score: Integer;
        resolved_segments: Integer;
        resolved_anchor_units: Integer;
        resolved_has_anchor: Boolean;
        support_score: Integer;
        support_segments: Integer;
        support_path: string;
        tail_match_count: Integer;
        tail_mismatch_count: Integer;
        exact_match_count: Integer;
        exact_mismatch_count: Integer;
        exact_strong_match_count: Integer;
        exact_strong_mismatch_count: Integer;

        function build_text_from_units_local(const text_units: TArray<string>;
            const start_unit: Integer; const unit_count: Integer): string;
        var
            unit_idx: Integer;
        begin
            Result := '';
            if (unit_count <= 0) or (start_unit < 0) or
                (start_unit + unit_count - 1 > High(text_units)) then
            begin
                Exit;
            end;

            for unit_idx := start_unit to start_unit + unit_count - 1 do
            begin
                Result := Result + text_units[unit_idx];
            end;
        end;
    begin
        Result := False;
        if (Length(candidates) = 0) or (input_syllable_count < 4) or
            (not is_full_pinyin_key(lookup_text)) then
        begin
            Exit;
        end;

        candidate := candidates[0];
        if Trim(candidate.comment) <> '' then
        begin
            Exit;
        end;

        candidate_text := Trim(candidate.text);
        if (candidate_text = '') or
            (get_candidate_text_unit_count(candidate_text) <>
            input_syllable_count) then
        begin
            Exit;
        end;

        if candidate.has_dict_weight or (candidate.source = cs_user) then
        begin
            Exit(True);
        end;

        if is_problematic_single_char_chain_candidate_for_query(
            lookup_text, candidate) then
        begin
            Exit;
        end;

        support_path := infer_segment_path_for_query_text_with_score(
            lookup_text, candidate_text, support_score, support_segments);
        if (support_path = '') or (support_score <= -960) then
        begin
            Exit;
        end;

        candidate_units := split_text_units(candidate_text);
        if Length(candidate_units) <> input_syllable_count then
        begin
            Exit;
        end;

        get_exact_window_consistency_stats_local(candidate_text, 2, 5,
            exact_match_count, exact_mismatch_count, exact_strong_match_count,
            exact_strong_mismatch_count);
        if exact_strong_mismatch_count > 0 then
        begin
            Exit(False);
        end;
        if (exact_mismatch_count > 0) and (exact_strong_match_count = 0) then
        begin
            Exit(False);
        end;

        tail_match_count := 0;
        tail_mismatch_count := 0;
        for span_syllables := c_tail_min_syllables to
            Min(c_tail_max_syllables, input_syllable_count) do
        begin
            start_idx := input_syllable_count - span_syllables;
            if not try_resolve_best_exact_subspan_local(start_idx,
                span_syllables, resolved_text, resolved_score,
                resolved_segments, resolved_path, resolved_has_anchor,
                resolved_anchor_units) or (resolved_text = '') then
            begin
                Continue;
            end;

            candidate_chunk_text := build_text_from_units_local(candidate_units,
                start_idx, span_syllables);
            if candidate_chunk_text = '' then
            begin
                Continue;
            end;

            if SameText(candidate_chunk_text, resolved_text) then
            begin
                Inc(tail_match_count);
            end
            else if (span_syllables = 2) or resolved_has_anchor or
                (resolved_score >= 4096) then
            begin
                Inc(tail_mismatch_count);
            end;
        end;

        if tail_mismatch_count > 0 then
        begin
            Exit(False);
        end;

        if (tail_match_count > 0) and
            ((exact_strong_match_count >= 2) or
            ((exact_strong_match_count >= 1) and
            (exact_mismatch_count = 0))) then
        begin
            Exit(True);
        end;

        Result := (support_score >= c_min_support_score) and
            (support_segments <= 4) and
            ((exact_strong_match_count >= 2) or
            ((exact_strong_match_count >= 1) and
            (exact_mismatch_count = 0)));
    end;

    function has_useful_long_sentence_prediction_candidate(
        const candidates: TncCandidateList): Boolean;
    var
        candidate_idx: Integer;
        encoded_path: string;
        segment_count: Integer;
        comment_units: Integer;
        path_idx: Integer;
    begin
        Result := False;
        for candidate_idx := 0 to High(candidates) do
        begin
            encoded_path := get_segment_path_for_candidate(candidates[candidate_idx]);
            segment_count := 0;
            if Trim(encoded_path) <> '' then
            begin
                segment_count := 1;
                for path_idx := 1 to Length(encoded_path) do
                begin
                    if encoded_path[path_idx] = c_segment_path_separator then
                    begin
                        Inc(segment_count);
                    end;
                end;
            end;
            if segment_count <= 1 then
            begin
                Continue;
            end;
            if not is_natural_predictive_segment_path_local(encoded_path) then
            begin
                Continue;
            end;
            if Trim(candidates[candidate_idx].comment) = '' then
            begin
                if get_candidate_text_unit_count(Trim(candidates[candidate_idx].text)) >=
                    Max(2, input_syllable_count - 1) then
                begin
                    Exit(True);
                end;
                Continue;
            end;

            comment_units := get_effective_compact_pinyin_unit_count(
                normalize_pinyin_text(candidates[candidate_idx].comment));
            if (comment_units <= 1) and
                (get_candidate_text_unit_count(Trim(candidates[candidate_idx].text)) >=
                Max(2, input_syllable_count - 2)) then
            begin
                Exit(True);
            end;
        end;
    end;

    function has_strong_delayed_long_decode_candidate(
        const candidates: TncCandidateList): Boolean;
    var
        candidate_idx: Integer;
        text_units: Integer;
        comment_units: Integer;
        candidate: TncCandidate;
        segment_score_hint: Integer;
    begin
        Result := False;
        if has_useful_long_sentence_prediction_candidate(candidates) then
        begin
            Exit(True);
        end;

        for candidate_idx := 0 to High(candidates) do
        begin
            candidate := candidates[candidate_idx];
            text_units := get_candidate_text_unit_count(Trim(candidate.text));
            if text_units < 2 then
            begin
                Continue;
            end;

            segment_score_hint := get_candidate_segment_path_score_hint(candidate);
            if candidate.comment = '' then
            begin
                if (text_units >= Max(2, input_syllable_count - 1)) and
                    (candidate.has_dict_weight or (candidate.source = cs_user) or
                    (segment_score_hint > Low(Integer))) then
                begin
                    Exit(True);
                end;
                Continue;
            end;

            comment_units := get_effective_compact_pinyin_unit_count(
                normalize_pinyin_text(candidate.comment));
            if (comment_units <= 1) and
                (text_units >= Max(2, input_syllable_count - 2)) and
                (candidate.has_dict_weight or (candidate.source = cs_user) or
                (segment_score_hint > Low(Integer))) then
            begin
                Exit(True);
            end;
        end;
    end;

    procedure trim_candidates_for_delayed_long_decode(
        var candidates: TncCandidateList);
    const
        c_complete_limit = 6;
        c_partial_limit = 8;
        c_single_partial_limit = 3;
        c_user_limit = 6;
    var
        sorted_candidates: TncCandidateList;
        trimmed_candidates: TncCandidateList;
        idx: Integer;
        out_idx: Integer;
        text_units: Integer;
        user_count: Integer;
        complete_count: Integer;
        partial_count: Integer;
        single_partial_count: Integer;
        candidate: TncCandidate;
    begin
        if Length(candidates) <= 0 then
        begin
            Exit;
        end;

        sorted_candidates := candidates;
        sort_candidates_lightweight(sorted_candidates);
        SetLength(trimmed_candidates, 0);
        out_idx := 0;
        user_count := 0;
        complete_count := 0;
        partial_count := 0;
        single_partial_count := 0;

        for idx := 0 to High(sorted_candidates) do
        begin
            candidate := sorted_candidates[idx];
            text_units := get_candidate_text_unit_count(Trim(candidate.text));

            if candidate.source = cs_user then
            begin
                if user_count >= c_user_limit then
                begin
                    Continue;
                end;
                Inc(user_count);
            end
            else if candidate.comment = '' then
            begin
                if complete_count >= c_complete_limit then
                begin
                    Continue;
                end;
                Inc(complete_count);
            end
            else if text_units <= 1 then
            begin
                if single_partial_count >= c_single_partial_limit then
                begin
                    Continue;
                end;
                Inc(single_partial_count);
            end
            else
            begin
                if partial_count >= c_partial_limit then
                begin
                    Continue;
                end;
                Inc(partial_count);
            end;

            SetLength(trimmed_candidates, out_idx + 1);
            trimmed_candidates[out_idx] := candidate;
            Inc(out_idx);
        end;

        candidates := trimmed_candidates;
    end;

