        function try_get_best_exact_phrase_local(const start_idx: Integer;
            const len: Integer; const prefer_quantity_tail: Boolean;
            out out_text: string; out out_score: Integer;
            out out_reliable: Boolean): Boolean;
        var
            query_key: string;
            results: TncCandidateList;
            result_idx: Integer;
            candidate_text: string;
            candidate_score: Integer;
            direct_weight: Integer;
            best_direct_weight: Integer;
            fixed_first: string;
            first_unit: string;
            second_unit: string;
            split_len: Integer;
            left_text: string;
            right_text: string;
            left_score: Integer;
            right_score: Integer;
            left_reliable: Boolean;
            right_reliable: Boolean;

            function has_reliable_dict_weight_local(
                const candidate: TncCandidate): Boolean;
            begin
                Result := candidate.has_dict_weight and
                    (candidate.dict_weight > 0) and
                    ((candidate.score <= 0) or
                    (candidate.dict_weight <= candidate.score * 4));
            end;
        begin
            Result := False;
            out_text := '';
            out_score := Low(Integer);
            out_reliable := False;
            best_direct_weight := Low(Integer);
            query_key := build_query_key_local(start_idx, len);
            if query_key = '' then
            begin
                Exit;
            end;
            if not lookup_exact_full_pinyin_cached_local(query_key, results) then
            begin
                if not m_dictionary.lookup(query_key, results) then
                begin
                    if len = 3 then
                    begin
                        for split_len := 2 downto 1 do
                        begin
                            if try_get_best_exact_phrase_local(start_idx,
                                split_len, False, left_text, left_score,
                                left_reliable) and
                                try_get_best_exact_phrase_local(start_idx + split_len,
                                len - split_len, False, right_text, right_score,
                                right_reliable) then
                            begin
                                out_text := left_text + right_text;
                                out_score := left_score + right_score +
                                    c_prefix_tail_bonus + (len * len * 256);
                                if m_dictionary <> nil then
                                begin
                                    Inc(out_score, m_dictionary.get_context_bonus(
                                        left_text, right_text));
                                end;
                                out_reliable := left_reliable and right_reliable;
                                Exit(True);
                            end;
                        end;
                    end
                    else if len >= 4 then
                    begin
                        for split_len := len - 1 downto 2 do
                        begin
                            if try_get_best_exact_phrase_local(start_idx,
                                split_len, False, left_text, left_score,
                                left_reliable) and
                                try_get_best_exact_phrase_local(start_idx + split_len,
                                len - split_len, False, right_text, right_score,
                                right_reliable) then
                            begin
                                out_text := left_text + right_text;
                                out_score := left_score + right_score +
                                    c_prefix_tail_bonus + (len * len * 256);
                                if m_dictionary <> nil then
                                begin
                                    Inc(out_score, m_dictionary.get_context_bonus(
                                        left_text, right_text));
                                end;
                                out_reliable := left_reliable and right_reliable;
                                Exit(True);
                            end;
                        end;
                    end;
                    Exit;
                end;
            end;

            fixed_first := '';
            if len >= 2 then
            begin
                fixed_first := get_fixed_tail_single_local(
                    syllables_local[start_idx].text);
            end;

            for result_idx := 0 to High(results) do
            begin
                if result_idx >= c_probe_limit then
                begin
                    Break;
                end;
                if Trim(results[result_idx].comment) <> '' then
                begin
                    Continue;
                end;

                candidate_text := Trim(results[result_idx].text);
                if (candidate_text = '') or
                    (get_candidate_text_unit_count(candidate_text) <> len) then
                begin
                    Continue;
                end;
                if (len >= 2) and (results[result_idx].source <> cs_user) and
                    (not has_reliable_dict_weight_local(results[result_idx])) then
                begin
                    Continue;
                end;

                candidate_score := get_candidate_weight_local(results[result_idx]);
                direct_weight := candidate_score;
                if (results[result_idx].source = cs_user) and
                    (direct_weight >= c_weak_direct_exact_split_weight) then
                begin
                    direct_weight := High(Integer);
                end;
                if direct_weight > best_direct_weight then
                begin
                    best_direct_weight := direct_weight;
                end;
                Inc(candidate_score, get_preferred_query_phrase_bonus_local(
                    query_key, candidate_text));
                Inc(candidate_score, (c_probe_limit - result_idx) * 96);

                if prefer_quantity_tail and (fixed_first <> '') then
                begin
                    first_unit := text_first_unit_local(candidate_text);
                    second_unit := text_second_unit_local(candidate_text);
                    if SameText(first_unit, fixed_first) and
                        is_quantity_tail_unit_local(second_unit) then
                    begin
                        Inc(candidate_score, c_quantity_tail_bonus);
                    end;
                end;

                if (not Result) or (candidate_score > out_score) or
                    ((candidate_score = out_score) and
                    (CompareText(candidate_text, out_text) < 0)) then
                begin
                    Result := True;
                    out_text := candidate_text;
                    out_score := candidate_score;
                    out_reliable := (len = 1) or
                        (results[result_idx].source = cs_user) or
                        has_reliable_dict_weight_local(results[result_idx]);
                end;
            end;

            if (len >= 3) and ((not Result) or
                (best_direct_weight < c_weak_direct_exact_split_weight)) then
            begin
                if len = 3 then
                begin
                    for split_len := 2 downto 1 do
                    begin
                        if try_get_best_exact_phrase_local(start_idx,
                            split_len, False, left_text, left_score,
                            left_reliable) and
                            try_get_best_exact_phrase_local(start_idx + split_len,
                            len - split_len, False, right_text, right_score,
                            right_reliable) then
                        begin
                            candidate_text := left_text + right_text;
                            candidate_score := left_score + right_score +
                                c_prefix_tail_bonus + (len * len * 256);
                            if m_dictionary <> nil then
                            begin
                                Inc(candidate_score, m_dictionary.get_context_bonus(
                                    left_text, right_text));
                            end;
                            if (not Result) or (candidate_score > out_score) or
                                ((candidate_score = out_score) and
                                (CompareText(candidate_text, out_text) < 0)) then
                            begin
                                Result := True;
                                out_text := candidate_text;
                                out_score := candidate_score;
                                out_reliable := left_reliable and right_reliable;
                            end;
                        end;
                    end;
                end
                else
                begin
                    for split_len := len - 1 downto 2 do
                    begin
                        if try_get_best_exact_phrase_local(start_idx,
                            split_len, False, left_text, left_score,
                            left_reliable) and
                            try_get_best_exact_phrase_local(start_idx + split_len,
                            len - split_len, False, right_text, right_score,
                            right_reliable) then
                        begin
                            candidate_text := left_text + right_text;
                            candidate_score := left_score + right_score +
                                c_prefix_tail_bonus + (len * len * 256);
                            if m_dictionary <> nil then
                            begin
                                Inc(candidate_score, m_dictionary.get_context_bonus(
                                    left_text, right_text));
                            end;
                            if (not Result) or (candidate_score > out_score) or
                                ((candidate_score = out_score) and
                                (CompareText(candidate_text, out_text) < 0)) then
                            begin
                                Result := True;
                                out_text := candidate_text;
                                out_score := candidate_score;
                                out_reliable := left_reliable and right_reliable;
                            end;
                        end;
                    end;
                end;
            end;
        end;

        function try_get_fixed_single_tail_local(const start_idx: Integer;
            out out_text: string; out out_score: Integer): Boolean;
        var
            query_key: string;
            results: TncCandidateList;
            result_idx: Integer;
            candidate_score: Integer;
        begin
            Result := False;
            out_text := get_fixed_tail_single_local(syllables_local[start_idx].text);
            out_score := 0;
            if out_text = '' then
            begin
                Exit;
            end;

            query_key := build_query_key_local(start_idx, 1);
            if (query_key <> '') and
                lookup_exact_full_pinyin_cached_local(query_key, results) then
            begin
                for result_idx := 0 to High(results) do
                begin
                    if result_idx >= c_probe_limit then
                    begin
                        Break;
                    end;
                    if (Trim(results[result_idx].comment) <> '') or
                        (not SameText(Trim(results[result_idx].text), out_text)) then
                    begin
                        Continue;
                    end;
                    candidate_score := get_candidate_weight_local(results[result_idx]);
                    if candidate_score > out_score then
                    begin
                        out_score := candidate_score;
                    end;
                end;
            end;

            if out_score <= 0 then
            begin
                out_score := 520;
            end;
            Inc(out_score, c_fixed_tail_bonus);
            Result := True;
        end;
    begin
        if (Length(candidates) = 0) or (m_dictionary = nil) or
            (input_syllable_count < 3) or (input_syllable_count > 6) or
            (not is_full_pinyin_key(lookup_text)) then
        begin
            Exit;
        end;

        syllables_local := get_effective_compact_pinyin_syllables(lookup_text);
        syllable_count_local := Length(syllables_local);
        if syllable_count_local <> input_syllable_count then
        begin
            Exit;
        end;

        if try_get_protective_full_exact_candidate_local(picked,
            best_score) then
        begin
            promote_or_insert_protective_full_exact_candidate_local(picked,
                best_score);
            Exit;
        end;

        if (syllable_count_local = 3) and
            (not has_weak_direct_full_exact_candidate_local) then
        begin
            Exit;
        end;

        best_text := '';
        best_path := '';
        best_score := Low(Integer);
        best_reliable := False;
        best_tail_len := 0;
        best_tail_is_fixed_single := False;
        for tail_len := 1 to Min(2, syllable_count_local - 2) do
        begin
            tail_is_fixed_single := False;
            head_len := syllable_count_local - tail_len;
            if not try_get_best_exact_phrase_local(0, head_len,
                (tail_len = 1) and
                is_modal_tail_syllable_local(syllables_local[head_len].text),
                head_text, head_score, head_reliable) then
            begin
                Continue;
            end;

            if tail_len = 1 then
            begin
                if (head_len >= 1) and
                    try_get_best_exact_phrase_local(head_len - 1, 2, True,
                    preferred_two_tail_text, preferred_two_tail_score,
                    tail_reliable) and
                    SameText(text_first_unit_local(preferred_two_tail_text),
                    get_fixed_tail_single_local(syllables_local[head_len - 1].text)) and
                    is_quantity_tail_unit_local(
                    text_second_unit_local(preferred_two_tail_text)) then
                begin
                    Continue;
                end;

                tail_is_fixed_single := try_get_fixed_single_tail_local(
                    head_len, tail_text, tail_score);
                tail_reliable := tail_is_fixed_single;
                if (not tail_is_fixed_single) and
                    not try_get_best_exact_phrase_local(head_len, tail_len,
                    False, tail_text, tail_score, tail_reliable) then
                begin
                    Continue;
                end;
            end
            else if not try_get_best_exact_phrase_local(head_len, tail_len,
                True, tail_text, tail_score, tail_reliable) then
            begin
                Continue;
            end;

            combined_text := head_text + tail_text;
            if get_candidate_text_unit_count(combined_text) <>
                input_syllable_count then
            begin
                Continue;
            end;

            combined_score := head_score + tail_score + c_prefix_tail_bonus +
                (head_len * head_len * 512);
            if tail_len > 1 then
            begin
                Inc(combined_score, (tail_len - 1) * c_exact_tail_span_bonus);
            end;
            Inc(combined_score, m_dictionary.get_context_bonus(head_text,
                tail_text));
            if combined_score > best_score then
            begin
                best_score := combined_score;
                best_text := combined_text;
                best_path := head_text + c_segment_path_separator + tail_text;
                best_reliable := head_reliable and tail_reliable;
                best_tail_len := tail_len;
                best_tail_is_fixed_single := tail_is_fixed_single;
            end;
            if tail_is_fixed_single and (best_text <> '') then
            begin
                Break;
            end;
        end;

        if best_text = '' then
        begin
            Exit;
        end;

        if (best_tail_len = 1) and (not best_tail_is_fixed_single) and
            has_covering_partial_anchor_local then
        begin
            Exit;
        end;

        existing_index := -1;
        for idx := 0 to High(candidates) do
        begin
            if (Trim(candidates[idx].comment) = '') and
                SameText(Trim(candidates[idx].text), best_text) then
            begin
                existing_index := idx;
                Break;
            end;
        end;

        if existing_index = 0 then
        begin
            if best_reliable then
            begin
                candidates[0].has_dict_weight := True;
                candidates[0].dict_weight := Max(candidates[0].dict_weight,
                    best_score);
            end;
            remember_segment_path_for_candidate(best_text, '', best_path,
                Max(candidates[0].score, best_score));
            Exit;
        end;

        if existing_index > 0 then
        begin
            picked := candidates[existing_index];
            picked.score := Max(Max(candidates[0].score + 2048,
                picked.score), best_score);
            if best_reliable then
            begin
                picked.has_dict_weight := True;
                picked.dict_weight := Max(picked.dict_weight, best_score);
            end;
            remember_segment_path_for_candidate(picked.text, '', best_path,
                picked.score);
            for idx := existing_index downto 1 do
            begin
                candidates[idx] := candidates[idx - 1];
            end;
            candidates[0] := picked;
        end
        else
        begin
            FillChar(picked, SizeOf(picked), 0);
            picked.text := best_text;
            picked.comment := '';
            picked.score := Max(candidates[0].score + 2048, best_score);
            picked.source := cs_rule;
            picked.has_dict_weight := best_reliable;
            if best_reliable then
            begin
                picked.dict_weight := best_score;
            end
            else
            begin
                picked.dict_weight := 0;
            end;
            remember_segment_path_for_candidate(picked.text, '', best_path,
                picked.score);
            SetLength(candidates, Length(candidates) + 1);
            for idx := High(candidates) downto 1 do
            begin
                candidates[idx] := candidates[idx - 1];
            end;
            candidates[0] := picked;
        end;

        if m_config.debug_mode then
        begin
            m_last_full_path_debug_info := m_last_full_path_debug_info +
                Format(' sptail=[text=%s score=%d]', [best_text, best_score]);
        end;
    end;

    procedure ensure_best_short_natural_split_candidate_visible(
        var candidates: TncCandidateList);
    const
        c_max_span_local = 3;
        c_probe_limit_local = 8;
        c_min_user_direct_weight_local = 300;
        c_invalid_score_local = Low(Integer) div 4;
    var
        syllables_local: TncPinyinParseResult;
        syllable_count_local: Integer;
        scores: TArray<Integer>;
        texts: TArray<string>;
        paths: TArray<string>;
        last_segments: TArray<string>;
        segment_counts: TArray<Integer>;
        pos: Integer;
        span_len: Integer;
        next_pos: Integer;
        result_idx: Integer;
        results: TncCandidateList;
        query_key: string;
        candidate_text: string;
        candidate_weight: Integer;
        segment_score: Integer;
        next_score: Integer;
        best_text: string;
        best_path: string;
        existing_index: Integer;
        idx: Integer;
        top_text: string;
        top_weight: Integer;
        top_complete: Boolean;
        picked: TncCandidate;

        function build_query_key_local(const start_idx: Integer;
            const local_len: Integer): string;
        var
            local_idx: Integer;
        begin
            Result := '';
            for local_idx := start_idx to start_idx + local_len - 1 do
            begin
                Result := Result + normalize_pinyin_text(
                    syllables_local[local_idx].text);
            end;
        end;

        function get_candidate_weight_local(const candidate: TncCandidate): Integer;
        begin
            Result := candidate.score;
            if candidate.has_dict_weight and (candidate.dict_weight > Result) then
            begin
                Result := candidate.dict_weight;
            end;
        end;
    begin
        if (Length(candidates) = 0) or (m_dictionary = nil) or
            (input_syllable_count < 4) or (input_syllable_count > 6) then
        begin
            Exit;
        end;

        syllables_local := get_effective_compact_pinyin_syllables(lookup_text);
        syllable_count_local := Length(syllables_local);
        if syllable_count_local <> input_syllable_count then
        begin
            Exit;
        end;

        SetLength(scores, syllable_count_local + 1);
        SetLength(texts, syllable_count_local + 1);
        SetLength(paths, syllable_count_local + 1);
        SetLength(last_segments, syllable_count_local + 1);
        SetLength(segment_counts, syllable_count_local + 1);
        for idx := 0 to syllable_count_local do
        begin
            scores[idx] := c_invalid_score_local;
            texts[idx] := '';
            paths[idx] := '';
            last_segments[idx] := '';
            segment_counts[idx] := 0;
        end;
        scores[0] := 0;

        for pos := 0 to syllable_count_local - 1 do
        begin
            if scores[pos] <= c_invalid_score_local div 2 then
            begin
                Continue;
            end;

            for span_len := 1 to Min(c_max_span_local,
                syllable_count_local - pos) do
            begin
                query_key := build_query_key_local(pos, span_len);
                if (query_key = '') or (not m_dictionary.lookup(query_key,
                    results)) then
                begin
                    Continue;
                end;

                for result_idx := 0 to High(results) do
                begin
                    if result_idx >= c_probe_limit_local then
                    begin
                        Break;
                    end;
                    if Trim(results[result_idx].comment) <> '' then
                    begin
                        Continue;
                    end;

                    candidate_text := Trim(results[result_idx].text);
                    if (candidate_text = '') or
                        (get_candidate_text_unit_count(candidate_text) <>
                        span_len) then
                    begin
                        Continue;
                    end;

                    candidate_weight := get_candidate_weight_local(
                        results[result_idx]);
                    if (results[result_idx].source = cs_user) and
                        (candidate_weight < c_min_user_direct_weight_local) then
                    begin
                        Continue;
                    end;

                    segment_score := candidate_weight + span_len * 512;
                    if span_len > 1 then
                    begin
                        Inc(segment_score, 1024);
                    end;
                    Inc(segment_score,
                        (c_probe_limit_local - result_idx) * 24);
                    if last_segments[pos] <> '' then
                    begin
                        Inc(segment_score, m_dictionary.get_context_bonus(
                            last_segments[pos], candidate_text));
                    end;

                    next_pos := pos + span_len;
                    next_score := scores[pos] + segment_score;
                    if next_score > scores[next_pos] then
                    begin
                        scores[next_pos] := next_score;
                        texts[next_pos] := texts[pos] + candidate_text;
                        if paths[pos] <> '' then
                        begin
                            paths[next_pos] := paths[pos] +
                                c_segment_path_separator + candidate_text;
                        end
                        else
                        begin
                            paths[next_pos] := candidate_text;
                        end;
                        last_segments[next_pos] := candidate_text;
                        segment_counts[next_pos] := segment_counts[pos] + 1;
                    end;
                end;
            end;
        end;

        if (scores[syllable_count_local] <= c_invalid_score_local div 2) or
            (segment_counts[syllable_count_local] < 2) then
        begin
            Exit;
        end;

        best_text := texts[syllable_count_local];
        best_path := paths[syllable_count_local];
        if (best_text = '') or
            (get_candidate_text_unit_count(best_text) <> input_syllable_count) then
        begin
            Exit;
        end;

        top_text := Trim(candidates[0].text);
        top_complete := (Trim(candidates[0].comment) = '') and
            (get_candidate_text_unit_count(top_text) = input_syllable_count);
        top_weight := get_candidate_weight_local(candidates[0]);
        if top_complete and SameText(top_text, best_text) then
        begin
            remember_segment_path_for_candidate(best_text, '', best_path,
                Max(candidates[0].score, scores[syllable_count_local]));
            Exit;
        end;
        if top_complete and (candidates[0].source <> cs_user) and
            (top_weight >= 500) then
        begin
            Exit;
        end;
        if top_complete and
            (scores[syllable_count_local] < candidates[0].score + 512) then
        begin
            Exit;
        end;

        existing_index := -1;
        for idx := 0 to High(candidates) do
        begin
            if (Trim(candidates[idx].comment) = '') and
                SameText(Trim(candidates[idx].text), best_text) then
            begin
                existing_index := idx;
                Break;
            end;
        end;

        if existing_index = 0 then
        begin
            Exit;
        end;
        if existing_index > 0 then
        begin
            picked := candidates[existing_index];
            picked.score := Max(picked.score, candidates[0].score + 1024);
            picked.has_dict_weight := True;
            picked.dict_weight := Max(picked.dict_weight,
                scores[syllable_count_local]);
            for idx := existing_index downto 1 do
            begin
                candidates[idx] := candidates[idx - 1];
            end;
            candidates[0] := picked;
        end
        else
        begin
            FillChar(picked, SizeOf(picked), 0);
            picked.text := best_text;
            picked.comment := '';
            picked.score := Max(scores[syllable_count_local],
                candidates[0].score + 1024);
            picked.source := cs_rule;
            picked.has_dict_weight := True;
            picked.dict_weight := scores[syllable_count_local];
            SetLength(candidates, Length(candidates) + 1);
            for idx := High(candidates) downto 1 do
            begin
                candidates[idx] := candidates[idx - 1];
            end;
            candidates[0] := picked;
        end;
        remember_segment_path_for_candidate(best_text, '', best_path,
            scores[syllable_count_local]);
    end;

    procedure ensure_best_three_syllable_contextual_two_plus_one_complete_candidate_visible(
        var candidates: TncCandidateList);
    const
        c_tail_probe_limit = 16;
        c_context_scale = 4;
        c_preferred_tail_bonus = 96;
        c_complete_promote_bonus = 1152;
    var
        effective_syllables: TncPinyinParseResult;
        head_key: string;
        tail_key: string;
        tail_results: TncCandidateList;
        head_texts: TArray<string>;
        head_scores: TArray<Integer>;
        best_tail_text: string;
        best_prefix_text: string;
        combined_text: string;
        candidate_combined_text: string;
        candidate_text: string;
        resolved_text_local: string;
        resolved_path_local: string;
        resolved_has_anchor_local: Boolean;
        best_tail_score: Integer;
        candidate_score: Integer;
        context_bonus: Integer;
        prefix_popularity: Integer;
        query_bonus: Integer;
        exact_bonus: Integer;
        preferred_exact_bonus: Integer;
        idx: Integer;
        existing_index: Integer;
        candidate_units: Integer;
        resolved_segments_local: Integer;
        resolved_anchor_units_local: Integer;
        is_preferred: Boolean;
        picked: TncCandidate;
        best_tail_context_bonus: Integer;
        prefix_results: TncCandidateList;
        head_option_idx: Integer;

        function build_syllable_query_key_local(const start_idx: Integer;
            const syllable_count_local: Integer): string;
        var
            local_idx: Integer;
        begin
            Result := '';
            if (start_idx < 0) or (syllable_count_local <= 0) or
                (start_idx + syllable_count_local - 1 > High(effective_syllables)) then
            begin
                Exit;
            end;

            for local_idx := start_idx to start_idx + syllable_count_local - 1 do
            begin
                Result := Result +
                    normalize_pinyin_text(effective_syllables[local_idx].text);
            end;
        end;

        function build_prefix_text_local(const text_value: string;
            const unit_count_local: Integer): string;
        var
            local_units: TArray<string>;
            local_idx: Integer;
        begin
            Result := '';
            local_units := split_text_units(Trim(text_value));
            if Length(local_units) < unit_count_local then
            begin
                Exit;
            end;
            for local_idx := 0 to unit_count_local - 1 do
            begin
                Result := Result + local_units[local_idx];
            end;
        end;

        function get_candidate_score_local(const candidate: TncCandidate): Integer;
        begin
            Result := candidate.score;
            if candidate.has_dict_weight and (candidate.dict_weight > Result) then
            begin
                Result := candidate.dict_weight;
            end;
            if Result < 0 then
            begin
                Result := 0;
            end;
        end;

        function get_exact_query_text_bonus_local(const candidate_text_local: string): Integer;
        var
            local_results: TncCandidateList;
            local_idx: Integer;
        begin
            Result := 0;
            if (m_dictionary = nil) or (lookup_text = '') or
                (candidate_text_local = '') then
            begin
                Exit;
            end;

            if not m_dictionary.lookup_exact_full_pinyin(lookup_text, local_results) then
            begin
                Exit;
            end;
            for local_idx := 0 to High(local_results) do
            begin
                if Trim(local_results[local_idx].comment) <> '' then
                begin
                    Continue;
                end;
                if SameText(Trim(local_results[local_idx].text), candidate_text_local) then
                begin
                    Exit(3072);
                end;
            end;
        end;

        function has_competing_exact_full_phrase_local(
            const candidate_text_local: string): Boolean;
        var
            local_results: TncCandidateList;
            local_idx: Integer;
            local_text: string;
            has_competing_exact: Boolean;
            candidate_is_exact: Boolean;
            normalized_query: string;
        begin
            Result := False;
            if (m_dictionary = nil) or (lookup_text = '') or
                (Trim(candidate_text_local) = '') then
            begin
                Exit;
            end;

            normalized_query := normalize_pinyin_text(lookup_text);
            if is_latest_session_query_choice(candidate_text_local) or
                (m_dictionary.get_query_choice_bonus(normalized_query,
                candidate_text_local) > 0) then
            begin
                Exit;
            end;

            if not m_dictionary.lookup_exact_full_pinyin(lookup_text,
                local_results) then
            begin
                Exit;
            end;

            has_competing_exact := False;
            candidate_is_exact := False;
            for local_idx := 0 to High(local_results) do
            begin
                if Trim(local_results[local_idx].comment) <> '' then
                begin
                    Continue;
                end;

                local_text := Trim(local_results[local_idx].text);
                if get_candidate_text_unit_count(local_text) <> input_syllable_count then
                begin
                    Continue;
                end;

                if SameText(local_text, Trim(candidate_text_local)) then
                begin
                    candidate_is_exact := True;
                end
                else
                begin
                    has_competing_exact := True;
                end;
            end;

            Result := has_competing_exact and (not candidate_is_exact);
        end;

        procedure add_head_option_local(const text_value: string;
            const score_value: Integer);
        var
            option_idx: Integer;
            insert_idx: Integer;
            tmp_text: string;
            tmp_score: Integer;
        begin
            if text_value = '' then
            begin
                Exit;
            end;
            for option_idx := 0 to High(head_texts) do
            begin
                if SameText(head_texts[option_idx], text_value) then
                begin
                    if score_value > head_scores[option_idx] then
                    begin
                        head_scores[option_idx] := score_value;
                    end;
                    Exit;
                end;
            end;

            insert_idx := Length(head_texts);
            SetLength(head_texts, insert_idx + 1);
            SetLength(head_scores, insert_idx + 1);
            head_texts[insert_idx] := text_value;
            head_scores[insert_idx] := score_value;

            while (insert_idx > 0) and
                (head_scores[insert_idx] > head_scores[insert_idx - 1]) do
            begin
                tmp_text := head_texts[insert_idx - 1];
                head_texts[insert_idx - 1] := head_texts[insert_idx];
                head_texts[insert_idx] := tmp_text;
                tmp_score := head_scores[insert_idx - 1];
                head_scores[insert_idx - 1] := head_scores[insert_idx];
                head_scores[insert_idx] := tmp_score;
                Dec(insert_idx);
            end;

            if Length(head_texts) > 6 then
            begin
                SetLength(head_texts, 6);
                SetLength(head_scores, 6);
            end;
        end;

        function collect_head_phrase_options_local: Boolean;
        var
            local_results: TncCandidateList;
            local_idx: Integer;
            local_text: string;
            local_score: Integer;
        begin
            SetLength(head_texts, 0);
            SetLength(head_scores, 0);

            if try_resolve_best_exact_subspan_local(0, 2, resolved_text_local,
                local_score, resolved_segments_local, resolved_path_local,
                resolved_has_anchor_local, resolved_anchor_units_local) and
                (get_candidate_text_unit_count(Trim(resolved_text_local)) = 2) then
            begin
                if resolved_has_anchor_local then
                begin
                    Inc(local_score, resolved_anchor_units_local * 192);
                end;
                if resolved_segments_local > 1 then
                begin
                    Dec(local_score, (resolved_segments_local - 1) * 96);
                end;
                add_head_option_local(Trim(resolved_text_local), local_score);
            end;

            if m_dictionary.lookup(head_key, local_results) then
            begin
                for local_idx := 0 to High(local_results) do
                begin
                    if local_idx >= 12 then
                    begin
                        Break;
                    end;
                    if Trim(local_results[local_idx].comment) <> '' then
                    begin
                        Continue;
                    end;

                    local_text := Trim(local_results[local_idx].text);
                    if get_candidate_text_unit_count(local_text) <> 2 then
                    begin
                        Continue;
                    end;

                    local_score := get_candidate_score_local(local_results[local_idx]) +
                        get_preferred_query_phrase_bonus_local(head_key, local_text);
                    add_head_option_local(local_text, local_score);
                end;
            end;
            Result := Length(head_texts) > 0;
        end;

        function try_get_best_prefix_derived_complete_text_local(
            out out_text: string; out out_score: Integer): Boolean;
        var
            local_idx: Integer;
            prefix_text_local: string;
            prefix_score_local: Integer;
            prefix_popularity_local: Integer;
            syllable_idx: Integer;
            prefix_units_local: TArray<string>;
            prefix_scores_local: TDictionary<string, Integer>;
            aggregated_score_local: Integer;
            existing_prefix_score_local: Integer;
        begin
            Result := False;
            out_text := '';
            out_score := Low(Integer);
            if not m_dictionary.lookup_full_pinyin_prefix(lookup_text, prefix_results) then
            begin
                Exit;
            end;

            prefix_scores_local := TDictionary<string, Integer>.Create;
            try
                for local_idx := 0 to High(prefix_results) do
                begin
                    if local_idx >= 48 then
                    begin
                        Break;
                    end;
                    if Trim(prefix_results[local_idx].comment) <> '' then
                    begin
                        Continue;
                    end;
                    if is_runtime_chain_candidate(prefix_results[local_idx]) or
                        is_runtime_common_pattern_candidate(prefix_results[local_idx]) or
                        is_runtime_redup_candidate(prefix_results[local_idx]) then
                    begin
                        Continue;
                    end;

                    prefix_text_local := build_prefix_text_local(prefix_results[local_idx].text, 3);
                    if get_candidate_text_unit_count(prefix_text_local) <> 3 then
                    begin
                        Continue;
                    end;
                    prefix_units_local := split_text_units(prefix_text_local);
                    if Length(prefix_units_local) <> 3 then
                    begin
                        Continue;
                    end;

                    for syllable_idx := 0 to 2 do
                    begin
                        if not match_single_char_candidate_for_syllable(
                            effective_syllables[syllable_idx].text,
                            prefix_units_local[syllable_idx], is_preferred) then
                        begin
                            prefix_text_local := '';
                            Break;
                        end;
                    end;
                    if prefix_text_local = '' then
                    begin
                        Continue;
                    end;

                    prefix_popularity_local := 0;
                    if m_dictionary is TncSqliteDictionary then
                    begin
                        prefix_popularity_local := TncSqliteDictionary(m_dictionary).
                            get_prefix_popularity_hint(prefix_text_local);
                    end;

                    prefix_score_local := 1024 +
                        Min(256, Max(0, get_candidate_score_local(prefix_results[local_idx])) div 8) +
                        get_preferred_query_phrase_bonus_local(lookup_text, prefix_text_local);
                    if prefix_popularity_local > 0 then
                    begin
                        Inc(prefix_score_local, Round(Ln(1.0 + prefix_popularity_local) * 96.0));
                    end;

                    aggregated_score_local := prefix_score_local;
                    if prefix_scores_local.TryGetValue(prefix_text_local,
                        existing_prefix_score_local) then
                    begin
                        Inc(aggregated_score_local, existing_prefix_score_local);
                    end;
                    prefix_scores_local.AddOrSetValue(prefix_text_local, aggregated_score_local);

                    if aggregated_score_local > out_score then
                    begin
                        out_score := aggregated_score_local;
                        out_text := prefix_text_local;
                        Result := True;
                        if m_config.debug_mode then
                        begin
                            m_last_full_path_debug_info := m_last_full_path_debug_info +
                                Format(' t321pick=[text=%s pop=%d score=%d agg=%d]',
                                [prefix_text_local, prefix_popularity_local,
                                prefix_score_local, aggregated_score_local]);
                        end;
                    end;
                end;
            finally
                prefix_scores_local.Free;
            end;
        end;
    begin
        if (Length(candidates) = 0) or (input_syllable_count <> 3) or
            (not is_full_pinyin_key(lookup_text)) or (m_dictionary = nil) then
        begin
            Exit;
        end;

        effective_syllables := get_effective_compact_pinyin_syllables(
            normalize_pinyin_text(lookup_text));
        if Length(effective_syllables) <> 3 then
        begin
            Exit;
        end;

        head_key := build_syllable_query_key_local(0, 2);
        tail_key := build_syllable_query_key_local(2, 1);
        if (head_key = '') or (tail_key = '') then
        begin
            Exit;
        end;

        if not collect_head_phrase_options_local then
        begin
            if m_config.debug_mode then
            begin
                m_last_full_path_debug_info := m_last_full_path_debug_info +
                    Format(' t321=[nohead key=%s]', [head_key]);
            end;
            Exit;
        end;

        if not m_dictionary.lookup(tail_key, tail_results) then
        begin
            SetLength(tail_results, 0);
        end;

        combined_text := '';
        best_tail_text := '';
        best_tail_score := Low(Integer);
        best_tail_context_bonus := 0;
        for idx := 0 to High(tail_results) do
        begin
            if idx >= c_tail_probe_limit then
            begin
                Break;
            end;
            if Trim(tail_results[idx].comment) <> '' then
            begin
                Continue;
            end;
            if is_runtime_chain_candidate(tail_results[idx]) or
                is_runtime_common_pattern_candidate(tail_results[idx]) or
                is_runtime_redup_candidate(tail_results[idx]) then
            begin
                Continue;
            end;

            candidate_text := Trim(tail_results[idx].text);
            candidate_units := get_candidate_text_unit_count(candidate_text);
            if candidate_units <> 1 then
            begin
                Continue;
            end;
            if not match_single_char_candidate_for_syllable(tail_key, candidate_text,
                is_preferred) then
            begin
                Continue;
            end;

            for head_option_idx := 0 to High(head_texts) do
            begin
                context_bonus := m_dictionary.get_context_bonus(
                    head_texts[head_option_idx], candidate_text);
                prefix_popularity := 0;
                candidate_combined_text := head_texts[head_option_idx] + candidate_text;
                if m_dictionary is TncSqliteDictionary then
                begin
                    prefix_popularity := TncSqliteDictionary(m_dictionary).
                        get_prefix_popularity_hint(candidate_combined_text);
                end;
                exact_bonus := get_exact_query_text_bonus_local(candidate_combined_text);
                query_bonus := get_preferred_query_phrase_bonus_local(lookup_text,
                    candidate_combined_text);
                preferred_exact_bonus := get_preferred_exact_subspan_bonus_local(
                    lookup_text, candidate_combined_text);
                if (context_bonus <= 0) and (prefix_popularity <= 0) and
                    (exact_bonus <= 0) and (query_bonus <= 0) and
                    (preferred_exact_bonus <= 0) and (not is_preferred) then
                begin
                    Continue;
                end;

                candidate_score := get_candidate_score_local(tail_results[idx]) +
                    (context_bonus * c_context_scale) +
                    Round(Ln(1.0 + prefix_popularity) * 256.0) +
                    query_bonus + exact_bonus + preferred_exact_bonus;
                if is_preferred then
                begin
                    Inc(candidate_score, c_preferred_tail_bonus);
                end;
                if (context_bonus <= 0) and (prefix_popularity <= 0) and
                    (exact_bonus <= 0) and (query_bonus <= 0) and
                    (preferred_exact_bonus <= 0) then
                begin
                    Dec(candidate_score, 384);
                end;

                candidate_score := head_scores[head_option_idx] +
                    candidate_score + c_complete_promote_bonus;
                if candidate_score > best_tail_score then
                begin
                    best_tail_score := candidate_score;
                    best_tail_text := candidate_combined_text;
                    best_tail_context_bonus := context_bonus;
                end;
            end;
        end;

        best_prefix_text := '';
        if try_get_best_prefix_derived_complete_text_local(best_prefix_text, candidate_score) and
            ((best_tail_text = '') or
            (candidate_score > best_tail_score)) then
        begin
            combined_text := best_prefix_text;
            best_tail_text := '';
            best_tail_score := candidate_score;
            candidate_score := best_tail_score;
        end
        else if best_tail_text <> '' then
        begin
            combined_text := best_tail_text;
            candidate_score := best_tail_score;
        end;

        if combined_text = '' then
        begin
            if m_config.debug_mode then
            begin
                m_last_full_path_debug_info := m_last_full_path_debug_info +
                    Format(' t321=[notail head=%s tail=%s]', [head_key, tail_key]);
            end;
            Exit;
        end;

        if has_competing_exact_full_phrase_local(combined_text) then
        begin
            if m_config.debug_mode then
            begin
                m_last_full_path_debug_info := m_last_full_path_debug_info +
                    Format(' t321=[skip exact=%s text=%s]',
                    [lookup_text, combined_text]);
            end;
            Exit;
        end;

        existing_index := -1;
        for idx := 0 to High(candidates) do
        begin
            if (Trim(candidates[idx].comment) = '') and
                SameText(Trim(candidates[idx].text), combined_text) then
            begin
                existing_index := idx;
                Break;
            end;
        end;

        if existing_index = 0 then
        begin
            if candidates[0].score < candidate_score then
            begin
                candidates[0].score := candidate_score;
            end;
            Exit;
        end;

        if existing_index > 0 then
        begin
            picked := candidates[existing_index];
            if picked.score < candidate_score then
            begin
                picked.score := candidate_score;
            end;
            for idx := existing_index downto 1 do
            begin
                candidates[idx] := candidates[idx - 1];
            end;
            candidates[0] := picked;
            Exit;
        end;

        picked.text := combined_text;
        picked.comment := '';
        picked.score := candidate_score;
        picked.source := cs_rule;
        picked.has_dict_weight := False;
        picked.dict_weight := 0;
        if best_tail_text <> '' then
        begin
            remember_segment_path_for_candidate(picked.text, '', picked.text,
                picked.score);
        end;

        SetLength(candidates, Length(candidates) + 1);
        for idx := High(candidates) downto 1 do
        begin
            candidates[idx] := candidates[idx - 1];
        end;
        candidates[0] := picked;
        if m_config.debug_mode then
        begin
            m_last_full_path_debug_info := m_last_full_path_debug_info +
                Format(' t321=[promote text=%s head=%s tail=%s ctx=%d score=%d]',
                [Trim(picked.text), head_key, best_tail_text, best_tail_context_bonus,
                picked.score]);
        end;
    end;

