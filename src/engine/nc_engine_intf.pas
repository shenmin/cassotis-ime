                    local_candidate.score, local_chunk_alignment_score,
                    local_support_score, local_head_boundary_score);
                if local_support_score <= -960 then
                begin
                    if best_support_score > -960 then
                    begin
                        Continue;
                    end;
                    if (local_chunk_alignment_score <
                        best_chunk_alignment_score + 24000) or
                        (local_rerank_score <
                        best_rerank_score + 36000) then
