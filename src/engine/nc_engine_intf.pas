        best_scores: TArray<Integer>;
        best_segments: TArray<Integer>;
        best_texts: TArray<string>;
        best_paths: TArray<string>;
        best_first_chunks: TArray<string>;
        best_beam_options: TArray<TSubquerySolverBeamOptionArray>;
        idx: Integer;
        existing_index: Integer;
        picked: TncCandidate;
        top_path_segment_count: Integer;
        should_promote: Boolean;
        query_cache_states: TDictionary<string, Integer>;
        query_cache_texts: TDictionary<string, string>;
        query_cache_scores: TDictionary<string, Integer>;
        query_option_cache_states: TDictionary<string, Integer>;
        query_option_cache_options: TDictionary<string, TSubquerySolverBeamOptionArray>;
        query_engine: TncEngine;
        query_engine_config: TncEngineConfig;
        has_extendable_tail_local: Boolean;
        strict_solver_text_local: string;
        strict_solver_path_local: string;
        strict_solver_score_local: Integer;
        strict_solver_segments_local: Integer;
        function has_extendable_tail_query_local(const pinyin_key: string): Boolean;
        var
            local_syllables: TncPinyinParseResult;
            local_syllable_count: Integer;
            suffix_ch: Char;
            extended_key: string;
        begin
            Result := False;
            if pinyin_key = '' then
            begin
                Exit;
            end;

            local_syllables := get_effective_compact_pinyin_syllables(pinyin_key);
            local_syllable_count := Length(local_syllables);
            if local_syllable_count < 4 then
            begin
                Exit;
            end;

            for suffix_ch := 'a' to 'z' do
            begin
                extended_key := pinyin_key + suffix_ch;
                if get_effective_compact_pinyin_unit_count(extended_key) =
                    local_syllable_count then
                begin
                    Exit(True);
                end;
            end;
        end;

        function get_path_segment_count_local(const encoded_path: string): Integer;
        var
            parts: TArray<string>;
            part_idx: Integer;
        begin
            Result := 0;
            if Trim(encoded_path) = '' then
            begin
                Exit;
            end;

            parts := encoded_path.Split([c_segment_path_separator]);
            for part_idx := 0 to High(parts) do
            begin
                if Trim(parts[part_idx]) <> '' then
                begin
                    Inc(Result);
                end;
            end;
        end;

        function build_query_key_local(const start_idx: Integer;
            const syllable_count_part: Integer): string;
        var
            local_idx: Integer;
        begin
            Result := '';
            if (start_idx < 0) or (syllable_count_part <= 0) or
                (start_idx + syllable_count_part - 1 > High(effective_syllables)) then
            begin
                Exit;
            end;

            for local_idx := start_idx to start_idx + syllable_count_part - 1 do
            begin
                Result := Result + normalize_pinyin_text(
                    effective_syllables[local_idx].text);
            end;
        end;

