            best_partial_option_local: TExactChunkChainOption;
            best_split_option_local: TExactChunkChainOption;
            has_best_partial_option_local: Boolean;
            has_best_split_option_local: Boolean;
        const
            c_standalone_split_option_probe_limit = 6;
            c_standalone_single_char_option_limit = 6;
            procedure add_standalone_option_local(
                const candidate_option: TExactChunkChainOption);
            var
                option_idx_local: Integer;
            begin
                if candidate_option.text = '' then
                begin
                    Exit;
                end;
                for option_idx_local := 0 to High(out_options) do
                begin
                    if SameText(out_options[option_idx_local].text,
                        candidate_option.text) then
                    begin
                        if is_exact_chunk_option_better_local(candidate_option,
                            out_options[option_idx_local]) then
                        begin
                            out_options[option_idx_local] := candidate_option;
                        end;
                        Exit;
                    end;
                end;
                SetLength(out_options, Length(out_options) + 1);
                out_options[High(out_options)] := candidate_option;
            end;
        begin
            Result := False;
            SetLength(out_options, 0);
            if (query_key_local = '') or (not is_full_pinyin_key(query_key_local)) or
                (input_syllable_count < 8) or
                (expected_syllables <= 2) or
                (expected_syllables > c_chain_lattice_max_chunk_syllables) then
            begin
                Exit;
            end;

            if expected_syllables = 1 then
            begin
                if m_dictionary.lookup_exact_full_pinyin(query_key_local,
                    local_results) then
                begin
                    for local_idx := 0 to High(local_results) do
                    begin
                        if local_idx >= c_chain_probe_limit then
                        begin
                            Break;
                        end;
                        if Trim(local_results[local_idx].comment) <> '' then
                        begin
                            Continue;
                        end;

                        candidate_text_local := Trim(local_results[local_idx].text);
                        if (get_candidate_text_unit_count(candidate_text_local) <> 1) or
                            (not is_valid_standalone_cjk_phrase_text_local(
                            candidate_text_local, 1)) then
                        begin
                            Continue;
                        end;

                        candidate_score_local := local_results[local_idx].score;
                        if local_results[local_idx].has_dict_weight and
                            (local_results[local_idx].dict_weight >
                            candidate_score_local) then
                        begin
                            candidate_score_local := local_results[local_idx].dict_weight;
                        end;
                        Inc(candidate_score_local,
                            get_preferred_query_phrase_bonus_local(
                            query_key_local, candidate_text_local));
                        Inc(candidate_score_local,
                            get_exact_query_text_bonus_local(query_key_local,
                            candidate_text_local));
                        Dec(candidate_score_local,
                            get_context_free_single_char_penalty_local(
                            query_key_local, candidate_text_local));

                        local_option := Default(TExactChunkChainOption);
                        local_option.text := candidate_text_local;
                        local_option.path := candidate_text_local;
                        local_option.query_key := query_key_local;
                        local_option.score := candidate_score_local;
                        local_option.segments := 1;
                        local_option.has_anchor := True;
                        local_option.anchor_units := 1;
                        add_standalone_option_local(local_option);
                    end;
                end;
                sort_and_trim_exact_chunk_options_local(out_options,
                    c_standalone_single_char_option_limit);
                Exit(Length(out_options) > 0);
            end;

            if standalone_chunk_states.TryGetValue(query_key_local, cached_state) then
            begin
                if cached_state = 1 then
                begin
                    if standalone_chunk_options.TryGetValue(query_key_local,
                        cached_options_local) then
                    begin
                        out_options := Copy(cached_options_local);
                        Exit(Length(out_options) > 0);
                    end;
                    standalone_chunk_texts.TryGetValue(query_key_local,
                        candidate_text_local);
                    standalone_chunk_scores.TryGetValue(query_key_local,
                        candidate_score_local);
                    if candidate_text_local <> '' then
                    begin
                        SetLength(out_options, 1);
                        out_options[0] := Default(TExactChunkChainOption);
                        out_options[0].text := candidate_text_local;
                        out_options[0].path := candidate_text_local;
                        out_options[0].query_key := query_key_local;
                        out_options[0].score := candidate_score_local;
                        out_options[0].segments := 1;
                        out_options[0].has_anchor :=
                            expected_syllables >= c_chain_min_anchor_syllables;
                        if out_options[0].has_anchor then
                        begin
                            out_options[0].anchor_units := expected_syllables;
                        end
                        else
                        begin
                            out_options[0].anchor_units := 0;
                        end;
                        Exit(True);
                    end;
                    Exit(False);
                end;
                Exit(False);
            end;

            if standalone_chunk_budget_remaining <= 0 then
            begin
                Exit;
            end;
            Dec(standalone_chunk_budget_remaining);

            if standalone_chunk_engine = nil then
            begin
                standalone_chunk_config := m_config;
                standalone_chunk_config.debug_mode := False;
                standalone_chunk_engine := TncEngine.Create(standalone_chunk_config);
            end;

            standalone_chunk_states.AddOrSetValue(query_key_local, 3);
            standalone_chunk_engine.m_disable_subspan_standalone_oracle :=
                m_disable_subspan_standalone_oracle + 1;
            standalone_chunk_engine.m_composition_text := query_key_local;
            standalone_chunk_engine.build_candidates;
            SetLength(snapshot_candidates_local,
                Length(standalone_chunk_engine.m_candidates));
            SetLength(snapshot_scores_local,
                Length(standalone_chunk_engine.m_candidates));
            for candidate_idx_local := 0 to High(standalone_chunk_engine.m_candidates) do
            begin
                snapshot_candidates_local[candidate_idx_local] :=
                    standalone_chunk_engine.m_candidates[candidate_idx_local];
                snapshot_scores_local[candidate_idx_local] :=
                    standalone_chunk_engine.get_rank_score(
                    standalone_chunk_engine.m_candidates[candidate_idx_local]);
            end;

            best_complete_text_local := '';
            best_complete_score_local := Low(Integer);
            best_partial_text_local := '';
            best_partial_score_local := Low(Integer);
            best_partial_comment_local := '';
            best_split_text_local := '';
            best_split_score_local := Low(Integer);
            has_best_partial_option_local := False;
            has_best_split_option_local := False;

            if m_dictionary.lookup_exact_full_pinyin(query_key_local,
                local_results) then
            begin
                for local_idx := 0 to High(local_results) do
                begin
                    if local_idx >= c_chain_probe_limit * 3 then
                    begin
                        Break;
                    end;
                    if Trim(local_results[local_idx].comment) <> '' then
                    begin
                        Continue;
                    end;

                    candidate_text_local := Trim(local_results[local_idx].text);
                    if (get_candidate_text_unit_count(candidate_text_local) <>
                        expected_syllables) or
                        (not is_valid_standalone_cjk_phrase_text_local(
                        candidate_text_local, expected_syllables)) then
                    begin
                        Continue;
                    end;

                    candidate_score_local := local_results[local_idx].score;
                    if local_results[local_idx].has_dict_weight and
                        (local_results[local_idx].dict_weight >
                        candidate_score_local) then
                    begin
                        candidate_score_local := local_results[local_idx].dict_weight;
                    end;
                    Inc(candidate_score_local,
                        get_preferred_query_phrase_bonus_local(query_key_local,
                        candidate_text_local));
                    Inc(candidate_score_local,
                        get_exact_query_text_bonus_local(query_key_local,
                        candidate_text_local));

                    if candidate_score_local > best_complete_score_local then
                    begin
                        best_complete_text_local := candidate_text_local;
                        best_complete_score_local := candidate_score_local;
                    end;

                    local_option := Default(TExactChunkChainOption);
                    local_option.text := candidate_text_local;
                    local_option.path := candidate_text_local;
                    local_option.query_key := query_key_local;
                    local_option.score := candidate_score_local;
                    local_option.segments := 1;
                    local_option.has_anchor :=
                        expected_syllables >= c_chain_min_anchor_syllables;
                    if local_option.has_anchor then
                    begin
                        local_option.anchor_units := expected_syllables;
                    end
                    else
                    begin
                        local_option.anchor_units := 0;
                    end;
                    add_standalone_option_local(local_option);
                end;
            end;

            for candidate_idx_local := 0 to High(snapshot_candidates_local) do
            begin
                if candidate_idx_local >= c_chain_probe_limit then
                begin
                    Break;
                end;

                candidate_local := snapshot_candidates_local[candidate_idx_local];
                candidate_text_local := Trim(candidate_local.text);
                if candidate_text_local = '' then
                begin
                    Continue;
                end;

                if Trim(candidate_local.comment) = '' then
                begin
                    candidate_score_local :=
                        get_exact_chunk_effective_weight_local(candidate_local);
                end
                else
                begin
                    candidate_score_local := snapshot_scores_local[
                        candidate_idx_local];
                end;
                Inc(candidate_score_local, get_preferred_query_phrase_bonus_local(
                    query_key_local, candidate_text_local));
                candidate_units_local :=
                    get_candidate_text_unit_count(candidate_text_local);

                if Trim(candidate_local.comment) = '' then
                begin
                    if (candidate_units_local <> expected_syllables) or
                        (not is_valid_standalone_cjk_phrase_text_local(
                        candidate_text_local, expected_syllables)) then
                    begin
                        Continue;
                    end;

                    inferred_path_local :=
                        infer_segment_path_for_query_text_with_score(
                        query_key_local, candidate_text_local, infer_score_local,
                        infer_segments_local);
                    if inferred_path_local <> '' then
                    begin
                        Inc(candidate_score_local, infer_score_local);
                        if infer_segments_local > 1 then
                        begin
                            Inc(candidate_score_local,
                                infer_segments_local * 160);
                        end;
                    end
                    else if expected_syllables >= 3 then
                    begin
                        Dec(candidate_score_local, 1536);
                    end;

                    if candidate_score_local > best_complete_score_local then
                    begin
                        best_complete_text_local := candidate_text_local;
                        best_complete_score_local := candidate_score_local;
                    end;
                    local_option := Default(TExactChunkChainOption);
                    local_option.text := candidate_text_local;
                    local_option.path := candidate_text_local;
                    local_option.query_key := query_key_local;
                    local_option.score := candidate_score_local;
                    local_option.segments := 1;
                    local_option.has_anchor :=
                        expected_syllables >= c_chain_min_anchor_syllables;
                    if local_option.has_anchor then
                    begin
                        local_option.anchor_units := expected_syllables;
                    end
                    else
                    begin
                        local_option.anchor_units := 0;
                    end;
                    add_standalone_option_local(local_option);
                    Continue;
                end;

                comment_key_local := normalize_pinyin_text(candidate_local.comment);
                if (comment_key_local = '') or
                    (not is_full_pinyin_key(comment_key_local)) or
                    (not is_boundary_tail_comment_local(comment_key_local)) then
                begin
                    Continue;
                end;

                comment_syllables_local := get_effective_compact_pinyin_syllables(
                    comment_key_local);
                if (Length(comment_syllables_local) = 0) or
                    (candidate_units_local + Length(comment_syllables_local) <>
                    expected_syllables) then
                begin
                    Continue;
                end;

                if not try_collect_standalone_query_candidates_local(comment_key_local,
                    Length(comment_syllables_local), right_options_local) or
                    (Length(right_options_local) = 0) then
                begin
                    Continue;
                end;
                tail_text_local := right_options_local[0].text;
                tail_score_local := right_options_local[0].score;

                combined_text_local := candidate_text_local + tail_text_local;
                if not is_valid_standalone_cjk_phrase_text_local(
                    combined_text_local, expected_syllables) then
                begin
                    Continue;
                end;

                combined_score_local := candidate_score_local + tail_score_local;
                if m_dictionary <> nil then
                begin
                    context_bonus_local := m_dictionary.get_context_bonus(
                        candidate_text_local, tail_text_local);
                    Inc(combined_score_local, context_bonus_local);
                end;
                Inc(combined_score_local,
                    get_preferred_query_phrase_bonus_local(query_key_local,
                    combined_text_local));
                Inc(combined_score_local,
                    get_exact_query_text_bonus_local(query_key_local,
                    combined_text_local));
                Inc(combined_score_local, 1024);

                if combined_score_local > best_partial_score_local then
                begin
                    best_partial_text_local := combined_text_local;
                    best_partial_score_local := combined_score_local;
                    best_partial_comment_local := comment_key_local;
                end;
                local_option := Default(TExactChunkChainOption);
                local_option.text := combined_text_local;
                local_option.path := combined_text_local;
                local_option.query_key := query_key_local;
                local_option.score := combined_score_local;
                local_option.segments := 1;
                local_option.has_anchor :=
                    expected_syllables >= c_chain_min_anchor_syllables;
                if local_option.has_anchor then
                begin
                    local_option.anchor_units := expected_syllables;
                end
                else
                begin
                    local_option.anchor_units := 0;
                end;
                if (not has_best_partial_option_local) or
                    is_exact_chunk_option_better_local(local_option,
                    best_partial_option_local) then
                begin
                    best_partial_option_local := local_option;
                    has_best_partial_option_local := True;
                end;
            end;

            query_syllables_local := get_effective_compact_pinyin_syllables(
                query_key_local);
            if Length(query_syllables_local) = expected_syllables then
            begin
                for split_idx_local := 1 to expected_syllables - 1 do
                begin
                    left_key_local := '';
                    for local_idx := 0 to split_idx_local - 1 do
                    begin
                        left_key_local := left_key_local + normalize_pinyin_text(
                            query_syllables_local[local_idx].text);
                    end;

                    right_key_local := '';
                    for local_idx := split_idx_local to High(query_syllables_local) do
                    begin
                        right_key_local := right_key_local + normalize_pinyin_text(
                            query_syllables_local[local_idx].text);
                    end;

                    if (left_key_local = '') or (right_key_local = '') then
                    begin
                        Continue;
                    end;

                    if not try_collect_standalone_query_candidates_local(
                        left_key_local, split_idx_local, left_options_local) or
                        (Length(left_options_local) = 0) then
                    begin
                        Continue;
                    end;
                    if not try_collect_standalone_query_candidates_local(
                        right_key_local, expected_syllables - split_idx_local,
                        right_options_local) or
                        (Length(right_options_local) = 0) then
                    begin
                        Continue;
                    end;
                    for left_option_idx_local := 0 to
                        Min(High(left_options_local),
                        c_standalone_split_option_probe_limit - 1) do
                    begin
                        left_text_local := left_options_local[left_option_idx_local].text;
                        left_score_local :=
                            left_options_local[left_option_idx_local].score;
                        for right_option_idx_local := 0 to
                            Min(High(right_options_local),
                            c_standalone_split_option_probe_limit - 1) do
                        begin
                            right_text_local :=
                                right_options_local[right_option_idx_local].text;
                            right_score_local :=
                                right_options_local[right_option_idx_local].score;

                            combined_text_local := left_text_local + right_text_local;
                            if not is_valid_standalone_cjk_phrase_text_local(
                                combined_text_local, expected_syllables) then
                            begin
                                Continue;
                            end;

                            combined_score_local := left_score_local +
                                right_score_local - 96;
                            if m_dictionary <> nil then
                            begin
                                context_bonus_local := m_dictionary.get_context_bonus(
                                    left_text_local, right_text_local);
                                Inc(combined_score_local, context_bonus_local);
                            end;
                            Inc(combined_score_local,
                                get_preferred_query_phrase_bonus_local(
                                query_key_local, combined_text_local));
                            Inc(combined_score_local,
                                get_exact_query_text_bonus_local(
                                query_key_local, combined_text_local));
                            inferred_path_local :=
                                infer_segment_path_for_query_text_with_score(
                                query_key_local, combined_text_local,
                                infer_score_local, infer_segments_local);
                            if inferred_path_local <> '' then
                            begin
                                Inc(combined_score_local, infer_score_local);
                                if infer_segments_local > 1 then
                                begin
                                    Inc(combined_score_local,
                                        infer_segments_local * 160);
                                end;
                            end;

                            if combined_score_local > best_split_score_local then
                            begin
                                best_split_text_local := combined_text_local;
                                best_split_score_local := combined_score_local;
                            end;
                            local_option := Default(TExactChunkChainOption);
                            local_option.text := combined_text_local;
                            local_option.path :=
                                left_options_local[left_option_idx_local].path;
                            if right_options_local[right_option_idx_local].path <> '' then
                            begin
                                if local_option.path <> '' then
                                begin
                                    local_option.path := local_option.path +
                                        c_segment_path_separator;
                                end;
                                local_option.path := local_option.path +
                                    right_options_local[right_option_idx_local].path;
                            end;
                            local_option.query_key := query_key_local;
                            local_option.score := combined_score_local;
                            local_option.segments :=
                                left_options_local[left_option_idx_local].segments +
                                right_options_local[right_option_idx_local].segments;
                            local_option.has_anchor :=
                                left_options_local[left_option_idx_local].has_anchor or
                                right_options_local[right_option_idx_local].has_anchor;
                            local_option.anchor_units :=
                                left_options_local[left_option_idx_local].anchor_units;
                            if right_options_local[right_option_idx_local].anchor_units >
                                local_option.anchor_units then
                            begin
                                local_option.anchor_units :=
                                    right_options_local[right_option_idx_local].anchor_units;
                            end;
                            if (not has_best_split_option_local) or
                                is_exact_chunk_option_better_local(local_option,
                                best_split_option_local) then
                            begin
                                best_split_option_local := local_option;
                                has_best_split_option_local := True;
                            end;
                        end;
                    end;
                end;
            end;

            if has_best_partial_option_local then
            begin
                if (best_complete_text_local <> '') and
                    is_boundary_tail_comment_local(best_partial_comment_local) and
                    (best_partial_score_local > best_complete_score_local - 256) then
                begin
                    add_standalone_option_local(best_partial_option_local);
                end
                else if best_complete_text_local = '' then
                begin
                    add_standalone_option_local(best_partial_option_local);
                end;
            end;

            if has_best_split_option_local then
            begin
                add_standalone_option_local(best_split_option_local);
            end;

            sort_and_trim_exact_chunk_options_local(out_options,
                c_chain_standalone_option_limit);

            if Length(out_options) > 0 then
            begin
                standalone_chunk_states.AddOrSetValue(query_key_local, 1);
                standalone_chunk_options.AddOrSetValue(query_key_local,
                    Copy(out_options));
                standalone_chunk_texts.AddOrSetValue(query_key_local,
                    out_options[0].text);
                standalone_chunk_scores.AddOrSetValue(query_key_local,
                    out_options[0].score);
                Exit(True);
            end;

            standalone_chunk_states.AddOrSetValue(query_key_local, 2);
        end;

        function try_get_best_standalone_query_candidate_local(
            const query_key_local: string; const expected_syllables: Integer;
            out out_text: string; out out_score: Integer): Boolean;
        var
            local_options: TExactChunkChainOptionArray;
        begin
            Result := try_collect_standalone_query_candidates_local(query_key_local,
                expected_syllables, local_options) and (Length(local_options) > 0);
            if Result then
            begin
                out_text := local_options[0].text;
                out_score := local_options[0].score;
            end
            else
            begin
                out_text := '';
                out_score := 0;
            end;
        end;

        function try_get_standalone_chunk_candidate_local(const start_idx: Integer;
            const syllable_count_part: Integer; out out_text: string;
            out out_score: Integer): Boolean;
        var
            query_key_local: string;
        begin
            Result := False;
            out_text := '';
            out_score := 0;
            if (syllable_count_part < 3) or
                (syllable_count_part > c_chain_lattice_max_chunk_syllables) or
                (m_disable_subspan_standalone_oracle > 0) then
            begin
                Exit;
            end;

            query_key_local := build_query_key_local(start_idx, syllable_count_part);
            if (query_key_local = '') or (not is_full_pinyin_key(query_key_local)) then
            begin
                Exit;
            end;
            Result := try_get_best_standalone_query_candidate_local(query_key_local,
                syllable_count_part, out_text, out_score);
        end;

        procedure try_update_best_from_position(const start_idx: Integer);
        var
            chunk_syllables: Integer;
            next_idx: Integer;
            resolved_text: string;
            resolved_path: string;
            resolved_score: Integer;
            resolved_segments: Integer;
            resolved_anchor_units: Integer;
            resolved_has_anchor: Boolean;
            total_score: Integer;
            total_segments: Integer;
            total_anchor_units: Integer;
            total_has_anchor: Boolean;
            combined_text: string;
            combined_path: string;
            better_candidate: Boolean;
            standalone_text: string;
            standalone_score: Integer;
            standalone_min_score: Integer;
        begin
            for chunk_syllables := 1 to Min(c_chain_max_chunk_syllables,
                syllable_count_local - start_idx) do
            begin
                next_idx := start_idx + chunk_syllables;
                if (next_idx < syllable_count_local) and
                    (best_scores[next_idx] = Low(Integer)) then
                begin
                    Continue;
                end;

                resolved_text := '';
                resolved_path := '';
                resolved_score := 0;
                resolved_segments := 0;
                resolved_anchor_units := -1;
                resolved_has_anchor := False;

                if (chunk_syllables >= 2) and
                    try_get_standalone_chunk_candidate_local(start_idx,
                    chunk_syllables, standalone_text, standalone_score) and
                    (standalone_text <> '') then
                begin
                    resolved_text := standalone_text;
                    resolved_path := standalone_text;
                    resolved_segments := 1;
                    resolved_has_anchor := chunk_syllables >= c_chain_min_anchor_syllables;
                    if resolved_has_anchor then
                    begin
                        resolved_anchor_units := chunk_syllables;
                    end
                    else
                    begin
                        resolved_anchor_units := 0;
                    end;
                    resolved_score := standalone_score +
                        (chunk_syllables * chunk_syllables * c_chain_length_bonus);
                    if resolved_has_anchor then
                    begin
                        Inc(resolved_score, c_chain_anchor_bonus);
                    end;
                end
                else if not try_resolve_best_exact_subspan_local(start_idx,
                    chunk_syllables, resolved_text, resolved_score,
                    resolved_segments, resolved_path, resolved_has_anchor,
                    resolved_anchor_units) then
                begin
                    Continue;
                end;

                if (chunk_syllables >= 2) and
                    (resolved_segments > 1) and
                    try_get_standalone_chunk_candidate_local(start_idx,
                    chunk_syllables, standalone_text, standalone_score) and
                    (standalone_text <> '') then
                begin
                    standalone_min_score := standalone_score +
                        (chunk_syllables * chunk_syllables * c_chain_length_bonus);
                    if chunk_syllables >= c_chain_min_anchor_syllables then
                    begin
                        Inc(standalone_min_score, c_chain_anchor_bonus);
                    end;
                    resolved_text := standalone_text;
                    resolved_score := Max(resolved_score + 2048, standalone_min_score);
                    resolved_segments := 1;
                    resolved_path := standalone_text;
                    resolved_has_anchor := chunk_syllables >= c_chain_min_anchor_syllables;
                    if resolved_has_anchor then
                    begin
                        resolved_anchor_units := chunk_syllables;
                    end
                    else
                    begin
                        resolved_anchor_units := 0;
                    end;
                    if m_config.debug_mode then
                    begin
                        m_last_full_path_debug_info := m_last_full_path_debug_info +
                            Format(' xoracle=[key=%s text=%s score=%d]',
                            [build_query_key_local(start_idx, chunk_syllables),
                            standalone_text, standalone_min_score]);
                    end;
                end;

                total_score := resolved_score;
                total_segments := resolved_segments;
                total_has_anchor := resolved_has_anchor;
                total_anchor_units := resolved_anchor_units;
                combined_text := resolved_text;
                combined_path := resolved_path;

                if next_idx < syllable_count_local then
                begin
                    Inc(total_score, best_scores[next_idx]);
                    Inc(total_segments, best_segments[next_idx]);
                    if best_has_anchor[next_idx] then
                    begin
                        total_has_anchor := True;
                        if best_anchor_units[next_idx] > total_anchor_units then
                        begin
                            total_anchor_units := best_anchor_units[next_idx];
                        end;
                    end;
                    combined_text := combined_text + best_texts[next_idx];
                    if best_paths[next_idx] <> '' then
                    begin
                        if combined_path <> '' then
                        begin
                            combined_path := combined_path + c_segment_path_separator;
                        end;
                        combined_path := combined_path + best_paths[next_idx];
                    end;
                end;

                better_candidate := False;
                if total_score > best_scores[start_idx] then
                begin
                    better_candidate := True;
                end
                else if total_score = best_scores[start_idx] then
                begin
                    if total_has_anchor and (not best_has_anchor[start_idx]) then
                    begin
                        better_candidate := True;
                    end
                    else if total_has_anchor = best_has_anchor[start_idx] then
                    begin
                        if total_anchor_units > best_anchor_units[start_idx] then
                        begin
                            better_candidate := True;
                        end
                        else if total_anchor_units = best_anchor_units[start_idx] then
                        begin
                            if total_segments < best_segments[start_idx] then
                            begin
                                better_candidate := True;
                            end
                            else if (total_segments = best_segments[start_idx]) and
                                (combined_text <> '') and
                                ((best_texts[start_idx] = '') or
                                (CompareText(combined_text, best_texts[start_idx]) < 0)) then
                            begin
                                better_candidate := True;
                            end;
                        end;
                    end;
                end;

                if better_candidate then
                begin
                    best_scores[start_idx] := total_score;
                    best_texts[start_idx] := combined_text;
                    best_paths[start_idx] := combined_path;
                    best_segments[start_idx] := total_segments;
                    best_has_anchor[start_idx] := total_has_anchor;
                    best_anchor_units[start_idx] := total_anchor_units;
                end;
            end;
        end;

        function is_exact_chunk_chain_state_better_local(
            const left_state: TExactChunkChainState;
            const right_state: TExactChunkChainState): Boolean;
        begin
            Result := False;
            if left_state.score > right_state.score then
            begin
                Exit(True);
            end;
            if left_state.score < right_state.score then
            begin
                Exit(False);
            end;
            if left_state.has_anchor and (not right_state.has_anchor) then
            begin
                Exit(True);
            end;
            if (not left_state.has_anchor) and right_state.has_anchor then
            begin
                Exit(False);
            end;
            if left_state.anchor_units > right_state.anchor_units then
            begin
                Exit(True);
            end;
            if left_state.anchor_units < right_state.anchor_units then
            begin
                Exit(False);
            end;
            if left_state.segments < right_state.segments then
            begin
                Exit(True);
            end;
            if left_state.segments > right_state.segments then
            begin
                Exit(False);
            end;
            if (left_state.text <> '') and
                ((right_state.text = '') or
                (CompareText(left_state.text, right_state.text) < 0)) then
            begin
                Exit(True);
            end;
        end;

        procedure consider_exact_chunk_chain_state_local(
            var states: TExactChunkChainStateArray;
            const candidate_state: TExactChunkChainState);
        var
            state_idx: Integer;
            insert_idx: Integer;
            existing_state: TExactChunkChainState;
        begin
            if candidate_state.text = '' then
            begin
                Exit;
            end;

            for state_idx := 0 to High(states) do
            begin
                if SameText(states[state_idx].text, candidate_state.text) then
                begin
                    if is_exact_chunk_chain_state_better_local(candidate_state,
                        states[state_idx]) then
                    begin
                        states[state_idx] := candidate_state;
                    end;
                    Exit;
                end;
            end;

            SetLength(states, Length(states) + 1);
            states[High(states)] := candidate_state;
            for insert_idx := High(states) downto 1 do
            begin
                if not is_exact_chunk_chain_state_better_local(states[insert_idx],
                    states[insert_idx - 1]) then
                begin
                    Break;
                end;
                existing_state := states[insert_idx - 1];
                states[insert_idx - 1] := states[insert_idx];
                states[insert_idx] := existing_state;
            end;

            if Length(states) > c_chain_lattice_beam_width then
            begin
                SetLength(states, c_chain_lattice_beam_width);
            end;
        end;

        procedure consider_exact_chunk_option_local(
            var options: TExactChunkChainOptionArray;
            const candidate_option: TExactChunkChainOption);
        var
            option_idx: Integer;
        begin
            if candidate_option.text = '' then
            begin
                Exit;
            end;

            for option_idx := 0 to High(options) do
            begin
                if SameText(options[option_idx].text, candidate_option.text) then
                begin
                    if candidate_option.score > options[option_idx].score then
                    begin
                        options[option_idx] := candidate_option;
                    end;
                    Exit;
                end;
            end;

            SetLength(options, Length(options) + 1);
            options[High(options)] := candidate_option;
        end;

        function has_exact_chunk_merge_bonus_local(const left_query_key: string;
            const right_query_key: string; const combined_text: string;
            const expected_units: Integer): Boolean;
        var
            local_results: TncCandidateList;
            local_idx: Integer;
            local_text: string;
        begin
            Result := False;
            if (left_query_key = '') or (right_query_key = '') or
                (combined_text = '') or (expected_units <= 0) then
            begin
                Exit;
            end;

            if not m_dictionary.lookup_exact_full_pinyin(left_query_key +
                right_query_key, local_results) then
            begin
                Exit;
            end;

            for local_idx := 0 to High(local_results) do
            begin
                if local_idx >= c_chain_lattice_probe_limit then
                begin
                    Break;
                end;
                if Trim(local_results[local_idx].comment) <> '' then
                begin
                    Continue;
                end;

                local_text := Trim(local_results[local_idx].text);
                if (local_text = '') or
                    (get_candidate_text_unit_count(local_text) <> expected_units) then
                begin
                    Continue;
                end;

                if SameText(local_text, combined_text) then
                begin
                    Exit(True);
                end;
            end;
        end;

        function try_collect_exact_chunk_options_local(const start_idx: Integer;
            const syllable_count_part: Integer;
            out options: TExactChunkChainOptionArray): Boolean;
        var
            query_key_local: string;
            local_results: TncCandidateList;
            local_idx: Integer;
            local_text: string;
            local_score: Integer;
            local_option: TExactChunkChainOption;
            standalone_options_local: TExactChunkChainOptionArray;
            standalone_option_idx_local: Integer;
        begin
            Result := False;
            SetLength(options, 0);
            query_key_local := build_query_key_local(start_idx, syllable_count_part);
            if query_key_local = '' then
            begin
                Exit;
            end;

            if syllable_count_part = 1 then
            begin
                if (get_fixed_boundary_single_char_for_standalone_local(
                    effective_syllables[start_idx].text) <> '') and
                    try_get_best_single_char_for_query_key_local(query_key_local,
                    local_text, local_score) and (local_text <> '') then
                begin
                    local_option := Default(TExactChunkChainOption);
                    local_option.text := local_text;
                    local_option.path := local_text;
                    local_option.query_key := query_key_local;
                    local_option.score := local_score +
                        c_chain_lattice_fixed_single_bonus;
                    local_option.segments := 1;
                    local_option.has_anchor := True;
                    local_option.anchor_units := 1;
                    consider_exact_chunk_option_local(options, local_option);
                end;
                Exit(Length(options) > 0);
            end;

            if m_dictionary.lookup_exact_full_pinyin(query_key_local, local_results) then
            begin
                for local_idx := 0 to High(local_results) do
                begin
                    if local_idx >= c_chain_lattice_probe_limit then
                    begin
                        Break;
                    end;
                    if Trim(local_results[local_idx].comment) <> '' then
                    begin
                        Continue;
                    end;

                    local_text := Trim(local_results[local_idx].text);
                    if (local_text = '') or
                        (get_candidate_text_unit_count(local_text) <>
                        syllable_count_part) or
                        (not is_valid_standalone_cjk_phrase_text_local(
                        local_text, syllable_count_part)) then
                    begin
                        Continue;
                    end;

                    local_score := local_results[local_idx].score;
                    if local_results[local_idx].has_dict_weight and
                        (local_results[local_idx].dict_weight > local_score) then
                    begin
                        local_score := local_results[local_idx].dict_weight;
                    end;
                    if syllable_count_part <= 2 then
                    begin
                        case local_idx of
                            0:
                                Inc(local_score, 16384);
                            1:
                                Inc(local_score, 2048);
                            2, 3:
                                Dec(local_score, 2048);
                        else
                            Dec(local_score, 4096);
                        end;
                    end
                    else
                    begin
                        case local_idx of
                            0:
                                Inc(local_score, 4096);
                            1:
                                Inc(local_score, 2048);
                            2, 3:
                                Inc(local_score, 1024);
                        else
                            Inc(local_score, 512);
                        end;
                    end;
                    Inc(local_score, get_preferred_query_phrase_bonus_local(
                        query_key_local, local_text));
                    Inc(local_score, get_exact_chunk_length_bonus_local(
                        syllable_count_part));
                    if syllable_count_part >= c_chain_min_anchor_syllables then
                    begin
                        Inc(local_score, c_chain_anchor_bonus);
                    end;
                    local_option := Default(TExactChunkChainOption);
                    local_option.text := local_text;
                    local_option.path := local_text;
                    local_option.query_key := query_key_local;
                    local_option.score := local_score;
                    local_option.segments := 1;
                    local_option.has_anchor :=
                        syllable_count_part >= c_chain_min_anchor_syllables;
                    if local_option.has_anchor then
                    begin
                        local_option.anchor_units := syllable_count_part;
                    end
                    else
                    begin
                        local_option.anchor_units := 0;
                    end;
                    consider_exact_chunk_option_local(options, local_option);
                end;
            end;

            if (Length(options) = 0) and (syllable_count_part = 3) and
                try_resolve_three_syllable_split_option_local(start_idx,
                local_option) then
            begin
                consider_exact_chunk_option_local(options, local_option);
            end;

            if (Length(options) = 0) and (syllable_count_part >= 3) and
                (syllable_count_part <= 3) and
                try_collect_standalone_query_candidates_local(query_key_local,
                syllable_count_part, standalone_options_local) then
            begin
                for standalone_option_idx_local := 0 to High(standalone_options_local) do
                begin
                    local_option := standalone_options_local[
                        standalone_option_idx_local];
                    local_option.query_key := query_key_local;
                    Inc(local_option.score, get_exact_chunk_length_bonus_local(
                        syllable_count_part));
                    if syllable_count_part >= c_chain_min_anchor_syllables then
                    begin
                        Inc(local_option.score, c_chain_anchor_bonus);
                    end;
                    consider_exact_chunk_option_local(options, local_option);
                end;
            end;

            if m_config.debug_mode and (Length(options) > 0) then
            begin
                m_last_full_path_debug_info := m_last_full_path_debug_info +
                    Format(' xopt=[key=%s n=%d', [query_key_local, Length(options)]);
                for local_idx := 0 to Min(High(options), 2) do
                begin
                    m_last_full_path_debug_info := m_last_full_path_debug_info +
                        Format(' {%d:%s s=%d seg=%d}',
                        [local_idx, options[local_idx].text, options[local_idx].score,
                        options[local_idx].segments]);
                end;
                m_last_full_path_debug_info := m_last_full_path_debug_info + ']';
            end;

            Result := Length(options) > 0;
        end;

        function try_build_exact_chunk_lattice_local(out out_text: string;
            out out_path: string; out out_score: Integer;
            out out_segments: Integer; out out_has_anchor: Boolean;
            out out_anchor_units: Integer): Boolean;
        var
            start_idx: Integer;
            next_idx: Integer;
            chunk_syllables: Integer;
            option_idx: Integer;
            state_idx: Integer;
            options: TExactChunkChainOptionArray;
            suffix_states: TExactChunkChainStateArray;
            candidate_state: TExactChunkChainState;
            combined_score: Integer;
            combined_text: string;
            combined_path: string;
            combined_anchor_units: Integer;
            combined_has_anchor: Boolean;
            combined_segments: Integer;
        begin
            Result := False;
            out_text := '';
            out_path := '';
            out_score := Low(Integer);
            out_segments := MaxInt;
            out_has_anchor := False;
            out_anchor_units := -1;

            SetLength(lattice_state_map, syllable_count_local + 1);
            SetLength(lattice_state_map[syllable_count_local], 1);
            lattice_state_map[syllable_count_local][0] :=
                Default(TExactChunkChainState);
            lattice_state_map[syllable_count_local][0].score := 0;
            lattice_state_map[syllable_count_local][0].segments := 0;
            lattice_state_map[syllable_count_local][0].anchor_units := -1;

            for start_idx := syllable_count_local - 1 downto 0 do
            begin
                SetLength(lattice_state_map[start_idx], 0);
                for chunk_syllables := 1 to Min(c_chain_lattice_max_chunk_syllables,
                    syllable_count_local - start_idx) do
                begin
                    next_idx := start_idx + chunk_syllables;
                    if (next_idx < syllable_count_local) and
                        (Length(lattice_state_map[next_idx]) = 0) then
                    begin
                        Continue;
                    end;

                    if not try_collect_exact_chunk_options_local(start_idx,
                        chunk_syllables, options) then
                    begin
                        Continue;
                    end;

                    if next_idx < syllable_count_local then
                    begin
                        suffix_states := lattice_state_map[next_idx];
                    end
                    else
                    begin
                        suffix_states := lattice_state_map[syllable_count_local];
                    end;

                    for option_idx := 0 to High(options) do
                    begin
                        for state_idx := 0 to High(suffix_states) do
                        begin
                            combined_score := options[option_idx].score +
                                suffix_states[state_idx].score;
                            if (suffix_states[state_idx].first_chunk_text <> '') and
                                (m_dictionary <> nil) then
                            begin
                                Inc(combined_score, m_dictionary.get_context_bonus(
                                    options[option_idx].text,
                                    suffix_states[state_idx].first_chunk_text));
                                if has_exact_chunk_merge_bonus_local(
                                    options[option_idx].query_key,
                                    suffix_states[state_idx].first_chunk_query_key,
                                    options[option_idx].text +
                                    suffix_states[state_idx].first_chunk_text,
                                    get_candidate_text_unit_count(
                                    options[option_idx].text) +
                                    get_candidate_text_unit_count(
                                    suffix_states[state_idx].first_chunk_text)) then
                                begin
                                    Inc(combined_score, c_chain_lattice_merge_bonus);
                                end;
                            end;

                            combined_text := options[option_idx].text +
                                suffix_states[state_idx].text;
                            combined_path := options[option_idx].path;
                            if suffix_states[state_idx].path <> '' then
                            begin
                                if combined_path <> '' then
                                begin
                                    combined_path := combined_path +
                                        c_segment_path_separator;
                                end;
                                combined_path := combined_path +
                                    suffix_states[state_idx].path;
                            end;
                            combined_segments := options[option_idx].segments +
                                suffix_states[state_idx].segments;
                            combined_has_anchor := options[option_idx].has_anchor or
                                suffix_states[state_idx].has_anchor;
                            combined_anchor_units := options[option_idx].anchor_units;
                            if suffix_states[state_idx].anchor_units >
                                combined_anchor_units then
                            begin
                                combined_anchor_units :=
                                    suffix_states[state_idx].anchor_units;
                            end;

                            candidate_state := Default(TExactChunkChainState);
                            candidate_state.text := combined_text;
                            candidate_state.path := combined_path;
                            candidate_state.first_chunk_text :=
                                options[option_idx].text;
                            candidate_state.first_chunk_query_key :=
                                options[option_idx].query_key;
                            candidate_state.score := combined_score;
                            candidate_state.segments := combined_segments;
                            candidate_state.has_anchor := combined_has_anchor;
                            candidate_state.anchor_units := combined_anchor_units;
                            consider_exact_chunk_chain_state_local(
                                lattice_state_map[start_idx], candidate_state);
                        end;
                    end;
                end;
            end;

            if Length(lattice_state_map[0]) = 0 then
            begin
                Exit;
            end;

            out_text := lattice_state_map[0][0].text;
            out_path := lattice_state_map[0][0].path;
            out_score := lattice_state_map[0][0].score;
            out_segments := lattice_state_map[0][0].segments;
            out_has_anchor := lattice_state_map[0][0].has_anchor;
            out_anchor_units := lattice_state_map[0][0].anchor_units;
            Result := out_text <> '';
        end;
    begin
        if (Length(candidates) = 0) or
            (input_syllable_count < c_long_sentence_exact_min_syllables) or
            (not is_full_pinyin_key(lookup_text)) or
            (m_dictionary = nil) then
        begin
            Exit;
        end;

        if input_syllable_count <= 6 then
        begin
            Exit;
        end;

        if (input_syllable_count >= 8) and
            (Trim(candidates[0].comment) = '') and
            (get_candidate_text_unit_count(Trim(candidates[0].text)) =
            input_syllable_count) and
            is_trusted_top_complete_candidate_local(candidates) then
        begin
            Exit;
        end;

        effective_syllables := get_effective_compact_pinyin_syllables(lookup_text);
        syllable_count_local := Length(effective_syllables);
        if syllable_count_local <> input_syllable_count then
        begin
            Exit;
        end;

        SetLength(best_scores, syllable_count_local + 1);
        SetLength(best_texts, syllable_count_local + 1);
        SetLength(best_paths, syllable_count_local + 1);
        SetLength(best_segments, syllable_count_local + 1);
        SetLength(best_has_anchor, syllable_count_local + 1);
        SetLength(best_anchor_units, syllable_count_local + 1);
        standalone_chunk_states := TDictionary<string, Integer>.Create;
        standalone_chunk_texts := TDictionary<string, string>.Create;
        standalone_chunk_scores := TDictionary<string, Integer>.Create;
        standalone_chunk_options :=
            TDictionary<string, TExactChunkChainOptionArray>.Create;
        standalone_chunk_engine := nil;
        standalone_chunk_budget_remaining := 12;
        use_direct_chunk_lattice_only := syllable_count_local <= 8;
        suppress_subspan_oracle_local := syllable_count_local <= 8;
        if suppress_subspan_oracle_local then
        begin
            Inc(m_disable_subspan_standalone_oracle);
        end;
        if syllable_count_local >= 12 then
        begin
            standalone_chunk_budget_remaining := 16;
        end;
        if syllable_count_local >= 18 then
        begin
            standalone_chunk_budget_remaining := 24;
        end;

        try
            for idx := 0 to syllable_count_local do
            begin
                best_scores[idx] := Low(Integer);
                best_texts[idx] := '';
                best_paths[idx] := '';
                best_segments[idx] := MaxInt;
                best_has_anchor[idx] := False;
                best_anchor_units[idx] := -1;
            end;

            best_scores[syllable_count_local] := 0;
            best_texts[syllable_count_local] := '';
            best_paths[syllable_count_local] := '';
            best_segments[syllable_count_local] := 0;
            best_has_anchor[syllable_count_local] := False;
            best_anchor_units[syllable_count_local] := -1;

            if not use_direct_chunk_lattice_only then
            begin
                for idx := syllable_count_local - 1 downto 0 do
                begin
                    try_update_best_from_position(idx);
                end;
            end;

            if (input_syllable_count >= 4) and
                try_build_exact_chunk_lattice_local(lattice_text, lattice_path,
                lattice_score, lattice_segments, lattice_has_anchor,
                lattice_anchor_units) and
                (lattice_text <> '') and
                (get_candidate_text_unit_count(lattice_text) = input_syllable_count) then
            begin
                if m_config.debug_mode then
                begin
                    m_last_full_path_debug_info := m_last_full_path_debug_info +
                        Format(' xlattice=[text=%s score=%d seg=%d top=%s topscore=%d]',
                        [lattice_text, lattice_score, lattice_segments,
                        best_texts[0], best_scores[0]]);
                end;
                if (best_scores[0] = Low(Integer)) or
                    (lattice_score > best_scores[0]) or
                    ((lattice_score = best_scores[0]) and
                    lattice_has_anchor and (not best_has_anchor[0])) or
                    ((lattice_score = best_scores[0]) and
                    (lattice_has_anchor = best_has_anchor[0]) and
                    (lattice_anchor_units > best_anchor_units[0])) or
                    ((lattice_score = best_scores[0]) and
                    (lattice_anchor_units = best_anchor_units[0]) and
                    (lattice_segments < best_segments[0])) then
                begin
                    best_scores[0] := lattice_score;
                    best_texts[0] := lattice_text;
                    best_paths[0] := lattice_path;
                    best_segments[0] := lattice_segments;
                    best_has_anchor[0] := lattice_has_anchor;
                    best_anchor_units[0] := lattice_anchor_units;
                    if m_config.debug_mode then
                    begin
                        m_last_full_path_debug_info := m_last_full_path_debug_info +
                            Format(' xlattice=[promote text=%s seg=%d]',
                            [lattice_text, lattice_segments]);
                    end;
                end;
            end;

            preferred_phrase_bonus := get_preferred_query_phrase_bonus_local(
                lookup_text, best_texts[0]);
            current_path_preference_local := 0;
            support_path_local := infer_segment_path_for_query_text_with_score(
                lookup_text, best_texts[0], current_support_local,
                current_path_preference_local);
            xchain_metric_local := current_support_local + preferred_phrase_bonus;
            FillChar(problematic_candidate_local, SizeOf(problematic_candidate_local), 0);
            problematic_candidate_local.text := best_texts[0];
            problematic_candidate_local.comment := '';
            xchain_problematic_local :=
                is_problematic_single_char_chain_candidate_for_query(lookup_text,
                problematic_candidate_local);
            if xchain_problematic_local then
            begin
                Dec(xchain_metric_local, 1536);
            end;
            if support_path_local <> '' then
            begin
                best_paths[0] := support_path_local;
            end;

            if (best_scores[0] = Low(Integer)) or
                ((not best_has_anchor[0]) and (preferred_phrase_bonus <= 0)) or
                (best_texts[0] = '') or
                (get_candidate_text_unit_count(best_texts[0]) <> input_syllable_count) then
            begin
                if m_config.debug_mode then
                begin
                    m_last_full_path_debug_info := m_last_full_path_debug_info +
                        Format(' xchain=[miss text=%s anchor=%d seg=%d]',
                        [best_texts[0], Ord(best_has_anchor[0]), best_segments[0]]);
                end;
                Exit;
            end;

            best_visible_index := -1;
            best_visible_metric := Low(Integer);
            best_visible_problematic_local := False;
            for idx := 0 to High(candidates) do
            begin
                current_candidate_text_local := Trim(candidates[idx].text);
                if (Trim(candidates[idx].comment) <> '') or
                    (current_candidate_text_local = '') or
                    (get_candidate_text_unit_count(current_candidate_text_local) <>
                    input_syllable_count) then
                begin
                    Continue;
                end;
                current_path_preference_local := 0;
                support_path_local := infer_segment_path_for_query_text_with_score(
                    lookup_text, current_candidate_text_local,
                    current_support_local, current_path_preference_local);
                current_metric_local := current_support_local +
                    get_preferred_query_phrase_bonus_local(lookup_text,
                    current_candidate_text_local);
                FillChar(problematic_candidate_local, SizeOf(problematic_candidate_local), 0);
                problematic_candidate_local.text := current_candidate_text_local;
                problematic_candidate_local.comment := '';
                if is_problematic_single_char_chain_candidate_for_query(lookup_text,
                    problematic_candidate_local) then
                begin
                    Dec(current_metric_local, 1536);
                end;
                if (best_visible_index < 0) or
                    (current_metric_local > best_visible_metric) or
                    ((current_metric_local = best_visible_metric) and
                    (CompareText(current_candidate_text_local,
                    Trim(candidates[best_visible_index].text)) < 0)) then
                begin
                    best_visible_index := idx;
                    best_visible_metric := current_metric_local;
                    best_visible_problematic_local :=
                        is_problematic_single_char_chain_candidate_for_query(
                        lookup_text, problematic_candidate_local);
                end;
            end;

            if (best_visible_index >= 0) and
                (not SameText(Trim(candidates[best_visible_index].text),
                best_texts[0])) and
                ((best_visible_metric > xchain_metric_local + 2048) or
                ((best_visible_metric = xchain_metric_local) and
                (not best_visible_problematic_local) and
                xchain_problematic_local)) then
            begin
                best_texts[0] := Trim(candidates[best_visible_index].text);
                preferred_phrase_bonus := get_preferred_query_phrase_bonus_local(
                    lookup_text, best_texts[0]);
                best_paths[0] := get_segment_path_for_candidate(
                    candidates[best_visible_index]);
                if best_paths[0] = '' then
                begin
                    current_path_preference_local := 0;
                    support_path_local := infer_segment_path_for_query_text_with_score(
                        lookup_text, best_texts[0], current_support_local,
                        current_path_preference_local);
                    best_paths[0] := support_path_local;
                end;
                best_segments[0] := get_path_segment_count_local(best_paths[0]);
                if best_segments[0] <= 0 then
                begin
                    best_segments[0] := 1;
                end;
                best_has_anchor[0] := True;
                best_anchor_units[0] := input_syllable_count;
                if m_config.debug_mode then
                begin
                    m_last_full_path_debug_info := m_last_full_path_debug_info +
                        Format(' xchain=[prefer_visible text=%s metric=%d xmetric=%d]',
                        [best_texts[0], best_visible_metric, xchain_metric_local]);
                end;
            end;

            existing_index := -1;
            for idx := 0 to High(candidates) do
            begin
                if (Trim(candidates[idx].comment) = '') and
                    SameText(Trim(candidates[idx].text), best_texts[0]) then
                begin
                    existing_index := idx;
                    Break;
                end;
            end;

            if existing_index = 0 then
            begin
                Exit;
            end;

            top_path_segment_count := get_path_segment_count_local(
                get_segment_path_for_candidate(candidates[0]));
            top_preferred_phrase_bonus := get_preferred_query_phrase_bonus_local(
                lookup_text, Trim(candidates[0].text));
            should_promote := False;
            if Trim(candidates[0].comment) <> '' then
            begin
                should_promote := True;
            end
            else if get_candidate_text_unit_count(Trim(candidates[0].text)) <>
                input_syllable_count then
            begin
                should_promote := True;
            end
            else if (top_path_segment_count > 0) and
                (best_segments[0] < top_path_segment_count) then
            begin
                should_promote := True;
            end
            else if (top_path_segment_count = 0) and best_has_anchor[0] and
                (best_segments[0] <= 2) then
            begin
                should_promote := True;
            end
            else if existing_index > 0 then
            begin
                should_promote := True;
            end
            else if preferred_phrase_bonus > top_preferred_phrase_bonus then
            begin
                should_promote := True;
            end
            else if best_scores[0] > candidates[0].score + 4096 then
            begin
                should_promote := True;
            end;

            if not should_promote then
            begin
                if m_config.debug_mode then
                begin
                    m_last_full_path_debug_info := m_last_full_path_debug_info +
                        Format(' xchain=[skip text=%s seg=%d topseg=%d top=%s]',
                        [best_texts[0], best_segments[0], top_path_segment_count,
                        Trim(candidates[0].text)]);
                end;
                Exit;
            end;

            if existing_index > 0 then
            begin
                picked := candidates[existing_index];
                if picked.score < Max(candidates[0].score + 2048,
                    best_scores[0]) then
                begin
                    picked.score := Max(candidates[0].score + 2048,
                        best_scores[0]);
                end;
            end
            else
            begin
                FillChar(picked, SizeOf(picked), 0);
                picked.text := best_texts[0];
                picked.comment := '';
                picked.score := Max(candidates[0].score + 2048, best_scores[0]);
                picked.source := cs_rule;
                picked.has_dict_weight := False;
                picked.dict_weight := 0;
                remember_segment_path_for_candidate(picked.text, '',
                    best_paths[0], picked.score);
            end;

            if best_paths[0] <> '' then
            begin
                remember_segment_path_for_candidate(Trim(picked.text), '',
                    best_paths[0], picked.score);
            end;

            if existing_index > 0 then
            begin
                for idx := existing_index downto 1 do
                begin
                    candidates[idx] := candidates[idx - 1];
                end;
            end
            else
            begin
                SetLength(candidates, Length(candidates) + 1);
                for idx := High(candidates) downto 1 do
                begin
                    candidates[idx] := candidates[idx - 1];
                end;
            end;
            candidates[0] := picked;
            if m_config.debug_mode then
            begin
                m_last_full_path_debug_info := m_last_full_path_debug_info +
                    Format(' xchain=[promote text=%s seg=%d]',
                    [best_texts[0], best_segments[0]]);
            end;
        finally
            if suppress_subspan_oracle_local then
            begin
                Dec(m_disable_subspan_standalone_oracle);
            end;
            standalone_chunk_engine.Free;
            standalone_chunk_options.Free;
            standalone_chunk_scores.Free;
            standalone_chunk_texts.Free;
            standalone_chunk_states.Free;
        end;
    end;

