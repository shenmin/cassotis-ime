                    lookup_text, best_text);
                best_support_score := local_support_score;
                best_chunk_alignment_score := local_chunk_alignment_score;
                best_rerank_score := local_rerank_score;
                best_head_boundary_score := get_fixed_boundary_head_score_local(
                    best_text);
                best_path_confidence_score := get_candidate_path_confidence_score(
                    picked_candidate_local);
