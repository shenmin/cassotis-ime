        function build_visibility_query_key(const start_idx: Integer;
            const syllable_count_local: Integer): string;
        var
            local_idx: Integer;
        begin
            Result := '';
            if (start_idx < 0) or (syllable_count_local <= 0) or
                (start_idx + syllable_count_local - 1 > High(visibility_syllables)) then
            begin
                Exit;
            end;
            for local_idx := start_idx to start_idx + syllable_count_local - 1 do
            begin
                Result := Result + normalize_pinyin_text(visibility_syllables[local_idx].text);
            end;
        end;

        function try_get_best_exact_three_syllable_text_local(const start_idx: Integer;
            out out_text: string; out out_weight: Integer): Boolean;
        const
            c_probe_limit = 8;
        var
            query_key: string;
            exact_results: TncCandidateList;
            result_idx: Integer;
            candidate_text: string;
            candidate_units: Integer;
            weight_value: Integer;
        begin
            Result := False;
            out_text := '';
            out_weight := 0;
            query_key := build_visibility_query_key(start_idx, 3);
            if (query_key = '') or (m_dictionary = nil) or
                (not m_dictionary.lookup_exact_full_pinyin(query_key, exact_results)) then
            begin
                Exit;
            end;

            for result_idx := 0 to High(exact_results) do
            begin
                if result_idx >= c_probe_limit then
                begin
                    Break;
                end;
                if Trim(exact_results[result_idx].comment) <> '' then
                begin
                    Continue;
                end;
                if (exact_results[result_idx].source = cs_user) or
                    (not exact_results[result_idx].has_dict_weight) or
                    is_runtime_chain_candidate(exact_results[result_idx]) or
                    is_runtime_common_pattern_candidate(exact_results[result_idx]) or
                    is_runtime_redup_candidate(exact_results[result_idx]) then
                begin
                    Continue;
                end;
                candidate_text := Trim(exact_results[result_idx].text);
                candidate_units := get_candidate_text_unit_count(candidate_text);
                if candidate_units <> 3 then
                begin
                    Continue;
                end;

                if exact_results[result_idx].has_dict_weight then
                begin
                    weight_value := exact_results[result_idx].dict_weight;
                end
                else
                begin
                    weight_value := exact_results[result_idx].score;
                end;
                if weight_value > out_weight then
                begin
                    out_text := candidate_text;
                    out_weight := weight_value;
                    Result := True;
                end;
            end;
        end;

        function get_sentence_visibility_adjustment_local(
            const candidate: TncCandidate): Integer;
        var
            encoded_path: string;
            segment_parts: TArray<string>;
            segment_text: string;
            next_segment_text: string;
            segment_units: Integer;
            next_segment_units: Integer;
            segment_idx: Integer;
            syllable_idx: Integer;
            left_fixed: string;
            right_fixed: string;
            combined_text: string;
            exact_three_text: string;
            exact_three_weight: Integer;
        begin
            Result := 0;
            if candidate.comment <> '' then
            begin
                Exit;
            end;

            encoded_path := get_segment_path_for_candidate(candidate);
            if get_encoded_path_segment_count_local(encoded_path) <= 1 then
            begin
                Exit;
            end;

            if Length(visibility_syllables) <> m_last_lookup_syllable_count then
            begin
                Exit;
            end;

            segment_parts := encoded_path.Split([c_segment_path_separator]);
            syllable_idx := 0;
            for segment_idx := 0 to High(segment_parts) do
            begin
                segment_text := Trim(segment_parts[segment_idx]);
                segment_units := get_candidate_text_unit_count(segment_text);
                if (segment_units = 2) and
                    (syllable_idx + 1 <= High(visibility_syllables)) then
                begin
                    left_fixed := get_fixed_bridge_single_char_local(
                        visibility_syllables[syllable_idx].text);
                    right_fixed := get_fixed_bridge_single_char_local(
                        visibility_syllables[syllable_idx + 1].text);
                    if (left_fixed <> '') and (right_fixed <> '') and
                        (segment_text <> left_fixed + right_fixed) then
                    begin
                        Dec(Result, 1600);
                    end;

                    if (segment_idx < High(segment_parts)) and
                        (syllable_idx + 2 <= High(visibility_syllables)) then
                    begin
                        next_segment_text := Trim(segment_parts[segment_idx + 1]);
                        next_segment_units := get_candidate_text_unit_count(next_segment_text);
                        if next_segment_units >= 1 then
                        begin
                            combined_text := segment_text + split_text_units(next_segment_text)[0];
                            if try_get_best_exact_three_syllable_text_local(
                                syllable_idx, exact_three_text, exact_three_weight) and
                                (exact_three_weight >= 520) then
                            begin
                                if combined_text = exact_three_text then
                                begin
                                    Inc(Result, 520);
                                end
                                else
                                begin
                                    Dec(Result, 880);
                                end;
                            end;
                        end;
                    end;
                end;
                Inc(syllable_idx, segment_units);
            end;
        end;
    begin
        if Length(candidates) <= 1 then
        begin
            Exit;
        end;

        Exit;

        visibility_syllables := get_effective_compact_pinyin_syllables(
            normalize_pinyin_text(m_last_lookup_key));

        best_index := -1;
        best_score_hint := Low(Integer);
        best_segment_count := MaxInt;
        best_candidate_score := Low(Integer);
        best_visibility_adjustment := Low(Integer);
        for idx := 0 to High(candidates) do
        begin
            if not is_lightweight_sentence_complete_candidate_for_visibility(candidates[idx]) then
            begin
                Continue;
            end;

            top_score_hint := get_candidate_segment_path_score_hint(candidates[idx]);
            top_segment_count := get_encoded_path_segment_count_local(
                get_segment_path_for_candidate(candidates[idx]));
            top_candidate_score := candidates[idx].score;
            top_visibility_adjustment := get_sentence_visibility_adjustment_local(candidates[idx]);
            if (best_index < 0) or
                (top_visibility_adjustment > best_visibility_adjustment) or
                ((top_visibility_adjustment = best_visibility_adjustment) and
                (top_candidate_score > best_candidate_score)) or
                ((Abs(top_candidate_score - best_candidate_score) <=
                c_lightweight_segment_tiebreak_margin) and
                (top_visibility_adjustment = best_visibility_adjustment) and
                (top_segment_count < best_segment_count)) or
                ((top_visibility_adjustment = best_visibility_adjustment) and
                (Abs(top_candidate_score - best_candidate_score) <=
                c_lightweight_segment_tiebreak_margin) and
                (top_segment_count = best_segment_count) and
                (top_score_hint > best_score_hint)) or
                ((top_visibility_adjustment = best_visibility_adjustment) and
                (top_candidate_score = best_candidate_score) and
                (top_segment_count = best_segment_count) and
                (top_score_hint > best_score_hint)) then
            begin
                best_score_hint := top_score_hint;
                best_segment_count := top_segment_count;
                best_candidate_score := top_candidate_score;
                best_visibility_adjustment := top_visibility_adjustment;
                best_index := idx;
            end;
        end;

        if best_index <= 0 then
        begin
            Exit;
        end;

        if is_lightweight_sentence_complete_candidate_for_visibility(candidates[0]) then
        begin
            top_score_hint := get_candidate_segment_path_score_hint(candidates[0]);
            top_segment_count := get_encoded_path_segment_count_local(
                get_segment_path_for_candidate(candidates[0]));
            top_candidate_score := candidates[0].score;
            top_visibility_adjustment := get_sentence_visibility_adjustment_local(candidates[0]);
            if (top_visibility_adjustment > best_visibility_adjustment) or
                ((top_visibility_adjustment = best_visibility_adjustment) and
                (top_candidate_score > best_candidate_score)) or
                ((top_visibility_adjustment = best_visibility_adjustment) and
                ((top_candidate_score + c_lightweight_segment_tiebreak_margin >=
                best_candidate_score) and
                (top_segment_count <= best_segment_count))) or
                ((top_visibility_adjustment = best_visibility_adjustment) and
                (top_candidate_score + c_lightweight_segment_tiebreak_margin >=
                best_candidate_score) and
                (top_segment_count = best_segment_count) and
                (top_score_hint >= best_score_hint)) then
            begin
                Exit;
            end;
        end;

        picked := candidates[best_index];
        for idx := best_index downto 1 do
        begin
            candidates[idx] := candidates[idx - 1];
        end;
        candidates[0] := picked;
    end;

    procedure ensure_best_exact_prefix_partial_precedes_suspicious_long_candidate(
        var candidates: TncCandidateList);
    var
        best_index: Integer;
        best_units: Integer;
        best_score: Integer;
        best_has_dict_weight: Boolean;
        idx: Integer;
        current_units: Integer;
        partial_comment_syllables: Integer;
        top_units: Integer;
        top_path_segments: Integer;
        top_is_suspicious_complete: Boolean;
        top_is_suspicious_partial: Boolean;
        picked: TncCandidate;
    begin
        if (Length(candidates) <= 1) or
            (input_syllable_count < 5) or
            (not is_full_pinyin_key(lookup_text)) then
        begin
            Exit;
        end;

        best_index := -1;
        best_units := -1;
        best_score := Low(Integer);
        best_has_dict_weight := False;
        for idx := 0 to High(candidates) do
        begin
            if Trim(candidates[idx].comment) = '' then
            begin
                Continue;
            end;
            if not is_full_pinyin_key(normalize_pinyin_text(candidates[idx].comment)) then
            begin
                Continue;
            end;
            if not is_strong_exact_partial_candidate_for_visibility(candidates[idx]) then
            begin
                Continue;
            end;

            current_units := get_candidate_text_unit_count(Trim(candidates[idx].text));
            if current_units < 2 then
            begin
                Continue;
            end;

            partial_comment_syllables := get_effective_compact_pinyin_unit_count(
                normalize_pinyin_text(candidates[idx].comment));
            if current_units + partial_comment_syllables <> input_syllable_count then
            begin
                Continue;
            end;

            if (candidates[idx].has_dict_weight and (not best_has_dict_weight)) or
                ((candidates[idx].has_dict_weight = best_has_dict_weight) and
                (current_units > best_units)) or
                ((candidates[idx].has_dict_weight = best_has_dict_weight) and
                (current_units = best_units) and
                (candidates[idx].score > best_score)) then
            begin
                best_index := idx;
                best_units := current_units;
                best_score := candidates[idx].score;
                best_has_dict_weight := candidates[idx].has_dict_weight;
            end;
        end;

        if best_index <= 0 then
        begin
            Exit;
        end;

        top_units := get_candidate_text_unit_count(Trim(candidates[0].text));
        top_path_segments := get_encoded_path_segment_count_local(
            get_segment_path_for_candidate(candidates[0]));
        top_is_suspicious_complete := (Trim(candidates[0].comment) = '') and
            (top_units = input_syllable_count) and
            (not candidates[0].has_dict_weight) and
            (top_path_segments > 1);
        top_is_suspicious_partial := (Trim(candidates[0].comment) <> '') and
            is_full_pinyin_key(normalize_pinyin_text(candidates[0].comment)) and
            (not candidates[0].has_dict_weight);

        if not (top_is_suspicious_complete or top_is_suspicious_partial) then
        begin
            Exit;
        end;

        picked := candidates[best_index];
        for idx := best_index downto 1 do
        begin
            candidates[idx] := candidates[idx - 1];
        end;
        candidates[0] := picked;
    end;

    procedure ensure_best_user_complete_candidate_visible(var candidates: TncCandidateList);
    var
        best_index: Integer;
        best_bonus: Integer;
        current_top_bonus: Integer;
        latest_query_choice_text: string;
        normalized_query: string;
        idx: Integer;
        local_bonus: Integer;
        picked: TncCandidate;
    begin
        if Length(candidates) <= 1 then
        begin
            Exit;
        end;
        if m_last_lookup_syllable_count < 2 then
        begin
            Exit;
        end;

        normalized_query := normalize_pinyin_text(m_last_lookup_key);
        latest_query_choice_text := '';
        if (normalized_query <> '') and (m_dictionary <> nil) then
        begin
            latest_query_choice_text := Trim(
                m_dictionary.get_query_latest_choice_text(normalized_query));
        end;

        best_index := -1;
        best_bonus := Low(Integer);
        for idx := 0 to High(candidates) do
        begin
            if (candidates[idx].source <> cs_user) or (candidates[idx].comment <> '') or
                (get_candidate_text_unit_count(Trim(candidates[idx].text)) <>
                m_last_lookup_syllable_count) then
            begin
                Continue;
            end;

            local_bonus := 0;
            if is_latest_session_query_choice(candidates[idx].text) then
            begin
                Inc(local_bonus, 800);
            end;
            if (latest_query_choice_text <> '') and
                SameText(Trim(candidates[idx].text), latest_query_choice_text) then
            begin
                Inc(local_bonus, 720);
            end;
            if (normalized_query <> '') and (m_dictionary <> nil) then
            begin
                Inc(local_bonus,
                    m_dictionary.get_query_choice_bonus(normalized_query, candidates[idx].text));
            end;

            if (best_index < 0) or (local_bonus > best_bonus) or
                ((local_bonus = best_bonus) and (candidates[idx].score > candidates[best_index].score)) then
            begin
                best_index := idx;
                best_bonus := local_bonus;
            end;
        end;

        if best_index <= 0 then
        begin
            Exit;
        end;

        current_top_bonus := 0;
        if (candidates[0].source = cs_user) and (candidates[0].comment = '') and
            (get_candidate_text_unit_count(Trim(candidates[0].text)) = m_last_lookup_syllable_count) then
        begin
            if is_latest_session_query_choice(candidates[0].text) then
            begin
                Inc(current_top_bonus, 800);
            end;
            if (latest_query_choice_text <> '') and
                SameText(Trim(candidates[0].text), latest_query_choice_text) then
            begin
                Inc(current_top_bonus, 720);
            end;
            if (normalized_query <> '') and (m_dictionary <> nil) then
            begin
                Inc(current_top_bonus,
                    m_dictionary.get_query_choice_bonus(normalized_query, candidates[0].text));
            end;
        end;

        if (best_bonus <= 0) and (candidates[0].source = cs_user) then
        begin
            Exit;
        end;
        if (best_bonus <= current_top_bonus) and (candidates[0].source = cs_user) then
        begin
            Exit;
        end;

        picked := candidates[best_index];
        for idx := best_index downto 1 do
        begin
            candidates[idx] := candidates[idx - 1];
        end;
        candidates[0] := picked;
    end;

    procedure ensure_best_dict_exact_prefix_partial_visible(
        var candidates: TncCandidateList);
    var
        best_index: Integer;
        best_units: Integer;
        best_score: Integer;
        idx: Integer;
        current_units: Integer;
        picked: TncCandidate;
    begin
        if (Length(candidates) <= 1) or
            (input_syllable_count < c_long_sentence_exact_min_syllables) or
            (not is_full_pinyin_key(lookup_text)) then
        begin
            Exit;
        end;

        best_index := -1;
        best_units := -1;
        best_score := Low(Integer);
        for idx := 0 to High(candidates) do
        begin
            if (Trim(candidates[idx].comment) = '') or
                (not is_full_pinyin_key(normalize_pinyin_text(candidates[idx].comment))) or
                (not candidates[idx].has_dict_weight) then
            begin
                Continue;
            end;

            current_units := get_candidate_text_unit_count(Trim(candidates[idx].text));
            if current_units < 2 then
            begin
                Continue;
            end;

            if (current_units > best_units) or
                ((current_units = best_units) and
                (candidates[idx].score > best_score)) then
            begin
                best_index := idx;
                best_units := current_units;
                best_score := candidates[idx].score;
            end;
        end;

