    function has_short_exact_complete_anchor(
        const candidates: TncCandidateList): Boolean;
    var
        idx: Integer;
    begin
        Result := False;
        if (input_syllable_count < 2) or (input_syllable_count > 8) or
            ((not is_full_pinyin_key(lookup_text)) and
            (not is_short_mixed_head_only_fast_anchor_query)) then
        begin
            Exit;
        end;

        for idx := 0 to High(candidates) do
        begin
            if (Trim(candidates[idx].comment) <> '') or
                (not candidates[idx].has_dict_weight) then
            begin
                Continue;
            end;
            if get_candidate_text_unit_count(Trim(candidates[idx].text)) <>
                input_syllable_count then
            begin
                Continue;
            end;
            Exit(True);
        end;
    end;

    function seed_short_full_exact_resolved_candidate_local(
        var io_candidates: TncCandidateList): Boolean;
    var
        resolved_text_local: string;
        resolved_path_local: string;
        resolved_score_local: Integer;
        resolved_segments_local: Integer;
        resolved_anchor_units_local: Integer;
        resolved_has_anchor_local: Boolean;
        support_score_local: Integer;
        support_segments_local: Integer;
        support_path_local: string;
        existing_index_local: Integer;
        idx_local: Integer;
        seeded_candidate_local: TncCandidate;
    begin
        Result := False;
        if (not short_full_exact_query) or (m_dictionary = nil) or
            (not is_full_pinyin_key(lookup_text)) or
            (input_syllable_count < 2) or (input_syllable_count > 2) then
        begin
            Exit;
        end;

        if not try_resolve_best_exact_subspan_local(0, input_syllable_count,
            resolved_text_local, resolved_score_local, resolved_segments_local,
            resolved_path_local, resolved_has_anchor_local,
            resolved_anchor_units_local) then
        begin
            Exit;
        end;

        if (Trim(resolved_text_local) = '') or
            (get_candidate_text_unit_count(Trim(resolved_text_local)) <>
            input_syllable_count) then
        begin
            Exit;
        end;

        support_path_local := '';
        support_score_local := 0;
        support_segments_local := 0;
        if Trim(resolved_path_local) = '' then
        begin
            support_path_local := infer_segment_path_for_query_text_with_score(
                lookup_text, Trim(resolved_text_local), support_score_local,
                support_segments_local);
            if Trim(support_path_local) <> '' then
            begin
                resolved_path_local := support_path_local;
            end;
        end;
        if Trim(resolved_path_local) = '' then
        begin
            Exit;
        end;

        existing_index_local := -1;
        for idx_local := 0 to High(io_candidates) do
        begin
            if (Trim(io_candidates[idx_local].comment) = '') and
                SameText(Trim(io_candidates[idx_local].text),
                Trim(resolved_text_local)) then
            begin
                existing_index_local := idx_local;
                Break;
            end;
        end;

        if existing_index_local = 0 then
        begin
            if not io_candidates[0].has_dict_weight then
            begin
                io_candidates[0].has_dict_weight := True;
                io_candidates[0].dict_weight := Max(io_candidates[0].score,
                    resolved_score_local);
            end;
            remember_segment_path_for_candidate(Trim(io_candidates[0].text), '',
                resolved_path_local, io_candidates[0].dict_weight);
            Exit(True);
        end;

        if existing_index_local > 0 then
        begin
            seeded_candidate_local := io_candidates[existing_index_local];
            if not seeded_candidate_local.has_dict_weight then
            begin
                seeded_candidate_local.has_dict_weight := True;
                seeded_candidate_local.dict_weight := Max(
                    seeded_candidate_local.score, resolved_score_local);
            end;
            for idx_local := existing_index_local downto 1 do
            begin
                io_candidates[idx_local] := io_candidates[idx_local - 1];
            end;
            io_candidates[0] := seeded_candidate_local;
            remember_segment_path_for_candidate(Trim(io_candidates[0].text), '',
                resolved_path_local, io_candidates[0].dict_weight);
            Exit(True);
        end;

        FillChar(seeded_candidate_local, SizeOf(seeded_candidate_local), 0);
        seeded_candidate_local.text := Trim(resolved_text_local);
        seeded_candidate_local.comment := '';
        seeded_candidate_local.score := Max(resolved_score_local, 2048);
        seeded_candidate_local.source := cs_rule;
        seeded_candidate_local.has_dict_weight := True;
        seeded_candidate_local.dict_weight := seeded_candidate_local.score;

        SetLength(io_candidates, Length(io_candidates) + 1);
        for idx_local := High(io_candidates) downto 1 do
        begin
            io_candidates[idx_local] := io_candidates[idx_local - 1];
        end;
        io_candidates[0] := seeded_candidate_local;
        remember_segment_path_for_candidate(Trim(io_candidates[0].text), '',
            resolved_path_local, io_candidates[0].dict_weight);
        if m_config.debug_mode then
        begin
            m_last_full_path_debug_info := m_last_full_path_debug_info +
                Format(' sfx=[seed text=%s seg=%d]',
                [Trim(resolved_text_local), resolved_segments_local]);
        end;
        Result := True;
    end;

    function get_fixed_resolved_boundary_char_local(
        const syllable_text: string): string;
    var
        normalized_syllable: string;
    begin
        Result := '';
        normalized_syllable := normalize_pinyin_text(syllable_text);
        if normalized_syllable = 'dan' then
        begin
            Result := string(Char($4F46));
        end
        else if normalized_syllable = 'sui' then
        begin
            Result := string(Char($867D));
        end
        else if normalized_syllable = 'wo' then
        begin
            Result := string(Char($6211));
        end
        else if normalized_syllable = 'ni' then
        begin
            Result := string(Char($4F60));
        end
        else if normalized_syllable = 'ta' then
        begin
            Result := string(Char($4ED6));
        end
        else if normalized_syllable = 'he' then
        begin
            Result := string(Char($548C));
        end
        else if normalized_syllable = 'qu' then
        begin
            Result := string(Char($53BB));
        end
        else if normalized_syllable = 'shi' then
        begin
            Result := string(Char($662F));
        end
        else if normalized_syllable = 'ye' then
        begin
            Result := string(Char($4E5F));
        end
        else if normalized_syllable = 'hui' then
        begin
            Result := string(Char($4F1A));
        end
        else if normalized_syllable = 'ba' then
        begin
            Result := string(Char($628A));
        end
        else if normalized_syllable = 'de' then
        begin
            Result := string(Char($7684));
        end
        else if normalized_syllable = 'zai' then
        begin
            Result := string(Char($5728));
        end
        else if normalized_syllable = 'zhe' then
        begin
