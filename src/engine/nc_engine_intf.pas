        c_chunk_cover_bonus = 2600;
        c_anchor_bonus = 3600;
        c_segment_penalty = 2400;
        c_strong_chunk_bonus = 6000;
        c_cross_boundary_swallow_penalty = 36000;
        c_short_chunk_under_strong_penalty = 4000;
        c_short_exact_variant_limit = 8;
    var
        dp_scores: TArray<Integer>;
        dp_segments: TArray<Integer>;
        dp_anchor_units: TArray<Integer>;
        dp_has_anchor: TArray<Boolean>;
        dp_texts: TArray<string>;
