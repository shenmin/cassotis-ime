                    Exit;
                end;

                if syllable_count = 1 then
                begin
                    if not try_get_best_long_sentence_single_char_local(
                        exact_syllables[start_idx].text, piece_text, piece_weight) then
                    begin
                        Exit;
                    end;
                    anchored := is_strong_sentence_boundary_single_local(
                        exact_syllables[start_idx].text);
                    Exit(True);
                end;

                query_key := build_exact_syllable_text(start_idx, syllable_count);
                if query_key = '' then
                begin
                    Exit;
                end;

                if syllable_count = 2 then
                begin
                    if not try_get_best_two_syllable_exact_phrase_local(start_idx,
                        piece_text, piece_weight) then
                    begin
                        Exit;
                    end;
                end
                else if syllable_count = 3 then
                begin
                    if not try_get_best_three_syllable_exact_phrase_local(start_idx,
                        piece_text, piece_weight) then
                    begin
                        if not try_get_best_sentence_phrase_weight_local(query_key, 2,
                            piece_text, piece_weight) then
                        begin
                            Exit;
                        end;
                    end;
                end
                else
                begin
                    if not try_get_best_sentence_phrase_weight_local(query_key, 2,
                        piece_text, piece_weight) then
                    begin
                        Exit;
                    end;
                end;

                anchored := get_preferred_exact_phrase_bonus_local(query_key,
                    piece_text) > 0;
                Result := True;
            end;
        var
            best_text_local: string;
            best_weight_local: Integer;
            best_rank_bonus_local: Integer;
            query_key: string;
            direct_text: string;
            direct_weight: Integer;
            split_pos: Integer;
            left_text: string;
            right_text: string;
            left_weight: Integer;
            right_weight: Integer;
            left_anchor: Boolean;
            right_anchor: Boolean;
            combined_text: string;
            combined_weight: Integer;
        begin
            Result := False;
            out_text := '';
            out_weight := 0;
            out_rank_bonus := 0;
            if (segment_syllables < 3) or (segment_syllables > 4) or
                (segment_start < 0) or
                (segment_start + segment_syllables > Length(exact_syllables)) then
            begin
                Exit;
            end;

            best_text_local := '';
            best_weight_local := 0;
            best_rank_bonus_local := 0;

            if segment_syllables = 3 then
            begin
                query_key := build_exact_syllable_text(segment_start, segment_syllables);
                if try_get_best_three_syllable_exact_phrase_local(segment_start,
                    direct_text, direct_weight) and
                    (get_preferred_exact_phrase_bonus_local(query_key, direct_text) > 0) then
                begin
                    best_text_local := direct_text;
                    best_weight_local := direct_weight;
                    best_rank_bonus_local := 2200;
                    Result := True;
                end;
            end;

            for split_pos := 1 to segment_syllables - 1 do
            begin
                if not try_get_segment_piece_local(segment_start, split_pos,
                    left_text, left_weight, left_anchor) then
                begin
                    Continue;
                end;
                if not try_get_segment_piece_local(segment_start + split_pos,
                    segment_syllables - split_pos, right_text, right_weight,
                    right_anchor) then
                begin
                    Continue;
                end;
                if (not left_anchor) and (not right_anchor) then
                begin
                    Continue;
                end;

                combined_text := left_text + right_text;
                combined_weight := left_weight + right_weight;
                if (not Result) or (combined_weight > best_weight_local) then
                begin
                    best_text_local := combined_text;
                    best_weight_local := combined_weight;
                    best_rank_bonus_local := 2400;
                    Result := True;
                end;
            end;

            if not Result then
            begin
                Exit;
            end;

            out_text := best_text_local;
            out_weight := best_weight_local;
            out_rank_bonus := best_rank_bonus_local;
        end;

        function try_get_best_resolved_exact_segment_candidate_local(
            const segment_start: Integer; const segment_syllables: Integer;
            out out_text: string; out out_weight: Integer;
            out out_rank_bonus: Integer): Boolean;
        var
            query_key: string;
            candidate_text_local: string;
            candidate_weight_local: Integer;
            candidate_rank_bonus_local: Integer;
        begin
            Result := False;
            out_text := '';
            out_weight := 0;
            out_rank_bonus := 0;
            if (segment_start < 0) or (segment_syllables <= 0) or
                (segment_start + segment_syllables > Length(exact_syllables)) then
            begin
                Exit;
            end;

            if segment_syllables = 1 then
            begin
                if try_get_best_long_sentence_single_char_local(
                    exact_syllables[segment_start].text,
                    candidate_text_local, candidate_weight_local) then
                begin
                    candidate_rank_bonus_local := c_long_sentence_top_exact_bonus;
                    if is_strong_sentence_boundary_single_local(
                        exact_syllables[segment_start].text) then
                    begin
                        Inc(candidate_rank_bonus_local, 260);
                    end;
                    out_text := candidate_text_local;
                    out_weight := candidate_weight_local;
                    out_rank_bonus := candidate_rank_bonus_local;
                    Exit(True);
                end;
                Exit(False);
            end;

            if segment_syllables = 2 then
            begin
                if try_get_best_two_syllable_exact_phrase_local(segment_start,
                    candidate_text_local, candidate_weight_local) then
                begin
                    out_text := candidate_text_local;
                    out_weight := candidate_weight_local;
                    out_rank_bonus := c_long_sentence_top_exact_bonus + 240;
                    Exit(True);
                end;
                Exit(False);
            end;

            if try_build_preferred_split_exact_segment_local(segment_start,
                segment_syllables, candidate_text_local, candidate_weight_local,
                candidate_rank_bonus_local) then
            begin
                out_text := candidate_text_local;
                out_weight := candidate_weight_local;
                out_rank_bonus := candidate_rank_bonus_local;
                Exit(True);
            end;

            if segment_syllables = 3 then
            begin
                if try_get_best_three_syllable_exact_phrase_local(segment_start,
                    candidate_text_local, candidate_weight_local) then
                begin
                    out_text := candidate_text_local;
                    out_weight := candidate_weight_local;
                    out_rank_bonus := c_long_sentence_top_exact_bonus + 220;
                    Exit(True);
                end;
            end;

            query_key := build_exact_syllable_text(segment_start, segment_syllables);
            if (query_key <> '') and try_get_best_sentence_phrase_weight_local(
                query_key, 2, candidate_text_local, candidate_weight_local) then
            begin
                out_text := candidate_text_local;
                out_weight := candidate_weight_local;
                out_rank_bonus := c_long_sentence_top_exact_bonus + 160;
                Exit(True);
            end;
        end;

        function try_build_preferred_sentence_rescue_candidate_local(
            out out_candidate: TncCandidate): Boolean;
        const
            c_rescue_max_piece_syllables = 6;
            c_rescue_anchor_bonus = 960;
        type
            TPreferredSentenceState = record
                valid: Boolean;
                text: string;
                score: Integer;
                anchor_count: Integer;
            end;
            TPreferredSentenceStateArray = array of TPreferredSentenceState;
            function try_get_piece_local(const start_idx: Integer;
                const syllable_count: Integer; out piece_text: string;
                out piece_weight: Integer; out anchored: Boolean): Boolean;
            var
                query_key: string;
            begin
                Result := False;
                piece_text := '';
                piece_weight := 0;
                anchored := False;
                if (syllable_count <= 0) or (start_idx < 0) or
                    (start_idx + syllable_count > Length(exact_syllables)) then
                begin
                    Exit;
                end;

                if syllable_count = 1 then
                begin
                    if not try_get_best_long_sentence_single_char_local(
                        exact_syllables[start_idx].text, piece_text, piece_weight) then
                    begin
                        Exit;
                    end;
                    anchored := is_strong_sentence_boundary_single_local(
                        exact_syllables[start_idx].text);
                    Exit(True);
                end;

                query_key := build_exact_syllable_text(start_idx, syllable_count);
                if query_key = '' then
                begin
                    Exit;
                end;

                if syllable_count = 2 then
                begin
                    if not try_get_best_two_syllable_exact_phrase_local(start_idx,
                        piece_text, piece_weight) then
                    begin
                        Exit;
                    end;
                end
                else if syllable_count = 3 then
                begin
                    if not try_get_best_three_syllable_exact_phrase_local(start_idx,
                        piece_text, piece_weight) then
                    begin
                        if not try_get_best_sentence_phrase_weight_local(query_key, 2,
                            piece_text, piece_weight) then
                        begin
                            Exit;
                        end;
                    end;
                end
                else
                begin
                    if not try_get_best_sentence_phrase_weight_local(query_key, 2,
                        piece_text, piece_weight) then
                    begin
                        Exit;
                    end;
                end;

                anchored := get_preferred_exact_phrase_bonus_local(query_key,
                    piece_text) > 0;
                Result := True;
            end;
        var
            states: TPreferredSentenceStateArray;
            pos: Integer;
            next_pos: Integer;
            piece_len: Integer;
            piece_text: string;
            piece_weight: Integer;
            piece_anchor: Boolean;
            next_score: Integer;
            next_text: string;
            total_syllables: Integer;
        begin
            Result := False;
            FillChar(out_candidate, SizeOf(out_candidate), 0);
            total_syllables := Length(exact_syllables);
            if total_syllables < 3 then
            begin
                Exit;
            end;

            SetLength(states, total_syllables + 1);
            states[0].valid := True;
            states[0].text := '';
            states[0].score := 0;
            states[0].anchor_count := 0;

            for pos := 0 to total_syllables - 1 do
            begin
                if not states[pos].valid then
                begin
                    Continue;
                end;

                for piece_len := 1 to Min(c_rescue_max_piece_syllables,
                    total_syllables - pos) do
                begin
                    if not try_get_piece_local(pos, piece_len, piece_text,
                        piece_weight, piece_anchor) then
                    begin
                        Continue;
                    end;

                    next_pos := pos + piece_len;
                    next_score := states[pos].score + piece_weight;
                    if piece_anchor then
                    begin
                        Inc(next_score, c_rescue_anchor_bonus);
                    end;
                    if piece_len = 1 then
                    begin
                        Dec(next_score, c_long_sentence_single_penalty);
                    end
                    else
                    begin
                        Inc(next_score,
                            c_long_sentence_multi_bonus + (piece_len * 24));
                    end;
                    if next_pos = total_syllables then
                    begin
                        Inc(next_score, c_long_sentence_completion_bonus);
                    end
                    else
                    begin
                        Inc(next_score, c_long_sentence_continuation_bonus);
                    end;

                    next_text := states[pos].text + piece_text;
                    if (not states[next_pos].valid) or
                        (next_score > states[next_pos].score) then
                    begin
                        states[next_pos].valid := True;
                        states[next_pos].text := next_text;
                        states[next_pos].score := next_score;
                        states[next_pos].anchor_count := states[pos].anchor_count +
                            Ord(piece_anchor);
                    end;
                end;
            end;

            if (not states[total_syllables].valid) or
                (states[total_syllables].anchor_count <= 0) then
            begin
                Exit;
            end;

            out_candidate.text := states[total_syllables].text;
            out_candidate.score := states[total_syllables].score;
            out_candidate.source := cs_rule;
            out_candidate.comment := '';
            Result := Trim(out_candidate.text) <> '';
        end;

