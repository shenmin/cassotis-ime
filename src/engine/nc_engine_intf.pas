                        Continue;
                    end;

                    best_idx_local := local_idx;
                    best_support_local := local_support_score;
                    best_chunk_local := local_chunk_alignment_score;
                    best_rerank_local := local_rerank_score;
                    Continue;
                end;

                if not (((local_support_score > top_support_local +
                    c_support_margin) and
                    (local_chunk_alignment_score >= top_chunk_local - 2048) and
                    (local_rerank_score >= top_rerank_local - 8192)) or
                    ((local_chunk_alignment_score > top_chunk_local +
                    c_chunk_margin) and
                    (local_rerank_score > top_rerank_local +
                    c_rerank_margin)) or
                    (top_problematic_local and
