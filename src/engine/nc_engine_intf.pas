            if Length(units) > 0 then
            begin
                Result := units[0];
            end;
        end;

        function has_exact_single_char_tail_local(const value: string): Boolean;
        const
            c_tail_probe_limit = 12;
        var
            local_value: string;
            local_results: TncCandidateList;
            local_idx: Integer;
        begin
            Result := False;
            local_value := normalize_pinyin_text(value);
            if (local_value = '') or (m_dictionary = nil) or
                (not m_dictionary.lookup(local_value, local_results)) then
            begin
                Exit;
            end;

            for local_idx := 0 to High(local_results) do
            begin
                if local_idx >= c_tail_probe_limit then
                begin
                    Break;
                end;
                if Trim(local_results[local_idx].comment) <> '' then
                begin
                    Continue;
                end;
                if get_candidate_text_unit_count(Trim(local_results[local_idx].text)) = 1 then
                begin
                    Exit(True);
                end;
            end;
        end;

