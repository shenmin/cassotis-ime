        procedure try_promote_full_query_subspan_resolved_candidate_local;
        const
            c_max_short_query_syllables = 7;
        var
            resolved_text_local: string;
            resolved_path_local: string;
            resolved_score_local: Integer;
            resolved_segments_local: Integer;
            resolved_anchor_units_local: Integer;
            resolved_has_anchor_local: Boolean;
            resolved_support_score_local: Integer;
            resolved_chunk_alignment_score_local: Integer;
            resolved_rerank_score_local: Integer;
            resolved_head_boundary_score_local: Integer;
            resolved_phrase_bonus_local: Integer;
            local_idx: Integer;
            promote_margin_local: Integer;
            resolved_candidate_local: TncCandidate;
        begin
            if (best_text = '') or (input_syllable_count < 3) or
                (input_syllable_count > c_max_short_query_syllables) or
                (not is_full_pinyin_key(lookup_text)) then
            begin
                Exit;
            end;

            if not try_resolve_best_exact_subspan_local(0, input_syllable_count,
                resolved_text_local, resolved_score_local,
                resolved_segments_local, resolved_path_local,
                resolved_has_anchor_local, resolved_anchor_units_local) then
            begin
                Exit;
            end;
            if (resolved_text_local = '') or SameText(resolved_text_local,
                best_text) or
                (get_candidate_text_unit_count(resolved_text_local) <>
                input_syllable_count) then
            begin
                Exit;
            end;

            if (resolved_segments_local <= 1) and
                (not resolved_has_anchor_local) and
                (input_syllable_count > 4) then
            begin
                Exit;
            end;

            resolved_support_score_local := get_full_query_support_score_local(
                resolved_text_local);
            if (resolved_support_score_local <= -960) and
                (best_support_score > -960) then
            begin
                Exit;
            end;

            resolved_head_boundary_score_local :=
                get_fixed_boundary_head_score_local(resolved_text_local);
            resolved_chunk_alignment_score_local :=
                get_full_query_chunk_alignment_score_fast_local(
                resolved_text_local, resolved_support_score_local);
            resolved_rerank_score_local := Max(resolved_score_local,
                build_full_query_rerank_score_local(resolved_score_local,
                resolved_chunk_alignment_score_local,
                resolved_support_score_local,
                resolved_head_boundary_score_local));
            resolved_phrase_bonus_local :=
                get_preferred_query_phrase_bonus_local(lookup_text,
                resolved_text_local);

            if input_syllable_count <= 4 then
            begin
                promote_margin_local := 512;
            end
            else
            begin
                promote_margin_local := 1024;
            end;

            if not ((resolved_support_score_local >
                best_support_score + 128) or
                (resolved_rerank_score_local >=
                best_rerank_score + promote_margin_local) or
                ((resolved_head_boundary_score_local >
                best_head_boundary_score) and
                (resolved_rerank_score_local >= best_rerank_score - 512)) or
                ((input_syllable_count <= 4) and
                (resolved_chunk_alignment_score_local >
                best_chunk_alignment_score + 1024) and
                (resolved_rerank_score_local >= best_rerank_score - 1024)) or
                ((best_support_score <= -960) and
                (resolved_rerank_score_local >= best_rerank_score))) then
            begin
                Exit;
            end;

            FillChar(resolved_candidate_local, SizeOf(resolved_candidate_local), 0);
            for local_idx := 0 to High(candidates) do
            begin
                if (Trim(candidates[local_idx].comment) = '') and
                    SameText(Trim(candidates[local_idx].text),
                    resolved_text_local) then
                begin
                    resolved_candidate_local := candidates[local_idx];
                    Break;
                end;
            end;
            if resolved_candidate_local.text = '' then
            begin
                for local_idx := 0 to High(exact_results) do
                begin
