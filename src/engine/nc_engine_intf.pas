        function get_fixed_boundary_head_score_local(
            const candidate_text: string): Integer;
        var
            syllables_local: TncPinyinParseResult;
            text_units_local: TArray<string>;
            head_idx: Integer;
            expected_char: string;
        begin
            Result := 0;
            syllables_local := get_effective_compact_pinyin_syllables(lookup_text);
            text_units_local := split_text_units(Trim(candidate_text));
            for head_idx := 0 to Min(Min(High(syllables_local), High(text_units_local)), 3) do
            begin
                expected_char := get_fixed_boundary_single_char_for_query_syllable_local(
                    syllables_local[head_idx].text);
                if expected_char = '' then
                begin
                    Continue;
                end;
                if SameText(text_units_local[head_idx], expected_char) then
                begin
                    Inc(Result);
                end;
            end;
        end;

        function has_material_support_advantage(const candidate_support: Integer;
            const current_support: Integer): Boolean;
        var
            support_margin: Integer;
        begin
            if input_syllable_count <= 4 then
            begin
                support_margin := 128;
            end
            else if input_syllable_count <= 6 then
            begin
                support_margin := 256;
            end
            else
            begin
                support_margin := 512;
            end;
            Result := candidate_support > current_support + support_margin;
        end;

        function get_common_prefix_unit_count_local(const left_text: string;
            const right_text: string): Integer;
        var
            left_units: TArray<string>;
            right_units: TArray<string>;
            unit_idx: Integer;
        begin
            Result := 0;
            left_units := split_text_units(Trim(left_text));
            right_units := split_text_units(Trim(right_text));
            for unit_idx := 0 to Min(High(left_units), High(right_units)) do
            begin
                if not SameText(left_units[unit_idx], right_units[unit_idx]) then
                begin
                    Break;
                end;
                Inc(Result);
            end;
        end;

        function build_text_from_units_local(const text_units: TArray<string>;
            const start_unit: Integer; const unit_count: Integer): string;
        var
            unit_idx: Integer;
        begin
            Result := '';
            if (unit_count <= 0) or (start_unit < 0) or
                (start_unit + unit_count - 1 > High(text_units)) then
            begin
                Exit;
            end;

            for unit_idx := start_unit to start_unit + unit_count - 1 do
            begin
                Result := Result + text_units[unit_idx];
            end;
        end;

        function get_full_query_chunk_alignment_score_local(
            const candidate_text: string): Integer;
        const
            c_chunk_min_syllables = 2;
            c_chunk_max_syllables = 5;
        var
            candidate_units_local: TArray<string>;
            start_idx_local: Integer;
            span_syllables_local: Integer;
            candidate_chunk_text_local: string;
            resolved_text_local: string;
            resolved_path_local: string;
            resolved_score_local: Integer;
            resolved_segments_local: Integer;
            resolved_anchor_units_local: Integer;
            resolved_has_anchor_local: Boolean;
            window_weight_local: Integer;
        begin
            Result := 0;
            if (not is_full_pinyin_key(lookup_text)) or
                (input_syllable_count < 3) or
                (m_disable_subspan_standalone_oracle > 0) then
            begin
                Exit;
            end;

            candidate_units_local := split_text_units(Trim(candidate_text));
            if Length(candidate_units_local) <> input_syllable_count then
            begin
                Exit;
            end;

            for start_idx_local := 0 to input_syllable_count -
                c_chunk_min_syllables do
            begin
                for span_syllables_local := c_chunk_min_syllables to
                    Min(c_chunk_max_syllables,
                    input_syllable_count - start_idx_local) do
                begin
                    if not try_resolve_best_exact_subspan_local(
                        start_idx_local, span_syllables_local,
                        resolved_text_local, resolved_score_local,
                        resolved_segments_local, resolved_path_local,
                        resolved_has_anchor_local,
                        resolved_anchor_units_local) then
                    begin
                        Continue;
                    end;
                    if resolved_text_local = '' then
                    begin
                        Continue;
                    end;

                    candidate_chunk_text_local := build_text_from_units_local(
                        candidate_units_local, start_idx_local,
                        span_syllables_local);
                    if candidate_chunk_text_local = '' then
                    begin
                        Continue;
                    end;

                    window_weight_local := Min(4096,
                        Max(512, resolved_score_local div 8));
                    Inc(window_weight_local, span_syllables_local * 96);
                    if resolved_has_anchor_local then
                    begin
                        Inc(window_weight_local, 256);
                    end;
                    if start_idx_local + span_syllables_local =
                        input_syllable_count then
                    begin
                        Inc(window_weight_local, window_weight_local * 2);
                        if span_syllables_local <= 2 then
                        begin
                            Inc(window_weight_local, window_weight_local * 2);
                        end
                        else if span_syllables_local = 3 then
                        begin
                            Inc(window_weight_local, window_weight_local);
                        end;
                    end
                    else if start_idx_local + span_syllables_local =
                        input_syllable_count - 1 then
                    begin
                        Inc(window_weight_local, window_weight_local div 2);
                    end;

                    if SameText(candidate_chunk_text_local,
                        resolved_text_local) then
                    begin
                        Inc(Result, window_weight_local);
                        if (start_idx_local + span_syllables_local =
                            input_syllable_count) and
                            (span_syllables_local = 2) and
                            ((resolved_segments_local <= 1) or
                            (resolved_score_local >= 4096)) then
                        begin
                            Inc(Result, window_weight_local * 3);
                        end;
                        if (span_syllables_local = 2) and
                            ((resolved_segments_local <= 1) or
                            (resolved_score_local >= 4096)) then
                        begin
                            Inc(Result, window_weight_local div 2);
                        end;
                    end
                    else if (start_idx_local + span_syllables_local =
                        input_syllable_count) and
                        (span_syllables_local = 2) and
                        ((resolved_segments_local <= 1) or
                        (resolved_score_local >= 4096)) then
                    begin
                        Dec(Result, window_weight_local * 6);
                    end
                    else if (span_syllables_local = 2) and
                        ((resolved_segments_local <= 1) or
                        (resolved_score_local >= 4096)) then
                    begin
                        Dec(Result, window_weight_local);
                    end
                    else if (span_syllables_local >= 4) or
                        resolved_has_anchor_local then
                    begin
                        Dec(Result, window_weight_local div 2);
                    end
                    else if window_weight_local >= 1536 then
                    begin
                        Dec(Result, window_weight_local div 3);
                    end;
                end;
            end;
        end;

        function get_full_query_chunk_alignment_score_fast_local(
            const candidate_text: string; const candidate_support: Integer): Integer;
        begin
            if (input_syllable_count >= 10) and (candidate_support > -960) then
            begin
                Exit(0);
            end;

            Result := get_full_query_chunk_alignment_score_local(candidate_text);
        end;

        function allow_supportless_override_local(
            const candidate_support: Integer; const current_support: Integer;
            const candidate_chunk_alignment: Integer;
            const current_chunk_alignment: Integer;
            const candidate_rerank_score: Integer;
            const current_rerank_score: Integer): Boolean;
        begin
            Result := True;
            if (candidate_support <= -960) and (current_support > -960) then
            begin
                Result := False;
                Exit;
            end;
            if candidate_support > -960 then
            begin
                Exit;
            end;
            if current_support > -960 then
            begin
                Result := (candidate_chunk_alignment >
                    current_chunk_alignment + 4096) and
                    (candidate_rerank_score > current_rerank_score + 12000);
                Exit;
            end;

            Result := (candidate_chunk_alignment > current_chunk_alignment + 1600) and
                (candidate_rerank_score > current_rerank_score + 2400);
        end;

        function has_material_chunk_alignment_advantage_local(
            const candidate_chunk_alignment: Integer;
            const current_chunk_alignment: Integer;
            const candidate_support: Integer;
            const current_support: Integer): Boolean;
        begin
            Result := False;
            if candidate_chunk_alignment <= current_chunk_alignment + 2048 then
            begin
                Exit;
            end;
            if has_material_support_advantage(current_support, candidate_support) and
                (candidate_chunk_alignment <= current_chunk_alignment + 4096) then
            begin
                Exit;
            end;
            Result := True;
        end;

        function has_material_rerank_advantage_local(
            const candidate_rerank_score: Integer;
            const current_rerank_score: Integer;
            const candidate_support: Integer;
            const current_support: Integer): Boolean;
        begin
            Result := False;
            if (candidate_support <= -960) and (current_support > -960) then
            begin
                Exit;
            end;
            if candidate_rerank_score <= current_rerank_score + 1024 then
            begin
                Exit;
            end;

            if has_material_support_advantage(current_support, candidate_support) and
                (candidate_rerank_score <= current_rerank_score + 6000) then
            begin
                Exit;
            end;

            Result := True;
        end;

        function allow_support_priority_override_local(
            const candidate_support: Integer;
            const current_support: Integer;
            const candidate_rerank_score: Integer;
            const current_rerank_score: Integer): Boolean;
        begin
            // Support still matters, but it must not blindly outrank a much
            // stronger full-query rerank. Otherwise frequent but misaligned
            // paths such as "至于/只能" overpower better exact chunk chains.
            if current_support <= -960 then
            begin
                Exit(True);
            end;

            if input_syllable_count >= 4 then
            begin
                Result := candidate_rerank_score >= current_rerank_score + 256;
            end
            else
            begin
                Result := candidate_rerank_score >= current_rerank_score - 2048;
            end;
        end;

        function allow_path_priority_override_local(
            const candidate_rerank_score: Integer;
            const current_rerank_score: Integer;
            const candidate_support: Integer;
            const current_support: Integer): Boolean;
        begin
            Result := not has_material_rerank_advantage_local(
                current_rerank_score, candidate_rerank_score,
                current_support, candidate_support);
        end;

        function build_full_query_rerank_score_local(
            const candidate_score: Integer;
            const chunk_alignment_score: Integer;
            const support_score_value: Integer;
            const head_boundary_score_value: Integer): Integer;
        var
            capped_score_local: Integer;
        begin
            if support_score_value > -960 then
            begin
                capped_score_local := Min(candidate_score, 24000);
            end
            else
            begin
                capped_score_local := Min(candidate_score, 12000);
            end;

            Result := capped_score_local + (chunk_alignment_score * 2) +
                (head_boundary_score_value * 8192);
            if (support_score_value <= -960) and
                (head_boundary_score_value <= 0) then
            begin
                Dec(Result, 12000);
            end;
        end;

        function prefer_long_same_prefix_score_override_local(
            const candidate_text: string; const candidate_support: Integer;
            const candidate_score: Integer; const current_text: string;
            const current_support: Integer; const current_score: Integer): Boolean;
        const
            c_support_tolerance_local = 8192;
            c_score_margin_local = 1200;
            c_large_score_margin_local = 6000;
        begin
            Result := False;
            if input_syllable_count < 4 then
            begin
                Exit;
            end;
            if get_common_prefix_unit_count_local(candidate_text, current_text) < 1 then
            begin
                Exit;
            end;
            if candidate_score <= current_score + c_score_margin_local then
            begin
                Exit;
            end;

            if (candidate_support > -960) and (current_support > -960) and
                (candidate_support + c_support_tolerance_local < current_support) and
                (candidate_score <= current_score + c_large_score_margin_local) then
            begin
                Exit;
            end;

            Result := True;
        end;

        function get_full_query_support_score_local(
            const candidate_text: string): Integer;
        begin
            if (candidate_text = '') or (input_syllable_count < 3) then
            begin
                Exit(0);
            end;

            support_path := infer_segment_path_for_query_text_with_score(
                lookup_text, candidate_text, support_score, support_segments);
            if support_path <> '' then
            begin
                Result := support_score + (support_segments * 320);
            end
            else
            begin
                Result := -960;
            end;
        end;

        function get_full_query_choice_bonus_local(
            const candidate_text: string): Integer;
        begin
            Result := get_session_query_bonus(candidate_text);
            if is_latest_session_query_choice(candidate_text) then
            begin
                Inc(Result, 1200);
            end;
        end;

        function try_build_preferred_query_phrase_candidate_local(
            out out_candidate: TncCandidate): Boolean;
        var
            preferred_text: string;
            preferred_bonus_local: Integer;
            syllables_local: TncPinyinParseResult;
            text_units_local: TArray<string>;
            local_idx: Integer;
            local_is_preferred: Boolean;
            preferred_score: Integer;
        begin
            FillChar(out_candidate, SizeOf(out_candidate), 0);
            Result := False;
            if not try_get_preferred_query_phrase_text_local(lookup_text,
                preferred_text, preferred_bonus_local) then
            begin
                Exit;
            end;

            syllables_local := get_effective_compact_pinyin_syllables(lookup_text);
            text_units_local := split_text_units(preferred_text);
            if (Length(syllables_local) <> input_syllable_count) or
                (Length(text_units_local) <> input_syllable_count) then
            begin
                Exit;
            end;

            for local_idx := 0 to High(text_units_local) do
            begin
                if not match_single_char_candidate_for_syllable(
                    syllables_local[local_idx].text, text_units_local[local_idx],
                    local_is_preferred) then
                begin
                    Exit(False);
                end;
            end;

            preferred_score := preferred_bonus_local + 2048;
            if Length(candidates) > 0 then
            begin
                preferred_score := Max(preferred_score, candidates[0].score + 2048);
            end;

            out_candidate.text := preferred_text;
            out_candidate.comment := '';
            out_candidate.score := preferred_score;
            out_candidate.source := cs_rule;
            out_candidate.has_dict_weight := False;
            out_candidate.dict_weight := 0;
            remember_segment_path_for_candidate(out_candidate.text, '',
                out_candidate.text, out_candidate.score);
            Result := True;
        end;

        procedure maybe_promote_best_supported_full_candidate_local;
        var
            local_idx: Integer;
            local_candidate: TncCandidate;
            local_text: string;
            local_support_score: Integer;
            local_chunk_alignment_score: Integer;
            local_rerank_score: Integer;
            local_head_boundary_score: Integer;
            local_best_found: Boolean;
            local_best_candidate: TncCandidate;
            local_best_text: string;
            local_best_support_score: Integer;
            local_best_chunk_alignment_score: Integer;
            local_best_rerank_score: Integer;
            local_best_head_boundary_score: Integer;
        begin
            if (not is_full_pinyin_key(lookup_text)) or
                (input_syllable_count < 4) then
            begin
                Exit;
            end;

            local_best_found := False;
            local_best_text := '';
            local_best_support_score := Low(Integer);
            local_best_chunk_alignment_score := Low(Integer);
            local_best_rerank_score := Low(Integer);
            local_best_head_boundary_score := Low(Integer);

            for local_idx := 0 to High(candidates) do
            begin
                local_candidate := candidates[local_idx];
                if Trim(local_candidate.comment) <> '' then
                begin
                    Continue;
                end;
                local_text := Trim(local_candidate.text);
                if get_candidate_text_unit_count(local_text) <> input_syllable_count then
                begin
                    Continue;
                end;

                local_support_score := get_full_query_support_score_local(local_text);
                if local_support_score <= -960 then
                begin
                    Continue;
                end;

                local_head_boundary_score :=
                    get_fixed_boundary_head_score_local(local_text);
                local_chunk_alignment_score :=
                    get_full_query_chunk_alignment_score_fast_local(local_text,
                    local_support_score);
                local_rerank_score := build_full_query_rerank_score_local(
                    local_candidate.score, local_chunk_alignment_score,
                    local_support_score, local_head_boundary_score);

                if (not local_best_found) or
                    has_material_chunk_alignment_advantage_local(
                    local_chunk_alignment_score,
                    local_best_chunk_alignment_score, local_support_score,
                    local_best_support_score) or
                    has_material_rerank_advantage_local(local_rerank_score,
                    local_best_rerank_score, local_support_score,
                    local_best_support_score) or
                    ((local_rerank_score = local_best_rerank_score) and
                    (local_head_boundary_score > local_best_head_boundary_score)) or
                    ((local_rerank_score = local_best_rerank_score) and
                    (local_head_boundary_score = local_best_head_boundary_score) and
                    has_material_support_advantage(local_support_score,
                    local_best_support_score)) then
                begin
                    local_best_found := True;
                    local_best_candidate := local_candidate;
                    local_best_text := local_text;
                    local_best_support_score := local_support_score;
