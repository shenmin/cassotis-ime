                begin
                    Continue;
                end;
                if longer_weight > best_weight then
                begin
                    best_weight := longer_weight;
                end;
            end;

            if best_weight <= Low(Integer) div 4 then
            begin
                Exit;
            end;

            if best_weight >= candidate_weight + 80 then
            begin
                Exit(920);
            end
            else if best_weight >= candidate_weight - 20 then
            begin
                Exit(680);
            end
            else if best_weight >= candidate_weight - 160 then
            begin
                Exit(420);
            end;
        end;

        function get_single_plus_following_phrase_penalty(const segment_start: Integer;
            const segment_syllables: Integer; const candidate_text: string;
            const candidate_weight: Integer): Integer;
        const
            c_probe_limit = 6;
        var
            single_text: string;
            single_weight: Integer;
            follow_len: Integer;
            follow_key: string;
            follow_results: TncCandidateList;
            follow_idx: Integer;
            follow_text: string;
            follow_units: Integer;
            follow_weight: Integer;
            best_follow_weight: Integer;
            combined_weight: Integer;
        begin
            Result := 0;
            if (segment_syllables <> 2) or
                (get_candidate_text_unit_count(candidate_text) <> 2) or
                (segment_start < 0) or
                (segment_start + 2 >= head_syllable_count) then
            begin
                Exit;
            end;

            if not try_get_best_sentence_single_char(
                normalize_pinyin_text(syllables[segment_start].text),
                single_text, single_weight) then
            begin
                Exit;
            end;

            best_follow_weight := Low(Integer);
            for follow_len := 2 to Min(max_segment_len, head_syllable_count - (segment_start + 1)) do
            begin
                follow_key := build_syllable_query_key(segment_start + 1, follow_len);
                if (follow_key = '') or
                    (not dictionary_exact_lookup_cached(follow_key, follow_results)) then
                begin
                    Continue;
                end;

                for follow_idx := 0 to High(follow_results) do
                begin
                    if follow_idx >= c_probe_limit then
                    begin
                        Break;
                    end;
                    if Trim(follow_results[follow_idx].comment) <> '' then
                    begin
                        Continue;
                    end;
                    if not is_allowed_sentence_segment_candidate(
                        follow_results[follow_idx], segment_start + 1, follow_len) then
                    begin
                        Continue;
                    end;

                    follow_text := Trim(follow_results[follow_idx].text);
                    follow_units := get_candidate_text_unit_count(follow_text);
                    if follow_units < 2 then
                    begin
                        Continue;
                    end;

                    if follow_results[follow_idx].has_dict_weight then
                    begin
                        follow_weight := follow_results[follow_idx].dict_weight;
                    end
                    else
                    begin
                        follow_weight := follow_results[follow_idx].score;
                    end;

                    if follow_weight > best_follow_weight then
                    begin
                        best_follow_weight := follow_weight;
                    end;
                end;
            end;

            if best_follow_weight <= Low(Integer) div 4 then
            begin
                Exit;
            end;

            combined_weight := single_weight + best_follow_weight;
            if combined_weight >= candidate_weight + 520 then
            begin
                Exit(880);
            end
            else if combined_weight >= candidate_weight + 320 then
            begin
                Exit(640);
            end
            else if combined_weight >= candidate_weight + 180 then
            begin
                Exit(420);
            end;
        end;

        function try_get_best_following_sentence_phrase_weight(
            const start_idx: Integer; const min_syllables: Integer;
            out out_weight: Integer): Boolean;
        var
            follow_len: Integer;
            follow_text: string;
            follow_units: Integer;
            follow_weight: Integer;
            follow_anchor_units: Integer;
        begin
            Result := False;
            out_weight := 0;
            if (start_idx < 0) or (start_idx >= head_syllable_count) or
                (min_syllables < 2) then
            begin
                Exit;
            end;

            for follow_len := min_syllables to
                Min(max_segment_len, head_syllable_count - start_idx) do
            begin
                if not try_resolve_best_exact_sentence_subspan(start_idx, follow_len,
                    follow_text, follow_weight, follow_anchor_units) then
                begin
                    Continue;
                end;
                follow_units := get_candidate_text_unit_count(follow_text);
                if follow_units < 2 then
                begin
                    Continue;
                end;
                if follow_weight > out_weight then
                begin
                    out_weight := follow_weight;
                    Result := True;
                end;
            end;
        end;

        function get_fixed_boundary_follow_phrase_penalty(
            const segment_start: Integer; const segment_syllables: Integer;
            const candidate_text: string; const candidate_weight: Integer): Integer;
        var
            left_key: string;
            right_key: string;
            left_fixed: string;
            right_fixed: string;
            left_text: string;
            right_text: string;
            left_weight: Integer;
            right_weight: Integer;
            follow_weight: Integer;
            combined_weight: Integer;
        begin
            Result := 0;
            if (segment_syllables <> 2) or
                (get_candidate_text_unit_count(candidate_text) <> 2) or
                (segment_start < 0) or (segment_start + 1 >= head_syllable_count) then
            begin
                Exit;
            end;

            left_key := normalize_pinyin_text(syllables[segment_start].text);
            right_key := normalize_pinyin_text(syllables[segment_start + 1].text);
            left_fixed := get_fixed_sentence_single_char(left_key);
            right_fixed := get_fixed_sentence_single_char(right_key);

            if (left_fixed <> '') and
                try_get_best_sentence_single_char(left_key, left_text, left_weight) and
                try_get_best_following_sentence_phrase_weight(segment_start + 1, 2,
                follow_weight) then
            begin
                combined_weight := left_weight + follow_weight;
                if combined_weight >= candidate_weight + 520 then
                begin
                    Exit(1520);
                end
                else if combined_weight >= candidate_weight + 320 then
                begin
                    Exit(1120);
                end
                else if combined_weight >= candidate_weight + 160 then
                begin
                    Exit(760);
                end;
            end;

            if (right_fixed <> '') and (segment_start + 2 < head_syllable_count) and
                try_get_best_sentence_single_char(left_key, left_text, left_weight) and
                try_get_best_sentence_single_char(right_key, right_text, right_weight) and
                try_get_best_following_sentence_phrase_weight(segment_start + 2, 2,
                follow_weight) then
            begin
                combined_weight := left_weight + right_weight + follow_weight;
                if combined_weight >= candidate_weight + 640 then
                begin
                    Exit(1840);
                end
                else if combined_weight >= candidate_weight + 420 then
                begin
                    Exit(1360);
                end
                else if combined_weight >= candidate_weight + 220 then
                begin
                    Exit(920);
                end;
            end;
        end;

        function try_build_two_single_rescue_segment(const segment_start: Integer;
            out out_text: string; out out_weight: Integer;
            out out_rank_bonus: Integer): Boolean;
        var
            left_text: string;
            right_text: string;
            left_weight: Integer;
            right_weight: Integer;
            left_fixed: string;
            right_fixed: string;
        begin
            Result := False;
            out_text := '';
            out_weight := 0;
            out_rank_bonus := 0;
            if (segment_start < 0) or (segment_start + 1 >= head_syllable_count) or
                (head_syllable_count < c_long_sentence_full_path_min_syllables) then
            begin
                Exit;
            end;

            left_fixed := get_fixed_sentence_single_char(
                normalize_pinyin_text(syllables[segment_start].text));
            right_fixed := get_fixed_sentence_single_char(
                normalize_pinyin_text(syllables[segment_start + 1].text));
            if (left_fixed = '') and (right_fixed = '') then
            begin
                Exit;
            end;

            if should_skip_two_single_rescue_segment(segment_start) then
            begin
                Exit;
            end;

            if (not try_get_best_sentence_single_char(
                normalize_pinyin_text(syllables[segment_start].text), left_text, left_weight)) or
                (not try_get_best_sentence_single_char(
                normalize_pinyin_text(syllables[segment_start + 1].text), right_text, right_weight)) then
            begin
                Exit;
            end;

            out_text := left_text + right_text;
            out_weight := left_weight + right_weight;
            out_rank_bonus := c_light_sentence_two_single_rescue_bonus;
            Result := get_candidate_text_unit_count(out_text) = 2;
        end;

        procedure add_state(var states: TLightSentenceStateArray;
            const candidate_state: TLightSentenceState);
        var
            idx: Integer;
            insert_idx: Integer;
            tmp_state: TLightSentenceState;
        begin
            for idx := 0 to High(states) do
            begin
                if states[idx].path = candidate_state.path then
                begin
                    if candidate_state.score > states[idx].score then
                    begin
                        states[idx] := candidate_state;
                    end;
                    Exit;
                end;
            end;

            insert_idx := Length(states);
            SetLength(states, insert_idx + 1);
            states[insert_idx] := candidate_state;
            while (insert_idx > 0) and (states[insert_idx].score > states[insert_idx - 1].score) do
            begin
                tmp_state := states[insert_idx - 1];
                states[insert_idx - 1] := states[insert_idx];
                states[insert_idx] := tmp_state;
                Dec(insert_idx);
            end;

            if Length(states) > get_light_sentence_beam_width_local then
            begin
                SetLength(states, get_light_sentence_beam_width_local);
            end;
        end;

        procedure append_light_candidate(const text_value: string; const comment_value: string;
            const path_value: string; const score_value: Integer;
            const path_score_hint_value: Integer);
        var
            candidate: TncCandidate;
            next_index: Integer;
        begin
            if Trim(text_value) = '' then
            begin
                Exit;
            end;

            candidate.text := Trim(text_value);
            candidate.comment := Trim(comment_value);
            candidate.score := score_value;
            candidate.source := cs_rule;
            candidate.has_dict_weight := False;
            candidate.dict_weight := 0;

            next_index := Length(out_candidates);
            SetLength(out_candidates, next_index + 1);
            out_candidates[next_index] := candidate;
            remember_segment_path_for_candidate(candidate.text, candidate.comment,
                Trim(path_value), path_score_hint_value);
        end;

        procedure append_intermediate_state_partials;
        const
            c_intermediate_partial_limit = 12;
            c_intermediate_partial_bonus = 220;
            c_fixed_boundary_partial_bonus = 560;
        var
            pos_local: Integer;
            state_idx_local: Integer;
            remaining_key: string;
            state_text: string;
            state_units: Integer;
            emitted_count: Integer;
            duplicate_found: Boolean;
            existing_idx: Integer;
            state_value: TLightSentenceState;
            last_fixed_text: string;
            last_syllable_key: string;
            score_bonus: Integer;
        begin
            if tail_prefix <> '' then
            begin
                Exit;
            end;

            emitted_count := 0;
            for pos_local := head_syllable_count - 1 downto 2 do
            begin
                remaining_key := build_syllable_query_key(pos_local,
                    head_syllable_count - pos_local);
                if remaining_key = '' then
                begin
                    Continue;
                end;

                for state_idx_local := 0 to Min(7, High(state_map[pos_local])) do
                begin
                    state_value := state_map[pos_local][state_idx_local];
                    state_text := Trim(state_value.text);
                    state_units := get_candidate_text_unit_count(state_text);
                    if state_units < 2 then
                    begin
                        Continue;
                    end;

                    duplicate_found := False;
                    for existing_idx := 0 to High(out_candidates) do
                    begin
                        if SameText(Trim(out_candidates[existing_idx].text), state_text) and
                            SameText(normalize_pinyin_text(out_candidates[existing_idx].comment),
                            remaining_key) then
                        begin
                            duplicate_found := True;
                            Break;
                        end;
                    end;
                    if duplicate_found then
                    begin
                        Continue;
                    end;

                    score_bonus := c_intermediate_partial_bonus +
                        ((head_syllable_count - pos_local) * 36);
                    if state_value.last_segment_syllable_count = 1 then
                    begin
                        last_syllable_key := normalize_pinyin_text(
                            syllables[pos_local - 1].text);
                        last_fixed_text := get_fixed_sentence_single_char(
                            last_syllable_key);
                        if (last_fixed_text <> '') and
                            SameText(Trim(state_value.prev_text), last_fixed_text) then
                        begin
                            Inc(score_bonus, c_fixed_boundary_partial_bonus);
                        end;
                    end;

                    append_light_candidate(state_text, remaining_key,
                        state_value.path, state_value.score + score_bonus,
                        state_value.lexical_rank_score + score_bonus);
                    Inc(emitted_count);
                    if emitted_count >= c_intermediate_partial_limit then
                    begin
                        Exit;
                    end;
                end;
            end;
        end;

        function can_predict_one_letter_tail_local(const prefix_value: string): Boolean;
        begin
            Result := (Length(prefix_value) <> 1) or
                SameText(prefix_value, 'w') or SameText(prefix_value, 'h');
        end;

        function try_predict_tail_single_char(const prefix_value: string;
            const prev_prev_text: string; const prev_text: string;
            out out_text: string): Boolean;
        const
            c_tail_completion_keys: array[0..17] of string = (
                'wo', 'he', 'yi', 'yu', 'you', 'yao', 'shi', 'zai', 'bu',
                'le', 'hai', 'hen', 'hui', 'neng', 'qu', 'lai', 'gei', 'de'
            );
        var
            completion_idx: Integer;
            exact_results: TncCandidateList;
            result_idx: Integer;
            completion_key: string;
            candidate_text: string;
            candidate_score: Integer;
            best_score: Integer;
            second_score: Integer;
            is_preferred: Boolean;
        begin
            Result := False;
            out_text := '';
            if prefix_value = '' then
            begin
                Exit;
            end;
            if not can_predict_one_letter_tail_local(prefix_value) then
            begin
                Exit;
            end;

            best_score := Low(Integer);
            second_score := Low(Integer);
            for completion_idx := Low(c_tail_completion_keys) to High(c_tail_completion_keys) do
            begin
                completion_key := c_tail_completion_keys[completion_idx];
                if (Copy(completion_key, 1, Length(prefix_value)) <> prefix_value) then
                begin
                    Continue;
                end;
                if not dictionary_exact_lookup_cached(completion_key, exact_results) then
                begin
                    Continue;
                end;

                for result_idx := 0 to High(exact_results) do
                begin
                    if result_idx >= c_light_sentence_tail_completion_top_n then
                    begin
                        Break;
                    end;
                    candidate_text := Trim(exact_results[result_idx].text);
                    if (get_candidate_text_unit_count(candidate_text) <> 1) or
                        (not match_single_char_candidate_for_syllable(
                        completion_key, candidate_text, is_preferred)) then
                    begin
                        Continue;
                    end;

                    candidate_score := exact_results[result_idx].score;
                    if exact_results[result_idx].has_dict_weight and
                        (exact_results[result_idx].dict_weight > candidate_score) then
                    begin
                        candidate_score := exact_results[result_idx].dict_weight;
                    end;
                    if is_preferred then
                    begin
                        Inc(candidate_score, 60);
                    end;
                    if is_allowed_single_char_for_sentence(candidate_text) then
                    begin
                        Inc(candidate_score, 80);
                    end;
                    if (m_dictionary <> nil) and (prev_text <> '') then
                    begin
                        Inc(candidate_score, get_sentence_context_bonus_scaled(
                            prev_text, candidate_text));
                        if prev_prev_text <> '' then
                        begin
                            Inc(candidate_score, get_sentence_trigram_bonus_scaled(
                                prev_prev_text, prev_text, candidate_text));
                        end;
                    end;

                    if candidate_score > best_score then
                    begin
                        second_score := best_score;
                        best_score := candidate_score;
                        out_text := candidate_text;
                    end
                    else if candidate_score > second_score then
                    begin
                        second_score := candidate_score;
                    end;
                end;
            end;

            Result := (out_text <> '') and
                ((second_score <= Low(Integer) div 4) or ((best_score - second_score) >= 120));
            if not Result then
            begin
                out_text := '';
            end;
        end;

        var
            pos: Integer;
            state_idx: Integer;
        seg_len: Integer;
        next_pos: Integer;
        seg_key: string;
        exact_results: TncCandidateList;
        lookup_results: TncCandidateList;
        exact_lookup_results: TncCandidateList;
        result_idx: Integer;
        merged_result_idx: Integer;
        accepted_count: Integer;
        base_state: TLightSentenceState;
        candidate_state: TLightSentenceState;
        candidate_text: string;
        candidate_units: Integer;
        exact_effective_weight: Integer;
        weak_phrase_penalty: Integer;
        lookahead_bonus: Integer;
        tail_text: string;
        tail_partial_bonus: Integer;
        rescue_text: string;
            rescue_weight: Integer;
            rescue_rank_bonus: Integer;
            top_exact_effective_weight: Integer;
            exact_same_as_rescue: Boolean;
            resolved_segment_text: string;
            resolved_segment_weight: Integer;
            resolved_segment_anchor_units: Integer;
            resolved_inserted: Boolean;
            resolved_candidate: TncCandidate;
            lookbehind_bonus: Integer;
            duplicate_found: Boolean;
    begin
        SetLength(out_candidates, 0);
        Result := False;
        exact_sentence_subspan_cache_prepared := False;
        if (m_dictionary = nil) or (not m_config.enable_segment_candidates) then
        begin
            Exit;
        end;

        normalized_query := normalize_pinyin_text(query_text);
        if normalized_query = '' then
        begin
            Exit;
        end;

        syllables := get_effective_compact_pinyin_syllables(normalized_query);
        if Length(syllables) < 2 then
        begin
            Exit;
        end;

        head_syllable_count := Length(syllables);
        tail_prefix := '';
        if not is_full_pinyin_key(normalize_pinyin_text(syllables[High(syllables)].text)) then
        begin
            tail_prefix := normalize_pinyin_text(syllables[High(syllables)].text);
            Dec(head_syllable_count);
        end;

        if head_syllable_count < 2 then
        begin
            Exit;
        end;
        if (tail_prefix = '') and (head_syllable_count < 4) then
        begin
            Exit;
        end;

        if head_syllable_count >= 8 then
        begin
            max_segment_len := 4;
        end
        else
        begin
            max_segment_len := 3;
        end;

        SetLength(state_map, head_syllable_count + 1);
        SetLength(state_map[0], 1);
        state_map[0][0].score := 0;
        state_map[0][0].lexical_rank_score := 0;
        state_map[0][0].text := '';
        state_map[0][0].path := '';
        state_map[0][0].prev_text := '';
        state_map[0][0].prev_prev_text := '';
        state_map[0][0].last_segment_syllable_count := 0;

        for pos := 0 to head_syllable_count - 1 do
        begin
            for state_idx := 0 to High(state_map[pos]) do
            begin
                base_state := state_map[pos][state_idx];
                for seg_len := 1 to Min(max_segment_len, head_syllable_count - pos) do
                begin
                    seg_key := build_syllable_query_key(pos, seg_len);
                    resolved_inserted := False;
                    resolved_segment_text := '';
                    resolved_segment_weight := 0;
                    resolved_segment_anchor_units := 0;
                    if (seg_len >= 2) and try_resolve_best_exact_sentence_subspan(
                        pos, seg_len, resolved_segment_text, resolved_segment_weight,
                        resolved_segment_anchor_units) then
                    begin
                        FillChar(resolved_candidate, SizeOf(resolved_candidate), 0);
                        resolved_candidate.text := resolved_segment_text;
                        resolved_candidate.comment := '';
                        resolved_candidate.score := resolved_segment_weight;
                        resolved_candidate.source := cs_rule;
                        resolved_candidate.has_dict_weight := True;
                        resolved_candidate.dict_weight := resolved_segment_weight;
                        resolved_inserted := True;
                    end;

                    SetLength(exact_results, 0);
                    if dictionary_lookup_cached(seg_key, lookup_results) then
                    begin
                        SetLength(exact_results, Length(lookup_results));
                        for merged_result_idx := 0 to High(lookup_results) do
                        begin
                            exact_results[merged_result_idx] :=
                                lookup_results[merged_result_idx];
                        end;
                    end;

                    if dictionary_exact_lookup_cached(seg_key, exact_lookup_results) then
                    begin
                        for result_idx := 0 to High(exact_lookup_results) do
                        begin
                            duplicate_found := False;
                            for merged_result_idx := 0 to High(exact_results) do
                            begin
                                if SameText(Trim(exact_results[merged_result_idx].text),
                                    Trim(exact_lookup_results[result_idx].text)) and
                                    SameText(Trim(exact_results[merged_result_idx].comment),
                                    Trim(exact_lookup_results[result_idx].comment)) then
                                begin
                                    duplicate_found := True;
                                    Break;
                                end;
                            end;
                            if duplicate_found then
                            begin
                                Continue;
                            end;
                            SetLength(exact_results, Length(exact_results) + 1);
                            exact_results[High(exact_results)] :=
                                exact_lookup_results[result_idx];
                        end;
                    end;

                    if resolved_inserted then
                    begin
                        duplicate_found := False;
                        for result_idx := 0 to High(exact_results) do
                        begin
                            if SameText(Trim(exact_results[result_idx].text),
                                resolved_candidate.text) then
                            begin
                                duplicate_found := True;
                                Break;
                            end;
                        end;
                        if not duplicate_found then
                        begin
                            SetLength(exact_results, Length(exact_results) + 1);
                            for result_idx := High(exact_results) downto 1 do
                            begin
                                exact_results[result_idx] := exact_results[result_idx - 1];
                            end;
                            exact_results[0] := resolved_candidate;
                        end;
                    end;

                    if Length(exact_results) = 0 then
                    begin
                        Continue;
                    end;

                    accepted_count := 0;
                    top_exact_effective_weight := 0;
                    exact_same_as_rescue := False;
                    next_pos := pos + seg_len;
                    for result_idx := 0 to High(exact_results) do
                    begin
                        if accepted_count >= get_light_sentence_exact_top_n_local then
                        begin
                            Break;
                        end;
                        if not is_allowed_sentence_segment_candidate(
                            exact_results[result_idx], pos, seg_len) then
                        begin
                            Continue;
                        end;

                        candidate_text := Trim(exact_results[result_idx].text);
                        candidate_units := get_candidate_text_unit_count(candidate_text);
                        if exact_results[result_idx].has_dict_weight then
                        begin
                            exact_effective_weight := exact_results[result_idx].dict_weight;
                        end
                        else
                        begin
                            exact_effective_weight := exact_results[result_idx].score;
                        end;
                        Inc(exact_effective_weight,
                            get_preferred_query_phrase_bonus_local(seg_key,
                            candidate_text));
                        if exact_effective_weight > top_exact_effective_weight then
                        begin
                            top_exact_effective_weight := exact_effective_weight;
                        end;
                        candidate_state.score := base_state.score + exact_results[result_idx].score;
                        Inc(candidate_state.score,
                            get_preferred_query_phrase_bonus_local(seg_key,
                            candidate_text));
                        candidate_state.lexical_rank_score := base_state.lexical_rank_score +
                            ((get_light_sentence_exact_top_n_local - result_idx) *
                            c_light_sentence_exact_rank_step);
                        Inc(candidate_state.score,
                            (get_light_sentence_exact_top_n_local - result_idx) *
                            c_light_sentence_exact_rank_step);
                        if base_state.text <> '' then
                        begin
                            Dec(candidate_state.score, c_light_sentence_additional_segment_penalty);
                        end;

                        if candidate_units >= 2 then
                        begin
                            Inc(candidate_state.score, c_light_sentence_multi_bonus + (seg_len * 24));
                            if seg_len >= 3 then
                            begin
                                Inc(candidate_state.score, 560 + ((seg_len - 3) * 160));
                            end;

                            weak_phrase_penalty := get_weak_two_syllable_phrase_penalty(
                                pos, seg_len, candidate_text, exact_effective_weight);
                            if (seg_len = 2) and (candidate_units = 2) and
                                (weak_phrase_penalty >= 760) and
                                (exact_effective_weight <= 360) then
                            begin
                                Continue;
                            end;
                            if weak_phrase_penalty > 0 then
                            begin
                                Dec(candidate_state.score, weak_phrase_penalty);
                            end;

                            weak_phrase_penalty := get_longer_exact_prefix_penalty(
                                pos, seg_len, candidate_text, exact_effective_weight);
                            if weak_phrase_penalty > 0 then
                            begin
                                Dec(candidate_state.score, weak_phrase_penalty);
                            end;

                            weak_phrase_penalty := get_single_plus_following_phrase_penalty(
                                pos, seg_len, candidate_text, exact_effective_weight);
                            if weak_phrase_penalty > 0 then
                            begin
                                Dec(candidate_state.score, weak_phrase_penalty);
                            end;

                            weak_phrase_penalty := get_fixed_boundary_follow_phrase_penalty(
                                pos, seg_len, candidate_text, exact_effective_weight);
                            if weak_phrase_penalty > 0 then
                            begin
                                Dec(candidate_state.score, weak_phrase_penalty);
                            end;
                            Inc(candidate_state.score,
                                get_fixed_boundary_alignment_adjustment(
                                pos, seg_len, candidate_text));

                            lookahead_bonus := get_exact_phrase_lookahead_bonus(
                                pos, seg_len, candidate_text);
                            if lookahead_bonus > 0 then
                            begin
                                Inc(candidate_state.score, lookahead_bonus);
                            end;

                            lookbehind_bonus := get_exact_phrase_lookbehind_bonus(
                                pos, seg_len, candidate_text, exact_effective_weight);
                            if lookbehind_bonus > 0 then
                            begin
                                Inc(candidate_state.score, lookbehind_bonus);
                            end;
                        end
                        else
                        begin
                            Dec(candidate_state.score, c_light_sentence_single_penalty);
                            if get_candidate_text_unit_count(base_state.prev_text) = 1 then
                            begin
                                Dec(candidate_state.score, 240);
                            end;
                            if get_candidate_text_unit_count(base_state.prev_prev_text) = 1 then
                            begin
                                Dec(candidate_state.score, 120);
                            end;
                            if has_exact_merged_phrase_for_recent_transition(base_state, pos, seg_len) then
                            begin
                                Dec(candidate_state.score, 1680);
                            end;
                            if has_exact_merged_phrase_for_single_bridge(base_state, pos, seg_len) then
                            begin
                                Dec(candidate_state.score, 1120);
                            end;

                            lookbehind_bonus := get_exact_phrase_lookbehind_bonus(
                                pos, seg_len, candidate_text, exact_effective_weight);
                            if lookbehind_bonus > 0 then
                            begin
                                Inc(candidate_state.score, lookbehind_bonus);
                            end;
                        end;

                        if (m_dictionary <> nil) and (base_state.prev_text <> '') then
                        begin
                            Inc(candidate_state.score,
                                get_sentence_context_bonus_scaled(
                                base_state.prev_text, candidate_text));
                            if base_state.prev_prev_text <> '' then
                            begin
                                Inc(candidate_state.score,
                                    get_sentence_trigram_bonus_scaled(
                                    base_state.prev_prev_text,
                                    base_state.prev_text, candidate_text));
                            end;
                        end;

                        Inc(candidate_state.score,
                            get_sentence_final_modal_particle_adjustment(
                            seg_key, candidate_text, next_pos = head_syllable_count));

                        if base_state.text <> '' then
                        begin
                            candidate_state.text := base_state.text + candidate_text;
                            candidate_state.path := base_state.path + c_segment_path_separator + candidate_text;
                        end
                        else
                        begin
                            candidate_state.text := candidate_text;
                            candidate_state.path := candidate_text;
                        end;
                        candidate_state.prev_prev_text := base_state.prev_text;
                        candidate_state.prev_text := candidate_text;
                        candidate_state.last_segment_syllable_count := seg_len;
                        add_state(state_map[next_pos], candidate_state);
                        Inc(accepted_count);
                    end;

                    if (seg_len = 2) and
                        try_build_two_single_rescue_segment(pos, rescue_text, rescue_weight,
                        rescue_rank_bonus) and
                        (accepted_count <= 0) then
                    begin
                        for result_idx := 0 to Min(get_light_sentence_exact_top_n_local - 1,
                            High(exact_results)) do
                        begin
                            if SameText(Trim(exact_results[result_idx].text), rescue_text) then
                            begin
                                exact_same_as_rescue := True;
                                Break;
                            end;
                        end;

                        if not exact_same_as_rescue then
                        begin
                            candidate_state.score := base_state.score + rescue_weight;
                            candidate_state.lexical_rank_score := base_state.lexical_rank_score +
                                rescue_rank_bonus;
                            Inc(candidate_state.score, rescue_rank_bonus);
                            if base_state.text <> '' then
                            begin
                                Dec(candidate_state.score, c_light_sentence_additional_segment_penalty);
                            end;
                            Inc(candidate_state.score, c_light_sentence_multi_bonus + (seg_len * 24));

                            if (m_dictionary <> nil) and (base_state.prev_text <> '') then
                            begin
                                Inc(candidate_state.score,
                                    get_sentence_context_bonus_scaled(
                                    base_state.prev_text, rescue_text));
                                if base_state.prev_prev_text <> '' then
                                begin
                                    Inc(candidate_state.score,
                                        get_sentence_trigram_bonus_scaled(
                                        base_state.prev_prev_text,
                                        base_state.prev_text, rescue_text));
                                end;
                            end;

                            lookahead_bonus := get_exact_phrase_lookahead_bonus(
                                pos, seg_len, rescue_text);
                            if lookahead_bonus > 0 then
                            begin
                                Inc(candidate_state.score, lookahead_bonus);
                            end;

                            lookbehind_bonus := get_exact_phrase_lookbehind_bonus(
                                pos, seg_len, rescue_text, rescue_weight);
                            if lookbehind_bonus > 0 then
                            begin
                                Inc(candidate_state.score, lookbehind_bonus);
                            end;

                            if next_pos = head_syllable_count then
                            begin
                                Inc(candidate_state.score, 220);
                            end;
                            Inc(candidate_state.score,
                                get_fixed_boundary_alignment_adjustment(
                                pos, seg_len, rescue_text));

                            if base_state.text <> '' then
                            begin
                                candidate_state.text := base_state.text + rescue_text;
                                candidate_state.path := base_state.path + c_segment_path_separator +
                                    rescue_text;
                            end
                            else
                            begin
                                candidate_state.text := rescue_text;
                                candidate_state.path := rescue_text;
                            end;
                            candidate_state.prev_prev_text := base_state.prev_text;
                            candidate_state.prev_text := rescue_text;
                            candidate_state.last_segment_syllable_count := seg_len;
                            add_state(state_map[next_pos], candidate_state);
                        end;
                    end;
                end;
            end;
        end;

        final_states := state_map[head_syllable_count];
        if Length(final_states) <= 0 then
        begin
            Exit;
        end;

        for state_idx := 0 to Min(get_light_sentence_emit_limit_local - 1, High(final_states)) do
        begin
            append_light_candidate(final_states[state_idx].text, '',
                final_states[state_idx].path, final_states[state_idx].score + 320,
                final_states[state_idx].lexical_rank_score);
        end;

        append_intermediate_state_partials;

        if tail_prefix <> '' then
        begin
            tail_partial_bonus := c_light_sentence_tail_partial_bonus;
            if not can_predict_one_letter_tail_local(tail_prefix) then
            begin
                Inc(tail_partial_bonus, c_light_sentence_tail_prediction_bonus);
            end;
            append_light_candidate(final_states[0].text, tail_prefix,
                final_states[0].path, final_states[0].score + tail_partial_bonus,
                final_states[0].lexical_rank_score);

            tail_text := '';
            if try_predict_tail_single_char(tail_prefix, final_states[0].prev_prev_text,
                final_states[0].prev_text, tail_text) then
            begin
                append_light_candidate(final_states[0].text + tail_text, '',
                    final_states[0].path + c_segment_path_separator + tail_text,
                    final_states[0].score + c_light_sentence_tail_prediction_bonus,
                    final_states[0].lexical_rank_score + c_light_sentence_tail_prediction_bonus);
            end;
        end;

        sort_candidates_lightweight(out_candidates);
        Result := Length(out_candidates) > 0;
    end;

    function build_strict_chunk_oracle_sentence_candidates(
        const query_text: string; out out_candidates: TncCandidateList): Boolean;
    const
        c_enable_nested_oracle: Boolean = False;
        c_oracle_beam_width = 10;
        c_oracle_emit_limit = 4;
        c_oracle_probe_limit = 6;
        c_oracle_max_segment_syllables = 5;
        c_oracle_single_penalty = 420;
        c_oracle_additional_segment_penalty = 140;
        c_oracle_multi_bonus = 360;
        c_oracle_rank_step = 260;
        c_oracle_final_complete_bonus = 480;
        c_oracle_anchor_bonus = 220;
        c_oracle_standalone_match_bonus = 3200;
        c_oracle_standalone_mismatch_penalty = 2400;
    type
        TOracleState = record
            score: Integer;
            text: string;
            path: string;
            prev_text: string;
            prev_prev_text: string;
        end;
        TOracleStateArray = TArray<TOracleState>;
        TOracleSegmentOption = record
            text: string;
            path_text: string;
            score: Integer;
            rank: Integer;
        end;
        TOracleSegmentOptionArray = TArray<TOracleSegmentOption>;
    var
        normalized_query: string;
        syllables_local: TncPinyinParseResult;
        state_map: array of TOracleStateArray;
        final_states: TOracleStateArray;
        head_syllable_count_local: Integer;
        nested_option_states: TDictionary<string, Integer>;
        nested_option_cache: TDictionary<string, TOracleSegmentOptionArray>;
        nested_engine: TncEngine;
        nested_engine_config: TncEngineConfig;

        function build_syllable_query_key_local(const start_idx: Integer;
            const syllable_count_local: Integer): string;
        var
            idx: Integer;
        begin
            Result := '';
            for idx := start_idx to start_idx + syllable_count_local - 1 do
            begin
                Result := Result + normalize_pinyin_text(syllables_local[idx].text);
            end;
        end;

        function get_oracle_context_bonus_local(const left_text: string;
            const right_text: string): Integer;
        begin
            Result := 0;
            if (m_dictionary = nil) or (left_text = '') or (right_text = '') then
            begin
                Exit;
            end;

            Result := m_dictionary.get_context_bonus(left_text, right_text) * 4;
        end;

        function get_oracle_trigram_bonus_local(const left_left_text: string;
            const left_text: string; const right_text: string): Integer;
        begin
            Result := 0;
            if (m_dictionary = nil) or (left_left_text = '') or (left_text = '') or
                (right_text = '') then
            begin
                Exit;
            end;

            Result := m_dictionary.get_context_trigram_bonus(left_left_text,
                left_text, right_text) * 6;
        end;

        function get_fixed_oracle_single_char(
            const syllable_text: string): string;
        var
            normalized_syllable: string;
        begin
            Result := '';
            normalized_syllable := normalize_pinyin_text(syllable_text);
            if normalized_syllable = 'dan' then
            begin
                Result := string(Char($4F46));
            end
            else if normalized_syllable = 'sui' then
            begin
                Result := string(Char($867D));
            end
            else if normalized_syllable = 'er' then
            begin
                Result := string(Char($800C));
            end
            else if normalized_syllable = 'wo' then
            begin
                Result := string(Char($6211));
            end
            else if normalized_syllable = 'ni' then
            begin
                Result := string(Char($4F60));
            end
            else if normalized_syllable = 'ta' then
            begin
                Result := string(Char($4ED6));
            end
            else if normalized_syllable = 'he' then
            begin
                Result := string(Char($548C));
            end
            else if normalized_syllable = 'qu' then
            begin
                Result := string(Char($53BB));
            end
            else if normalized_syllable = 'shi' then
            begin
                Result := string(Char($662F));
            end
            else if normalized_syllable = 'ye' then
            begin
                Result := string(Char($4E5F));
            end
            else if normalized_syllable = 'yu' then
            begin
                Result := string(Char($4E8E));
            end
            else if normalized_syllable = 'de' then
            begin
                Result := string(Char($7684));
            end
            else if normalized_syllable = 'zai' then
            begin
                Result := string(Char($5728));
            end
            else if normalized_syllable = 'ba' then
            begin
                Result := string(Char($628A));
            end
            else if normalized_syllable = 'bei' then
            begin
                Result := string(Char($88AB));
            end
            else if normalized_syllable = 'bing' then
            begin
                Result := string(Char($5E76));
            end
            else if normalized_syllable = 'que' then
            begin
                Result := string(Char($5374));
            end;
        end;

        function segment_has_fixed_oracle_boundary_local(
            const start_idx: Integer; const syllable_count_local: Integer): Boolean;
        var
            unit_idx_local: Integer;
        begin
            Result := False;
            if (start_idx < 0) or (syllable_count_local <= 0) or
                (start_idx + syllable_count_local > head_syllable_count_local) then
            begin
                Exit;
            end;

            for unit_idx_local := 0 to syllable_count_local - 1 do
            begin
                if get_fixed_oracle_single_char(
                    normalize_pinyin_text(
                    syllables_local[start_idx + unit_idx_local].text)) <> '' then
                begin
                    Exit(True);
                end;
            end;
        end;

        function oracle_candidate_respects_fixed_boundaries_local(
            const start_idx: Integer; const syllable_count_local: Integer;
            const text_value: string): Boolean;
        var
            text_units_local: TArray<string>;
            unit_idx_local: Integer;
            expected_char_local: string;
        begin
            Result := False;
            if (start_idx < 0) or (syllable_count_local <= 0) or
                (start_idx + syllable_count_local > head_syllable_count_local) then
            begin
                Exit;
            end;

            text_units_local := split_text_units(Trim(text_value));
            if Length(text_units_local) <> syllable_count_local then
            begin
                Exit;
            end;

            for unit_idx_local := 0 to syllable_count_local - 1 do
            begin
                expected_char_local := get_fixed_oracle_single_char(
                    normalize_pinyin_text(
                    syllables_local[start_idx + unit_idx_local].text));
                if (expected_char_local <> '') and
                    (not SameText(text_units_local[unit_idx_local],
                    expected_char_local)) then
                begin
                    Exit(False);
                end;
            end;

            Result := True;
        end;

        function is_allowed_oracle_single_char(const value: string): Boolean;
        begin
            Result := False;
            if Length(value) <> 1 then
            begin
                Exit;
            end;

            case Ord(value[1]) of
                $6211, $4F60, $4ED6, $5979, $5B83, $4EEC, $548C, $53BB, $6765,
                $5728, $662F, $6709, $8981, $60F3, $4F1A, $80FD, $53EA, $628A, $88AB,
                $8BA9, $7ED9, $5411, $5BF9, $8DDF, $540C, $4ECE, $4E0E, $4E8E, $5C31,
                $4E5F, $90FD, $8FD8, $53C8, $518D, $4E0D, $5F88, $592A, $6700, $5DF2,
                $5C06, $5230, $7684, $4E86, $7740, $8FC7, $4F46, $867D, $800C, $5E76,
                $5374:
                    Result := True;
            end;
        end;

        function is_preferred_oracle_single_char_candidate_local(
            const syllable_key_local: string; const value: string;
            const effective_weight_local: Integer): Boolean;
        const
            c_oracle_single_probe_limit = 8;
            c_oracle_preferred_max_rank = 3;
            c_oracle_top_ratio_pct = 85;
        var
            exact_single_results_local: TncCandidateList;
            idx_local: Integer;
            candidate_text_local: string;
            weight_value_local: Integer;
            top_weight_value_local: Integer;
            single_char_rank_local: Integer;
            fixed_text_local: string;
        begin
            Result := False;
            if (m_dictionary = nil) or (syllable_key_local = '') or
                (Length(Trim(value)) <> 1) then
            begin
                Exit;
            end;

            fixed_text_local := get_fixed_oracle_single_char(syllable_key_local);
            if fixed_text_local <> '' then
            begin
                Exit(SameText(fixed_text_local, value));
            end;

            if not m_dictionary.single_char_matches_pinyin(syllable_key_local,
                value) then
            begin
                Exit(False);
            end;

            if not dictionary_exact_lookup_cached(syllable_key_local,
                exact_single_results_local) then
            begin
                Exit(True);
            end;

            top_weight_value_local := 0;
            single_char_rank_local := 0;
            for idx_local := 0 to High(exact_single_results_local) do
            begin
                if idx_local >= c_oracle_single_probe_limit then
                begin
                    Break;
                end;

                candidate_text_local := Trim(exact_single_results_local[idx_local].text);
                if (candidate_text_local = '') or
                    (Trim(exact_single_results_local[idx_local].comment) <> '') or
                    (get_candidate_text_unit_count(candidate_text_local) <> 1) then
                begin
                    Continue;
                end;

                Inc(single_char_rank_local);
                if exact_single_results_local[idx_local].has_dict_weight then
                begin
                    weight_value_local :=
                        exact_single_results_local[idx_local].dict_weight;
                end
                else
                begin
                    weight_value_local := exact_single_results_local[idx_local].score;
                end;

                if top_weight_value_local <= 0 then
                begin
                    top_weight_value_local := weight_value_local;
                end;

                if not SameText(candidate_text_local, value) then
                begin
                    Continue;
                end;

                Exit((single_char_rank_local <= c_oracle_preferred_max_rank) or
                    (top_weight_value_local <= 0) or
                    ((effective_weight_local * 100) >=
                    (top_weight_value_local * c_oracle_top_ratio_pct)));
            end;
        end;

        function is_extended_allowed_oracle_single_char_local(
            const syllable_key_local: string; const value: string;
            const effective_weight_local: Integer): Boolean;
        const
            c_oracle_extended_single_min_weight = 300;
        var
            fixed_text_local: string;
        begin
            fixed_text_local := get_fixed_oracle_single_char(syllable_key_local);
            if fixed_text_local <> '' then
            begin
                Exit(SameText(fixed_text_local, value));
            end;

            Result := is_allowed_oracle_single_char(value);
            if Result then
            begin
                Exit;
            end;

            if head_syllable_count_local < 8 then
            begin
                Exit(False);
            end;
            if (Length(Trim(value)) <> 1) or
                (effective_weight_local < c_oracle_extended_single_min_weight) then
            begin
                Exit(False);
            end;

            Result := is_preferred_oracle_single_char_candidate_local(
                syllable_key_local, value, effective_weight_local);
        end;

        function normalize_oracle_segment_weight_local(const raw_weight: Integer;
            const syllable_count_local: Integer): Integer;
        begin
            Result := raw_weight;
            if syllable_count_local = 2 then
            begin
                if Result > 240 then
                begin
                    Result := 240 + ((Result - 240) div 10);
                end;
            end;
        end;

        function try_get_best_oracle_standalone_query_candidate_local(
            const query_key_local: string; const expected_syllables_local: Integer;
            out out_text: string; out out_score: Integer): Boolean;
        const
            c_probe_limit_local = 8;
        var
            cached_state_local: Integer;
            snapshot_candidates_local: TncCandidateList;
            snapshot_scores_local: TArray<Integer>;
            candidate_idx_local: Integer;
            candidate_local: TncCandidate;
            candidate_text_local: string;
            candidate_units_local: Integer;
            candidate_score_local: Integer;
            best_text_local: string;
            best_score_local: Integer;
            preferred_exact_bonus_local: Integer;
            preferred_text_local: string;
            preferred_bonus_local: Integer;
            support_score_local: Integer;
            support_segments_local: Integer;
            support_path_local: string;
        begin
            Result := False;
            out_text := '';
            out_score := 0;
            preferred_text_local := '';
            preferred_bonus_local := 0;
            if (query_key_local = '') or
                (not is_full_pinyin_key(query_key_local)) or
                (expected_syllables_local < 2) or
                (expected_syllables_local > 8) or
                (m_disable_subspan_standalone_oracle > 0) then
            begin
                Exit;
            end;

            try_get_preferred_query_phrase_text_local(query_key_local,
                preferred_text_local, preferred_bonus_local);

            if subspan_oracle_states = nil then
            begin
                subspan_oracle_states := TDictionary<string, Integer>.Create;
                subspan_oracle_texts := TDictionary<string, string>.Create;
                subspan_oracle_scores := TDictionary<string, Integer>.Create;
            end;

            if subspan_oracle_states.TryGetValue(query_key_local,
                cached_state_local) then
            begin
                if cached_state_local = 1 then
                begin
                    subspan_oracle_texts.TryGetValue(query_key_local, out_text);
                    subspan_oracle_scores.TryGetValue(query_key_local, out_score);
                    Exit(out_text <> '');
                end;
                Exit(False);
            end;

            if subspan_oracle_budget_remaining <= 0 then
            begin
                Exit;
            end;

            if subspan_oracle_engine = nil then
            begin
                subspan_oracle_config := m_config;
                subspan_oracle_config.debug_mode := False;
                subspan_oracle_config.max_candidates := 6;
                subspan_oracle_engine := TncEngine.Create(subspan_oracle_config);
            end;

            Dec(subspan_oracle_budget_remaining);
            subspan_oracle_states.AddOrSetValue(query_key_local, 3);
            subspan_oracle_engine.m_disable_subspan_standalone_oracle :=
                m_disable_subspan_standalone_oracle + 1;
            subspan_oracle_engine.reset;
            subspan_oracle_engine.m_composition_text := query_key_local;
            subspan_oracle_engine.build_candidates;

            SetLength(snapshot_candidates_local,
                Length(subspan_oracle_engine.m_candidates));
            SetLength(snapshot_scores_local,
                Length(subspan_oracle_engine.m_candidates));
            for candidate_idx_local := 0 to High(subspan_oracle_engine.m_candidates) do
            begin
                snapshot_candidates_local[candidate_idx_local] :=
                    subspan_oracle_engine.m_candidates[candidate_idx_local];
                snapshot_scores_local[candidate_idx_local] :=
                    subspan_oracle_engine.get_rank_score(
                    subspan_oracle_engine.m_candidates[candidate_idx_local]);
            end;

            best_text_local := '';
            best_score_local := Low(Integer);
            for candidate_idx_local := 0 to High(snapshot_candidates_local) do
            begin
                if candidate_idx_local >= c_probe_limit_local then
                begin
                    Break;
                end;

                candidate_local := snapshot_candidates_local[candidate_idx_local];
                if Trim(candidate_local.comment) <> '' then
                begin
                    Continue;
                end;

                candidate_text_local := Trim(candidate_local.text);
                candidate_units_local := get_candidate_text_unit_count(
                    candidate_text_local);
                if candidate_units_local <> expected_syllables_local then
                begin
                    Continue;
                end;

                candidate_score_local :=
                    snapshot_scores_local[candidate_idx_local] +
                    get_preferred_query_phrase_bonus_local(query_key_local,
                    candidate_text_local);
                preferred_exact_bonus_local :=
                    get_preferred_exact_subspan_bonus_local(query_key_local,
                    candidate_text_local);
                if preferred_exact_bonus_local > 0 then
                begin
                    Inc(candidate_score_local,
                        preferred_exact_bonus_local + 12000);
                end;
                support_path_local := infer_segment_path_for_query_text_with_score(
                    query_key_local, candidate_text_local, support_score_local,
                    support_segments_local);
                if support_path_local <> '' then
                begin
                    Inc(candidate_score_local, support_score_local);
                    Inc(candidate_score_local,
                        Max(0, 2048 - (support_segments_local * 128)));
                end
                else
                begin
                    Dec(candidate_score_local, 2048);
                end;

                if candidate_score_local > best_score_local then
                begin
                    best_score_local := candidate_score_local;
                    best_text_local := candidate_text_local;
                end;
            end;

            if best_text_local <> '' then
            begin
                out_text := best_text_local;
                out_score := best_score_local;
                subspan_oracle_states.AddOrSetValue(query_key_local, 1);
                subspan_oracle_texts.AddOrSetValue(query_key_local, out_text);
                subspan_oracle_scores.AddOrSetValue(query_key_local, out_score);
                Exit(True);
            end;

            subspan_oracle_states.AddOrSetValue(query_key_local, 2);
        end;

        function is_oracle_segment_option_better_local(
            const left_option: TOracleSegmentOption;
            const right_option: TOracleSegmentOption): Boolean;
        begin
            Result := False;
            if left_option.score > right_option.score then
            begin
                Exit(True);
            end;
            if left_option.score < right_option.score then
            begin
                Exit(False);
            end;
            if left_option.rank < right_option.rank then
            begin
                Exit(True);
            end;
            if left_option.rank > right_option.rank then
            begin
                Exit(False);
            end;
            if (left_option.text <> '') and
                ((right_option.text = '') or
                (CompareText(left_option.text, right_option.text) < 0)) then
            begin
                Exit(True);
            end;
        end;

        procedure add_oracle_segment_option_local(
            var options: TOracleSegmentOptionArray;
            const option_value: TOracleSegmentOption);
        const
            c_nested_emit_limit = 4;
        var
            option_idx_local: Integer;
            insert_idx_local: Integer;
            tmp_option_local: TOracleSegmentOption;
        begin
            if Trim(option_value.text) = '' then
            begin
                Exit;
            end;

            for option_idx_local := 0 to High(options) do
            begin
                if SameText(options[option_idx_local].text, option_value.text) then
                begin
                    if is_oracle_segment_option_better_local(option_value,
                        options[option_idx_local]) then
                    begin
                        options[option_idx_local] := option_value;
                    end;
                    Exit;
                end;
            end;

            insert_idx_local := Length(options);
            SetLength(options, insert_idx_local + 1);
            options[insert_idx_local] := option_value;
            while (insert_idx_local > 0) and
                is_oracle_segment_option_better_local(options[insert_idx_local],
                options[insert_idx_local - 1]) do
            begin
                tmp_option_local := options[insert_idx_local - 1];
                options[insert_idx_local - 1] := options[insert_idx_local];
                options[insert_idx_local] := tmp_option_local;
                Dec(insert_idx_local);
            end;

            if Length(options) > c_nested_emit_limit then
            begin
                SetLength(options, c_nested_emit_limit);
            end;
        end;

        function collect_nested_oracle_segment_options_local(
            const query_key_local: string; const expected_units_local: Integer;
            out out_options: TOracleSegmentOptionArray): Boolean;
        const
            c_nested_probe_limit = 8;
        var
            cache_state_local: Integer;
            candidate_idx_local: Integer;
            nested_candidate_local: TncCandidate;
            candidate_text_local: string;
            candidate_units_local: Integer;
            candidate_rank_score_local: Integer;
            option_local: TOracleSegmentOption;
            path_text_local: string;
        begin
            SetLength(out_options, 0);
            if not c_enable_nested_oracle then
            begin
                Exit(False);
            end;
            if (query_key_local = '') or (expected_units_local < 2) then
            begin
                Exit(False);
            end;

            if nested_option_states.TryGetValue(query_key_local, cache_state_local) then
            begin
                if (cache_state_local = 1) and
                    nested_option_cache.TryGetValue(query_key_local, out_options) then
                begin
                    Exit(Length(out_options) > 0);
                end;
                Exit(False);
            end;

            if nested_engine = nil then
            begin
                nested_engine_config := m_config;
                nested_engine_config.debug_mode := False;
                nested_engine := TncEngine.Create(nested_engine_config);
                nested_engine.m_disable_subspan_standalone_oracle :=
                    m_disable_subspan_standalone_oracle + 1;
            end;

            nested_engine.m_composition_text := query_key_local;
            nested_engine.build_candidates;

            for candidate_idx_local := 0 to High(nested_engine.m_candidates) do
            begin
                if candidate_idx_local >= c_nested_probe_limit then
                begin
                    Break;
                end;

                nested_candidate_local := nested_engine.m_candidates[candidate_idx_local];
                if Trim(nested_candidate_local.comment) <> '' then
                begin
                    Continue;
                end;
                if nested_engine.is_runtime_chain_candidate(nested_candidate_local) or
                    nested_engine.is_runtime_common_pattern_candidate(
                    nested_candidate_local) or
                    nested_engine.is_runtime_redup_candidate(nested_candidate_local) then
                begin
                    Continue;
                end;

                candidate_text_local := Trim(nested_candidate_local.text);
                if candidate_text_local = '' then
                begin
                    Continue;
                end;
                candidate_units_local := get_candidate_text_unit_count(
                    candidate_text_local);
                if candidate_units_local <> expected_units_local then
                begin
                    Continue;
                end;

                candidate_rank_score_local :=
                    nested_engine.get_rank_score(nested_candidate_local);
                if candidate_rank_score_local < 0 then
                begin
                    candidate_rank_score_local := 0;
                end;
                candidate_rank_score_local := normalize_oracle_segment_weight_local(
                    Max(120, candidate_rank_score_local div 48),
                    expected_units_local);
                Inc(candidate_rank_score_local,
                    (c_nested_probe_limit - candidate_idx_local) *
                    (c_oracle_rank_step div 2));
                if expected_units_local >= 3 then
                begin
                    Inc(candidate_rank_score_local, 96);
                end;

                path_text_local := nested_engine.get_segment_path_for_candidate(
                    nested_candidate_local, candidate_idx_local);
                if Trim(path_text_local) = '' then
                begin
                    path_text_local := candidate_text_local;
                end;

                option_local := Default(TOracleSegmentOption);
                option_local.text := candidate_text_local;
                option_local.path_text := path_text_local;
                option_local.score := candidate_rank_score_local;
                option_local.rank := candidate_idx_local;
                add_oracle_segment_option_local(out_options, option_local);
            end;

            if Length(out_options) > 0 then
            begin
                nested_option_states.AddOrSetValue(query_key_local, 1);
                nested_option_cache.AddOrSetValue(query_key_local,
                    Copy(out_options));
                Exit(True);
            end;

            nested_option_states.AddOrSetValue(query_key_local, 2);
            Result := False;
        end;

        procedure add_state(var states: TOracleStateArray;
            const candidate_state: TOracleState);
        var
            idx: Integer;
            insert_idx: Integer;
            tmp_state: TOracleState;
        begin
            for idx := 0 to High(states) do
            begin
                if states[idx].path = candidate_state.path then
                begin
                    if candidate_state.score > states[idx].score then
                    begin
                        states[idx] := candidate_state;
                    end;
                    Exit;
                end;
            end;

            insert_idx := Length(states);
            SetLength(states, insert_idx + 1);
            states[insert_idx] := candidate_state;
            while (insert_idx > 0) and
                (states[insert_idx].score > states[insert_idx - 1].score) do
            begin
                tmp_state := states[insert_idx - 1];
                states[insert_idx - 1] := states[insert_idx];
                states[insert_idx] := tmp_state;
                Dec(insert_idx);
            end;

            if Length(states) > c_oracle_beam_width then
            begin
                SetLength(states, c_oracle_beam_width);
            end;
        end;

        procedure append_oracle_candidate(const text_value: string;
            const path_value: string; const score_value: Integer);
        var
            candidate: TncCandidate;
            next_index: Integer;
        begin
            if Trim(text_value) = '' then
            begin
                Exit;
            end;

            candidate.text := Trim(text_value);
            candidate.comment := '';
            candidate.score := score_value;
            candidate.source := cs_rule;
            candidate.has_dict_weight := False;
            candidate.dict_weight := 0;

            next_index := Length(out_candidates);
            SetLength(out_candidates, next_index + 1);
            out_candidates[next_index] := candidate;
            remember_segment_path_for_candidate(candidate.text, '',
                Trim(path_value), score_value);
        end;

    var
        pos: Integer;
        seg_len: Integer;
        next_pos: Integer;
        state_idx: Integer;
        base_state: TOracleState;
        candidate_state: TOracleState;
        seg_key: string;
        fixed_text: string;
        single_results: TncCandidateList;
        lookup_results: TncCandidateList;
        exact_results: TncCandidateList;
        merged_results: TncCandidateList;
        exact_idx: Integer;
        merged_idx: Integer;
        duplicate_found: Boolean;
        candidate_text: string;
        candidate_units: Integer;
        effective_weight: Integer;
        result_idx: Integer;
        resolved_text_local: string;
        resolved_score_local: Integer;
        resolved_segments_local: Integer;
        resolved_path_local: string;
        resolved_has_anchor_local: Boolean;
        resolved_anchor_units_local: Integer;
        resolved_chunk_text_local: string;
        resolved_chunk_valid_local: Boolean;
        prefer_resolved_chunk_local: Boolean;
        allow_raw_merged_local: Boolean;
        nested_segment_options_local: TOracleSegmentOptionArray;
        nested_option_idx_local: Integer;
        nested_option_local: TOracleSegmentOption;
        standalone_query_text_local: string;
        standalone_query_score_local: Integer;
        standalone_query_candidate_local: TncCandidate;
        standalone_query_valid_local: Boolean;
    begin
        SetLength(out_candidates, 0);
        Result := False;
        nested_option_states := nil;
        nested_option_cache := nil;
        nested_engine := nil;
        if m_dictionary = nil then
        begin
            Exit;
        end;

        normalized_query := normalize_pinyin_text(query_text);
        if (normalized_query = '') or (not is_full_pinyin_key(normalized_query)) then
        begin
            Exit;
        end;

        syllables_local := get_effective_compact_pinyin_syllables(normalized_query);
        head_syllable_count_local := Length(syllables_local);
        if head_syllable_count_local < 4 then
        begin
            Exit;
        end;

        if c_enable_nested_oracle then
        begin
            nested_option_states := TDictionary<string, Integer>.Create;
            nested_option_cache := TDictionary<string, TOracleSegmentOptionArray>.Create;
        end;
        try
        SetLength(state_map, head_syllable_count_local + 1);
        SetLength(state_map[0], 1);
        state_map[0][0].score := 0;
        state_map[0][0].text := '';
        state_map[0][0].path := '';
        state_map[0][0].prev_text := '';
        state_map[0][0].prev_prev_text := '';

        for pos := 0 to head_syllable_count_local - 1 do
        begin
            for state_idx := 0 to High(state_map[pos]) do
            begin
                base_state := state_map[pos][state_idx];

                seg_key := normalize_pinyin_text(syllables_local[pos].text);
                fixed_text := get_fixed_oracle_single_char(seg_key);
                if fixed_text <> '' then
                begin
                    candidate_state.score := base_state.score + 960 -
                        c_oracle_single_penalty;
                    if base_state.text <> '' then
                    begin
                        Dec(candidate_state.score,
                            c_oracle_additional_segment_penalty);
                        Inc(candidate_state.score,
                            get_oracle_context_bonus_local(base_state.prev_text,
                            fixed_text));
                        if base_state.prev_prev_text <> '' then
                        begin
                            Inc(candidate_state.score,
                                get_oracle_trigram_bonus_local(
                                base_state.prev_prev_text,
                                base_state.prev_text, fixed_text));
                        end;
                        candidate_state.text := base_state.text + fixed_text;
                        candidate_state.path := base_state.path +
                            c_segment_path_separator + fixed_text;
                    end
                    else
                    begin
                        candidate_state.text := fixed_text;
                        candidate_state.path := fixed_text;
                    end;
                    candidate_state.prev_prev_text := base_state.prev_text;
                    candidate_state.prev_text := fixed_text;
                    add_state(state_map[pos + 1], candidate_state);
                end
                else if dictionary_exact_lookup_cached(seg_key, single_results) then
                begin
                    for result_idx := 0 to Min(c_oracle_probe_limit - 1,
                        High(single_results)) do
                    begin
                        if Trim(single_results[result_idx].comment) <> '' then
                        begin
                            Continue;
                        end;
                        candidate_text := Trim(single_results[result_idx].text);
                        if get_candidate_text_unit_count(candidate_text) <> 1 then
                        begin
                            Continue;
                        end;

                        effective_weight := single_results[result_idx].score;
                        if single_results[result_idx].has_dict_weight and
                            (single_results[result_idx].dict_weight >
                            effective_weight) then
                        begin
                            effective_weight := single_results[result_idx].dict_weight;
                        end;
                        if not is_extended_allowed_oracle_single_char_local(
                            seg_key, candidate_text, effective_weight) then
                        begin
                            Continue;
                        end;

                        candidate_state.score := base_state.score + effective_weight -
                            c_oracle_single_penalty;
                        if base_state.text <> '' then
                        begin
                            Dec(candidate_state.score,
                                c_oracle_additional_segment_penalty);
                            Inc(candidate_state.score,
                                get_oracle_context_bonus_local(base_state.prev_text,
                                candidate_text));
                            if base_state.prev_prev_text <> '' then
                            begin
                                Inc(candidate_state.score,
                                    get_oracle_trigram_bonus_local(
                                    base_state.prev_prev_text,
                                    base_state.prev_text, candidate_text));
                            end;
                            candidate_state.text := base_state.text + candidate_text;
                            candidate_state.path := base_state.path +
                                c_segment_path_separator + candidate_text;
                        end
                        else
                        begin
                            candidate_state.text := candidate_text;
                            candidate_state.path := candidate_text;
                        end;
                        candidate_state.prev_prev_text := base_state.prev_text;
                        candidate_state.prev_text := candidate_text;
                        add_state(state_map[pos + 1], candidate_state);
                    end;
                end;

                for seg_len := 2 to Min(c_oracle_max_segment_syllables,
                    head_syllable_count_local - pos) do
                begin
                    seg_key := build_syllable_query_key_local(pos, seg_len);
                    if seg_key = '' then
                    begin
                        Continue;
                    end;

                    resolved_chunk_text_local := '';
                    resolved_chunk_valid_local := False;
                    if try_resolve_best_exact_subspan_local(pos, seg_len,
                        resolved_text_local, resolved_score_local,
                        resolved_segments_local, resolved_path_local,
                        resolved_has_anchor_local,
                        resolved_anchor_units_local) then
                    begin
                        candidate_text := Trim(resolved_text_local);
                        candidate_units := get_candidate_text_unit_count(
                            candidate_text);
                        if (candidate_text <> '') and
                            (candidate_units = seg_len) then
                        begin
                            prefer_resolved_chunk_local :=
                                (seg_len >= 3) or resolved_has_anchor_local or
                                (resolved_segments_local > 1);
                            if prefer_resolved_chunk_local then
                            begin
                                next_pos := pos + seg_len;
                                candidate_state.score := base_state.score +
                                    resolved_score_local + c_oracle_multi_bonus +
                                    (seg_len * c_oracle_rank_step);
                                if resolved_segments_local > 1 then
                                begin
                                    Dec(candidate_state.score,
                                        (resolved_segments_local - 1) *
                                        (c_oracle_additional_segment_penalty div 2));
                                end;
                                if base_state.text <> '' then
                                begin
                                    Dec(candidate_state.score,
                                        c_oracle_additional_segment_penalty);
                                    Inc(candidate_state.score,
                                        get_oracle_context_bonus_local(
                                        base_state.prev_text, candidate_text));
                                    if base_state.prev_prev_text <> '' then
                                    begin
                                        Inc(candidate_state.score,
                                            get_oracle_trigram_bonus_local(
                                            base_state.prev_prev_text,
                                            base_state.prev_text, candidate_text));
                                    end;
                                    candidate_state.text := base_state.text +
                                        candidate_text;
                                    if Trim(resolved_path_local) <> '' then
                                    begin
                                        candidate_state.path := base_state.path +
                                            c_segment_path_separator +
                                            Trim(resolved_path_local);
                                    end
                                    else
                                    begin
                                        candidate_state.path := base_state.path +
                                            c_segment_path_separator +
                                            candidate_text;
                                    end;
                                end
                                else
                                begin
                                    candidate_state.text := candidate_text;
                                    if Trim(resolved_path_local) <> '' then
                                    begin
                                        candidate_state.path := Trim(
                                            resolved_path_local);
                                    end
                                    else
                                    begin
                                        candidate_state.path := candidate_text;
                                    end;
                                end;
                                if resolved_has_anchor_local or
                                    (seg_len >= 3) then
                                begin
                                    Inc(candidate_state.score,
                                        c_oracle_anchor_bonus);
                                end;
                                candidate_state.prev_prev_text := base_state.prev_text;
                                candidate_state.prev_text := candidate_text;
                                add_state(state_map[next_pos], candidate_state);
                                resolved_chunk_text_local := candidate_text;
                                resolved_chunk_valid_local := True;
                            end;
                        end;
                    end;

                    SetLength(merged_results, 0);
                    if dictionary_lookup_cached(seg_key, lookup_results) then
                    begin
                        SetLength(merged_results, Length(lookup_results));
                        for merged_idx := 0 to High(lookup_results) do
                        begin
                            merged_results[merged_idx] := lookup_results[merged_idx];
                        end;
                    end;

                    if dictionary_exact_lookup_cached(seg_key, exact_results) then
                    begin
                        for exact_idx := 0 to High(exact_results) do
                        begin
                            duplicate_found := False;
                            for merged_idx := 0 to High(merged_results) do
                            begin
                                if SameText(Trim(merged_results[merged_idx].text),
                                    Trim(exact_results[exact_idx].text)) and
                                    SameText(Trim(merged_results[merged_idx].comment),
                                    Trim(exact_results[exact_idx].comment)) then
                                begin
                                    duplicate_found := True;
                                    Break;
                                end;
                            end;
                            if duplicate_found then
                            begin
                                Continue;
                            end;
                            SetLength(merged_results, Length(merged_results) + 1);
                            merged_results[High(merged_results)] := exact_results[exact_idx];
                        end;
                    end;

                    if Length(merged_results) <= 0 then
                    begin
                        SetLength(merged_results, 0);
                    end;

                    standalone_query_valid_local := False;
                    if (seg_len <= 5) and (head_syllable_count_local >= 6) and
                        try_get_best_oracle_standalone_query_candidate_local(
                        seg_key, seg_len, standalone_query_text_local,
                        standalone_query_score_local) and
                        (standalone_query_text_local <> '') then
                    begin
                        standalone_query_valid_local :=
                            oracle_candidate_respects_fixed_boundaries_local(
                            pos, seg_len, standalone_query_text_local);
                        if standalone_query_valid_local then
                        begin
                            duplicate_found := False;
                            for merged_idx := 0 to High(merged_results) do
                            begin
                                if SameText(
                                    Trim(merged_results[merged_idx].text),
                                    standalone_query_text_local) then
                                begin
                                    duplicate_found := True;
                                    Break;
                                end;
                            end;

                            if not duplicate_found then
                            begin
                                FillChar(standalone_query_candidate_local,
                                    SizeOf(standalone_query_candidate_local), 0);
                                standalone_query_candidate_local.text :=
                                    standalone_query_text_local;
                                standalone_query_candidate_local.comment := '';
                                standalone_query_candidate_local.score :=
                                    standalone_query_score_local;
                                standalone_query_candidate_local.source := cs_rule;
                                standalone_query_candidate_local.has_dict_weight := True;
                                standalone_query_candidate_local.dict_weight :=
                                    standalone_query_score_local;
                                SetLength(merged_results, Length(merged_results) + 1);
                                for merged_idx := High(merged_results) downto 1 do
                                begin
                                    merged_results[merged_idx] :=
                                        merged_results[merged_idx - 1];
                                end;
                                merged_results[0] :=
                                    standalone_query_candidate_local;
                            end;
                        end;
                    end;

                    allow_raw_merged_local := True;
                    if head_syllable_count_local >= 8 then
                    begin
                        if resolved_chunk_valid_local then
                        begin
                            allow_raw_merged_local := False;
                        end
                        else if seg_len >= 4 then
                        begin
                            allow_raw_merged_local := False;
                        end;
                    end;
                    if standalone_query_valid_local and
                        ((seg_len >= 4) or
                        (standalone_query_score_local >= 24000)) then
                    begin
                        allow_raw_merged_local := False;
                    end;

                    if standalone_query_valid_local then
                    begin
                        next_pos := pos + seg_len;
                        candidate_state.score := base_state.score +
                            standalone_query_score_local + c_oracle_multi_bonus +
                            (seg_len * c_oracle_rank_step) +
                            c_oracle_standalone_match_bonus;
                        if base_state.text <> '' then
                        begin
                            Dec(candidate_state.score,
                                c_oracle_additional_segment_penalty);
                            Inc(candidate_state.score,
                                get_oracle_context_bonus_local(
                                base_state.prev_text,
                                standalone_query_text_local));
                            if base_state.prev_prev_text <> '' then
                            begin
                                Inc(candidate_state.score,
                                    get_oracle_trigram_bonus_local(
                                    base_state.prev_prev_text,
                                    base_state.prev_text,
                                    standalone_query_text_local));
                            end;
                            candidate_state.text := base_state.text +
                                standalone_query_text_local;
                            candidate_state.path := base_state.path +
                                c_segment_path_separator +
                                standalone_query_text_local;
                        end
                        else
                        begin
                            candidate_state.text := standalone_query_text_local;
                            candidate_state.path := standalone_query_text_local;
                        end;
                        if seg_len >= 3 then
                        begin
                            Inc(candidate_state.score, c_oracle_anchor_bonus);
                        end;
                        candidate_state.prev_prev_text := base_state.prev_text;
                        candidate_state.prev_text := standalone_query_text_local;
                        add_state(state_map[next_pos], candidate_state);
                    end;

                    if c_enable_nested_oracle and
                        ((seg_len >= 3) or
                        segment_has_fixed_oracle_boundary_local(pos, seg_len)) and
                        collect_nested_oracle_segment_options_local(seg_key, seg_len,
                        nested_segment_options_local) then
                    begin
                        next_pos := pos + seg_len;
                        for nested_option_idx_local := 0 to High(
                            nested_segment_options_local) do
                        begin
                            nested_option_local := nested_segment_options_local[
                                nested_option_idx_local];
                            if Trim(nested_option_local.text) = '' then
                            begin
                                Continue;
                            end;
                            if resolved_chunk_valid_local and SameText(
                                nested_option_local.text,
                                resolved_chunk_text_local) then
                            begin
                                Continue;
                            end;

                            candidate_state.score := base_state.score +
                                nested_option_local.score + c_oracle_multi_bonus +
                                ((c_oracle_probe_limit - Min(
                                nested_option_local.rank, c_oracle_probe_limit - 1)) *
                                c_oracle_rank_step);
                            if base_state.text <> '' then
                            begin
                                Dec(candidate_state.score,
                                    c_oracle_additional_segment_penalty);
                                Inc(candidate_state.score,
                                    get_oracle_context_bonus_local(
                                    base_state.prev_text,
                                    nested_option_local.text));
                                if base_state.prev_prev_text <> '' then
                                begin
                                    Inc(candidate_state.score,
                                        get_oracle_trigram_bonus_local(
                                        base_state.prev_prev_text,
                                        base_state.prev_text,
                                        nested_option_local.text));
                                end;
                                candidate_state.text := base_state.text +
                                    nested_option_local.text;
                                candidate_state.path := base_state.path +
                                    c_segment_path_separator +
                                    nested_option_local.path_text;
                            end
                            else
                            begin
                                candidate_state.text := nested_option_local.text;
                                candidate_state.path := nested_option_local.path_text;
                            end;
                            if seg_len >= 3 then
                            begin
                                Inc(candidate_state.score, c_oracle_anchor_bonus);
                            end;
                            candidate_state.prev_prev_text := base_state.prev_text;
                            candidate_state.prev_text := nested_option_local.text;
                            add_state(state_map[next_pos], candidate_state);
                        end;
                    end;

                    if allow_raw_merged_local and (Length(merged_results) > 0) then
                    begin
                        next_pos := pos + seg_len;
                        for result_idx := 0 to Min(c_oracle_probe_limit - 1,
                            High(merged_results)) do
                        begin
                            if Trim(merged_results[result_idx].comment) <> '' then
                            begin
                                Continue;
                            end;
                            if is_runtime_chain_candidate(
                                merged_results[result_idx]) or
                                is_runtime_common_pattern_candidate(
                                merged_results[result_idx]) or
                                is_runtime_redup_candidate(
                                merged_results[result_idx]) then
                            begin
                                Continue;
                            end;

                            candidate_text := Trim(merged_results[result_idx].text);
                            candidate_units := get_candidate_text_unit_count(
                                candidate_text);
                            if candidate_units < 2 then
                            begin
                                Continue;
                            end;
                            if resolved_chunk_valid_local and
                                SameText(candidate_text, resolved_chunk_text_local) then
                            begin
                                Continue;
                            end;

                            effective_weight := merged_results[result_idx].score;
                            if merged_results[result_idx].has_dict_weight and
                                (merged_results[result_idx].dict_weight >
                                effective_weight) then
                            begin
                                effective_weight :=
                                    merged_results[result_idx].dict_weight;
                            end;
                            effective_weight :=
                                normalize_oracle_segment_weight_local(
                                effective_weight, seg_len);
                            Inc(effective_weight,
                                get_preferred_query_phrase_bonus_local(seg_key,
                                candidate_text));
                            if standalone_query_valid_local then
                            begin
                                if SameText(candidate_text,
                                    standalone_query_text_local) then
                                begin
                                    Inc(effective_weight,
                                        c_oracle_standalone_match_bonus);
                                end
                                else if seg_len <= 5 then
                                begin
                                    Dec(effective_weight,
                                        c_oracle_standalone_mismatch_penalty *
                                        IfThen(seg_len >= 4, 2, 1));
                                end;
                            end;

                            candidate_state.score := base_state.score +
                                effective_weight + c_oracle_multi_bonus +
                                ((c_oracle_probe_limit - result_idx) *
                                c_oracle_rank_step);
                            if base_state.text <> '' then
                            begin
                                Dec(candidate_state.score,
                                    c_oracle_additional_segment_penalty);
                                Inc(candidate_state.score,
                                    get_oracle_context_bonus_local(
                                    base_state.prev_text, candidate_text));
                                if base_state.prev_prev_text <> '' then
                                begin
                                    Inc(candidate_state.score,
                                        get_oracle_trigram_bonus_local(
                                        base_state.prev_prev_text,
                                        base_state.prev_text, candidate_text));
                                end;
                                candidate_state.text := base_state.text +
                                    candidate_text;
                                candidate_state.path := base_state.path +
                                    c_segment_path_separator + candidate_text;
                            end
                            else
                            begin
                                candidate_state.text := candidate_text;
                                candidate_state.path := candidate_text;
                            end;
                            if seg_len >= 3 then
                            begin
                                Inc(candidate_state.score,
                                    c_oracle_anchor_bonus);
                            end;
                            candidate_state.prev_prev_text := base_state.prev_text;
                            candidate_state.prev_text := candidate_text;
                            add_state(state_map[next_pos], candidate_state);
                        end;
                    end;
                end;
            end;
        end;

        final_states := state_map[head_syllable_count_local];
        if Length(final_states) <= 0 then
        begin
            Exit;
        end;

        for state_idx := 0 to Min(c_oracle_emit_limit - 1, High(final_states)) do
        begin
            append_oracle_candidate(final_states[state_idx].text,
                final_states[state_idx].path,
                final_states[state_idx].score + c_oracle_final_complete_bonus);
        end;

        sort_candidates_lightweight(out_candidates);
        Result := Length(out_candidates) > 0;
        finally
            nested_engine.Free;
            nested_option_cache.Free;
            nested_option_states.Free;
        end;
    end;

    function build_exact_head_partial_candidates(const query_text: string;
        out out_candidates: TncCandidateList): Boolean;
    const
        c_head_partial_limit = 6;
        c_head_partial_bonus = 160;
    var
        normalized_query: string;
        syllables_local: TncPinyinParseResult;
        head_key: string;
        tail_comment: string;
        idx: Integer;
        head_results: TncCandidateList;
        candidate: TncCandidate;
        accepted_count: Integer;
    begin
        SetLength(out_candidates, 0);
        Result := False;
        if m_dictionary = nil then
        begin
            Exit;
        end;

        normalized_query := normalize_pinyin_text(query_text);
        if normalized_query = '' then
        begin
            Exit;
        end;

        syllables_local := get_effective_compact_pinyin_syllables(normalized_query);
        if Length(syllables_local) < 2 then
        begin
            Exit;
        end;

        tail_comment := normalize_pinyin_text(syllables_local[High(syllables_local)].text);
        if (tail_comment = '') or (not is_full_pinyin_key(tail_comment)) then
        begin
            Exit;
        end;

        head_key := '';
        for idx := 0 to High(syllables_local) - 1 do
        begin
            head_key := head_key + normalize_pinyin_text(syllables_local[idx].text);
        end;
        if head_key = '' then
        begin
            Exit;
        end;

        if not dictionary_exact_lookup_cached(head_key, head_results) then
        begin
            Exit;
        end;

        accepted_count := 0;
        for idx := 0 to High(head_results) do
        begin
            if accepted_count >= c_head_partial_limit then
            begin
                Break;
            end;
            if Trim(head_results[idx].comment) <> '' then
            begin
                Continue;
            end;
            candidate := head_results[idx];
            candidate.comment := tail_comment;
            Inc(candidate.score, c_head_partial_bonus);
            if candidate.dict_weight <= 0 then
            begin
                candidate.dict_weight := candidate.score;
            end;
            candidate.has_dict_weight := True;
            SetLength(out_candidates, Length(out_candidates) + 1);
            out_candidates[High(out_candidates)] := candidate;
            Inc(accepted_count);
        end;

        sort_candidates_lightweight(out_candidates);
        Result := Length(out_candidates) > 0;
    end;

    function build_exact_leading_prefix_partial_candidates(const query_text: string;
        out out_candidates: TncCandidateList): Boolean;
    const
        c_prefix_total_limit = 24;
        c_prefix_single_limit = 14;
        c_prefix_phrase_limit = 4;
        c_prefix_base_bonus = 220;
        c_prefix_bonus_per_syllable = 180;
        c_prefix_remaining_penalty = 42;
        c_prefix_max_syllables = 3;
        c_prefix_phrase_extra_bonus = 520;
        c_prefix_short_query_phrase_bonus = 260;
    var
        normalized_query: string;
        syllables_local: TncPinyinParseResult;
        prefix_count: Integer;
        tail_idx: Integer;
        result_idx: Integer;
        accepted_total: Integer;
        accepted_for_prefix: Integer;
        accepted_limit: Integer;
        prefix_key: string;
        tail_comment: string;
        head_results: TncCandidateList;
        candidate: TncCandidate;
        candidate_text: string;
        candidate_units: Integer;
        seen_key: string;
        seen: TDictionary<string, Byte>;
    begin
        SetLength(out_candidates, 0);
        Result := False;
        if m_dictionary = nil then
        begin
            Exit;
        end;

        normalized_query := normalize_pinyin_text(query_text);
        if normalized_query = '' then
        begin
            Exit;
        end;

        syllables_local := get_effective_compact_pinyin_syllables(normalized_query);
        if Length(syllables_local) < 2 then
        begin
            Exit;
        end;

        seen := TDictionary<string, Byte>.Create;
        try
            accepted_total := 0;
            prefix_key := '';
            for prefix_count := 1 to Min(c_prefix_max_syllables,
                Length(syllables_local) - 1) do
            begin
                prefix_key := prefix_key +
                    normalize_pinyin_text(syllables_local[prefix_count - 1].text);
                if prefix_key = '' then
                begin
                    Continue;
                end;

                tail_comment := '';
                for tail_idx := prefix_count to High(syllables_local) do
                begin
                    tail_comment := tail_comment +
                        normalize_pinyin_text(syllables_local[tail_idx].text);
                end;
                if tail_comment = '' then
                begin
                    Continue;
                end;

                if not dictionary_exact_lookup_cached(prefix_key, head_results) then
                begin
                    Continue;
                end;

                if prefix_count = 1 then
                begin
                    accepted_limit := c_prefix_single_limit;
                end
                else
                begin
                    accepted_limit := c_prefix_phrase_limit;
                end;

                accepted_for_prefix := 0;
                for result_idx := 0 to High(head_results) do
                begin
                    if (accepted_total >= c_prefix_total_limit) or
                        (accepted_for_prefix >= accepted_limit) then
                    begin
                        Break;
                    end;
                    if Trim(head_results[result_idx].comment) <> '' then
                    begin
                        Continue;
                    end;

                    candidate_text := Trim(head_results[result_idx].text);
                    if candidate_text = '' then
                    begin
                        Continue;
                    end;

                    candidate_units := get_candidate_text_unit_count(candidate_text);
                    if prefix_count = 1 then
                    begin
                        if candidate_units <> 1 then
                        begin
                            Continue;
                        end;
                    end
                    else if candidate_units < 2 then
                    begin
                        Continue;
                    end;

                    seen_key := candidate_text + #9 + tail_comment;
                    if seen.ContainsKey(seen_key) then
                    begin
                        Continue;
                    end;

                    candidate := head_results[result_idx];
                    candidate.comment := tail_comment;
                    Inc(candidate.score, c_prefix_base_bonus +
                        (prefix_count * c_prefix_bonus_per_syllable));
                    if prefix_count >= 2 then
                    begin
                        Inc(candidate.score, c_prefix_phrase_extra_bonus);
                        if Length(syllables_local) <= 4 then
                        begin
                            Inc(candidate.score, c_prefix_short_query_phrase_bonus);
                        end;
                    end;
                    Dec(candidate.score, (Length(syllables_local) - prefix_count) *
                        c_prefix_remaining_penalty);

                    SetLength(out_candidates, Length(out_candidates) + 1);
                    out_candidates[High(out_candidates)] := candidate;
                    seen.AddOrSetValue(seen_key, 1);
                    Inc(accepted_total);
                    Inc(accepted_for_prefix);
                end;
            end;
        finally
            seen.Free;
        end;

        sort_candidates_lightweight(out_candidates);
        Result := Length(out_candidates) > 0;
    end;

