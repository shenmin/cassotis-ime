    end;

    procedure ensure_strong_long_dict_prefix_partial_visible(
        var candidates: TncCandidateList);
    var
        syllables_local: TncPinyinParseResult;
        best_index: Integer;
        best_rank: Integer;
        best_synthetic_valid: Boolean;
        best_synthetic: TncCandidate;
        idx: Integer;
        current_rank: Integer;
        text_units: Integer;
        remaining_syllables: Integer;
        top_rank: Integer;
        top_is_suspicious: Boolean;
        picked: TncCandidate;
        prefix_count: Integer;
        prefix_key: string;
        tail_comment: string;
        tail_idx: Integer;
        exact_results: TncCandidateList;
        result_idx: Integer;
        candidate_text: string;
        candidate_units: Integer;
        weight_value: Integer;

        function get_fixed_sentence_single_char_local(
            const syllable_text: string): string;
        var
            normalized_syllable: string;
        begin
            Result := '';
            normalized_syllable := normalize_pinyin_text(syllable_text);
            if normalized_syllable = 'dan' then
            begin
                Result := string(Char($4F46));
            end
            else if normalized_syllable = 'sui' then
            begin
                Result := string(Char($867D));
            end
            else if normalized_syllable = 'er' then
            begin
                Result := string(Char($800C));
            end
            else if normalized_syllable = 'wo' then
            begin
                Result := string(Char($6211));
            end
            else if normalized_syllable = 'ni' then
            begin
                Result := string(Char($4F60));
            end
            else if normalized_syllable = 'ta' then
            begin
                Result := string(Char($4ED6));
            end
            else if normalized_syllable = 'he' then
            begin
                Result := string(Char($548C));
            end
            else if normalized_syllable = 'qu' then
            begin
                Result := string(Char($53BB));
            end
            else if normalized_syllable = 'shi' then
            begin
                Result := string(Char($662F));
            end
            else if normalized_syllable = 'ye' then
            begin
                Result := string(Char($4E5F));
            end
            else if normalized_syllable = 'yu' then
            begin
                Result := string(Char($4E8E));
            end
            else if normalized_syllable = 'hui' then
            begin
                Result := string(Char($4F1A));
            end
            else if normalized_syllable = 'ba' then
            begin
                Result := string(Char($628A));
            end
            else if normalized_syllable = 'de' then
            begin
                Result := string(Char($7684));
            end
            else if normalized_syllable = 'zai' then
            begin
                Result := string(Char($5728));
            end
            else if normalized_syllable = 'zhe' then
            begin
                Result := string(Char($8FD9));
            end
            else if normalized_syllable = 'que' then
            begin
                Result := string(Char($5374));
            end
            else if normalized_syllable = 'bing' then
            begin
                Result := string(Char($5E76));
            end
            else if normalized_syllable = 'qie' then
            begin
                Result := string(Char($4E14));
            end
            else if normalized_syllable = 'qing' then
            begin
                Result := string(Char($8BF7));
            end;
        end;
    begin
        if (Length(candidates) <= 1) or (input_syllable_count < 6) or
            (not is_full_pinyin_key(lookup_text)) then
        begin
            Exit;
        end;

        syllables_local := get_effective_compact_pinyin_syllables(lookup_text);
        if Length(syllables_local) <> input_syllable_count then
        begin
            Exit;
        end;

        best_index := -1;
        best_rank := Low(Integer);
        best_synthetic_valid := False;
        for idx := 0 to High(candidates) do
        begin
            if (Trim(candidates[idx].comment) = '') or
                (not is_full_pinyin_key(normalize_pinyin_text(candidates[idx].comment))) or
                (not candidates[idx].has_dict_weight) then
            begin
                Continue;
            end;

            text_units := get_candidate_text_unit_count(Trim(candidates[idx].text));
            if (text_units < 4) or (text_units >= input_syllable_count) then
            begin
                Continue;
            end;

            remaining_syllables := input_syllable_count - text_units;
            current_rank := candidates[idx].score +
                Min(1600, candidates[idx].dict_weight div 2) +
                (text_units * 520) - (remaining_syllables * 80);
            if (text_units <= High(syllables_local)) and
                (get_fixed_sentence_single_char_local(syllables_local[text_units].text) <> '') then
            begin
                Inc(current_rank, 2600);
            end;

            if (best_index < 0) or (current_rank > best_rank) then
            begin
                best_index := idx;
                best_rank := current_rank;
            end;
        end;

        if best_index < 0 then
        begin
            for prefix_count := Min(6, input_syllable_count - 2) downto 4 do
            begin
                prefix_key := '';
                for tail_idx := 0 to prefix_count - 1 do
                begin
                    prefix_key := prefix_key +
                        normalize_pinyin_text(syllables_local[tail_idx].text);
                end;
                if prefix_key = '' then
                begin
                    Continue;
                end;

                tail_comment := '';
                for tail_idx := prefix_count to High(syllables_local) do
                begin
                    tail_comment := tail_comment +
                        normalize_pinyin_text(syllables_local[tail_idx].text);
                end;
                if tail_comment = '' then
                begin
                    Continue;
                end;

                if not m_dictionary.lookup_exact_full_pinyin(prefix_key, exact_results) then
                begin
                    Continue;
                end;

                for result_idx := 0 to High(exact_results) do
                begin
                    if Trim(exact_results[result_idx].comment) <> '' then
                    begin
                        Continue;
                    end;

                    candidate_text := Trim(exact_results[result_idx].text);
                    candidate_units := get_candidate_text_unit_count(candidate_text);
                    if candidate_units <> prefix_count then
                    begin
                        Continue;
                    end;

                    weight_value := exact_results[result_idx].score;
                    if exact_results[result_idx].has_dict_weight and
                        (exact_results[result_idx].dict_weight > weight_value) then
                    begin
                        weight_value := exact_results[result_idx].dict_weight;
                    end;

                    current_rank := weight_value + (candidate_units * 520) -
                        ((input_syllable_count - candidate_units) * 80) +
                        Min(1600, weight_value div 2);
                    if (candidate_units <= High(syllables_local)) and
                        (get_fixed_sentence_single_char_local(
                        syllables_local[candidate_units].text) <> '') then
                    begin
                        Inc(current_rank, 2600);
                    end;

                    if current_rank > best_rank then
                    begin
                        best_rank := current_rank;
                        FillChar(best_synthetic, SizeOf(best_synthetic), 0);
                        best_synthetic.text := candidate_text;
                        best_synthetic.comment := tail_comment;
                        best_synthetic.score := weight_value + 920 +
                            (candidate_units * 72) -
                            ((input_syllable_count - candidate_units) * 26);
                        best_synthetic.source := exact_results[result_idx].source;
                        best_synthetic.has_dict_weight := True;
                        best_synthetic.dict_weight := weight_value;
                        best_synthetic_valid := True;
                    end;
                end;
            end;
        end;

        if (best_index < 0) and (not best_synthetic_valid) then
        begin
            Exit;
        end;

        top_rank := candidates[0].score;
        top_is_suspicious := (Trim(candidates[0].comment) <> '') and
            (not candidates[0].has_dict_weight);
        if (not top_is_suspicious) and (best_rank <= top_rank + 2400) then
        begin
            Exit;
        end;

        if best_index > 0 then
        begin
            picked := candidates[best_index];
            for idx := best_index downto 1 do
            begin
                candidates[idx] := candidates[idx - 1];
            end;
            candidates[0] := picked;
        end
        else if best_synthetic_valid then
        begin
            SetLength(candidates, Length(candidates) + 1);
            for idx := High(candidates) downto 1 do
            begin
                candidates[idx] := candidates[idx - 1];
            end;
            candidates[0] := best_synthetic;
        end;
    end;

    procedure filter_short_query_nonlexicon_complete_noise(var candidates: TncCandidateList);
    var
        idx: Integer;
        out_idx: Integer;
        candidate_text_units: Integer;
        has_short_complete_anchor: Boolean;
        partial_comment_syllables: Integer;

        function get_display_codepoint_count(const text: string): Integer;
        var
            pos_idx: Integer;
            codepoint: Integer;
            trimmed: string;
        begin
            Result := 0;
            trimmed := Trim(text);
            pos_idx := 1;
            while pos_idx <= Length(trimmed) do
            begin
                codepoint := Ord(trimmed[pos_idx]);
                if (codepoint >= $D800) and (codepoint <= $DBFF) and
                    (pos_idx < Length(trimmed)) and
                    (Ord(trimmed[pos_idx + 1]) >= $DC00) and
                    (Ord(trimmed[pos_idx + 1]) <= $DFFF) then
                begin
                    Inc(pos_idx);
                end;
                Inc(Result);
                Inc(pos_idx);
            end;
        end;

    begin
        if (Length(candidates) = 0) or (input_syllable_count < 2) or
            (not is_full_pinyin_key(lookup_text)) then
        begin
            Exit;
        end;

        has_short_complete_anchor := False;
        for idx := 0 to High(candidates) do
        begin
            candidate_text_units := get_display_codepoint_count(candidates[idx].text);
            if (Trim(candidates[idx].comment) = '') and
                (candidate_text_units >= 2) and (candidate_text_units <= 4) and
                (candidates[idx].has_dict_weight or (candidates[idx].source = cs_user)) then
            begin
                has_short_complete_anchor := True;
                Break;
            end;
            if (Trim(candidates[idx].comment) <> '') and
                (candidate_text_units >= 2) and (candidate_text_units <= 4) and
                (candidates[idx].source in [cs_rule, cs_user]) then
            begin
                partial_comment_syllables := get_effective_compact_pinyin_unit_count(
                    normalize_pinyin_text(Trim(candidates[idx].comment)));
                if (partial_comment_syllables > 0) and
                    (candidate_text_units + partial_comment_syllables = input_syllable_count) then
                begin
                    has_short_complete_anchor := True;
                    Break;
                end;
            end;
        end;
        if not has_short_complete_anchor then
        begin
            Exit;
        end;

        out_idx := 0;
        for idx := 0 to High(candidates) do
        begin
            candidate_text_units := get_display_codepoint_count(candidates[idx].text);
            if (candidates[idx].comment = '') and
                (candidate_text_units >= 2) and (candidate_text_units <= 4) and
                (not candidates[idx].has_dict_weight) and
                (candidates[idx].source <> cs_user) then
            begin
                Continue;
            end;

            if out_idx <> idx then
            begin
                candidates[out_idx] := candidates[idx];
            end;
            Inc(out_idx);
        end;
        SetLength(candidates, out_idx);
    end;

    procedure ensure_long_sentence_partial_exact_candidate_visible(
        var candidates: TncCandidateList);
    var
        best_index: Integer;
        best_score: Integer;
        idx: Integer;
        picked: TncCandidate;
    begin
        if (Length(candidates) = 0) or (input_syllable_count < c_long_sentence_exact_min_syllables) or
            is_full_pinyin_key(lookup_text) or
            (not has_long_sentence_extendable_tail_for_visibility_local) then
        begin
            Exit;
        end;

        best_index := -1;
        best_score := Low(Integer);
        for idx := 0 to High(candidates) do
        begin
            if not is_long_sentence_partial_exact_candidate_for_visibility(candidates[idx]) then
            begin
                Continue;
            end;
            if candidates[idx].score > best_score then
            begin
                best_index := idx;
                best_score := candidates[idx].score;
            end;
        end;

        if best_index <= 0 then
        begin
            Exit;
        end;

        picked := candidates[best_index];
        for idx := best_index downto 1 do
        begin
            candidates[idx] := candidates[idx - 1];
        end;
        candidates[0] := picked;
    end;

    procedure ensure_short_exact_tail_completion_visible(var candidates: TncCandidateList);
        function is_short_exact_tail_completion_seed_candidate(
            const candidate: TncCandidate): Boolean;
        var
            partial_text_units: Integer;
            encoded_path: string;
        begin
            Result := False;
            if Trim(candidate.comment) = '' then
            begin
                Exit;
            end;

            partial_text_units := get_candidate_text_unit_count(Trim(candidate.text));
            if partial_text_units < 2 then
            begin
                Exit;
            end;

            if partial_text_units <> input_syllable_count - 1 then
            begin
                Exit;
            end;

            if get_effective_compact_pinyin_unit_count(
                normalize_pinyin_text(candidate.comment)) <> 1 then
            begin
                Exit;
            end;

            encoded_path := get_segment_path_for_candidate(candidate);
            if not is_natural_predictive_segment_path_local(encoded_path) then
            begin
                Exit;
            end;

            Result := True;
        end;
        function can_extend_single_syllable_prefix(const value: string): Boolean;
        var
            effective_parts: TncPinyinParseResult;
            local_syllable_count: Integer;
            suffix_ch: Char;
            extended_key: string;
        begin
            Result := False;
            if value = '' then
            begin
                Exit;
            end;

            effective_parts := get_effective_compact_pinyin_syllables(value);
            local_syllable_count := Length(effective_parts);
            if local_syllable_count <> 1 then
            begin
                Exit;
            end;

            for suffix_ch := 'a' to 'z' do
            begin
                extended_key := value + suffix_ch;
                if get_effective_compact_pinyin_unit_count(extended_key) = 1 then
                begin
                    Exit(True);
                end;
            end;
        end;
        procedure get_prefix_tail_context(const partial_candidate: TncCandidate;
            out out_prev_prev_text: string; out out_prev_text: string);
        var
            encoded_path: string;
            segment_parts: TArray<string>;
            segment_count: Integer;
        begin
            out_prev_prev_text := '';
            out_prev_text := '';
            encoded_path := get_segment_path_for_candidate(partial_candidate);
            if Trim(encoded_path) <> '' then
            begin
                segment_parts := encoded_path.Split([c_segment_path_separator]);
                segment_count := Length(segment_parts);
                if segment_count >= 1 then
                begin
                    out_prev_text := Trim(segment_parts[segment_count - 1]);
                end;
                if segment_count >= 2 then
                begin
                    out_prev_prev_text := Trim(segment_parts[segment_count - 2]);
                end;
            end;

            if out_prev_text = '' then
            begin
                out_prev_text := Trim(partial_candidate.text);
            end;
        end;
        function lookup_exact_tail_cached(const pinyin_key: string;
            out out_results: TncCandidateList): Boolean;
        var
            cache_key: string;
            phase_start_tick: UInt64;
        begin
            SetLength(out_results, 0);
            if (m_dictionary = nil) or (pinyin_key = '') then
            begin
                Exit(False);
            end;

            cache_key := '#exact#' + pinyin_key;
            if lookup_cache.TryGetValue(cache_key, out_results) then
            begin
                Inc(lookup_cache_hits);
                Exit(Length(out_results) > 0);
            end;

            Inc(lookup_cache_misses);
            phase_start_tick := GetTickCount64;
            if not m_dictionary.lookup_exact_full_pinyin(pinyin_key, out_results) then
            begin
                SetLength(out_results, 0);
            end;
            Inc(lookup_elapsed_ms, Int64(GetTickCount64 - phase_start_tick));
            lookup_cache.AddOrSetValue(cache_key, out_results);
            Result := Length(out_results) > 0;
        end;
        function is_preferred_prefix_single_char(const value: string): Boolean;
        begin
            Result := False;
            if Length(value) <> 1 then
            begin
                Exit;
            end;

            case Ord(value[1]) of
                $4E00, $6211, $4F60, $4ED6, $5979, $5B83, $548C, $53BB, $6765, $5728,
                $662F, $6709, $8981, $60F3, $4F1A, $80FD, $628A, $88AB, $8BA9,
                $7ED9, $5411, $5BF9, $4E8E, $8DDF, $540C, $4ECE, $4E0E, $5C31,
                $4E5F, $90FD, $8FD8, $53C8, $518D, $4E0D, $5F88, $592A, $6700,
                $5DF2, $5C06, $5230, $7740, $8FC7, $4E86:
                    Result := True;
            end;
        end;
        function get_prefix_completion_priority(const value: string): Integer;
        begin
            if value = 'wo' then Exit(2000);
            if value = 'he' then Exit(1980);
            if value = 'yi' then Exit(1960);
            if value = 'you' then Exit(1940);
            if value = 'yao' then Exit(1930);
            if value = 'shi' then Exit(1920);
            if value = 'zai' then Exit(1910);
            if value = 'bu' then Exit(1900);
            if value = 'le' then Exit(1890);
            if value = 'hai' then Exit(1880);
            if value = 'hen' then Exit(1870);
            if value = 'jiu' then Exit(1860);
            if value = 'hui' then Exit(1850);
            if value = 'neng' then Exit(1840);
            if value = 'qu' then Exit(1830);
            if value = 'lai' then Exit(1820);
            if value = 'men' then Exit(1810);
            if value = 'gei' then Exit(1800);
            if value = 'bei' then Exit(1790);
            if value = 'ba' then Exit(1780);
            if value = 'de' then Exit(1770);

            Result := 1000 - Length(value);
        end;
        procedure sort_completion_list_by_priority(var completion_list: TList<string>);
        begin
            if (completion_list = nil) or (completion_list.Count <= 1) then
            begin
                Exit;
            end;

            completion_list.Sort(TComparer<string>.Construct(
                function(const left, right: string): Integer
                var
                    left_priority: Integer;
                    right_priority: Integer;
                    function calc_priority(const value: string): Integer;
                    begin
                        if value = 'wo' then Exit(2000);
                        if value = 'he' then Exit(1980);
                        if value = 'yi' then Exit(1960);
                        if value = 'you' then Exit(1940);
                        if value = 'yao' then Exit(1930);
                        if value = 'shi' then Exit(1920);
                        if value = 'zai' then Exit(1910);
                        if value = 'bu' then Exit(1900);
                        if value = 'le' then Exit(1890);
                        if value = 'hai' then Exit(1880);
                        if value = 'hen' then Exit(1870);
                        if value = 'jiu' then Exit(1860);
                        if value = 'hui' then Exit(1850);
                        if value = 'neng' then Exit(1840);
                        if value = 'qu' then Exit(1830);
                        if value = 'lai' then Exit(1820);
                        if value = 'men' then Exit(1810);
                        if value = 'gei' then Exit(1800);
                        if value = 'bei' then Exit(1790);
                        if value = 'ba' then Exit(1780);
                        if value = 'de' then Exit(1770);

                        Result := 1000 - Length(value);
                    end;
                begin
                    left_priority := calc_priority(left);
                    right_priority := calc_priority(right);
                    Result := right_priority - left_priority;
                    if Result <> 0 then
                    begin
                        Exit;
                    end;
                    Result := Length(left) - Length(right);
                    if Result <> 0 then
                    begin
                        Exit;
                    end;
                    Result := CompareText(left, right);
                end));
        end;
        function is_prefix_initial_final_compatible(const initial_value: string;
            const final_value: string): Boolean;
        begin
            if (initial_value = 'zh') or (initial_value = 'ch') or (initial_value = 'sh') or
                (initial_value = 'r') or (initial_value = 'z') or (initial_value = 'c') or
                (initial_value = 's') then
            begin
                if (final_value = 'ia') or (final_value = 'in') or (final_value = 'ing') or (final_value = 'iu') or
                    (final_value = 'ie') or (final_value = 'ian') or (final_value = 'iang') or
                    (final_value = 'iao') or (final_value = 'iong') or
                    (final_value = 'ue') or (final_value = 've') or (final_value = 'van') or
                    (final_value = 'vn') then
                begin
                    Exit(False);
                end;
            end;

            Result := True;
        end;
        procedure add_single_syllable_completion(const value: string;
            var completion_list: TList<string>);
        begin
            if (value = '') or (completion_list = nil) then
            begin
                Exit;
            end;
            if completion_list.IndexOf(value) >= 0 then
            begin
                Exit;
            end;
            completion_list.Add(value);
        end;
        procedure collect_single_syllable_completions(const prefix_value: string;
            var completion_list: TList<string>);
        const
            c_priority_completion_keys: array[0..20] of string = (
                'wo', 'he', 'yi', 'you', 'yao', 'shi', 'zai', 'bu', 'le', 'hai',
                'hen', 'jiu', 'hui', 'neng', 'qu', 'lai', 'men', 'gei', 'bei', 'ba',
                'de'
            );
            c_prefix_completion_initials: array[0..22] of string = (
                'zh', 'ch', 'sh',
                'b', 'p', 'm', 'f', 'd', 't', 'n', 'l', 'g', 'k', 'h',
                'j', 'q', 'x', 'r', 'z', 'c', 's', 'y', 'w'
            );
            c_prefix_completion_finals: array[0..35] of string = (
                'iang', 'iong', 'uang',
                'uai', 'uan', 'iao', 'ian', 'ing', 'ang', 'eng', 'ong',
                'ai', 'an', 'ao', 'ei', 'en', 'er', 'ou',
                'ia', 'ie', 'in', 'iu', 'ua', 'ui', 'un', 'uo',
                've', 'van', 'vn', 'ue',
                'a', 'e', 'i', 'o', 'u', 'v'
            );
            c_prefix_completion_no_initial_finals: array[0..11] of string = (
                'ang', 'eng',
                'ai', 'an', 'ao', 'ei', 'en', 'er', 'ou',
                'a', 'e', 'o'
            );
        var
            normalized_prefix: string;
            priority_idx: Integer;
            initial_idx: Integer;
            final_idx: Integer;
            initial_value: string;
            final_value: string;
            full_value: string;
            prefix_tail: string;
        begin
            normalized_prefix := normalize_pinyin_text(prefix_value);
            if (normalized_prefix = '') or (completion_list = nil) then
            begin
                Exit;
            end;

            if Length(normalized_prefix) = 1 then
            begin
                for priority_idx := Low(c_priority_completion_keys) to High(c_priority_completion_keys) do
                begin
                    full_value := c_priority_completion_keys[priority_idx];
                    if full_value.StartsWith(normalized_prefix) then
                    begin
                        add_single_syllable_completion(full_value, completion_list);
                    end;
                end;
                if completion_list.Count > 0 then
                begin
                    Exit;
                end;
            end;

            for initial_idx := Low(c_prefix_completion_initials) to High(c_prefix_completion_initials) do
            begin
                initial_value := c_prefix_completion_initials[initial_idx];
                for final_idx := Low(c_prefix_completion_finals) to High(c_prefix_completion_finals) do
                begin
                    final_value := c_prefix_completion_finals[final_idx];
                    if not is_prefix_initial_final_compatible(initial_value, final_value) then
                    begin
                        Continue;
                    end;
                    full_value := initial_value + final_value;
                    if full_value.StartsWith(normalized_prefix) then
                    begin
                        add_single_syllable_completion(full_value, completion_list);
                    end
                    else if normalized_prefix.StartsWith(initial_value) then
                    begin
                        prefix_tail := Copy(normalized_prefix, Length(initial_value) + 1, MaxInt);
                        if (prefix_tail <> '') and final_value.StartsWith(prefix_tail) then
                        begin
                            add_single_syllable_completion(full_value, completion_list);
                        end;
                    end;
                end;
            end;

            for final_idx := Low(c_prefix_completion_no_initial_finals) to High(c_prefix_completion_no_initial_finals) do
            begin
                final_value := c_prefix_completion_no_initial_finals[final_idx];
                if final_value.StartsWith(normalized_prefix) or normalized_prefix.StartsWith(final_value) then
                begin
                    add_single_syllable_completion(final_value, completion_list);
                end;
            end;
        end;
        function try_pick_fast_prefix_single_char_tail(
            const prefix_value: string; out out_text: string): Boolean;
        var
            local_completion_keys: TList<string>;
            local_probe_limit: Integer;
            local_completion_key: string;
            local_results: TncCandidateList;
            local_idx: Integer;
            local_result_idx: Integer;
            local_candidate_text: string;
            local_is_preferred: Boolean;
            local_fallback_text: string;
        begin
            Result := False;
            out_text := '';
            local_fallback_text := '';
            if Length(normalize_pinyin_text(prefix_value)) > 1 then
            begin
                Exit;
            end;

            local_completion_keys := TList<string>.Create;
            try
                collect_single_syllable_completions(prefix_value, local_completion_keys);
                sort_completion_list_by_priority(local_completion_keys);
                if local_completion_keys.Count <= 0 then
                begin
                    Exit;
                end;

                local_probe_limit := Min(3, local_completion_keys.Count);
                for local_idx := 0 to local_probe_limit - 1 do
                begin
                    local_completion_key := local_completion_keys[local_idx];
                    if not lookup_exact_tail_cached(local_completion_key, local_results) then
                    begin
                        Continue;
                    end;

                    for local_result_idx := 0 to High(local_results) do
                    begin
                        if local_result_idx >= 16 then
                        begin
                            Break;
                        end;
                        local_candidate_text := Trim(local_results[local_result_idx].text);
                        if get_candidate_text_unit_count(local_candidate_text) <> 1 then
                        begin
                            Continue;
                        end;
                        if not match_single_char_candidate_for_syllable(
                            local_completion_key, local_candidate_text, local_is_preferred) then
                        begin
                            Continue;
                        end;
                        if local_fallback_text = '' then
                        begin
                            local_fallback_text := local_candidate_text;
                        end;
                        if is_preferred_prefix_single_char(local_candidate_text) then
                        begin
                            out_text := local_candidate_text;
                            Exit(True);
                        end;
                    end;
                end;

                if (local_fallback_text <> '') and
                    (Length(normalize_pinyin_text(prefix_value)) > 1) then
                begin
                    out_text := local_fallback_text;
                    Exit(True);
                end;
            finally
                local_completion_keys.Free;
            end;
        end;
    var
        best_partial_index: Integer;
        best_partial_score: Integer;
        best_partial: TncCandidate;
        tail_lookup: TncCandidateList;
        tail_single_candidate: TncCandidateList;
        tail_idx: Integer;
        tail_is_preferred: Boolean;
        tail_text: string;
        tail_fallback_text: string;
        tail_fallback_score: Integer;
        tail_prefix_completion_keys: TList<string>;
        tail_prefix_completion_key: string;
        tail_prefix_results: TncCandidateList;
        tail_prefix_idx: Integer;
        tail_prefix_candidate: TncCandidate;
        tail_prefix_prev_text: string;
        tail_prefix_prev_prev_text: string;
        tail_prefix_score: Integer;
        tail_prefix_best_score: Integer;
        tail_prefix_second_best_score: Integer;
        tail_prefix_has_allowed_candidate: Boolean;
        tail_prefix_is_preferred: Boolean;
        tail_prefix_probe_limit: Integer;
        combined: TncCandidate;
        combined_path: string;
    begin
        if (Length(candidates) = 0) or (input_syllable_count < c_long_sentence_exact_min_syllables) then
        begin
            Exit;
        end;

        best_partial_index := -1;
        best_partial_score := Low(Integer);
        for tail_idx := 0 to High(candidates) do
        begin
            if not is_short_exact_tail_completion_seed_candidate(candidates[tail_idx]) then
            begin
                Continue;
            end;
            if candidates[tail_idx].score > best_partial_score then
            begin
                best_partial_index := tail_idx;
                best_partial_score := candidates[tail_idx].score;
            end;
        end;

        if best_partial_index < 0 then
        begin
            Exit;
        end;

        best_partial := candidates[best_partial_index];
        if (m_dictionary = nil) or
            (not lookup_exact_tail_cached(
            normalize_pinyin_text(best_partial.comment), tail_lookup)) then
        begin
            SetLength(tail_lookup, 0);
        end;

        tail_text := '';
        tail_fallback_text := '';
        tail_fallback_score := Low(Integer);
        for tail_idx := 0 to High(tail_lookup) do
        begin
            if get_candidate_text_unit_count(Trim(tail_lookup[tail_idx].text)) <> 1 then
            begin
                Continue;
            end;
            if not match_single_char_candidate_for_syllable(
                normalize_pinyin_text(best_partial.comment), Trim(tail_lookup[tail_idx].text),
                tail_is_preferred) then
            begin
                Continue;
            end;
            if not tail_is_preferred then
            begin
                if tail_lookup[tail_idx].score > tail_fallback_score then
                begin
                    tail_fallback_text := Trim(tail_lookup[tail_idx].text);
                    tail_fallback_score := tail_lookup[tail_idx].score;
                end;
                Continue;
            end;
            tail_text := Trim(tail_lookup[tail_idx].text);
            Break;
        end;

        if tail_text = '' then
        begin
            tail_text := tail_fallback_text;
        end;

        if tail_text = '' then
        begin
            if try_pick_fast_prefix_single_char_tail(best_partial.comment, tail_text) then
            begin
                // Fast path for one-letter trailing prefixes such as "w/h/y".
                // This avoids the much heavier context-scored completion scan.
            end
            else
            begin
            tail_prefix_completion_keys := TList<string>.Create;
            try
                collect_single_syllable_completions(best_partial.comment, tail_prefix_completion_keys);
                sort_completion_list_by_priority(tail_prefix_completion_keys);
                if Length(normalize_pinyin_text(best_partial.comment)) <= 1 then
                begin
                    tail_prefix_probe_limit := 4;
                end
                else
                begin
                    tail_prefix_probe_limit := 6;
                end;
                if can_extend_single_syllable_prefix(normalize_pinyin_text(best_partial.comment)) and
                    (tail_prefix_completion_keys.Count > 0) then
                begin
                    get_prefix_tail_context(best_partial, tail_prefix_prev_prev_text, tail_prefix_prev_text);
                    tail_prefix_has_allowed_candidate := False;
                    for tail_prefix_idx := 0 to tail_prefix_completion_keys.Count - 1 do
                    begin
                        if tail_prefix_idx >= tail_prefix_probe_limit then
                        begin
                            Break;
                        end;
                        tail_prefix_completion_key := tail_prefix_completion_keys[tail_prefix_idx];
                        if not lookup_exact_tail_cached(tail_prefix_completion_key, tail_prefix_results) then
                        begin
                            Continue;
                        end;
                        for tail_idx := 0 to High(tail_prefix_results) do
                        begin
                            if (get_candidate_text_unit_count(Trim(tail_prefix_results[tail_idx].text)) = 1) and
                                is_preferred_prefix_single_char(Trim(tail_prefix_results[tail_idx].text)) then
                            begin
                                tail_prefix_has_allowed_candidate := True;
                                Break;
                            end;
                        end;
                        if tail_prefix_has_allowed_candidate then
                        begin
                            Break;
                        end;
                    end;

                    tail_prefix_best_score := Low(Integer);
                    tail_prefix_second_best_score := Low(Integer);
                    for tail_prefix_idx := 0 to tail_prefix_completion_keys.Count - 1 do
                    begin
                        if tail_prefix_idx >= tail_prefix_probe_limit then
                        begin
                            Break;
                        end;
                        tail_prefix_completion_key := tail_prefix_completion_keys[tail_prefix_idx];
                        if not lookup_exact_tail_cached(tail_prefix_completion_key, tail_prefix_results) then
                        begin
                            Continue;
                        end;

                        for tail_idx := 0 to High(tail_prefix_results) do
                        begin
                            tail_prefix_candidate := tail_prefix_results[tail_idx];
                            if get_candidate_text_unit_count(Trim(tail_prefix_candidate.text)) <> 1 then
                            begin
                                Continue;
                            end;
                            if not match_single_char_candidate_for_syllable(
                                tail_prefix_completion_key, Trim(tail_prefix_candidate.text),
                                tail_prefix_is_preferred) then
                            begin
                                Continue;
                            end;
                            if tail_prefix_has_allowed_candidate and
                                (not is_preferred_prefix_single_char(Trim(tail_prefix_candidate.text))) then
                            begin
                                Continue;
                            end;

                            tail_prefix_score := tail_prefix_candidate.score;
                            if tail_prefix_candidate.has_dict_weight and
                                (tail_prefix_candidate.dict_weight > tail_prefix_score) then
                            begin
                                tail_prefix_score := tail_prefix_candidate.dict_weight;
                            end;
                            if tail_prefix_is_preferred then
                            begin
                                Inc(tail_prefix_score, 120);
                            end;
                            if is_preferred_prefix_single_char(Trim(tail_prefix_candidate.text)) then
                            begin
                                Inc(tail_prefix_score, 180);
                            end;
                            if (m_dictionary <> nil) and (tail_prefix_prev_text <> '') then
                            begin
                                Inc(tail_prefix_score, m_dictionary.get_context_bonus(
                                    tail_prefix_prev_text, Trim(tail_prefix_candidate.text)));
                                if tail_prefix_prev_prev_text <> '' then
                                begin
                                    Inc(tail_prefix_score, m_dictionary.get_context_trigram_bonus(
                                        tail_prefix_prev_prev_text, tail_prefix_prev_text,
                                        Trim(tail_prefix_candidate.text)));
                                end;
                            end;

                            if tail_prefix_score > tail_prefix_best_score then
                            begin
                                tail_prefix_second_best_score := tail_prefix_best_score;
                                tail_prefix_best_score := tail_prefix_score;
                                tail_text := Trim(tail_prefix_candidate.text);
                            end
                            else if tail_prefix_score > tail_prefix_second_best_score then
                            begin
                                tail_prefix_second_best_score := tail_prefix_score;
                            end;
                        end;
                    end;

                    if (tail_text <> '') and
                        (tail_prefix_second_best_score > Low(Integer) div 2) and
                        ((tail_prefix_best_score - tail_prefix_second_best_score) < 120) and
                        (Length(normalize_pinyin_text(best_partial.comment)) <= 1) then
                    begin
                        tail_text := '';
                    end;
                end;
            finally
                tail_prefix_completion_keys.Free;
            end;
            end;
        end;

        if tail_text = '' then
        begin
            Exit;
        end;

        combined.text := Trim(best_partial.text) + tail_text;
        combined.comment := '';
        combined.score := best_partial.score + 880;
        combined.source := best_partial.source;
        combined.has_dict_weight := False;
        combined.dict_weight := 0;

        combined_path := get_segment_path_for_candidate(best_partial);
        if combined_path <> '' then
        begin
            combined_path := combined_path + c_segment_path_separator + tail_text;
        end
        else
        begin
            combined_path := Trim(best_partial.text) + c_segment_path_separator + tail_text;
        end;
        remember_segment_path_for_candidate(combined.text, '', combined_path, combined.score);
        SetLength(tail_single_candidate, 1);
        tail_single_candidate[0] := combined;
        candidates := merge_candidate_lists(candidates, tail_single_candidate, 0);
        sort_candidates_lightweight(candidates);
    end;

    procedure ensure_incomplete_tail_partial_precedes_completed_extension(
        var candidates: TncCandidateList);
    var
        top_units: Integer;
        idx: Integer;
        best_index: Integer;
        best_units: Integer;
        best_score: Integer;
        partial_units: Integer;
        picked: TncCandidate;
        parser: TncPinyinParser;
        raw_parts: TncPinyinParseResult;
        last_tail_text: string;
        exact_results: TncCandidateList;

        function is_text_prefix_local(const prefix_value: string;
            const full_value: string): Boolean;
        begin
            Result := (prefix_value <> '') and (full_value <> '') and
                (Length(prefix_value) <= Length(full_value)) and
                SameText(Copy(full_value, 1, Length(prefix_value)), prefix_value);
        end;

        function has_current_exact_complete_local: Boolean;
        var
            exact_idx_local: Integer;
        begin
            Result := False;
            if (m_dictionary = nil) or
                (not m_dictionary.lookup_exact_full_pinyin(lookup_text, exact_results)) then
            begin
                Exit;
            end;

            for exact_idx_local := 0 to High(exact_results) do
            begin
                if (Trim(exact_results[exact_idx_local].comment) = '') and
                    (get_candidate_text_unit_count(Trim(exact_results[exact_idx_local].text)) >= 2) then
                begin
                    Exit(True);
                end;
            end;
        end;

        function has_visible_exact_completion_for_partial_local(
            const partial_text_local: string; const tail_comment_local: string): Boolean;
        var
            exact_tail_results_local: TncCandidateList;
            exact_tail_idx_local: Integer;
            candidate_idx_local: Integer;
            combined_text_local: string;
            normalized_tail_local: string;
        begin
            Result := False;
            normalized_tail_local := normalize_pinyin_text(tail_comment_local);
            if (partial_text_local = '') or (normalized_tail_local = '') or
                (not is_full_pinyin_key(normalized_tail_local)) or
                (m_dictionary = nil) then
            begin
                Exit;
            end;

            if not m_dictionary.lookup_exact_full_pinyin(normalized_tail_local,
                exact_tail_results_local) then
            begin
                Exit;
            end;

            for exact_tail_idx_local := 0 to High(exact_tail_results_local) do
            begin
                if Trim(exact_tail_results_local[exact_tail_idx_local].comment) <> '' then
                begin
                    Continue;
                end;

                combined_text_local := partial_text_local +
                    Trim(exact_tail_results_local[exact_tail_idx_local].text);
                if combined_text_local = partial_text_local then
                begin
                    Continue;
                end;

                for candidate_idx_local := 0 to High(candidates) do
                begin
                    if (Trim(candidates[candidate_idx_local].comment) = '') and
                        SameText(Trim(candidates[candidate_idx_local].text),
                        combined_text_local) then
                    begin
                        Exit(True);
                    end;
                end;
            end;
        end;
    begin
        if Length(candidates) <= 1 then
        begin
            if m_config.debug_mode then
            begin
                m_last_full_path_debug_info := m_last_full_path_debug_info +
                    ' itail=[skip short]';
            end;
            Exit;
        end;
        if Trim(candidates[0].comment) <> '' then
        begin
            if m_config.debug_mode then
            begin
                m_last_full_path_debug_info := m_last_full_path_debug_info +
                    ' itail=[skip top-partial]';
            end;
            Exit;
        end;

        parser := TncPinyinParser.Create;
        try
            raw_parts := parser.parse(normalize_pinyin_text(lookup_text));
        finally
            parser.Free;
        end;
        if Length(raw_parts) > 0 then
        begin
            last_tail_text := normalize_pinyin_text(raw_parts[High(raw_parts)].text);
            if (last_tail_text <> '') and is_full_pinyin_key(last_tail_text) and
                has_current_exact_complete_local then
            begin
                if m_config.debug_mode then
                begin
                    m_last_full_path_debug_info := m_last_full_path_debug_info +
                        Format(' itail=[skip exact-tail tail=%s]',
                        [last_tail_text]);
                end;
                Exit;
            end;
        end;

        top_units := get_candidate_text_unit_count(Trim(candidates[0].text));
        if top_units < 3 then
        begin
            if m_config.debug_mode then
            begin
                m_last_full_path_debug_info := m_last_full_path_debug_info +
                    Format(' itail=[skip top-units=%d]', [top_units]);
            end;
            Exit;
        end;

        best_index := -1;
        best_units := -1;
        best_score := Low(Integer);
        for idx := 1 to High(candidates) do
        begin
            if Trim(candidates[idx].comment) = '' then
            begin
                Continue;
            end;

            partial_units := get_candidate_text_unit_count(Trim(candidates[idx].text));
            if partial_units < 2 then
            begin
                Continue;
            end;
            if partial_units >= input_syllable_count then
            begin
                Continue;
            end;
            if partial_units < top_units - 1 then
            begin
                Continue;
            end;
            if has_visible_exact_completion_for_partial_local(
                Trim(candidates[idx].text), Trim(candidates[idx].comment)) then
            begin
                Continue;
            end;
            if not is_text_prefix_local(Trim(candidates[idx].text),
                Trim(candidates[0].text)) then
            begin
                Continue;
            end;

            if (partial_units > best_units) or
                ((partial_units = best_units) and (candidates[idx].score > best_score)) then
            begin
                best_index := idx;
                best_units := partial_units;
                best_score := candidates[idx].score;
            end;
        end;

        if best_index <= 0 then
        begin
            if m_config.debug_mode then
            begin
                m_last_full_path_debug_info := m_last_full_path_debug_info +
                    ' itail=[skip no-partial]';
            end;
            Exit;
        end;

        picked := candidates[best_index];
        while best_index > 0 do
        begin
            candidates[best_index] := candidates[best_index - 1];
            Dec(best_index);
        end;
        candidates[0] := picked;
        if m_config.debug_mode then
        begin
            m_last_full_path_debug_info := m_last_full_path_debug_info +
                Format(' itail=[promote text=%s comment=%s]',
                [Trim(candidates[0].text), Trim(candidates[0].comment)]);
        end;
    end;

    procedure ensure_complete_extension_precedes_prefix_partial(
        var candidates: TncCandidateList);
    var
        top_text: string;
        top_units: Integer;
        idx: Integer;
        best_index: Integer;
        best_score: Integer;
        best_shared_prefix_units: Integer;
        picked: TncCandidate;
        effective_syllables: TncPinyinParseResult;
        candidate_text: string;
        shared_prefix_units: Integer;
        suffix_text: string;

        function is_text_prefix_local(const prefix_value: string;
            const full_value: string): Boolean;
        begin
            Result := (prefix_value <> '') and (full_value <> '') and
                (Length(prefix_value) <= Length(full_value)) and
                SameText(Copy(full_value, 1, Length(prefix_value)), prefix_value);
        end;

        function get_shared_prefix_unit_count_local(const left_value: string;
            const right_value: string): Integer;
        var
            left_units: TArray<string>;
            right_units: TArray<string>;
            local_idx: Integer;
        begin
            Result := 0;
            left_units := split_text_units(Trim(left_value));
            right_units := split_text_units(Trim(right_value));
            for local_idx := 0 to Min(High(left_units), High(right_units)) do
            begin
                if not SameText(left_units[local_idx], right_units[local_idx]) then
                begin
                    Break;
                end;
                Inc(Result);
            end;
        end;

        function get_suffix_text_by_unit_count_local(const value: string;
            const prefix_units: Integer): string;
        var
            value_units: TArray<string>;
            local_idx: Integer;
        begin
            Result := '';
            value_units := split_text_units(Trim(value));
            if (prefix_units < 0) or (prefix_units > Length(value_units)) then
            begin
                Exit;
            end;
            for local_idx := prefix_units to High(value_units) do
            begin
                Result := Result + value_units[local_idx];
            end;
        end;

        function build_suffix_query_key_local(const prefix_units: Integer): string;
        var
            local_idx: Integer;
        begin
            Result := '';
            if (prefix_units < 0) or (prefix_units >= Length(effective_syllables)) then
            begin
                Exit;
            end;
            for local_idx := prefix_units to High(effective_syllables) do
            begin
                Result := Result +
                    normalize_pinyin_text(effective_syllables[local_idx].text);
            end;
        end;

        function is_exact_tail_completion_local(const suffix_key: string;
            const suffix_value: string): Boolean;
        var
            tail_results: TncCandidateList;
            tail_idx: Integer;
        begin
            Result := False;
            if (suffix_key = '') or (suffix_value = '') or (m_dictionary = nil) then
            begin
                Exit;
            end;
            if not m_dictionary.lookup_exact_full_pinyin(suffix_key, tail_results) then
            begin
                Exit;
            end;
            for tail_idx := 0 to High(tail_results) do
            begin
                if Trim(tail_results[tail_idx].comment) <> '' then
                begin
                    Continue;
                end;
                if SameText(Trim(tail_results[tail_idx].text), suffix_value) then
                begin
                    Exit(True);
                end;
            end;
        end;
    begin
        if Length(candidates) <= 1 then
        begin
            Exit;
        end;
        if not is_full_pinyin_key(lookup_text) then
        begin
            Exit;
        end;
        if Trim(candidates[0].comment) = '' then
        begin
            Exit;
        end;
        if not is_full_pinyin_key(normalize_pinyin_text(candidates[0].comment)) then
        begin
            Exit;
        end;

        top_text := Trim(candidates[0].text);
        if top_text = '' then
        begin
            Exit;
        end;
        top_units := get_candidate_text_unit_count(top_text);
        if top_units < 2 then
        begin
            Exit;
        end;

        effective_syllables := get_effective_compact_pinyin_syllables(lookup_text);
        if Length(effective_syllables) <> input_syllable_count then
        begin
            Exit;
        end;

        best_index := -1;
        best_score := Low(Integer);
        best_shared_prefix_units := -1;
        for idx := 1 to High(candidates) do
        begin
            if Trim(candidates[idx].comment) <> '' then
            begin
                Continue;
            end;
            candidate_text := Trim(candidates[idx].text);
            if get_candidate_text_unit_count(candidate_text) <> input_syllable_count then
            begin
                Continue;
            end;

            shared_prefix_units := get_shared_prefix_unit_count_local(top_text,
                candidate_text);
            if shared_prefix_units < Max(2, top_units - 1) then
            begin
                Continue;
            end;

            if shared_prefix_units < top_units then
            begin
                suffix_text := get_suffix_text_by_unit_count_local(candidate_text,
                    shared_prefix_units);
                if not is_exact_tail_completion_local(
                    build_suffix_query_key_local(shared_prefix_units), suffix_text) then
                begin
                    Continue;
                end;
            end
            else if not is_text_prefix_local(top_text, candidate_text) then
            begin
                Continue;
            end;

            if (shared_prefix_units > best_shared_prefix_units) or
                ((shared_prefix_units = best_shared_prefix_units) and
                (candidates[idx].score > best_score)) or
                ((shared_prefix_units = best_shared_prefix_units) and
                (candidates[idx].score = best_score) and (best_index < 0)) then
            begin
                best_index := idx;
                best_score := candidates[idx].score;
                best_shared_prefix_units := shared_prefix_units;
            end;
        end;

        if best_index <= 0 then
        begin
            Exit;
        end;

        picked := candidates[best_index];
        for idx := best_index downto 1 do
        begin
            candidates[idx] := candidates[idx - 1];
        end;
        candidates[0] := picked;
    end;

    procedure ensure_exact_backed_same_comment_partial_visible(
        var candidates: TncCandidateList);
    const
        c_probe_limit = 8;
    var
        top_text: string;
        top_comment: string;
        top_units: Integer;
        idx: Integer;
        candidate_text: string;
        candidate_units: Integer;
        top_units_list: TArray<string>;
        candidate_units_list: TArray<string>;
        shared_prefix_units: Integer;
        best_index: Integer;
        best_dict_weight: Integer;
        picked: TncCandidate;
        unit_idx: Integer;
    begin
        if Length(candidates) <= 1 then
        begin
            Exit;
        end;
        if is_full_pinyin_key(lookup_text) then
        begin
            Exit;
        end;
        top_comment := Trim(candidates[0].comment);
        if top_comment = '' then
        begin
            Exit;
        end;
        top_text := Trim(candidates[0].text);
        top_units := get_candidate_text_unit_count(top_text);
        if top_units < 2 then
        begin
            Exit;
        end;
        top_units_list := split_text_units(top_text);
        if Length(top_units_list) <> top_units then
        begin
            Exit;
        end;

        best_index := -1;
        best_dict_weight := Low(Integer);
        for idx := 1 to Min(c_probe_limit - 1, High(candidates)) do
        begin
            if not SameText(Trim(candidates[idx].comment), top_comment) then
            begin
                Continue;
            end;
            if not candidates[idx].has_dict_weight then
            begin
                Continue;
            end;

            candidate_text := Trim(candidates[idx].text);
            candidate_units := get_candidate_text_unit_count(candidate_text);
            if candidate_units <> top_units then
            begin
                Continue;
            end;
            candidate_units_list := split_text_units(candidate_text);
            if Length(candidate_units_list) <> top_units then
            begin
                Continue;
            end;

            shared_prefix_units := 0;
            for unit_idx := 0 to top_units - 1 do
            begin
                if not SameText(top_units_list[unit_idx],
                    candidate_units_list[unit_idx]) then
                begin
                    Break;
                end;
                Inc(shared_prefix_units);
            end;
            if shared_prefix_units < Max(1, top_units - 1) then
            begin
                Continue;
            end;
            if candidates[idx].dict_weight <= best_dict_weight then
            begin
                Continue;
            end;

            best_index := idx;
            best_dict_weight := candidates[idx].dict_weight;
        end;

        if best_index <= 0 then
        begin
            Exit;
        end;

        picked := candidates[best_index];
        while best_index > 0 do
        begin
            candidates[best_index] := candidates[best_index - 1];
            Dec(best_index);
        end;
        candidates[0] := picked;
    end;

    function is_single_text_unit(const value: string): Boolean;
    begin
        if Length(value) = 1 then
        begin
            Result := True;
            Exit;
        end;

        Result := (Length(value) = 2) and
            (Ord(value[1]) >= $D800) and (Ord(value[1]) <= $DBFF) and
            (Ord(value[2]) >= $DC00) and (Ord(value[2]) <= $DFFF);
    end;

    function try_get_single_text_unit_codepoint(const value: string; out codepoint: Integer): Boolean;
    begin
        Result := False;
        codepoint := 0;
        if Length(value) = 1 then
        begin
            codepoint := Ord(value[1]);
            Result := True;
            Exit;
        end;

        if (Length(value) = 2) and
            (Ord(value[1]) >= $D800) and (Ord(value[1]) <= $DBFF) and
            (Ord(value[2]) >= $DC00) and (Ord(value[2]) <= $DFFF) then
        begin
            codepoint := ((Ord(value[1]) - $D800) shl 10) + (Ord(value[2]) - $DC00) + $10000;
            Result := True;
        end;
    end;

    function dictionary_lookup_cached(const pinyin_key: string; out out_results: TncCandidateList): Boolean;
    var
        phase_start_tick: UInt64;
    begin
        SetLength(out_results, 0);
        if (m_dictionary = nil) or (pinyin_key = '') then
        begin
            Exit(False);
        end;

        if lookup_cache.TryGetValue(pinyin_key, out_results) then
        begin
            Inc(lookup_cache_hits);
            Exit(Length(out_results) > 0);
        end;

        Inc(lookup_cache_misses);
        phase_start_tick := GetTickCount64;
        if not m_dictionary.lookup(pinyin_key, out_results) then
        begin
            SetLength(out_results, 0);
        end;
        Inc(lookup_elapsed_ms, Int64(GetTickCount64 - phase_start_tick));
        lookup_cache.AddOrSetValue(pinyin_key, out_results);
        Result := Length(out_results) > 0;
    end;

    function dictionary_exact_lookup_cached(const pinyin_key: string;
        out out_results: TncCandidateList): Boolean;
    var
        cache_key: string;
        phase_start_tick: UInt64;
    begin
        SetLength(out_results, 0);
        if (m_dictionary = nil) or (pinyin_key = '') then
        begin
            Exit(False);
        end;

        cache_key := '#exact#' + pinyin_key;
        if lookup_cache.TryGetValue(cache_key, out_results) then
        begin
            Inc(lookup_cache_hits);
            Exit(Length(out_results) > 0);
        end;

        Inc(lookup_cache_misses);
        phase_start_tick := GetTickCount64;
        if not m_dictionary.lookup_exact_full_pinyin(pinyin_key, out_results) then
        begin
            SetLength(out_results, 0);
        end;
        Inc(lookup_elapsed_ms, Int64(GetTickCount64 - phase_start_tick));
        lookup_cache.AddOrSetValue(cache_key, out_results);
        Result := Length(out_results) > 0;
    end;

    function dictionary_prefix_lookup_cached(const pinyin_key: string;
        out out_results: TncCandidateList): Boolean;
    var
        cache_key: string;
        phase_start_tick: UInt64;
    begin
        SetLength(out_results, 0);
        if (m_dictionary = nil) or (pinyin_key = '') then
        begin
            Exit(False);
        end;

        cache_key := '#prefix#' + pinyin_key;
        if lookup_cache.TryGetValue(cache_key, out_results) then
        begin
            Inc(lookup_cache_hits);
            Exit(Length(out_results) > 0);
        end;

        Inc(lookup_cache_misses);
        phase_start_tick := GetTickCount64;
        if not m_dictionary.lookup_full_pinyin_prefix(pinyin_key, out_results) then
        begin
            SetLength(out_results, 0);
        end;
        Inc(lookup_elapsed_ms, Int64(GetTickCount64 - phase_start_tick));
        lookup_cache.AddOrSetValue(cache_key, out_results);
        Result := Length(out_results) > 0;
    end;

    function build_lightweight_sentence_candidates(const query_text: string;
        out out_candidates: TncCandidateList): Boolean;
    const
        c_light_sentence_beam_width = 12;
        c_light_sentence_long_beam_width = 6;
        c_light_sentence_emit_limit = 8;
        c_light_sentence_long_emit_limit = 6;
        c_light_sentence_exact_top_n = 6;
        c_light_sentence_long_exact_top_n = 4;
        c_light_sentence_tail_completion_top_n = 6;
        c_light_sentence_additional_segment_penalty = 120;
        c_light_sentence_single_penalty = 180;
        c_light_sentence_multi_bonus = 280;
        c_light_sentence_tail_partial_bonus = 140;
        c_light_sentence_tail_prediction_bonus = 260;
        c_light_sentence_exact_rank_step = 220;
        c_light_sentence_extended_single_min_weight = 560;
        c_light_sentence_two_single_rescue_bonus = 440;
        c_light_sentence_two_single_rescue_margin = 120;
    type
        TLightSentenceState = record
            score: Integer;
            lexical_rank_score: Integer;
            text: string;
            path: string;
            prev_text: string;
            prev_prev_text: string;
            last_segment_syllable_count: Integer;
        end;
        TLightSentenceStateArray = TArray<TLightSentenceState>;
    var
        normalized_query: string;
        syllables: TncPinyinParseResult;
        head_syllable_count: Integer;
        max_segment_len: Integer;
        tail_prefix: string;
        state_map: array of TLightSentenceStateArray;
        final_states: TLightSentenceStateArray;
        exact_sentence_subspan_cache_prepared: Boolean;
        exact_sentence_subspan_cache_ready: array of array of Boolean;
        exact_sentence_subspan_cache_weights: array of array of Integer;
        exact_sentence_subspan_cache_anchor_units: array of array of Integer;
        exact_sentence_subspan_cache_texts: array of array of string;

        function build_syllable_query_key(const start_idx: Integer;
            const syllable_count_local: Integer): string;
        var
            idx: Integer;
        begin
            Result := '';
            for idx := start_idx to start_idx + syllable_count_local - 1 do
            begin
                Result := Result + normalize_pinyin_text(syllables[idx].text);
            end;
        end;

        function get_light_sentence_beam_width_local: Integer;
        begin
            if head_syllable_count >= 10 then
            begin
                Exit(c_light_sentence_long_beam_width);
            end;

            Result := c_light_sentence_beam_width;
        end;

        function get_light_sentence_emit_limit_local: Integer;
        begin
            if head_syllable_count >= 10 then
            begin
                Exit(c_light_sentence_long_emit_limit);
            end;

            Result := c_light_sentence_emit_limit;
        end;

        function get_light_sentence_exact_top_n_local: Integer;
        begin
            if head_syllable_count >= 10 then
            begin
                Exit(c_light_sentence_long_exact_top_n);
            end;

            Result := c_light_sentence_exact_top_n;
        end;

        function get_sentence_context_bonus_scaled(const left_text: string;
            const right_text: string): Integer;
        var
            raw_bonus: Integer;
        begin
            Result := 0;
            if (m_dictionary = nil) or (left_text = '') or (right_text = '') then
            begin
                Exit;
            end;

            raw_bonus := m_dictionary.get_context_bonus(left_text, right_text);
            if raw_bonus > 0 then
            begin
                Result := raw_bonus * 4;
            end
            else
            begin
                Result := raw_bonus;
            end;
        end;

        function get_sentence_trigram_bonus_scaled(const left_left_text: string;
            const left_text: string; const right_text: string): Integer;
        var
            raw_bonus: Integer;
        begin
            Result := 0;
            if (m_dictionary = nil) or (left_left_text = '') or (left_text = '') or
                (right_text = '') then
            begin
                Exit;
            end;

            raw_bonus := m_dictionary.get_context_trigram_bonus(left_left_text,
                left_text, right_text);
            if raw_bonus > 0 then
            begin
                Result := raw_bonus * 6;
            end
            else
            begin
                Result := raw_bonus;
            end;
        end;

