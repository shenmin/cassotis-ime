        function try_get_dictionary_span_text_local(
            const query_key: string; const expected_units: Integer;
            out out_text: string; out out_bonus: Integer): Boolean;
        var
            results_local: TncCandidateList;
            result_idx_local: Integer;
            candidate_text_local: string;
            candidate_weight_local: Integer;
        begin
            Result := False;
            out_text := '';
            out_bonus := 0;
            if (query_key = '') or (expected_units <= 1) or
                (not dictionary_lookup_cached(query_key, results_local)) then
            begin
                Exit;
            end;

            for result_idx_local := 0 to High(results_local) do
            begin
                if result_idx_local >= c_dict_span_probe_limit then
                begin
                    Break;
                end;
                if Trim(results_local[result_idx_local].comment) <> '' then
                begin
                    Continue;
                end;

                candidate_text_local := Trim(results_local[result_idx_local].text);
                if (candidate_text_local = '') or
                    (get_candidate_text_unit_count(candidate_text_local) <>
                    expected_units) then
                begin
                    Continue;
                end;

                candidate_weight_local := results_local[result_idx_local].score;
                if results_local[result_idx_local].has_dict_weight and
                    (results_local[result_idx_local].dict_weight >
                    candidate_weight_local) then
                begin
                    candidate_weight_local :=
                        results_local[result_idx_local].dict_weight;
                end;
                Inc(candidate_weight_local,
                    get_directional_locative_span_bonus_local(
                    candidate_text_local));
                Inc(candidate_weight_local, get_preferred_query_phrase_bonus_local(
                    query_key, candidate_text_local));
                if candidate_weight_local < c_dict_span_min_weight then
                begin
                    Continue;
                end;

                if (not Result) or (candidate_weight_local > out_bonus) then
                begin
                    Result := True;
                    out_text := candidate_text_local;
                    out_bonus := candidate_weight_local;
                end;
            end;
        end;

        function try_get_span_text_local(const local_start_idx: Integer;
            const local_span_len: Integer; out out_text: string;
            out out_bonus: Integer; out out_is_phrase: Boolean): Boolean;
        var
            query_key_local: string;
            dict_text_local: string;
            dict_bonus_local: Integer;
        begin
            Result := False;
            out_text := '';
            out_bonus := 0;
            out_is_phrase := False;
            query_key_local := build_query_key_local(local_start_idx,
                local_span_len);
            if query_key_local = '' then
            begin
                Exit;
            end;

            if (local_span_len <= 4) and
                try_get_dictionary_span_text_local(query_key_local,
                local_span_len, dict_text_local, dict_bonus_local) then
            begin
                out_text := dict_text_local;
                out_bonus := dict_bonus_local + c_dict_span_bonus +
                    local_span_len * 120;
                out_is_phrase := True;
                Exit(True);
            end;
        end;

        function has_ambiguous_three_syllable_head_span_local: Boolean;
        const
            c_probe_limit = 8;
        var
            head_results_local: TncCandidateList;
            idx_local: Integer;
            candidate_text_local: string;
            candidate_count_local: Integer;
        begin
            Result := False;
            if input_syllable_count <> 3 then
            begin
                Exit;
            end;

            if not dictionary_lookup_cached(build_query_key_local(0, 2),
                head_results_local) then
            begin
                Exit;
            end;

            candidate_count_local := 0;
            for idx_local := 0 to High(head_results_local) do
            begin
                if idx_local >= c_probe_limit then
                begin
                    Break;
                end;
                if Trim(head_results_local[idx_local].comment) <> '' then
                begin
                    Continue;
                end;
                candidate_text_local := Trim(head_results_local[idx_local].text);
                if get_candidate_text_unit_count(candidate_text_local) <> 2 then
                begin
                    Continue;
                end;
                Inc(candidate_count_local);
                if candidate_count_local > 1 then
                begin
                    Exit(True);
                end;
            end;
        end;

        function try_build_two_span_tail_prefix_completion_local: Boolean;
        const
            c_tail_prefix_probe_limit = 8;
            c_tail_prefix_ambiguity_margin = 160;
        var
            head_text_local: string;
            head_bonus_local: Integer;
            head_is_phrase_local: Boolean;
            tail_prefix_key_local: string;
            tail_results_local: TncCandidateList;
            tail_idx_local: Integer;
            tail_text_local: string;
            tail_score_local: Integer;
            best_tail_text_local: string;
            best_tail_score_local: Integer;
            second_tail_score_local: Integer;
        begin
            Result := False;
            if input_syllable_count <> 4 then
            begin
                Exit;
            end;

            if not try_get_span_text_local(0, 2, head_text_local,
                head_bonus_local, head_is_phrase_local) then
            begin
                Exit;
            end;

            tail_prefix_key_local := build_query_key_local(2, 2);
            if (tail_prefix_key_local = '') or
                (not dictionary_prefix_lookup_cached(tail_prefix_key_local,
                tail_results_local)) then
            begin
                Exit;
            end;

            best_tail_text_local := '';
            best_tail_score_local := Low(Integer);
            second_tail_score_local := Low(Integer);
            for tail_idx_local := 0 to High(tail_results_local) do
            begin
                if tail_idx_local >= c_tail_prefix_probe_limit then
                begin
                    Break;
                end;
                if Trim(tail_results_local[tail_idx_local].comment) <> '' then
                begin
                    Continue;
                end;
                tail_text_local := Trim(tail_results_local[tail_idx_local].text);
                if get_candidate_text_unit_count(tail_text_local) <> 2 then
                begin
                    Continue;
                end;

                tail_score_local := tail_results_local[tail_idx_local].score;
                if tail_results_local[tail_idx_local].has_dict_weight and
                    (tail_results_local[tail_idx_local].dict_weight >
                    tail_score_local) then
                begin
                    tail_score_local := tail_results_local[tail_idx_local].dict_weight;
                end;
                if tail_score_local < c_dict_span_min_weight then
                begin
                    Continue;
                end;

                if tail_score_local > best_tail_score_local then
                begin
                    second_tail_score_local := best_tail_score_local;
                    best_tail_score_local := tail_score_local;
                    best_tail_text_local := tail_text_local;
                end
                else if tail_score_local > second_tail_score_local then
                begin
                    second_tail_score_local := tail_score_local;
                end;
            end;

            if best_tail_text_local = '' then
            begin
                Exit;
            end;
            if (second_tail_score_local > Low(Integer) div 2) and
                (second_tail_score_local >= best_tail_score_local -
                c_tail_prefix_ambiguity_margin) then
            begin
                Exit;
            end;

            out_candidate.text := head_text_local + best_tail_text_local;
            out_candidate.comment := '';
            out_candidate.source := cs_rule;
            out_candidate.score := c_prefix_base_score + head_bonus_local +
                best_tail_score_local + c_phrase_span_bonus * 2;
            out_candidate.has_dict_weight := True;
            out_candidate.dict_weight := out_candidate.score;
            Result := True;
        end;

        function try_get_single_text_local(const local_pos: Integer;
            out out_text: string; out out_score: Integer): Boolean;
        var
            local_results: TncCandidateList;
            local_idx: Integer;
            candidate_text_local: string;
            candidate_score_local: Integer;
        begin
            Result := False;
            out_text := get_fixed_single_text_local(
                syllables_local[local_pos].text);
            if out_text <> '' then
            begin
                out_score := 900;
                Exit(True);
            end;

            out_score := 0;
            if (m_dictionary = nil) or
                (not dictionary_lookup_cached(normalize_pinyin_text(
                syllables_local[local_pos].text), local_results)) then
            begin
                Exit;
            end;

            for local_idx := 0 to High(local_results) do
            begin
                candidate_text_local := Trim(local_results[local_idx].text);
                if get_candidate_text_unit_count(candidate_text_local) <> 1 then
                begin
                    Continue;
                end;
                if not is_preferred_partial_single_char_candidate(
                    local_results[local_idx]) then
                begin
                    Continue;
                end;

                candidate_score_local := local_results[local_idx].score;
                if local_results[local_idx].has_dict_weight and
                    (local_results[local_idx].dict_weight >
                    candidate_score_local) then
                begin
                    candidate_score_local := local_results[local_idx].dict_weight;
                end;
                if (not Result) or (candidate_score_local > out_score) then
                begin
                    Result := True;
                    out_text := candidate_text_local;
                    out_score := candidate_score_local;
                end;
            end;
        end;

        function try_build_two_syllable_head_single_tail_completion_local: Boolean;
        const
            c_min_head_weight = 420;
        var
            head_key_local: string;
            head_text_local: string;
            head_weight_local: Integer;
            tail_text_local: string;
            tail_score_local: Integer;
        begin
            Result := False;
            if input_syllable_count <> 3 then
            begin
                Exit;
            end;
            if normalize_pinyin_text(syllables_local[2].text) <> 'he' then
            begin
                Exit;
            end;

            head_key_local := build_query_key_local(0, 2);
            if (head_key_local = '') or
                (not try_get_dictionary_span_text_local(head_key_local, 2,
                head_text_local, head_weight_local)) or
                (head_weight_local < c_min_head_weight) then
            begin
                Exit;
            end;

            if (not try_get_single_text_local(2, tail_text_local,
                tail_score_local)) or (tail_text_local = '') then
            begin
                Exit;
            end;

            out_candidate.text := head_text_local + tail_text_local;
            out_candidate.comment := '';
            out_candidate.source := cs_rule;
            out_candidate.score := c_prefix_base_score + head_weight_local +
                tail_score_local + c_phrase_span_bonus;
            out_candidate.has_dict_weight := True;
            out_candidate.dict_weight := out_candidate.score;
            Result := True;
        end;
    begin
        Result := False;
        out_candidate.text := '';
        out_candidate.comment := '';
        out_candidate.score := 0;
        out_candidate.source := cs_rule;
        out_candidate.has_dict_weight := True;
        out_candidate.dict_weight := 0;

        if (m_dictionary = nil) or (lookup_text = '') or
            (input_syllable_count < 3) or
            has_strong_full_query_exact_complete_candidate_local or
            (query_has_modal_tail_suffix_local(lookup_text) and
            (not has_precise_extendable_tail_syllable_local(lookup_text))) then
        begin
            Exit;
        end;

        syllables_local := get_effective_compact_pinyin_syllables(lookup_text);
        if Length(syllables_local) <> input_syllable_count then
        begin
            Exit;
        end;

        tail_is_fragment_local := has_safe_trailing_initial_typing_state or
            ((has_short_extendable_tail_prefix_local or
            has_extendable_same_syllable_tail_local(lookup_text,
            input_syllable_count)) and
            (not is_stable_boundary_single_tail_local(
            syllables_local[High(syllables_local)].text))) or
            ((input_syllable_count = 3) and
            (not has_strong_full_query_exact_complete_candidate_local)) or
            ((input_syllable_count >= 8) and
            (not has_complete_exact_tail_phrase_local(3)) and
            (((not has_complete_exact_tail_phrase_local(2)) and
            (not is_stable_boundary_single_tail_local(
            syllables_local[High(syllables_local)].text))) or
            ((get_complete_exact_tail_phrase_weight_local(2) > 0) and
            (get_complete_exact_tail_phrase_weight_local(2) < 500)) or
            has_complete_exact_phrase_before_tail_local(2)));
        if not tail_is_fragment_local then
        begin
            Exit;
        end;
        if try_build_two_syllable_head_single_tail_completion_local then
        begin
            Result := True;
            Exit;
        end;
        if (input_syllable_count < 5) and
            ((input_syllable_count <> 3) or
            has_safe_trailing_initial_typing_state or
            (get_fixed_single_text_local(syllables_local[0].text) <> '') or
            has_ambiguous_three_syllable_head_span_local) then
        begin
            if not try_build_two_span_tail_prefix_completion_local then
            begin
                Exit;
            end;
            Result := True;
            Exit;
        end;

        prefix_count_local := Length(syllables_local) - 1;
        if prefix_count_local < 2 then
        begin
            Exit;
        end;

        tail_comment_local := '';
        for tail_idx_local := prefix_count_local to High(syllables_local) do
        begin
            tail_comment_local := tail_comment_local +
                normalize_pinyin_text(syllables_local[tail_idx_local].text);
        end;
        if tail_comment_local = '' then
        begin
            Exit;
        end;

        pos_local := 0;
        text_local := '';
        phrase_count_local := 0;
        last_span_len_local := 0;
        last_single_total_score_local := 0;
        out_candidate.score := c_prefix_base_score;
        while pos_local < prefix_count_local do
        begin
            span_len_local := Min(c_max_span, prefix_count_local - pos_local);
            while span_len_local >= 2 do
            begin
                if try_get_span_text_local(pos_local, span_len_local,
                    span_text_local, span_bonus_local,
                    span_is_phrase_local) then
                begin
                    text_local := text_local + span_text_local;
                    Inc(out_candidate.score, span_bonus_local);
                    Inc(pos_local, span_len_local);
                    Inc(phrase_count_local);
                    last_span_len_local := span_len_local;
                    last_single_total_score_local := 0;
                    Break;
                end;
                Dec(span_len_local);
            end;

            if span_len_local >= 2 then
            begin
                Continue;
            end;

            if not try_get_single_text_local(pos_local, single_text_local,
                single_score_local) then
            begin
                Exit;
            end;
            text_local := text_local + single_text_local;
            last_single_total_score_local := c_single_bonus + single_score_local;
            Inc(out_candidate.score, last_single_total_score_local);
            Inc(pos_local);
            last_span_len_local := 1;
        end;

        if (last_span_len_local = 1) and (prefix_count_local > 2) and
            ((not has_safe_trailing_initial_typing_state) or
            (input_syllable_count >= 8)) then
        begin
            text_units_local := split_text_units(text_local);
            if Length(text_units_local) = prefix_count_local then
            begin
                text_local := '';
                for unit_idx_local := 0 to High(text_units_local) - 1 do
                begin
                    text_local := text_local + text_units_local[unit_idx_local];
                end;
                tail_comment_local := normalize_pinyin_text(
                    syllables_local[prefix_count_local - 1].text) +
                    tail_comment_local;
                Dec(prefix_count_local);
                Dec(out_candidate.score, last_single_total_score_local);
            end;
        end;

        if (phrase_count_local <= 0) or
            (get_candidate_text_unit_count(text_local) <> prefix_count_local) then
        begin
            Exit;
        end;

        out_candidate.text := text_local;
        out_candidate.comment := tail_comment_local;
        Inc(out_candidate.score, prefix_count_local * 260);
        out_candidate.dict_weight := out_candidate.score;
        Result := True;
    end;

    function try_build_exact_span_chain_candidate_local(
        out out_candidate: TncCandidate; out out_encoded_path: string): Boolean;
    const
        c_min_syllables = 4;
        c_max_span = 4;
        c_span_probe_limit = 12;
        c_min_span_weight = 480;
        c_min_long_span_weight = 180;
        c_min_long_two_syllable_span_weight = 300;
        c_ambiguous_span_margin = 320;
        c_ambiguity_min_competitor_weight = 300;
        c_weak_fixed_head_phrase_weight = 700;
        c_base_score = 70000;
        c_span_score_bonus = 900;
        c_fixed_single_bonus = 180;
    var
        syllables_local: TncPinyinParseResult;
        phrase_count_local: Integer;
        text_local: string;
        encoded_path_local: string;
        chain_score_local: Integer;
        memo_known_local: TArray<Boolean>;
        memo_success_local: TArray<Boolean>;
        memo_text_local: TArray<string>;
        memo_path_local: TArray<string>;
        memo_score_local: TArray<Integer>;
        memo_phrase_count_local: TArray<Integer>;

        function build_query_key_local(const local_start_idx: Integer;
            const local_len: Integer): string;
        var
            local_idx: Integer;
        begin
            Result := '';
            for local_idx := local_start_idx to local_start_idx + local_len - 1 do
            begin
                Result := Result + normalize_pinyin_text(
                    syllables_local[local_idx].text);
            end;
        end;

        function get_fixed_single_text_local(const syllable_text: string): string;
        var
            normalized_syllable_local: string;
        begin
            Result := '';
            normalized_syllable_local := normalize_pinyin_text(syllable_text);
            if normalized_syllable_local = 'wo' then
            begin
                Result := string(Char($6211));
            end
            else if normalized_syllable_local = 'ni' then
            begin
                Result := string(Char($4F60));
            end
            else if normalized_syllable_local = 'ta' then
            begin
                Result := string(Char($4ED6));
            end
            else if normalized_syllable_local = 'he' then
            begin
                Result := string(Char($548C));
            end
            else if normalized_syllable_local = 'qu' then
            begin
                Result := string(Char($53BB));
            end
            else if normalized_syllable_local = 'shi' then
            begin
                Result := string(Char($662F));
            end
            else if normalized_syllable_local = 'yi' then
            begin
                Result := string(Char($4E00));
            end
            else if normalized_syllable_local = 'zai' then
            begin
                Result := string(Char($5728));
            end
            else if normalized_syllable_local = 'de' then
            begin
                Result := string(Char($7684));
            end
            else if normalized_syllable_local = 'le' then
            begin
                Result := string(Char($4E86));
            end
            else if normalized_syllable_local = 'ba' then
            begin
                Result := string(Char($5427));
            end;
        end;

        function is_place_noun_unit_local(const unit_value: string): Boolean;
        begin
            Result := (unit_value = string(Char($5BB6))) or
                (unit_value = string(Char($5E97))) or
                (unit_value = string(Char($5C4B))) or
                (unit_value = string(Char($697C))) or
                (unit_value = string(Char($57CE))) or
                (unit_value = string(Char($6751))) or
                (unit_value = string(Char($53BF))) or
                (unit_value = string(Char($5E02))) or
                (unit_value = string(Char($6821))) or
                (unit_value = string(Char($9662))) or
                (unit_value = string(Char($5382))) or
                (unit_value = string(Char($9986))) or
                (unit_value = string(Char($7AD9))) or
                (unit_value = string(Char($5C40))) or
                (unit_value = string(Char($6240))) or
                (unit_value = string(Char($56ED))) or
                (unit_value = string(Char($533A))) or
                (unit_value = string(Char($5708))) or
                (unit_value = string(Char($8DEF))) or
                (unit_value = string(Char($8857))) or
                (unit_value = string(Char($95E8))) or
                (unit_value = string(Char($5BA4))) or
                (unit_value = string(Char($623F))) or
                (unit_value = string(Char($5385))) or
                (unit_value = string(Char($573A))) or
                (unit_value = string(Char($53F8)));
        end;

        function get_min_span_weight_local(const local_span_len: Integer): Integer;
        begin
            if local_span_len >= 3 then
            begin
                Result := c_min_long_span_weight;
            end
            else if input_syllable_count >= 7 then
            begin
                Result := c_min_long_two_syllable_span_weight;
            end
            else
            begin
                Result := c_min_span_weight;
            end;
        end;

        function is_directional_locative_text_local(const text_value: string): Boolean;
        begin
            Result := get_directional_locative_span_bonus_local(text_value) > 0;
        end;

        function has_place_context_before_span_local(const local_pos: Integer): Boolean;
        const
            c_context_probe_limit = 8;
        var
            back_len_local: Integer;
            context_key_local: string;
            context_results_local: TncCandidateList;
            result_idx_local: Integer;
            context_text_local: string;
            context_units_local: TArray<string>;
        begin
            Result := False;
            if local_pos <= 0 then
            begin
                Exit;
            end;

            for back_len_local := 1 to Min(4, local_pos) do
            begin
                context_key_local := build_query_key_local(
                    local_pos - back_len_local, back_len_local);
                if (context_key_local = '') or
                    (not dictionary_exact_lookup_cached(context_key_local,
                    context_results_local)) then
                begin
                    Continue;
                end;

                for result_idx_local := 0 to High(context_results_local) do
                begin
                    if result_idx_local >= c_context_probe_limit then
                    begin
                        Break;
                    end;
                    if Trim(context_results_local[result_idx_local].comment) <> '' then
                    begin
                        Continue;
                    end;

                    context_text_local := Trim(context_results_local[result_idx_local].text);
                    context_units_local := split_text_units(context_text_local);
                    if (Length(context_units_local) > 0) and
                        is_place_noun_unit_local(
                        context_units_local[High(context_units_local)]) then
                    begin
                        Exit(True);
                    end;
                end;
            end;
        end;

        function has_directional_locative_context_for_span_local(
            const local_pos: Integer; const expected_units: Integer): Boolean;
        var
            next_key_local: string;
        begin
            Result := False;
            if (expected_units <> 2) or
                (not has_place_context_before_span_local(local_pos)) then
            begin
                Exit;
            end;

            if local_pos + expected_units >= Length(syllables_local) then
            begin
                Exit(True);
            end;

            next_key_local := normalize_pinyin_text(
                syllables_local[local_pos + expected_units].text);
            if next_key_local = 'de' then
            begin
                Result := True;
            end;
        end;

        function get_directional_locative_context_bonus_local(
            const candidate_text: string; const local_pos: Integer;
            const expected_units: Integer): Integer;
        const
            c_place_context_directional_bonus = 520;
        begin
            Result := 0;
            if is_directional_locative_text_local(candidate_text) and
                has_directional_locative_context_for_span_local(local_pos,
                expected_units) then
            begin
                Result := c_place_context_directional_bonus;
            end;
        end;

        function try_get_dictionary_span_text_local(
            const query_key: string; const expected_units: Integer;
            const required_tail_text: string; const local_pos: Integer;
            out out_text: string;
            out out_weight: Integer; out out_is_ambiguous: Boolean): Boolean;
        var
            results_local: TncCandidateList;
            result_idx_local: Integer;
            candidate_text_local: string;
            candidate_weight_local: Integer;
            candidate_preferred_bonus_local: Integer;
            direction_bonus_local: Integer;
            direction_context_bonus_local: Integer;
            has_directional_context_local: Boolean;
            has_directional_candidate_local: Boolean;
            candidate_units_local: TArray<string>;
            second_weight_local: Integer;
            valid_count_local: Integer;
        begin
            Result := False;
            out_text := '';
            out_weight := 0;
            out_is_ambiguous := False;
            second_weight_local := Low(Integer);
            valid_count_local := 0;
            if (query_key = '') or (expected_units <= 1) or
                (not dictionary_exact_lookup_cached(query_key, results_local)) then
            begin
                Exit;
            end;

            has_directional_context_local :=
                has_directional_locative_context_for_span_local(local_pos,
                expected_units);
            has_directional_candidate_local := False;
            if has_directional_context_local then
            begin
                for result_idx_local := 0 to High(results_local) do
                begin
                    if result_idx_local >= c_span_probe_limit then
                    begin
                        Break;
                    end;
                    if Trim(results_local[result_idx_local].comment) <> '' then
                    begin
                        Continue;
                    end;
                    candidate_text_local := Trim(results_local[result_idx_local].text);
                    if (candidate_text_local <> '') and
                        (get_candidate_text_unit_count(candidate_text_local) =
                        expected_units) and
                        is_directional_locative_text_local(candidate_text_local) then
                    begin
                        has_directional_candidate_local := True;
                        Break;
                    end;
                end;
            end;

            for result_idx_local := 0 to High(results_local) do
            begin
                if result_idx_local >= c_span_probe_limit then
                begin
                    Break;
                end;
                if Trim(results_local[result_idx_local].comment) <> '' then
                begin
                    Continue;
                end;

                candidate_text_local := Trim(results_local[result_idx_local].text);
                if (candidate_text_local = '') or
                    (get_candidate_text_unit_count(candidate_text_local) <>
                    expected_units) then
                begin
                    Continue;
                end;
                candidate_preferred_bonus_local :=
                    get_preferred_query_phrase_bonus_local(query_key,
                    candidate_text_local);
                if has_directional_context_local and
                    has_directional_candidate_local and
                    (not is_directional_locative_text_local(candidate_text_local)) then
                begin
                    candidate_preferred_bonus_local := 0;
                end;
                if required_tail_text <> '' then
                begin
                    candidate_units_local := split_text_units(candidate_text_local);
                    if (Length(candidate_units_local) <> expected_units) or
                        (candidate_units_local[High(candidate_units_local)] <>
                        required_tail_text) then
                    begin
                        if candidate_preferred_bonus_local <= 0 then
                        begin
                            Continue;
                        end;
                    end;
                end;

                candidate_weight_local := results_local[result_idx_local].score;
                if results_local[result_idx_local].has_dict_weight and
                    (results_local[result_idx_local].dict_weight >
                    candidate_weight_local) then
                begin
                    candidate_weight_local :=
                        results_local[result_idx_local].dict_weight;
                end;
                direction_bonus_local :=
                    get_directional_locative_span_bonus_local(
                    candidate_text_local);
                direction_context_bonus_local :=
                    get_directional_locative_context_bonus_local(
                    candidate_text_local, local_pos, expected_units);
                Inc(candidate_weight_local, direction_bonus_local);
                Inc(candidate_weight_local,
                    direction_context_bonus_local);
                Inc(candidate_weight_local, candidate_preferred_bonus_local);
                if candidate_weight_local >= c_ambiguity_min_competitor_weight then
                begin
                    Inc(valid_count_local);
                end;
                if candidate_weight_local <
                    get_min_span_weight_local(expected_units) then
                begin
                    second_weight_local := Max(second_weight_local,
                        candidate_weight_local);
                    Continue;
                end;

                if (not Result) or (candidate_weight_local > out_weight) then
                begin
                    if Result then
                    begin
                        second_weight_local := Max(second_weight_local,
                            out_weight);
                    end;
                    Result := True;
                    out_text := candidate_text_local;
                    out_weight := candidate_weight_local;
                end
                else
                begin
                    second_weight_local := Max(second_weight_local,
                        candidate_weight_local);
                end;
            end;

            if Result and (valid_count_local > 1) and
                (second_weight_local >= out_weight - c_ambiguous_span_margin) then
            begin
                out_is_ambiguous := True;
            end;
        end;

        function combine_path_segments_local(const head_path: string;
            const tail_path: string): string;
        begin
            Result := head_path;
            if tail_path = '' then
            begin
                Exit;
            end;
            if Result <> '' then
            begin
                Result := Result + string(Char($0003));
            end;
            Result := Result + tail_path;
        end;

        function get_first_path_segment_local(const encoded_path: string): string;
        var
            separator_pos_local: Integer;
        begin
            Result := Trim(encoded_path);
            if Result = '' then
            begin
                Exit;
            end;
            separator_pos_local := Pos(c_segment_path_separator, Result);
            if separator_pos_local > 0 then
            begin
                Result := Copy(Result, 1, separator_pos_local - 1);
            end;
        end;

        function get_following_context_bonus_local(const head_text: string;
            const tail_path: string): Integer;
        var
            tail_head_text_local: string;
        begin
            Result := 0;
            if (m_dictionary = nil) or (Trim(head_text) = '') or
                (Trim(tail_path) = '') then
            begin
                Exit;
            end;

            tail_head_text_local := get_first_path_segment_local(tail_path);
            if tail_head_text_local <> '' then
            begin
                Result := m_dictionary.get_context_bonus(head_text,
                    tail_head_text_local);
            end;
        end;

        function try_get_dictionary_single_text_local(const query_key: string;
            out out_text: string; out out_weight: Integer): Boolean;
        var
            results_local: TncCandidateList;
            result_idx_local: Integer;
            candidate_text_local: string;
            candidate_weight_local: Integer;
        begin
            Result := False;
            out_text := '';
            out_weight := 0;
            if (query_key = '') or
                (not dictionary_exact_lookup_cached(query_key, results_local)) then
            begin
                Exit;
            end;

            for result_idx_local := 0 to High(results_local) do
            begin
                if result_idx_local >= c_span_probe_limit then
                begin
                    Break;
                end;
                if Trim(results_local[result_idx_local].comment) <> '' then
                begin
                    Continue;
                end;

                candidate_text_local := Trim(results_local[result_idx_local].text);
                if (candidate_text_local = '') or
                    (get_candidate_text_unit_count(candidate_text_local) <> 1) then
                begin
                    Continue;
                end;

                candidate_weight_local := results_local[result_idx_local].score;
                if results_local[result_idx_local].has_dict_weight and
                    (results_local[result_idx_local].dict_weight >
                    candidate_weight_local) then
                begin
                    candidate_weight_local :=
                        results_local[result_idx_local].dict_weight;
                end;
                Inc(candidate_weight_local, get_preferred_query_phrase_bonus_local(
                    query_key, candidate_text_local));
                if (not Result) or (candidate_weight_local > out_weight) then
                begin
                    Result := True;
                    out_text := candidate_text_local;
                    out_weight := candidate_weight_local;
                end;
            end;
        end;

        function is_motion_tail_syllable_local(const syllable_text: string): Boolean;
        var
            normalized_local: string;
        begin
            normalized_local := normalize_pinyin_text(syllable_text);
            Result := (normalized_local = 'qu') or (normalized_local = 'lai') or
                (normalized_local = 'dao');
        end;

        function try_get_locative_li_span_text_local(const local_pos: Integer;
            out out_text: string; out out_weight: Integer): Boolean;
        const
            c_locative_li_motion_bonus = 3600;
        var
            head_key_local: string;
            local_results: TncCandidateList;
            local_idx: Integer;
            candidate_text_local: string;
            candidate_weight_local: Integer;
        begin
            Result := False;
            out_text := '';
            out_weight := 0;
            if (local_pos < 0) or (local_pos + 2 > High(syllables_local)) or
                (normalize_pinyin_text(syllables_local[local_pos + 1].text) <> 'li') or
                (not is_motion_tail_syllable_local(
                syllables_local[local_pos + 2].text)) then
            begin
                Exit;
            end;

            head_key_local := normalize_pinyin_text(syllables_local[local_pos].text);
            if (head_key_local = '') or
                (not dictionary_exact_lookup_cached(head_key_local, local_results)) then
            begin
                Exit;
            end;

            for local_idx := 0 to High(local_results) do
            begin
                if local_idx >= c_span_probe_limit then
                begin
                    Break;
                end;
                if Trim(local_results[local_idx].comment) <> '' then
                begin
                    Continue;
                end;

                candidate_text_local := Trim(local_results[local_idx].text);
                if (get_candidate_text_unit_count(candidate_text_local) <> 1) or
                    (not is_place_noun_unit_local(candidate_text_local)) then
                begin
                    Continue;
                end;

                candidate_weight_local := local_results[local_idx].score;
                if local_results[local_idx].has_dict_weight and
                    (local_results[local_idx].dict_weight > candidate_weight_local) then
                begin
                    candidate_weight_local := local_results[local_idx].dict_weight;
                end;
                Inc(candidate_weight_local, c_locative_li_motion_bonus);
                if (not Result) or (candidate_weight_local > out_weight) then
                begin
                    Result := True;
                    out_text := candidate_text_local + string(Char($91CC));
                    out_weight := candidate_weight_local;
                end;
            end;
        end;

        function try_get_locative_li_motion_span_text_local(const local_pos: Integer;
            out out_text: string; out out_path: string; out out_weight: Integer): Boolean;
        const
            c_locative_motion_span_bonus = 480;
        var
            locative_text_local: string;
            locative_weight_local: Integer;
            tail_key_local: string;
            previous_key_local: string;
            preferred_tail_text_local: string;
            tail_results_local: TncCandidateList;
            tail_idx_local: Integer;
            candidate_text_local: string;
            candidate_weight_local: Integer;
            tail_text_local: string;
            tail_weight_local: Integer;
        begin
            Result := False;
            out_text := '';
            out_path := '';
            out_weight := 0;
            if (local_pos < 0) or (local_pos + 2 > High(syllables_local)) or
                (not try_get_locative_li_span_text_local(local_pos,
                locative_text_local, locative_weight_local)) then
            begin
                Exit;
            end;

            tail_key_local := normalize_pinyin_text(
                syllables_local[local_pos + 2].text);
            previous_key_local := '';
            if local_pos > 0 then
            begin
                previous_key_local := normalize_pinyin_text(
                    syllables_local[local_pos - 1].text);
            end;

            preferred_tail_text_local := get_fixed_single_text_local(
                tail_key_local);
            if (tail_key_local = 'qu') and (previous_key_local = 'qu') then
            begin
                preferred_tail_text_local := string(Char($53D6));
            end;

            tail_text_local := '';
            tail_weight_local := Low(Integer);
            if (preferred_tail_text_local <> '') and
                dictionary_exact_lookup_cached(tail_key_local,
                tail_results_local) then
            begin
                for tail_idx_local := 0 to High(tail_results_local) do
                begin
                    if tail_idx_local >= c_span_probe_limit then
                    begin
                        Break;
                    end;
                    if Trim(tail_results_local[tail_idx_local].comment) <> '' then
                    begin
                        Continue;
                    end;

                    candidate_text_local := Trim(tail_results_local[tail_idx_local].text);
                    if (get_candidate_text_unit_count(candidate_text_local) <> 1) or
                        (candidate_text_local <> preferred_tail_text_local) then
                    begin
                        Continue;
                    end;

                    candidate_weight_local := tail_results_local[tail_idx_local].score;
                    if tail_results_local[tail_idx_local].has_dict_weight and
                        (tail_results_local[tail_idx_local].dict_weight >
                        candidate_weight_local) then
                    begin
                        candidate_weight_local :=
                            tail_results_local[tail_idx_local].dict_weight;
                    end;
                    tail_text_local := candidate_text_local;
                    tail_weight_local := candidate_weight_local;
                    Break;
                end;
            end;

            if tail_text_local = '' then
            begin
                if not try_get_dictionary_single_text_local(tail_key_local,
                    tail_text_local, tail_weight_local) then
                begin
                    Exit;
                end;
            end;

            out_text := locative_text_local + tail_text_local;
            out_path := combine_path_segments_local(locative_text_local,
                tail_text_local);
            out_weight := locative_weight_local + tail_weight_local +
                c_locative_motion_span_bonus;
            Inc(out_weight, get_following_context_bonus_local(locative_text_local,
                tail_text_local));
            Result := True;
        end;

        function try_resolve_final_three_syllable_span_text_local(
            const local_start: Integer; out out_text: string; out out_path: string;
            out out_weight: Integer): Boolean;
        var
            left_key_local: string;
            right_key_local: string;
            left_text_local: string;
            right_text_local: string;
            left_weight_local: Integer;
            right_weight_local: Integer;
            left_ambiguous_local: Boolean;
        begin
            Result := False;
            out_text := '';
            out_path := '';
            out_weight := 0;
            if (input_syllable_count > 8) or (local_start < 0) or
                (local_start + 2 <> High(syllables_local)) then
            begin
                Exit;
            end;

            left_key_local := build_query_key_local(local_start, 2);
            right_key_local := build_query_key_local(local_start + 2, 1);
            if (not try_get_dictionary_span_text_local(left_key_local, 2, '',
                local_start,
                left_text_local, left_weight_local, left_ambiguous_local)) or
                (left_ambiguous_local and (input_syllable_count < 7)) or
                (not try_get_dictionary_single_text_local(right_key_local,
                right_text_local, right_weight_local)) then
            begin
                Exit;
            end;

            out_text := left_text_local + right_text_local;
            out_path := combine_path_segments_local(left_text_local,
                right_text_local);
            out_weight := left_weight_local + right_weight_local;
            if m_dictionary <> nil then
            begin
                Inc(out_weight, m_dictionary.get_context_bonus(left_text_local,
                    right_text_local));
            end;
            Result := True;
        end;

        function has_resolved_final_tail_three_syllable_span_local: Boolean;
        var
            dummy_text_local: string;
            dummy_path_local: string;
            dummy_weight_local: Integer;
        begin
            Result := (Length(syllables_local) >= 3) and
                try_resolve_final_three_syllable_span_text_local(
                Length(syllables_local) - 3, dummy_text_local, dummy_path_local,
                dummy_weight_local);
        end;

        function try_build_from_pos_local(const local_pos: Integer;
            out out_text: string; out out_path: string; out out_score: Integer;
            out out_phrase_count: Integer): Boolean;
        var
            local_span_len: Integer;
            local_span_text: string;
            local_span_weight: Integer;
            local_span_ambiguous: Boolean;
            local_span_path: string;
            locative_span_text: string;
            locative_span_path: string;
            locative_span_weight: Integer;
            local_single_text: string;
            local_tail_text: string;
            local_tail_path: string;
            local_tail_score: Integer;
            local_tail_phrase_count: Integer;
            local_candidate_text: string;
            local_candidate_path: string;
            local_candidate_score: Integer;
            local_candidate_phrase_count: Integer;
            local_best_text: string;
            local_best_path: string;
            local_best_score: Integer;
            local_best_phrase_count: Integer;
        begin
            Result := False;
            out_text := '';
            out_path := '';
            out_score := 0;
            out_phrase_count := 0;

            if local_pos >= Length(syllables_local) then
            begin
                Result := True;
                Exit;
            end;

            if memo_known_local[local_pos] then
            begin
                Result := memo_success_local[local_pos];
                if Result then
                begin
                    out_text := memo_text_local[local_pos];
                    out_path := memo_path_local[local_pos];
                    out_score := memo_score_local[local_pos];
                    out_phrase_count := memo_phrase_count_local[local_pos];
                end;
                Exit;
            end;

            memo_known_local[local_pos] := True;
            local_best_text := '';
            local_best_path := '';
            local_best_score := Low(Integer);
            local_best_phrase_count := -1;

            for local_span_len := Min(c_max_span,
                Length(syllables_local) - local_pos) downto 2 do
            begin
                if local_span_len > 2 then
                begin
                    local_single_text := get_fixed_single_text_local(
                        syllables_local[local_pos + local_span_len - 1].text);
                end
                else
                begin
                    local_single_text := '';
                end;

                if try_get_dictionary_span_text_local(
                    build_query_key_local(local_pos, local_span_len),
                    local_span_len, local_single_text, local_pos, local_span_text,
                    local_span_weight, local_span_ambiguous) then
                begin
                    local_span_path := local_span_text;
                    if (local_span_len = 3) and
                        try_get_locative_li_motion_span_text_local(local_pos,
                        locative_span_text, locative_span_path,
                        locative_span_weight) and
                        (locative_span_weight > local_span_weight) then
                    begin
                        local_span_text := locative_span_text;
                        local_span_path := locative_span_path;
                        local_span_weight := locative_span_weight;
                        local_span_ambiguous := False;
                    end;
                end
                else if (local_span_len = 3) and
                    try_get_locative_li_motion_span_text_local(local_pos,
                    local_span_text, local_span_path, local_span_weight) then
                begin
                    local_span_ambiguous := False;
                end
                else if (local_span_len = 3) and
                    try_resolve_final_three_syllable_span_text_local(local_pos,
                    local_span_text, local_span_path, local_span_weight) then
                begin
                    local_span_ambiguous := False;
                end
                else
                begin
                    Continue;
                end;

                if local_span_ambiguous and (input_syllable_count < 7) then
                begin
                    Continue;
                end;
                if (local_span_len = 2) and
                    try_get_locative_li_span_text_local(local_pos,
                    locative_span_text, locative_span_weight) and
                    (locative_span_weight > local_span_weight) then
                begin
                    local_span_text := locative_span_text;
                    local_span_path := locative_span_text;
                    local_span_weight := locative_span_weight;
                    local_span_ambiguous := False;
                end;

                if (local_pos = 0) and (local_span_len = 2) and
                    (local_span_weight < c_weak_fixed_head_phrase_weight) and
                    (get_fixed_single_text_local(syllables_local[local_pos].text) <> '') then
                begin
                    Continue;
                end;

                if try_build_from_pos_local(local_pos + local_span_len,
                    local_tail_text, local_tail_path, local_tail_score,
                    local_tail_phrase_count) then
                begin
                    local_candidate_text := local_span_text + local_tail_text;
                    local_candidate_path := combine_path_segments_local(
                        local_span_path, local_tail_path);
                    local_candidate_score := local_span_weight +
                        local_span_len * c_span_score_bonus + local_tail_score +
                        get_following_context_bonus_local(local_span_text,
                        local_tail_path);
                    local_candidate_phrase_count := 1 + local_tail_phrase_count;
                    if (local_candidate_score > local_best_score) or
                        ((local_candidate_score = local_best_score) and
                        (local_candidate_phrase_count > local_best_phrase_count)) then
                    begin
                        local_best_text := local_candidate_text;
                        local_best_path := local_candidate_path;
                        local_best_score := local_candidate_score;
                        local_best_phrase_count := local_candidate_phrase_count;
                    end;
                end;
            end;

            local_single_text := get_fixed_single_text_local(
                syllables_local[local_pos].text);
            if local_single_text <> '' then
            begin
                if try_build_from_pos_local(local_pos + 1, local_tail_text,
                    local_tail_path, local_tail_score, local_tail_phrase_count) then
                begin
                    local_candidate_text := local_single_text + local_tail_text;
                    local_candidate_path := combine_path_segments_local(
                        local_single_text, local_tail_path);
                    local_candidate_score := c_fixed_single_bonus +
                        local_tail_score + get_following_context_bonus_local(
                        local_single_text, local_tail_path);
                    local_candidate_phrase_count := local_tail_phrase_count;
                    if (local_candidate_score > local_best_score) or
                        ((local_candidate_score = local_best_score) and
                        (local_candidate_phrase_count > local_best_phrase_count)) then
                    begin
                        local_best_text := local_candidate_text;
                        local_best_path := local_candidate_path;
                        local_best_score := local_candidate_score;
                        local_best_phrase_count := local_candidate_phrase_count;
                    end;
                end;
            end;

            if local_best_text = '' then
            begin
                memo_success_local[local_pos] := False;
                Exit;
            end;

            memo_success_local[local_pos] := True;
            memo_text_local[local_pos] := local_best_text;
            memo_path_local[local_pos] := local_best_path;
            memo_score_local[local_pos] := local_best_score;
            memo_phrase_count_local[local_pos] := local_best_phrase_count;
            out_text := local_best_text;
            out_path := local_best_path;
            out_score := local_best_score;
            out_phrase_count := local_best_phrase_count;
            Result := True;
        end;
    begin
        Result := False;
        out_encoded_path := '';
        out_candidate.text := '';
        out_candidate.comment := '';
        out_candidate.score := 0;
        out_candidate.source := cs_rule;
        out_candidate.has_dict_weight := True;
        out_candidate.dict_weight := 0;

        if (m_dictionary = nil) or (lookup_text = '') or
            (input_syllable_count < c_min_syllables) or
            (not is_full_pinyin_key(lookup_text)) or
            all_initial_compact_query or has_internal_dangling_initial or
            has_explicit_apostrophe_input then
        begin
            Exit;
        end;

        syllables_local := get_effective_compact_pinyin_syllables(lookup_text);
        if Length(syllables_local) <> input_syllable_count then
        begin
            Exit;
        end;
        if has_precise_extendable_tail_syllable_local(lookup_text) and
            (get_fixed_single_text_local(
            syllables_local[High(syllables_local)].text) = '') and
            (not has_complete_exact_tail_phrase_local(3)) and
            (not has_resolved_final_tail_three_syllable_span_local) and
            (not (((input_syllable_count >= 6) or
            ((Length(syllables_local) >= 3) and
            (get_fixed_single_text_local(
            syllables_local[High(syllables_local) - 2].text) <> ''))) and
            has_complete_exact_tail_phrase_local(2))) then
        begin
            Exit;
        end;

        SetLength(memo_known_local, Length(syllables_local) + 1);
        SetLength(memo_success_local, Length(syllables_local) + 1);
        SetLength(memo_text_local, Length(syllables_local) + 1);
        SetLength(memo_path_local, Length(syllables_local) + 1);
        SetLength(memo_score_local, Length(syllables_local) + 1);
        SetLength(memo_phrase_count_local, Length(syllables_local) + 1);

        if not try_build_from_pos_local(0, text_local, encoded_path_local,
            chain_score_local, phrase_count_local) then
        begin
            Exit;
        end;
        out_candidate.score := c_base_score + chain_score_local;

        if (phrase_count_local < 2) or
            (get_candidate_text_unit_count(text_local) <> input_syllable_count) then
        begin
            Exit;
        end;

        out_candidate.text := text_local;
        out_candidate.comment := '';
        out_candidate.dict_weight := out_candidate.score;
        out_encoded_path := encoded_path_local;
        Result := True;
    end;

    function try_build_stable_leading_prefix_partial_candidate_local(
        out out_candidate: TncCandidate): Boolean;
    const
        c_probe_window = 4;
        c_probe_limit = 16;
        c_prefix_bonus = 3600;
    var
        syllables_local: TncPinyinParseResult;
        prefix_count_local: Integer;
        idx_local: Integer;
        result_idx_local: Integer;
        prefix_key_local: string;
        tail_comment_local: string;
        prefix_results_local: TncCandidateList;
        candidate_text_local: string;
        candidate_units_local: Integer;
        candidate_score_local: Integer;
        best_idx_local: Integer;
        best_score_local: Integer;

        function build_syllable_key_local(const local_start_idx: Integer;
            const local_len: Integer): string;
        var
            local_idx: Integer;
        begin
            Result := '';
            for local_idx := local_start_idx to local_start_idx + local_len - 1 do
            begin
                Result := Result + normalize_pinyin_text(
                    syllables_local[local_idx].text);
            end;
        end;

        function try_build_single_text_local(const local_pos: Integer;
            out out_text: string; out out_score: Integer): Boolean;
        var
            local_results: TncCandidateList;
            local_idx: Integer;
            local_text: string;
            local_score: Integer;
        begin
            Result := False;
            out_text := '';
            out_score := 0;
            if (m_dictionary = nil) or
                (not m_dictionary.lookup(normalize_pinyin_text(
                syllables_local[local_pos].text), local_results)) then
            begin
                Exit;
            end;

            for local_idx := 0 to High(local_results) do
            begin
                local_text := Trim(local_results[local_idx].text);
                if get_candidate_text_unit_count(local_text) <> 1 then
                begin
                    Continue;
                end;

                local_score := local_results[local_idx].score;
                if local_results[local_idx].has_dict_weight and
                    (local_results[local_idx].dict_weight > local_score) then
                begin
                    local_score := local_results[local_idx].dict_weight;
                end;
                if (not Result) or (local_score > out_score) then
                begin
                    Result := True;
                    out_text := local_text;
                    out_score := local_score;
                end;
            end;
        end;

        function try_build_preferred_prefix_text_local(
            const local_prefix_count: Integer; out out_text: string;
            out out_score: Integer): Boolean;
        const
            c_max_span = 4;
            c_span_probe_limit = 12;
        var
            local_pos: Integer;
            local_span_len: Integer;
            local_query_key: string;
            local_text: string;
            local_bonus: Integer;
            local_units: TArray<string>;
            local_single_score: Integer;
            phrase_count_local: Integer;
            matched_local: Boolean;

            function try_get_dictionary_span_text_local(
                const local_query_key: string; const local_unit_count: Integer;
                out out_span_text: string; out out_span_score: Integer): Boolean;
            var
                local_results: TncCandidateList;
                local_idx: Integer;
                current_text: string;
                current_score: Integer;
            begin
                Result := False;
                out_span_text := '';
                out_span_score := 0;
                if (local_query_key = '') or
                    ((not dictionary_exact_lookup_cached(local_query_key,
                    local_results)) and
                    (not dictionary_lookup_cached(local_query_key,
                    local_results))) then
                begin
                    Exit;
                end;

                for local_idx := 0 to High(local_results) do
                begin
                    if local_idx >= c_span_probe_limit then
                    begin
                        Break;
                    end;
                    if Trim(local_results[local_idx].comment) <> '' then
                    begin
                        Continue;
                    end;

                    current_text := Trim(local_results[local_idx].text);
                    if (current_text = '') or
                        (get_candidate_text_unit_count(current_text) <>
                        local_unit_count) then
                    begin
                        Continue;
                    end;

                    current_score := local_results[local_idx].score;
                    if local_results[local_idx].has_dict_weight and
                        (local_results[local_idx].dict_weight > current_score) then
                    begin
                        current_score := local_results[local_idx].dict_weight;
                    end;

                    if (not Result) or (current_score > out_span_score) then
                    begin
                        Result := True;
                        out_span_text := current_text;
                        out_span_score := current_score;
                    end;
                end;
            end;
        begin
            Result := False;
            out_text := '';
            out_score := 0;
            local_pos := 0;
            phrase_count_local := 0;
            while local_pos < local_prefix_count do
            begin
                matched_local := False;
                local_span_len := Min(c_max_span,
                    local_prefix_count - local_pos);
                while local_span_len >= 2 do
                begin
                    local_query_key := build_syllable_key_local(local_pos,
                        local_span_len);
                    if try_get_preferred_query_phrase_text_local(
                        local_query_key, local_text, local_bonus) then
                    begin
                        local_units := split_text_units(local_text);
                        if Length(local_units) = local_span_len then
                        begin
                            out_text := out_text + local_text;
                            Inc(out_score, local_bonus +
                                local_span_len * 260);
                            Inc(local_pos, local_span_len);
                            Inc(phrase_count_local);
                            matched_local := True;
                            Break;
                        end;
                    end;
                    if (local_span_len <= 3) and
                        try_get_dictionary_span_text_local(local_query_key,
                        local_span_len, local_text, local_bonus) then
                    begin
                        out_text := out_text + local_text;
                        Inc(out_score, 1200 + local_bonus +
                            local_span_len * 220);
                        Inc(local_pos, local_span_len);
                        Inc(phrase_count_local);
                        matched_local := True;
                        Break;
                    end;
                    Dec(local_span_len);
                end;

                if matched_local then
                begin
                    Continue;
                end;

                if (phrase_count_local <= 0) or
                    (not try_build_single_text_local(local_pos, local_text,
                    local_single_score)) then
                begin
                    Exit;
                end;
                out_text := out_text + local_text;
                Inc(out_score, 500 + local_single_score);
                Inc(local_pos);
            end;

            Result := (phrase_count_local > 0) and
                (get_candidate_text_unit_count(out_text) = local_prefix_count);
        end;

        procedure normalize_candidate_to_prefix_partial_local(
            var io_candidate: TncCandidate; const local_prefix_count: Integer;
            const local_tail_comment: string);
        var
            local_units: TArray<string>;
            local_idx: Integer;
            local_text: string;
        begin
            local_units := split_text_units(Trim(io_candidate.text));
            if (local_prefix_count <= 0) or
                (Length(local_units) < local_prefix_count) then
            begin
                Exit;
            end;

            local_text := '';
            for local_idx := 0 to local_prefix_count - 1 do
            begin
                local_text := local_text + local_units[local_idx];
            end;
            io_candidate.text := local_text;
            io_candidate.comment := local_tail_comment;
        end;
    begin
        out_candidate.text := '';
        out_candidate.comment := '';
        out_candidate.score := 0;
        out_candidate.source := cs_rule;
        out_candidate.has_dict_weight := False;
        out_candidate.dict_weight := 0;
        Result := False;
        Exit;
        if (m_dictionary = nil) or (not is_full_pinyin_key(lookup_text)) or
            (input_syllable_count < 3) then
        begin
            Exit;
        end;

        syllables_local := get_effective_compact_pinyin_syllables(lookup_text);
        if Length(syllables_local) <> input_syllable_count then
        begin
            Exit;
        end;

        for prefix_count_local := input_syllable_count - 1 downto
            Max(2, input_syllable_count - c_probe_window) do
        begin
            prefix_key_local := '';
            for idx_local := 0 to prefix_count_local - 1 do
            begin
                prefix_key_local := prefix_key_local +
                    normalize_pinyin_text(syllables_local[idx_local].text);
            end;

            tail_comment_local := '';
            for idx_local := prefix_count_local to High(syllables_local) do
            begin
                tail_comment_local := tail_comment_local +
                    normalize_pinyin_text(syllables_local[idx_local].text);
            end;

            if (prefix_key_local = '') or (tail_comment_local = '') or
                (tail_comment_local = '') then
            begin
                Continue;
            end;

            if try_build_preferred_prefix_text_local(prefix_count_local,
                candidate_text_local, candidate_score_local) then
            begin
                out_candidate.text := candidate_text_local;
                out_candidate.comment := tail_comment_local;
                out_candidate.score := candidate_score_local + c_prefix_bonus +
                    (prefix_count_local * 220) -
                    ((input_syllable_count - prefix_count_local) * 30);
                out_candidate.source := cs_rule;
                out_candidate.dict_weight := out_candidate.score;
                out_candidate.has_dict_weight := True;
                normalize_candidate_to_prefix_partial_local(out_candidate,
                    prefix_count_local, tail_comment_local);
                Exit(True);
            end;

            if not dictionary_lookup_cached(prefix_key_local,
                prefix_results_local) then
            begin
                Continue;
            end;

            best_idx_local := -1;
            best_score_local := Low(Integer);
            for result_idx_local := 0 to High(prefix_results_local) do
            begin
                if result_idx_local >= c_probe_limit then
                begin
                    Break;
                end;
                if Trim(prefix_results_local[result_idx_local].comment) <> '' then
                begin
                    Continue;
                end;

                candidate_text_local := Trim(prefix_results_local[result_idx_local].text);
                candidate_units_local := get_candidate_text_unit_count(
                    candidate_text_local);
                if (candidate_text_local = '') or
                    (candidate_units_local <> prefix_count_local) then
                begin
                    Continue;
                end;

                candidate_score_local := prefix_results_local[result_idx_local].score;
                if prefix_results_local[result_idx_local].has_dict_weight and
                    (prefix_results_local[result_idx_local].dict_weight >
                    candidate_score_local) then
                begin
                    candidate_score_local :=
                        prefix_results_local[result_idx_local].dict_weight;
                end;

                if candidate_score_local > best_score_local then
                begin
                    best_score_local := candidate_score_local;
                    best_idx_local := result_idx_local;
                end;
            end;

            if best_idx_local >= 0 then
            begin
                out_candidate := prefix_results_local[best_idx_local];
                out_candidate.comment := tail_comment_local;
                out_candidate.score := best_score_local + c_prefix_bonus +
                    (prefix_count_local * 160) -
                    ((input_syllable_count - prefix_count_local) * 30);
                out_candidate.dict_weight := out_candidate.score;
                out_candidate.has_dict_weight := True;
                normalize_candidate_to_prefix_partial_local(out_candidate,
                    prefix_count_local, tail_comment_local);
                Exit(True);
            end;
        end;
    end;

begin
    subspan_oracle_states := nil;
    subspan_oracle_texts := nil;
    subspan_oracle_scores := nil;
    subspan_oracle_engine := nil;
    subspan_oracle_budget_remaining := 0;
    preferred_exact_candidate_cache := nil;
    preferred_exact_syllable_count_cache := nil;
    preferred_exact_state_cache := nil;
    preferred_query_phrase_bonus_cache := nil;
    preferred_query_phrase_text_cache := nil;
    preferred_query_phrase_text_bonus_cache := nil;
    learned_query_choice_override_cache := nil;
    stronger_query_choice_competitor_cache := nil;
    lookup_cache := m_build_lookup_cache;
    if lookup_cache = nil then
    begin
        lookup_cache := TDictionary<string, TncCandidateList>.Create;
        m_build_lookup_cache := lookup_cache;
    end;
    try
        preferred_exact_candidate_cache := TDictionary<string, TncCandidate>.Create;
        preferred_exact_syllable_count_cache := TDictionary<string, Integer>.Create;
        preferred_exact_state_cache := TDictionary<string, Byte>.Create;
        preferred_query_phrase_bonus_cache := TDictionary<string, Integer>.Create;
        preferred_query_phrase_text_cache := TDictionary<string, string>.Create;
        preferred_query_phrase_text_bonus_cache := TDictionary<string, Integer>.Create;
        learned_query_choice_override_cache := TDictionary<string, Byte>.Create;
        stronger_query_choice_competitor_cache := TDictionary<string, Byte>.Create;
        total_start_tick := GetTickCount64;
        lookup_cache_hits := 0;
        lookup_cache_misses := 0;
        lookup_elapsed_ms := 0;
        segment_elapsed_ms := 0;
        runtime_elapsed_ms := 0;
        post_elapsed_ms := 0;
        sort_elapsed_ms := 0;
        path_search_elapsed_ms := 0;
        SetLength(explicit_apostrophe_query_syllables, 0);
        explicit_apostrophe_query_parsed := False;
        SetLength(m_candidates, 0);
        confirmed_prefix_boundary_partial_preferred := False;
        m_last_lookup_key := '';
        m_last_lookup_normalized_from := '';
        m_last_lookup_syllable_count := 0;
        m_last_three_syllable_partial_preference_kind := 0;
        m_last_three_syllable_head_exact_text := '';
        m_last_three_syllable_head_strength := 0;
        m_last_three_syllable_tail_strength := 0;
        m_last_three_syllable_first_single_strength := 0;
        m_last_three_syllable_last_single_strength := 0;
        m_last_three_syllable_head_path_bonus := 0;
        m_last_three_syllable_tail_path_bonus := 0;
        m_last_three_syllable_partial_debug_info := '';
        m_last_full_path_debug_info := '';
        m_last_lookup_debug_extra := '';
        m_last_lookup_timing_info := '';
        m_runtime_chain_text := '';
        m_runtime_common_pattern_text := '';
        m_runtime_redup_text := '';
        clear_segment_path_tracking;
        clear_lookup_bonus_caches;
        if m_composition_text = '' then
        begin
            Exit;
        end;

        has_raw_candidates := False;
        has_segment_candidates := False;
        raw_from_dictionary := False;
        lookup_text := normalize_pinyin_text(m_composition_text);
        has_safe_trailing_initial_typing_state :=
            detect_safe_trailing_initial_typing_state(m_composition_text);
        if (not has_safe_trailing_initial_typing_state) and (not is_full_pinyin_key(lookup_text)) then
        begin
            normalized_lookup_text := normalize_adjacent_swap_typo(lookup_text);
            if (normalized_lookup_text <> '') and (not SameText(normalized_lookup_text, lookup_text)) then
            begin
                m_last_lookup_normalized_from := lookup_text;
                lookup_text := normalized_lookup_text;
            end;
        end;
        m_last_lookup_key := lookup_text;
        has_explicit_apostrophe_input := Pos('''', m_composition_text) > 0;
        fallback_comment := build_pinyin_comment(m_composition_text);
        if fallback_comment = '' then
        begin
            fallback_comment := build_pinyin_comment(lookup_text);
        end;
        allow_relaxed_missing_apostrophe := False;
        has_multi_syllable_input := fallback_comment <> '';
        relaxed_missing_apostrophe_comment := build_pinyin_comment(m_composition_text, True);
        if relaxed_missing_apostrophe_comment = '' then
        begin
            relaxed_missing_apostrophe_comment := build_pinyin_comment(lookup_text, True);
        end;
        has_relaxed_missing_apostrophe_partial :=
            (relaxed_missing_apostrophe_comment <> '') and
            (not SameText(relaxed_missing_apostrophe_comment, fallback_comment));
        has_relaxed_missing_apostrophe_boundary_shift := False;
        if has_relaxed_missing_apostrophe_partial then
        begin
            has_relaxed_missing_apostrophe_boundary_shift :=
                detect_relaxed_missing_apostrophe_boundary_shift(m_composition_text);
            if (not has_relaxed_missing_apostrophe_boundary_shift) and
                (lookup_text <> m_composition_text) then
            begin
                has_relaxed_missing_apostrophe_boundary_shift :=
                    detect_relaxed_missing_apostrophe_boundary_shift(lookup_text);
            end;
        end;
        has_internal_dangling_initial := detect_internal_dangling_initial(m_composition_text);
        if has_safe_trailing_initial_typing_state then
        begin
            has_internal_dangling_initial := False;
        end;
        all_initial_compact_query := detect_all_initial_compact_query(m_composition_text);
        if m_last_lookup_normalized_from <> '' then
        begin
            // If lookup key is typo-normalized (e.g. chagn->chang), segmenting by raw input
            // is usually noisy; force dangling-initial guard to suppress that path.
            if not has_safe_trailing_initial_typing_state then
            begin
                has_internal_dangling_initial := True;
            end;
        end;
        input_syllable_count := get_input_syllable_count_for_text(m_composition_text);
        if input_syllable_count <= 0 then
        begin
            input_syllable_count := get_input_syllable_count_for_text(lookup_text);
        end;
        if (m_last_lookup_normalized_from <> '') and (not has_safe_trailing_initial_typing_state) and
            is_full_pinyin_key(lookup_text) then
        begin
            // For malformed compact typos like "chagn" -> "chang", prefer the
            // normalized full-pinyin lookup intent over raw pseudo-segmentation.
            input_syllable_count := get_input_syllable_count_for_text(lookup_text);
            if input_syllable_count <= 1 then
            begin
                has_multi_syllable_input := False;
                fallback_comment := '';
                relaxed_missing_apostrophe_comment := '';
            end;
        end;
        subspan_oracle_budget_remaining := 0;
        m_last_lookup_syllable_count := input_syllable_count;
        short_full_exact_query := has_multi_syllable_input and
            (input_syllable_count >= 2) and (input_syllable_count <= 8) and
            is_full_pinyin_key(lookup_text);
        long_full_exact_query := has_multi_syllable_input and
            (input_syllable_count >= 12) and
            is_full_pinyin_key(lookup_text);
        delayed_long_decode_mode := should_use_delayed_long_decode_mode_local;
        normalized_typo_long_query_fast_path := has_multi_syllable_input and
            (m_last_lookup_normalized_from <> '') and
            has_internal_dangling_initial and
            is_full_pinyin_key(lookup_text) and
            (input_syllable_count >= c_long_sentence_full_path_min_syllables);
        ultra_long_partial_shortfast_applied := False;
        repeated_two_syllable_query := is_repeated_two_syllable_query_text(lookup_text);
        single_char_partial_min_count := 1;
        if repeated_two_syllable_query then
        begin
            // For repeated two-syllable input like "shishi", keep extra single-char
            // continuation options visible to reduce phrase-only crowding.
            single_char_partial_min_count := 2;
        end;
        if has_multi_syllable_input and is_full_pinyin_key(lookup_text) then
        begin
            if input_syllable_count >= 6 then
            begin
                single_char_partial_min_count := Max(single_char_partial_min_count, 3);
            end
            else if input_syllable_count >= 4 then
            begin
                single_char_partial_min_count := Max(single_char_partial_min_count, 2);
            end;
        end;
        runtime_phrase_added := False;
        runtime_redup_added := False;
        full_query_exact_promoted := False;
        raw_candidates_seeded_from_runtime_only := False;
        trailing_prefix_rescue_applied := False;
        has_strong_long_sentence_prediction := False;
        strict_oracle_sentence_built := False;
        strict_oracle_sentence_ok := False;
        stable_prefix_fast_exit_active := False;
        latest_query_choice_text := '';
        SetLength(relaxed_segment_candidates, 0);
        SetLength(explicit_apostrophe_aligned_candidates, 0);
        SetLength(lightweight_sentence_candidates, 0);
        SetLength(strict_oracle_sentence_candidates, 0);
        lightweight_sentence_applied := False;
        head_only_multi_syllable := m_config.enable_segment_candidates and
            has_multi_syllable_input and
            (not short_full_exact_query) and
            (all_initial_compact_query or
                (m_config.segment_head_only_multi_syllable and
                    (not has_internal_dangling_initial) and
                    (input_syllable_count < c_long_sentence_exact_min_syllables)));
        if (m_dictionary <> nil) and normalized_typo_long_query_fast_path and
            (not all_initial_compact_query) and
            try_build_direct_preferred_subspan_sentence_candidate_local(
            direct_preferred_candidate) then
        begin
            SetLength(m_candidates, 1);
            m_candidates[0] := direct_preferred_candidate;
            ensure_forced_single_char_partial(m_candidates);
            ensure_partial_fallback_visible(m_candidates, get_candidate_limit);
            ensure_single_char_partial_visible(m_candidates,
                get_candidate_limit, single_char_partial_min_count);
            finalize_modal_tail_sentence_candidate(m_candidates);
            finalize_le_plus_modal_particle_sentence_candidate(m_candidates);
            finalize_candidates_and_prepare_exit(Format(
                'multi=%d seg=%d dangling=%d head_only=%d runtime=%d redup=%d typofast=%d prefdirect=1 earlytypo=1 allinit=%d',
                [Ord(has_multi_syllable_input), Ord(has_segment_candidates),
                Ord(has_internal_dangling_initial),
                Ord(head_only_multi_syllable),
                Ord(runtime_phrase_added), Ord(runtime_redup_added),
                Ord(normalized_typo_long_query_fast_path),
                Ord(all_initial_compact_query)]));
            Exit;
        end;
        if (m_dictionary <> nil) and has_multi_syllable_input and
            (not all_initial_compact_query) and
            (not has_internal_dangling_initial) and
            try_build_exact_span_chain_candidate_local(
            direct_chain_candidate, direct_chain_encoded_path) then
        begin
            SetLength(m_candidates, 1);
            m_candidates[0] := direct_chain_candidate;
            ensure_forced_single_char_partial(m_candidates);
            ensure_partial_fallback_visible(m_candidates,
                get_candidate_limit);
            ensure_single_char_partial_visible(m_candidates,
                get_candidate_limit, single_char_partial_min_count);
            m_candidates[0] := direct_chain_candidate;
            remember_segment_path_for_candidate(direct_chain_candidate.text,
                direct_chain_candidate.comment, direct_chain_encoded_path,
                direct_chain_candidate.dict_weight);
            finalize_preserved_candidates_and_prepare_exit(Format(
                'multi=%d seg=%d dangling=%d head_only=%d runtime=%d redup=%d exactchain=1 allinit=%d',
                [Ord(has_multi_syllable_input),
                Ord(has_segment_candidates),
                Ord(has_internal_dangling_initial),
                Ord(head_only_multi_syllable),
                Ord(runtime_phrase_added), Ord(runtime_redup_added),
                Ord(all_initial_compact_query)]),
                direct_chain_candidate);
            Exit;
        end;
        if (m_dictionary <> nil) and has_multi_syllable_input and
            (not all_initial_compact_query) and
            (not has_internal_dangling_initial) and
            try_build_fragment_prefix_partial_candidate_local(
            fragment_prefix_candidate) then
        begin
            SetLength(m_candidates, 1);
            m_candidates[0] := fragment_prefix_candidate;
            fragment_preserved_candidate := fragment_prefix_candidate;
            has_fragment_complete_exact_candidate := False;
            if dictionary_exact_lookup_cached(lookup_text, raw_candidates) then
            begin
                m_candidates := merge_candidate_lists(m_candidates,
                    raw_candidates, 0);
                if (Trim(fragment_prefix_candidate.comment) <> '') and
                    try_get_best_complete_exact_candidate_local(raw_candidates,
                    fragment_preserved_candidate) then
                begin
                    has_fragment_complete_exact_candidate := True;
                end;
            end;
            ensure_forced_single_char_partial(m_candidates);
            ensure_partial_fallback_visible(m_candidates,
                get_candidate_limit);
            ensure_single_char_partial_visible(m_candidates,
                get_candidate_limit, single_char_partial_min_count);
            if has_fragment_complete_exact_candidate then
            begin
                promote_candidate_to_front_local(m_candidates,
                    fragment_preserved_candidate);
            end
            else
            begin
                m_candidates[0] := fragment_prefix_candidate;
            end;
            finalize_preserved_candidates_and_prepare_exit(Format(
                'multi=%d seg=%d dangling=%d head_only=%d runtime=%d redup=%d fragmentprefix=1 allinit=%d',
                [Ord(has_multi_syllable_input),
                Ord(has_segment_candidates),
                Ord(has_internal_dangling_initial),
                Ord(head_only_multi_syllable),
                Ord(runtime_phrase_added), Ord(runtime_redup_added),
                Ord(all_initial_compact_query)]),
                fragment_preserved_candidate);
            Exit;
        end;
        if m_dictionary <> nil then
        begin
            if has_multi_syllable_input and (input_syllable_count >= 5) and
                (input_syllable_count <= 6) and (not all_initial_compact_query) and
                (not has_internal_dangling_initial) and
                (not query_has_modal_tail_suffix_local(lookup_text)) and
                (not has_preferred_tail_phrase_local(2)) and
