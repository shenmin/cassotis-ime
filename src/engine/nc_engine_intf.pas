    function has_extendable_trailing_prefix_query_text(const pinyin_key: string): Boolean;
    var
        effective_syllables: TncPinyinParseResult;
        local_syllable_count: Integer;
        last_syllable_text: string;
        suffix_ch: Char;
        extended_key: string;
    begin
        Result := False;
        if pinyin_key = '' then
        begin
            Exit;
        end;

        effective_syllables := get_effective_compact_pinyin_syllables(pinyin_key);
        local_syllable_count := Length(effective_syllables);
        if local_syllable_count < 4 then
        begin
            Exit;
        end;

        last_syllable_text := Trim(effective_syllables[High(effective_syllables)].text);
        if last_syllable_text = '' then
        begin
            Exit;
        end;

        for suffix_ch := 'a' to 'z' do
        begin
            extended_key := pinyin_key + suffix_ch;
            if get_effective_compact_pinyin_unit_count(extended_key) = local_syllable_count then
            begin
                Exit(True);
            end;
        end;
    end;

    procedure filter_self_composed_complete_candidates_when_normal_complete_exists;
    const
        c_weak_complete_weight_for_prefix_tail = 300;
    var
        expected_units: Integer;
        idx: Integer;
        out_idx: Integer;
        has_normal_complete: Boolean;
        strongest_normal_complete_weight: Integer;
        candidate_text: string;
        removed_count: Integer;
        normal_complete_texts: TDictionary<string, Byte>;

        function is_complete_for_query_local(const candidate: TncCandidate): Boolean;
        begin
            Result := (Trim(candidate.comment) = '') and
                (get_candidate_text_unit_count(Trim(candidate.text)) = expected_units);
        end;

        function is_normal_complete_candidate_local(
            const candidate: TncCandidate): Boolean;
        begin
            Result := is_complete_for_query_local(candidate) and
                (candidate.has_dict_weight or (candidate.source = cs_user)) and
                (not is_problematic_single_char_chain_candidate_for_query(
                lookup_text, candidate));
        end;

        function is_self_composed_complete_candidate_local(
            const candidate: TncCandidate): Boolean;
        var
            text_key_local: string;
        begin
            text_key_local := Trim(candidate.text);
            Result := is_complete_for_query_local(candidate) and
                (candidate.source = cs_rule) and
                (not candidate.has_dict_weight) and
                ((normal_complete_texts = nil) or
                (not normal_complete_texts.ContainsKey(text_key_local)));
        end;

        function has_strong_prefix_single_tail_segment_path_local(
            const candidate: TncCandidate): Boolean;
        var
            encoded_path: string;
            segment_parts: TArray<string>;
            part_idx: Integer;
            tail_text: string;
            has_multi_char_head_segment: Boolean;
        begin
            Result := False;
            if strongest_normal_complete_weight >= c_weak_complete_weight_for_prefix_tail then
            begin
                Exit;
            end;

            encoded_path := get_segment_path_for_candidate(candidate);
            if get_encoded_path_segment_count_local(encoded_path) <= 1 then
            begin
                Exit;
            end;

            segment_parts := encoded_path.Split([c_segment_path_separator]);
            if Length(segment_parts) <= 1 then
            begin
                Exit;
            end;

            has_multi_char_head_segment := False;
            for part_idx := 0 to High(segment_parts) - 1 do
            begin
                if get_candidate_text_unit_count(Trim(segment_parts[part_idx])) >= 2 then
                begin
                    has_multi_char_head_segment := True;
                    Break;
                end;
            end;
            if not has_multi_char_head_segment then
            begin
                Exit;
            end;

            tail_text := Trim(segment_parts[High(segment_parts)]);
            if (tail_text = '') or (get_candidate_text_unit_count(tail_text) <> 1) then
            begin
                Exit;
            end;
            Result := True;
        end;
    begin
        normal_complete_texts := nil;
        if (Length(m_candidates) <= 1) or (not has_multi_syllable_input) or
            (not is_full_pinyin_key(lookup_text)) then
        begin
            Exit;
        end;

        expected_units := input_syllable_count;
        if expected_units < 2 then
        begin
            Exit;
        end;

        normal_complete_texts := TDictionary<string, Byte>.Create;
        try
            has_normal_complete := False;
            strongest_normal_complete_weight := Low(Integer);
            for idx := 0 to High(m_candidates) do
            begin
                if is_normal_complete_candidate_local(m_candidates[idx]) then
                begin
                    normal_complete_texts.AddOrSetValue(
                        Trim(m_candidates[idx].text), 1);
                    has_normal_complete := True;
                    if m_candidates[idx].source = cs_user then
                    begin
                        strongest_normal_complete_weight := High(Integer);
                    end
                    else if m_candidates[idx].dict_weight >
                        strongest_normal_complete_weight then
                    begin
                        strongest_normal_complete_weight := m_candidates[idx].dict_weight;
                    end;
                end;
            end;
            if not has_normal_complete then
            begin
                Exit;
            end;

            out_idx := 0;
            removed_count := 0;
            for idx := 0 to High(m_candidates) do
            begin
                if is_self_composed_complete_candidate_local(m_candidates[idx]) and
                    (not has_strong_prefix_single_tail_segment_path_local(
                    m_candidates[idx])) then
                begin
                    Inc(removed_count);
                    Continue;
                end;

                if out_idx <> idx then
                begin
                    m_candidates[out_idx] := m_candidates[idx];
                end;
                Inc(out_idx);
            end;

            if out_idx <> Length(m_candidates) then
            begin
                SetLength(m_candidates, out_idx);
            end;

            if m_config.debug_mode and (removed_count > 0) then
            begin
                candidate_text := '';
                if Length(m_candidates) > 0 then
                begin
                    candidate_text := Trim(m_candidates[0].text);
                end;
                m_last_full_path_debug_info := m_last_full_path_debug_info +
                    Format(' selfdrop=[n=%d top=%s]', [removed_count,
                    candidate_text]);
            end;
        finally
            normal_complete_texts.Free;
        end;
    end;

    procedure finalize_lookup_timing_info;
    var
        total_elapsed_ms: Int64;
        procedure promote_preferred_three_syllable_partial_shape_local;
        var
            local_idx: Integer;
            best_idx: Integer;
            best_score: Integer;
            picked_local: TncCandidate;
            text_units_local: Integer;
            comment_syllables_local: Integer;
        begin
            if (input_syllable_count <> 3) or
                (m_last_three_syllable_partial_preference_kind <> 1) or
                (Length(m_candidates) <= 1) then
            begin
                Exit;
            end;
            if (Trim(m_candidates[0].comment) = '') and
                (m_candidates[0].has_dict_weight or (m_candidates[0].source = cs_user)) then
            begin
                Exit;
            end;

            best_idx := -1;
            best_score := Low(Integer);
            for local_idx := 0 to High(m_candidates) do
            begin
                if Trim(m_candidates[local_idx].comment) = '' then
                begin
                    Continue;
                end;
                text_units_local := get_candidate_text_unit_count(
                    Trim(m_candidates[local_idx].text));
                comment_syllables_local := get_effective_compact_pinyin_unit_count(
                    normalize_pinyin_text(Trim(m_candidates[local_idx].comment)));
                if (text_units_local <> 1) or (comment_syllables_local <> 2) then
                begin
                    Continue;
                end;
                if (best_idx < 0) or (m_candidates[local_idx].score > best_score) then
                begin
                    best_idx := local_idx;
                    best_score := m_candidates[local_idx].score;
                end;
            end;
            if best_idx <= 0 then
            begin
                Exit;
            end;

            picked_local := m_candidates[best_idx];
            for local_idx := best_idx downto 1 do
            begin
                m_candidates[local_idx] := m_candidates[local_idx - 1];
            end;
            m_candidates[0] := picked_local;
        end;
        procedure promote_high_coverage_long_partial_local;
        var
            local_idx: Integer;
            best_idx: Integer;
            best_score: Integer;
            top_units: Integer;
            text_units_local: Integer;
            comment_syllables_local: Integer;
            picked_local: TncCandidate;
        begin
            if (input_syllable_count < 5) or (Length(m_candidates) <= 1) then
            begin
                Exit;
            end;
            top_units := get_candidate_text_unit_count(Trim(m_candidates[0].text));
            if (Trim(m_candidates[0].comment) = '') and
                (top_units >= input_syllable_count - 1) then
            begin
                Exit;
            end;

            best_idx := -1;
            best_score := Low(Integer);
            for local_idx := 0 to High(m_candidates) do
            begin
                if Trim(m_candidates[local_idx].comment) = '' then
                begin
                    Continue;
                end;
                text_units_local := get_candidate_text_unit_count(
                    Trim(m_candidates[local_idx].text));
                comment_syllables_local := get_effective_compact_pinyin_unit_count(
                    normalize_pinyin_text(Trim(m_candidates[local_idx].comment)));
                if (comment_syllables_local <= 0) or
                    (text_units_local + comment_syllables_local <> input_syllable_count) or
                    (text_units_local < input_syllable_count - 2) then
                begin
                    Continue;
                end;
                if (best_idx < 0) or (text_units_local >
                    get_candidate_text_unit_count(Trim(m_candidates[best_idx].text))) or
                    ((text_units_local =
                    get_candidate_text_unit_count(Trim(m_candidates[best_idx].text))) and
                    (m_candidates[local_idx].score > best_score)) then
                begin
                    best_idx := local_idx;
                    best_score := m_candidates[local_idx].score;
                end;
            end;
            if (best_idx <= 0) or
                ((get_candidate_text_unit_count(Trim(m_candidates[best_idx].text)) <=
                top_units + 1) and (m_candidates[best_idx].score <=
                m_candidates[0].score + 512)) then
            begin
                Exit;
            end;

            picked_local := m_candidates[best_idx];
            for local_idx := best_idx downto 1 do
            begin
                m_candidates[local_idx] := m_candidates[local_idx - 1];
            end;
            m_candidates[0] := picked_local;
        end;
        function final_fixed_single_for_pinyin_local(
            const syllable_text: string): string;
        var
            normalized_syllable: string;
        begin
            Result := '';
            normalized_syllable := normalize_pinyin_text(syllable_text);
            if normalized_syllable = 'wo' then
            begin
                Result := string(Char($6211));
            end
            else if normalized_syllable = 'he' then
            begin
                Result := string(Char($548C));
            end
            else if normalized_syllable = 'yi' then
            begin
                Result := string(Char($4E00));
            end
            else if normalized_syllable = 'qu' then
            begin
                Result := string(Char($53BB));
            end
            else if normalized_syllable = 'de' then
            begin
                Result := string(Char($7684));
