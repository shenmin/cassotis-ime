        function is_valid_standalone_cjk_phrase_text_local(const value: string;
            const expected_units: Integer): Boolean;
        var
            units: TArray<string>;
            unit_idx: Integer;
            codepoint: Integer;

            function try_get_codepoint_local(const unit_text: string;
                out out_codepoint: Integer): Boolean;
            begin
                Result := False;
                out_codepoint := 0;
                if unit_text = '' then
                begin
                    Exit;
                end;

                if Length(unit_text) = 1 then
                begin
                    out_codepoint := Ord(unit_text[1]);
                    Exit(True);
                end;

                if (Length(unit_text) = 2) and
                    (Ord(unit_text[1]) >= $D800) and
                    (Ord(unit_text[1]) <= $DBFF) and
                    (Ord(unit_text[2]) >= $DC00) and
                    (Ord(unit_text[2]) <= $DFFF) then
                begin
                    out_codepoint := ((Ord(unit_text[1]) - $D800) shl 10) +
                        (Ord(unit_text[2]) - $DC00) + $10000;
                    Exit(True);
                end;
            end;
        begin
            Result := False;
            if Trim(value) = '' then
            begin
                Exit;
            end;

            units := split_text_units(Trim(value));
            if Length(units) <> expected_units then
            begin
                Exit;
            end;

            for unit_idx := 0 to High(units) do
            begin
                if (not try_get_codepoint_local(units[unit_idx], codepoint)) or
                    (codepoint < $4E00) or (codepoint > $9FFF) then
                begin
                    Exit(False);
                end;
            end;

            Result := True;
        end;

        function try_get_best_single_char_for_query_key_local(
            const query_key_local: string; out out_text: string;
            out out_score: Integer): Boolean;
        var
            local_results: TncCandidateList;
            local_idx: Integer;
            candidate_text_local: string;
            candidate_score_local: Integer;
        begin
            Result := False;
            out_text := '';
            out_score := 0;
            if (query_key_local = '') or (m_dictionary = nil) then
            begin
                Exit;
            end;

            if not m_dictionary.lookup_exact_full_pinyin(query_key_local,
                local_results) then
            begin
                Exit;
            end;

            for local_idx := 0 to High(local_results) do
            begin
                if local_idx >= c_chain_probe_limit then
                begin
                    Break;
                end;
                if Trim(local_results[local_idx].comment) <> '' then
                begin
                    Continue;
                end;

                candidate_text_local := Trim(local_results[local_idx].text);
                if (get_candidate_text_unit_count(candidate_text_local) <> 1) or
                    (not is_valid_standalone_cjk_phrase_text_local(
                    candidate_text_local, 1)) then
                begin
                    Continue;
                end;

                candidate_score_local := local_results[local_idx].score;
                if local_results[local_idx].has_dict_weight and
                    (local_results[local_idx].dict_weight > candidate_score_local) then
                begin
                    candidate_score_local := local_results[local_idx].dict_weight;
                end;
                Inc(candidate_score_local, get_preferred_query_phrase_bonus_local(
                    query_key_local, candidate_text_local));
                Dec(candidate_score_local, get_context_free_single_char_penalty_local(
                    query_key_local, candidate_text_local));

                if (not Result) or (candidate_score_local > out_score) then
                begin
                    Result := True;
                    out_text := candidate_text_local;
                    out_score := candidate_score_local;
                end;
            end;
        end;

        function try_get_best_exact_phrase_for_query_key_local(
            const query_key_local: string; const expected_units: Integer;
            out out_text: string; out out_score: Integer): Boolean;
        var
            local_results: TncCandidateList;
            local_idx: Integer;
            candidate_text_local: string;
            candidate_score_local: Integer;
        begin
            Result := False;
            out_text := '';
            out_score := 0;
            if (query_key_local = '') or (expected_units <= 0) or
                (m_dictionary = nil) then
            begin
                Exit;
            end;

            if not m_dictionary.lookup_exact_full_pinyin(query_key_local,
                local_results) then
            begin
                Exit;
            end;

            for local_idx := 0 to High(local_results) do
            begin
                if local_idx >= c_chain_lattice_probe_limit then
                begin
                    Break;
                end;
                if Trim(local_results[local_idx].comment) <> '' then
                begin
                    Continue;
                end;

                candidate_text_local := Trim(local_results[local_idx].text);
                if (get_candidate_text_unit_count(candidate_text_local) <>
                    expected_units) or
                    (not is_valid_standalone_cjk_phrase_text_local(
                    candidate_text_local, expected_units)) then
                begin
                    Continue;
                end;

                candidate_score_local :=
                    get_exact_chunk_effective_weight_local(local_results[local_idx]);
                Inc(candidate_score_local, get_preferred_query_phrase_bonus_local(
                    query_key_local, candidate_text_local));
                Inc(candidate_score_local, get_exact_query_text_bonus_local(
                    query_key_local, candidate_text_local));

                if (not Result) or (candidate_score_local > out_score) then
                begin
                    Result := True;
                    out_text := candidate_text_local;
                    out_score := candidate_score_local;
                end;
            end;
        end;

        function try_resolve_three_syllable_split_option_local(
            const start_idx: Integer; out out_option: TExactChunkChainOption): Boolean;
        var
            head_key_local: string;
            tail_key_local: string;
            combined_score_local: Integer;

            procedure consider_split_local(const left_key: string; const left_units: Integer;
                const right_key: string; const right_units: Integer);
            var
                left_text_local: string;
                right_text_local: string;
                left_score_local: Integer;
                right_score_local: Integer;
                option_local: TExactChunkChainOption;
            begin
                if not try_get_best_exact_phrase_for_query_key_local(left_key,
                    left_units, left_text_local, left_score_local) then
                begin
                    Exit;
                end;
                if right_units = 1 then
                begin
                    if not try_get_best_single_char_for_query_key_local(right_key,
                        right_text_local, right_score_local) then
                    begin
                        Exit;
                    end;
                end
                else if not try_get_best_exact_phrase_for_query_key_local(right_key,
                    right_units, right_text_local, right_score_local) then
                begin
                    Exit;
                end;

                if (left_text_local = '') or (right_text_local = '') then
                begin
                    Exit;
                end;

                combined_score_local := left_score_local + right_score_local +
                    c_chain_lattice_merge_bonus + get_exact_chunk_length_bonus_local(3) +
                    c_chain_anchor_bonus;
                if m_dictionary <> nil then
                begin
                    Inc(combined_score_local, m_dictionary.get_context_bonus(
                        left_text_local, right_text_local));
                end;

                option_local := Default(TExactChunkChainOption);
                option_local.text := left_text_local + right_text_local;
                option_local.path := left_text_local + c_segment_path_separator +
                    right_text_local;
                option_local.query_key := left_key + right_key;
                option_local.score := combined_score_local;
                option_local.segments := 2;
                option_local.has_anchor := True;
                option_local.anchor_units := 2;

                if (not Result) or (option_local.score > out_option.score) or
                    ((option_local.score = out_option.score) and
                    (option_local.segments < out_option.segments)) or
                    ((option_local.score = out_option.score) and
                    (option_local.segments = out_option.segments) and
                    (CompareText(option_local.text, out_option.text) < 0)) then
                begin
                    Result := True;
                    out_option := option_local;
                end;
            end;
        begin
            Result := False;
            out_option := Default(TExactChunkChainOption);
            if (start_idx < 0) or (start_idx + 2 > High(effective_syllables)) then
            begin
                Exit;
            end;

            head_key_local := build_query_key_local(start_idx, 2);
            tail_key_local := build_query_key_local(start_idx + 2, 1);
            consider_split_local(head_key_local, 2, tail_key_local, 1);

            head_key_local := build_query_key_local(start_idx, 1);
            tail_key_local := build_query_key_local(start_idx + 1, 2);
            consider_split_local(head_key_local, 1, tail_key_local, 2);
        end;

        function is_exact_chunk_option_better_local(
            const left_option: TExactChunkChainOption;
            const right_option: TExactChunkChainOption): Boolean;
        begin
            Result := False;
            if left_option.score > right_option.score then
            begin
                Exit(True);
            end;
            if left_option.score < right_option.score then
            begin
                Exit(False);
            end;
            if left_option.has_anchor and (not right_option.has_anchor) then
            begin
                Exit(True);
            end;
            if (not left_option.has_anchor) and right_option.has_anchor then
            begin
                Exit(False);
            end;
            if left_option.anchor_units > right_option.anchor_units then
            begin
                Exit(True);
            end;
            if left_option.anchor_units < right_option.anchor_units then
            begin
                Exit(False);
            end;
            if left_option.segments < right_option.segments then
            begin
                Exit(True);
            end;
            if left_option.segments > right_option.segments then
            begin
                Exit(False);
            end;
            if (left_option.text <> '') and
                ((right_option.text = '') or
                (CompareText(left_option.text, right_option.text) < 0)) then
            begin
                Exit(True);
            end;
        end;

        procedure sort_and_trim_exact_chunk_options_local(
            var options: TExactChunkChainOptionArray; const max_count: Integer);
        var
            option_idx: Integer;
            insert_idx: Integer;
            existing_option: TExactChunkChainOption;
        begin
            for option_idx := 1 to High(options) do
            begin
                for insert_idx := option_idx downto 1 do
                begin
                    if not is_exact_chunk_option_better_local(options[insert_idx],
                        options[insert_idx - 1]) then
                    begin
                        Break;
                    end;
                    existing_option := options[insert_idx - 1];
                    options[insert_idx - 1] := options[insert_idx];
                    options[insert_idx] := existing_option;
                end;
            end;

            if (max_count > 0) and (Length(options) > max_count) then
            begin
                SetLength(options, max_count);
            end;
        end;

        function try_collect_standalone_query_candidates_local(
            const query_key_local: string; const expected_syllables: Integer;
            out out_options: TExactChunkChainOptionArray): Boolean;
        var
            cached_state: Integer;
            cached_options_local: TExactChunkChainOptionArray;
            snapshot_candidates_local: TncCandidateList;
            snapshot_scores_local: TArray<Integer>;
            candidate_idx_local: Integer;
