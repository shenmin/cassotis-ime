        procedure prepare_exact_subspan_cache_local;
        var
            local_idx: Integer;
        begin
            if exact_subspan_cache_prepared then
            begin
                Exit;
            end;

            exact_subspan_cache_prepared := True;
            exact_subspan_cache_syllables := get_effective_compact_pinyin_syllables(lookup_text);
            if Length(exact_subspan_cache_syllables) <> input_syllable_count then
            begin
                SetLength(exact_subspan_cache_syllables, 0);
                Exit;
            end;

            syllable_count_local := Length(exact_subspan_cache_syllables);
            SetLength(exact_subspan_cache_states, syllable_count_local);
            SetLength(exact_subspan_cache_scores, syllable_count_local);
            SetLength(exact_subspan_cache_segments, syllable_count_local);
            SetLength(exact_subspan_cache_anchor_units, syllable_count_local);
            SetLength(exact_subspan_cache_has_anchor, syllable_count_local);
            SetLength(exact_subspan_cache_texts, syllable_count_local);
            SetLength(exact_subspan_cache_paths, syllable_count_local);
            for local_idx := 0 to syllable_count_local - 1 do
            begin
                SetLength(exact_subspan_cache_states[local_idx], c_span_max_syllables + 1);
                SetLength(exact_subspan_cache_scores[local_idx], c_span_max_syllables + 1);
                SetLength(exact_subspan_cache_segments[local_idx], c_span_max_syllables + 1);
                SetLength(exact_subspan_cache_anchor_units[local_idx], c_span_max_syllables + 1);
                SetLength(exact_subspan_cache_has_anchor[local_idx], c_span_max_syllables + 1);
                SetLength(exact_subspan_cache_texts[local_idx], c_span_max_syllables + 1);
                SetLength(exact_subspan_cache_paths[local_idx], c_span_max_syllables + 1);
            end;
        end;

        function build_query_key_local(const local_start_idx: Integer;
            const local_span_syllables: Integer): string;
        var
            local_idx: Integer;
        begin
            Result := '';
            if (local_start_idx < 0) or (local_span_syllables <= 0) or
                (local_start_idx + local_span_syllables - 1 > High(exact_subspan_cache_syllables)) then
            begin
                Exit;
            end;

            for local_idx := local_start_idx to
                local_start_idx + local_span_syllables - 1 do
            begin
                Result := Result +
                    normalize_pinyin_text(exact_subspan_cache_syllables[local_idx].text);
            end;
        end;

        function subspan_has_fixed_boundary_local(const local_start_idx: Integer;
            const local_span_syllables: Integer): Boolean;
        var
            local_idx: Integer;
        begin
            Result := False;
            if (local_start_idx < 0) or (local_span_syllables <= 0) or
                (local_start_idx + local_span_syllables - 1 >
                High(exact_subspan_cache_syllables)) then
            begin
                Exit;
            end;

            for local_idx := local_start_idx to
                local_start_idx + local_span_syllables - 1 do
            begin
                if get_fixed_boundary_single_char_local(
                    exact_subspan_cache_syllables[local_idx].text) <> '' then
                begin
                    Exit(True);
                end;
            end;
        end;

        function is_valid_cjk_phrase_text_local(const value: string;
            const expected_units: Integer): Boolean;
        var
            units: TArray<string>;
            unit_idx: Integer;
            codepoint: Integer;

            function try_get_codepoint_local(const unit_text: string;
                out out_codepoint: Integer): Boolean;
            begin
                Result := False;
                out_codepoint := 0;
                if unit_text = '' then
                begin
                    Exit;
                end;

                if Length(unit_text) = 1 then
                begin
                    out_codepoint := Ord(unit_text[1]);
                    Exit(True);
                end;

                if (Length(unit_text) = 2) and
                    (Ord(unit_text[1]) >= $D800) and
                    (Ord(unit_text[1]) <= $DBFF) and
                    (Ord(unit_text[2]) >= $DC00) and
                    (Ord(unit_text[2]) <= $DFFF) then
                begin
                    out_codepoint := ((Ord(unit_text[1]) - $D800) shl 10) +
                        (Ord(unit_text[2]) - $DC00) + $10000;
                    Exit(True);
                end;
            end;
        begin
            Result := False;
            if Trim(value) = '' then
            begin
                Exit;
            end;

            units := split_text_units(Trim(value));
            if Length(units) <> expected_units then
            begin
                Exit;
            end;

            for unit_idx := 0 to High(units) do
            begin
                if (not try_get_codepoint_local(units[unit_idx], codepoint)) or
                    (codepoint < $4E00) or (codepoint > $9FFF) then
                begin
                    Exit(False);
                end;
            end;

            Result := True;
        end;

        function try_get_best_subspan_standalone_query_candidate_local(
            const query_key_local: string; const expected_syllables: Integer;
            out out_text: string; out out_score: Integer): Boolean;
        const
            c_subspan_oracle_probe_limit = 8;
        var
            cached_state_local: Integer;
            snapshot_candidates_local: TncCandidateList;
            snapshot_scores_local: TArray<Integer>;
            candidate_idx_local: Integer;
            candidate_local: TncCandidate;
            candidate_text_local: string;
            candidate_units_local: Integer;
            candidate_score_local: Integer;
            best_text_local: string;
            best_score_local: Integer;
            preferred_exact_bonus_local: Integer;
            preferred_text_local: string;
            preferred_bonus_local: Integer;
            support_score_local: Integer;
            support_segments_local: Integer;
            support_path_local: string;
        begin
            Result := False;
            out_text := '';
            out_score := 0;
            preferred_text_local := '';
            preferred_bonus_local := 0;
            if (query_key_local = '') or
                (not is_full_pinyin_key(query_key_local)) or
                (expected_syllables < 3) or (expected_syllables > 8) then
            begin
                Exit;
            end;
            if m_disable_subspan_standalone_oracle > 0 then
            begin
                Exit;
            end;
            try_get_preferred_query_phrase_text_local(query_key_local,
                preferred_text_local, preferred_bonus_local);

            if subspan_oracle_states = nil then
            begin
                subspan_oracle_states := TDictionary<string, Integer>.Create;
                subspan_oracle_texts := TDictionary<string, string>.Create;
                subspan_oracle_scores := TDictionary<string, Integer>.Create;
            end;

            if subspan_oracle_states.TryGetValue(query_key_local,
                cached_state_local) then
            begin
                if cached_state_local = 1 then
                begin
                    subspan_oracle_texts.TryGetValue(query_key_local, out_text);
                    subspan_oracle_scores.TryGetValue(query_key_local, out_score);
                    Exit(out_text <> '');
                end;
                Exit(False);
            end;

            if subspan_oracle_budget_remaining <= 0 then
            begin
                Exit;
            end;

            if subspan_oracle_engine = nil then
            begin
                subspan_oracle_config := m_config;
                subspan_oracle_config.debug_mode := False;
                subspan_oracle_config.max_candidates := 6;
                subspan_oracle_engine := TncEngine.Create(subspan_oracle_config);
            end;

            Dec(subspan_oracle_budget_remaining);
            subspan_oracle_states.AddOrSetValue(query_key_local, 3);
            subspan_oracle_engine.m_disable_subspan_standalone_oracle :=
                m_disable_subspan_standalone_oracle + 1;
            subspan_oracle_engine.reset;
            subspan_oracle_engine.m_composition_text := query_key_local;
            subspan_oracle_engine.build_candidates;

            SetLength(snapshot_candidates_local,
                Length(subspan_oracle_engine.m_candidates));
            SetLength(snapshot_scores_local,
                Length(subspan_oracle_engine.m_candidates));
            for candidate_idx_local := 0 to High(subspan_oracle_engine.m_candidates) do
            begin
                snapshot_candidates_local[candidate_idx_local] :=
                    subspan_oracle_engine.m_candidates[candidate_idx_local];
                snapshot_scores_local[candidate_idx_local] :=
                    subspan_oracle_engine.get_rank_score(
                    subspan_oracle_engine.m_candidates[candidate_idx_local]);
            end;

            best_text_local := '';
            best_score_local := Low(Integer);
            for candidate_idx_local := 0 to High(snapshot_candidates_local) do
            begin
                if candidate_idx_local >= c_subspan_oracle_probe_limit then
                begin
                    Break;
                end;

                candidate_local := snapshot_candidates_local[candidate_idx_local];
                if Trim(candidate_local.comment) <> '' then
                begin
                    Continue;
                end;

                candidate_text_local := Trim(candidate_local.text);
                candidate_units_local := get_candidate_text_unit_count(
                    candidate_text_local);
                if (candidate_units_local <> expected_syllables) or
                    (not is_valid_cjk_phrase_text_local(candidate_text_local,
                    expected_syllables)) then
                begin
                    Continue;
                end;

                candidate_score_local :=
                    snapshot_scores_local[candidate_idx_local] +
                    get_preferred_query_phrase_bonus_local(query_key_local,
                    candidate_text_local);
                preferred_exact_bonus_local :=
                    get_preferred_exact_subspan_bonus_local(query_key_local,
                    candidate_text_local);
                if preferred_exact_bonus_local > 0 then
                begin
                    Inc(candidate_score_local,
                        preferred_exact_bonus_local + 12000);
                end;
                support_path_local := infer_segment_path_for_query_text_with_score(
                    query_key_local, candidate_text_local, support_score_local,
                    support_segments_local);
                if support_path_local <> '' then
                begin
                    Inc(candidate_score_local, support_score_local);
                    Inc(candidate_score_local,
                        Max(0, 2048 - (support_segments_local * 128)));
                end
                else
                begin
                    Dec(candidate_score_local, 2048);
                end;

                if candidate_score_local > best_score_local then
                begin
                    best_score_local := candidate_score_local;
                    best_text_local := candidate_text_local;
                end;
            end;

            if best_text_local <> '' then
            begin
                out_text := best_text_local;
                out_score := best_score_local;
                subspan_oracle_states.AddOrSetValue(query_key_local, 1);
                subspan_oracle_texts.AddOrSetValue(query_key_local, out_text);
                subspan_oracle_scores.AddOrSetValue(query_key_local, out_score);
                Exit(True);
            end;

            subspan_oracle_states.AddOrSetValue(query_key_local, 2);
        end;

        function try_get_best_direct_exact_candidate_local(
            const local_start_idx: Integer; const local_span_syllables: Integer;
            out resolved_text: string; out resolved_score: Integer;
            out resolved_has_anchor: Boolean; out resolved_anchor_units: Integer;
            out resolved_exact_bonus: Integer): Boolean;
        const
            c_direct_probe_limit = 8;
            c_direct_rank_step = 240;
        var
            query_key_local: string;
            exact_results_local: TncCandidateList;
            exact_only_results_local: TncCandidateList;
            result_idx_local: Integer;
            candidate_text_local: string;
            candidate_units_local: Integer;
            base_weight_local: Integer;
            best_score_local: Integer;
            best_text_local: string;
            best_anchor_units_local: Integer;
            best_has_anchor_local: Boolean;
            exact_bonus_local: Integer;
            preferred_text_local: string;
            preferred_bonus_local: Integer;
            preferred_base_weight_local: Integer;

            function preferred_phrase_matches_local: Boolean;
            begin
                Result := is_valid_cjk_phrase_text_local(preferred_text_local,
                    local_span_syllables);
            end;
        begin
            Result := False;
            resolved_text := '';
            resolved_score := 0;
            resolved_has_anchor := False;
            resolved_anchor_units := -1;
            resolved_exact_bonus := 0;
            if (local_span_syllables <= 1) then
            begin
                Exit;
            end;

            query_key_local := build_query_key_local(local_start_idx,
                local_span_syllables);
            if query_key_local = '' then
            begin
                Exit;
            end;

            preferred_text_local := '';
            preferred_bonus_local := 0;
            best_score_local := Low(Integer);
            best_text_local := '';
            best_anchor_units_local := -1;
            best_has_anchor_local := False;
            if try_get_preferred_query_phrase_text_local(query_key_local,
                preferred_text_local, preferred_bonus_local) and
                preferred_phrase_matches_local then
            begin
                preferred_base_weight_local := preferred_bonus_local +
                    (c_direct_probe_limit * c_direct_rank_step) + 12000;
                if local_span_syllables >= 3 then
                begin
                    Inc(preferred_base_weight_local, 12000);
                end;
                best_score_local := preferred_base_weight_local;
                best_text_local := preferred_text_local;
                best_has_anchor_local := local_span_syllables >= 3;
                if best_has_anchor_local then
                begin
                    best_anchor_units_local := local_span_syllables;
                    resolved_exact_bonus := Max(resolved_exact_bonus,
                        preferred_bonus_local);
                end
                else
                begin
                    best_anchor_units_local := 0;
                end;
                Result := True;
            end;

            SetLength(exact_results_local, 0);
            if lookup_exact_full_pinyin_cached_local(query_key_local,
                exact_only_results_local) then
            begin
                for result_idx_local := 0 to High(exact_only_results_local) do
                begin
                    SetLength(exact_results_local, Length(exact_results_local) + 1);
                    exact_results_local[High(exact_results_local)] :=
                        exact_only_results_local[result_idx_local];
                end;
            end;

            if Length(exact_results_local) = 0 then
            begin
                if not Result then
                begin
                    Exit;
                end;
            end;

            for result_idx_local := 0 to High(exact_results_local) do
            begin
                if result_idx_local >= c_direct_probe_limit then
                begin
                    Break;
                end;
                if Trim(exact_results_local[result_idx_local].comment) <> '' then
                begin
                    Continue;
                end;
                if is_runtime_chain_candidate(exact_results_local[result_idx_local]) or
                    is_runtime_common_pattern_candidate(exact_results_local[result_idx_local]) or
                    is_runtime_redup_candidate(exact_results_local[result_idx_local]) then
                begin
                    Continue;
                end;

                candidate_text_local := Trim(exact_results_local[result_idx_local].text);
                candidate_units_local := get_candidate_text_unit_count(candidate_text_local);
                if candidate_units_local <> local_span_syllables then
                begin
                    Continue;
                end;
                if not is_valid_cjk_phrase_text_local(candidate_text_local,
                    local_span_syllables) then
                begin
                    Continue;
                end;

                base_weight_local := exact_results_local[result_idx_local].score;
                if exact_results_local[result_idx_local].has_dict_weight then
                begin
                    if local_span_syllables <= 2 then
                    begin
                        base_weight_local :=
                            exact_results_local[result_idx_local].dict_weight;
                    end
                    else if (base_weight_local <= 0) or
                        (exact_results_local[result_idx_local].dict_weight >
                        base_weight_local) then
                    begin
                        base_weight_local :=
                            exact_results_local[result_idx_local].dict_weight;
                    end;
                end;
                Inc(base_weight_local, get_preferred_query_phrase_bonus_local(
                    query_key_local, candidate_text_local));
                exact_bonus_local := get_preferred_exact_subspan_bonus_local(
                    query_key_local, candidate_text_local);
                Inc(base_weight_local, exact_bonus_local);
                if (preferred_text_local <> '') and
                    SameText(candidate_text_local, preferred_text_local) then
                begin
                    Inc(base_weight_local, 12000);
                    if local_span_syllables >= 3 then
                    begin
                        Inc(base_weight_local, 12000);
                    end;
                end;
                Inc(base_weight_local,
                    (c_direct_probe_limit - result_idx_local) * c_direct_rank_step);
                if (local_span_syllables >= 3) and (exact_bonus_local > 0) then
                begin
                    Inc(base_weight_local, 12000);
                end;

                resolved_score := base_weight_local +
                    (local_span_syllables * local_span_syllables * c_chunk_length_bonus);
                resolved_has_anchor := local_span_syllables >= 3;
                if resolved_has_anchor then
                begin
                    Inc(resolved_score, c_chunk_anchor_bonus);
                    resolved_anchor_units := local_span_syllables;
                end
                else
                begin
                    resolved_anchor_units := 0;
                end;

                if (not Result) or (resolved_score > best_score_local) or
                    ((resolved_score = best_score_local) and
                    (CompareText(candidate_text_local, best_text_local) < 0)) then
                begin
                    Result := True;
                    best_score_local := resolved_score;
                    best_text_local := candidate_text_local;
                    best_has_anchor_local := resolved_has_anchor;
                    best_anchor_units_local := resolved_anchor_units;
                    resolved_exact_bonus := exact_bonus_local;
                end;
            end;

            if not Result then
            begin
                Exit;
            end;

            resolved_text := best_text_local;
            resolved_score := best_score_local;
            resolved_has_anchor := best_has_anchor_local;
            resolved_anchor_units := best_anchor_units_local;
        end;

        function try_get_best_three_syllable_fixed_boundary_compound_local(
            const local_start_idx: Integer; out resolved_text: string;
            out resolved_score: Integer; out resolved_has_anchor: Boolean;
            out resolved_anchor_units: Integer): Boolean;
        const
            c_compound_probe_limit = 8;
            c_fixed_compound_bonus = 4096;
            c_fixed_boundary_tail_bonus = 1800;
        var
            local_query_key: string;
            head_query_key: string;
            tail_query_key: string;
            exact_results_local: TncCandidateList;
            exact_idx_local: Integer;
            candidate_text_local: string;
            candidate_units_local: Integer;
            candidate_weight_local: Integer;
            fixed_head_text_local: string;
            fixed_tail_text_local: string;
            fixed_head_weight_local: Integer;
            fixed_tail_weight_local: Integer;
            pair_text_local: string;
            pair_bonus_local: Integer;

            function normalize_compound_weight_local(
                const raw_weight: Integer): Integer;
            begin
                Result := raw_weight;
                if Result > 240 then
                begin
                    Result := 240 + ((Result - 240) div 10);
                end;
            end;

            function get_effective_weight_local(
                const candidate: TncCandidate): Integer;
            begin
                Result := candidate.score;
                if candidate.has_dict_weight and
                    (candidate.dict_weight > Result) then
                begin
                    Result := candidate.dict_weight;
                end;
            end;

            function try_get_fixed_single_weight_local(
                const local_fixed_start_idx: Integer; const expected_text: string;
                out out_weight: Integer): Boolean;
            var
                local_key: string;
                local_results: TncCandidateList;
                local_idx: Integer;
                candidate_weight: Integer;
            begin
                Result := False;
                out_weight := 0;
                if (expected_text = '') or (m_dictionary = nil) then
                begin
                    Exit;
                end;
                local_key := normalize_pinyin_text(
                    exact_subspan_cache_syllables[local_fixed_start_idx].text);
                if (local_key = '') or
                    (not lookup_exact_full_pinyin_cached_local(local_key,
                    local_results)) then
                begin
                    Exit;
                end;
                for local_idx := 0 to High(local_results) do
                begin
                    if Trim(local_results[local_idx].comment) <> '' then
                    begin
                        Continue;
                    end;
                    if Trim(local_results[local_idx].text) <> expected_text then
                    begin
                        Continue;
                    end;
                    candidate_weight := local_results[local_idx].score;
                    if local_results[local_idx].has_dict_weight and
                        (local_results[local_idx].dict_weight > candidate_weight) then
                    begin
                        candidate_weight := local_results[local_idx].dict_weight;
                    end;
                    if candidate_weight > out_weight then
                    begin
                        out_weight := candidate_weight;
                    end;
                end;
                Result := out_weight > 0;
            end;

            procedure consider_pair_local(const left_text: string;
                const left_weight: Integer; const right_text: string;
                const right_weight: Integer);
            var
                combined_text_local: string;
                combined_score_local: Integer;
            begin
                if (left_text = '') or (right_text = '') then
                begin
                    Exit;
                end;
                combined_text_local := left_text + right_text;
                if (get_candidate_text_unit_count(combined_text_local) <> 3) or
                    (not is_valid_cjk_phrase_text_local(combined_text_local, 3)) then
                begin
                    Exit;
                end;

                combined_score_local :=
                    normalize_compound_weight_local(
                    left_weight + right_weight + c_fixed_compound_bonus) +
                    (3 * 3 * c_chunk_length_bonus) + c_chunk_anchor_bonus;
                if m_dictionary <> nil then
                begin
                    Inc(combined_score_local,
                        m_dictionary.get_context_bonus(left_text, right_text));
                    Inc(combined_score_local,
                        m_dictionary.get_base_text_prefix_bonus(
                        combined_text_local));
                end;
                Inc(combined_score_local,
                    get_preferred_exact_subspan_bonus_local(local_query_key,
                    combined_text_local));
                Inc(combined_score_local,
                    get_preferred_query_phrase_bonus_local(local_query_key,
                    combined_text_local));

                if (not Result) or (combined_score_local > resolved_score) or
                    ((combined_score_local = resolved_score) and
                    (CompareText(combined_text_local, resolved_text) < 0)) then
                begin
                    Result := True;
                    resolved_text := combined_text_local;
                    resolved_score := combined_score_local;
                    resolved_has_anchor := True;
                    resolved_anchor_units := 3;
                end;
            end;
        begin
            Result := False;
            resolved_text := '';
            resolved_score := 0;
            resolved_has_anchor := False;
            resolved_anchor_units := 0;
            if (local_start_idx < 0) or
                (local_start_idx + 2 > High(exact_subspan_cache_syllables)) then
            begin
                Exit;
            end;

            local_query_key := build_query_key_local(local_start_idx, 3);
            if local_query_key = '' then
            begin
                Exit;
            end;

            fixed_tail_text_local := get_fixed_boundary_single_char_local(
                exact_subspan_cache_syllables[local_start_idx + 2].text);
            if fixed_tail_text_local <> '' then
            begin
                if not try_get_fixed_single_weight_local(local_start_idx + 2,
                    fixed_tail_text_local, fixed_tail_weight_local) then
                begin
                    fixed_tail_weight_local := 520;
                end;
                Inc(fixed_tail_weight_local, c_fixed_boundary_tail_bonus);
                tail_query_key := normalize_pinyin_text(
                    exact_subspan_cache_syllables[local_start_idx + 2].text);
                Inc(fixed_tail_weight_local,
                    get_preferred_query_phrase_bonus_local(tail_query_key,
                    fixed_tail_text_local));

                head_query_key := build_query_key_local(local_start_idx, 2);
                if (head_query_key <> '') and
                    lookup_exact_full_pinyin_cached_local(head_query_key,
                    exact_results_local) then
                begin
                    for exact_idx_local := 0 to High(exact_results_local) do
                    begin
                        if exact_idx_local >= c_compound_probe_limit then
                        begin
                            Break;
                        end;
                        if Trim(exact_results_local[exact_idx_local].comment) <> '' then
                        begin
                            Continue;
                        end;
                        if is_runtime_chain_candidate(exact_results_local[exact_idx_local]) or
                            is_runtime_common_pattern_candidate(exact_results_local[exact_idx_local]) or
                            is_runtime_redup_candidate(exact_results_local[exact_idx_local]) then
                        begin
                            Continue;
                        end;

                        candidate_text_local := Trim(
                            exact_results_local[exact_idx_local].text);
                        candidate_units_local := get_candidate_text_unit_count(
                            candidate_text_local);
                        if (candidate_units_local <> 2) or
                            (not is_valid_cjk_phrase_text_local(
                            candidate_text_local, 2)) then
                        begin
                            Continue;
                        end;

                        candidate_weight_local :=
                            get_effective_weight_local(
                            exact_results_local[exact_idx_local]);
                        Inc(candidate_weight_local,
                            get_preferred_exact_subspan_bonus_local(
                            head_query_key, candidate_text_local));
                        Inc(candidate_weight_local,
                            get_preferred_query_phrase_bonus_local(
                            head_query_key, candidate_text_local));
                        consider_pair_local(candidate_text_local,
                            candidate_weight_local, fixed_tail_text_local,
                            fixed_tail_weight_local);
                    end;
                end;
            end;

            fixed_head_text_local := get_fixed_boundary_single_char_local(
                exact_subspan_cache_syllables[local_start_idx].text);
            if fixed_head_text_local <> '' then
            begin
                if not try_get_fixed_single_weight_local(local_start_idx,
                    fixed_head_text_local, fixed_head_weight_local) then
                begin
                    fixed_head_weight_local := 520;
                end;
                Inc(fixed_head_weight_local, c_fixed_boundary_tail_bonus);
                head_query_key := normalize_pinyin_text(
                    exact_subspan_cache_syllables[local_start_idx].text);
                Inc(fixed_head_weight_local,
                    get_preferred_query_phrase_bonus_local(head_query_key,
                    fixed_head_text_local));

                tail_query_key := build_query_key_local(local_start_idx + 1, 2);
                if (tail_query_key <> '') and
                    lookup_exact_full_pinyin_cached_local(tail_query_key,
                    exact_results_local) then
                begin
                    for exact_idx_local := 0 to High(exact_results_local) do
                    begin
                        if exact_idx_local >= c_compound_probe_limit then
                        begin
                            Break;
                        end;
                        if Trim(exact_results_local[exact_idx_local].comment) <> '' then
                        begin
                            Continue;
                        end;
                        if is_runtime_chain_candidate(exact_results_local[exact_idx_local]) or
                            is_runtime_common_pattern_candidate(exact_results_local[exact_idx_local]) or
                            is_runtime_redup_candidate(exact_results_local[exact_idx_local]) then
                        begin
                            Continue;
                        end;

                        candidate_text_local := Trim(
                            exact_results_local[exact_idx_local].text);
                        candidate_units_local := get_candidate_text_unit_count(
                            candidate_text_local);
                        if (candidate_units_local <> 2) or
                            (not is_valid_cjk_phrase_text_local(
                            candidate_text_local, 2)) then
                        begin
                            Continue;
                        end;

                        candidate_weight_local :=
                            get_effective_weight_local(
                            exact_results_local[exact_idx_local]);
                        Inc(candidate_weight_local,
                            get_preferred_exact_subspan_bonus_local(
                            tail_query_key, candidate_text_local));
                        Inc(candidate_weight_local,
                            get_preferred_query_phrase_bonus_local(
                            tail_query_key, candidate_text_local));
                        consider_pair_local(fixed_head_text_local,
                            fixed_head_weight_local, candidate_text_local,
                            candidate_weight_local);
                    end;
                end;
            end;

            if (not Result) and
                try_get_preferred_query_phrase_text_local(local_query_key,
                pair_text_local, pair_bonus_local) and
                is_valid_cjk_phrase_text_local(pair_text_local, 3) then
            begin
                resolved_text := pair_text_local;
                resolved_score :=
                    normalize_compound_weight_local(
                    pair_bonus_local + c_fixed_compound_bonus) +
                    (3 * 3 * c_chunk_length_bonus) + c_chunk_anchor_bonus;
                resolved_has_anchor := True;
                resolved_anchor_units := 3;
                Result := True;
            end;
        end;

        function get_candidate_effective_weight_local(
            const candidate: TncCandidate; const chunk_syllables: Integer): Integer;
        begin
            Result := candidate.score;
            if candidate.has_dict_weight then
            begin
                if chunk_syllables <= 2 then
                begin
                    Result := candidate.dict_weight;
                end
                else if (Result <= 0) or (candidate.dict_weight > Result) then
                begin
                    Result := candidate.dict_weight;
                end;
            end;
        end;

        function get_first_meaningful_path_segment_local(
            const encoded_path: string): string;
        var
            parts: TArray<string>;
            part_idx: Integer;
            segment_text: string;
        begin
            Result := '';
            if Trim(encoded_path) = '' then
            begin
                Exit;
            end;

            parts := encoded_path.Split([c_segment_path_separator]);
            for part_idx := 0 to High(parts) do
            begin
                segment_text := Trim(parts[part_idx]);
                if segment_text = '' then
                begin
                    Continue;
                end;
                if get_candidate_text_unit_count(segment_text) >= 2 then
                begin
                    Exit(segment_text);
                end;
                if Result = '' then
                begin
                    Result := segment_text;
                end;
            end;
        end;

        function get_suffix_context_bonus_local(const chunk_text: string;
            const suffix_path: string): Integer;
        var
            meaningful_segment: string;
        begin
            Result := 0;
            if (m_dictionary = nil) or (chunk_text = '') or (suffix_path = '') then
            begin
                Exit;
            end;

            meaningful_segment := get_first_meaningful_path_segment_local(suffix_path);
            if meaningful_segment <> '' then
            begin
                Result := m_dictionary.get_context_bonus(chunk_text, meaningful_segment);
            end;
        end;

        function get_suffix_base_prefix_bonus_local(const chunk_text: string;
            const suffix_path: string): Integer;
        var
            meaningful_segment: string;
            prefix_text: string;
        begin
            Result := 0;
            if (m_dictionary = nil) or (chunk_text = '') or (suffix_path = '') then
            begin
                Exit;
            end;

            meaningful_segment := get_first_meaningful_path_segment_local(suffix_path);
            if meaningful_segment = '' then
            begin
                Exit;
            end;

            prefix_text := chunk_text + meaningful_segment;
            if (get_candidate_text_unit_count(prefix_text) < 2) or
                (get_candidate_text_unit_count(prefix_text) > 6) then
            begin
                Exit;
            end;
            Result := m_dictionary.get_base_text_prefix_bonus(prefix_text);
        end;

        function try_get_exact_single_char_weight_local(const local_start_idx: Integer;
            const expected_text: string; out out_weight: Integer): Boolean;
        var
            query_key: string;
            local_results: TncCandidateList;
            result_idx: Integer;
            candidate_weight: Integer;
        begin
            Result := False;
            out_weight := 0;
            if (expected_text = '') or (m_dictionary = nil) or
                (local_start_idx < 0) or
                (local_start_idx > High(exact_subspan_cache_syllables)) then
            begin
                Exit;
            end;

            query_key := normalize_pinyin_text(
                exact_subspan_cache_syllables[local_start_idx].text);
            if (query_key = '') or
                (not lookup_exact_full_pinyin_cached_local(query_key, local_results)) then
            begin
                Exit;
            end;

            for result_idx := 0 to High(local_results) do
            begin
                if Trim(local_results[result_idx].comment) <> '' then
                begin
                    Continue;
                end;
                if Trim(local_results[result_idx].text) <> expected_text then
                begin
                    Continue;
                end;

                candidate_weight := local_results[result_idx].score;
                if local_results[result_idx].has_dict_weight and
                    (local_results[result_idx].dict_weight > candidate_weight) then
                begin
                    candidate_weight := local_results[result_idx].dict_weight;
                end;
                if candidate_weight > out_weight then
                begin
                    out_weight := candidate_weight;
                end;
            end;

            Result := out_weight > 0;
        end;

        procedure collect_exact_single_char_candidates_local(
            const local_start_idx: Integer; const max_options: Integer;
            out out_texts: TArray<string>; out out_weights: TArray<Integer>);
        const
            c_single_probe_limit = 16;
        var
            query_key: string;
            local_results: TncCandidateList;
            result_idx: Integer;
            candidate_text: string;
            candidate_weight: Integer;
            candidate_is_preferred: Boolean;
            existing_idx: Integer;
            insert_idx: Integer;
            swap_text: string;
            swap_weight: Integer;
        begin
            SetLength(out_texts, 0);
            SetLength(out_weights, 0);
            if (max_options <= 0) or (m_dictionary = nil) or
                (local_start_idx < 0) or
                (local_start_idx > High(exact_subspan_cache_syllables)) then
            begin
                Exit;
            end;

            query_key := normalize_pinyin_text(
                exact_subspan_cache_syllables[local_start_idx].text);
            if (query_key = '') or
                (not lookup_exact_full_pinyin_cached_local(query_key, local_results)) then
            begin
                Exit;
            end;

            for result_idx := 0 to High(local_results) do
            begin
                if result_idx >= c_single_probe_limit then
                begin
                    Break;
                end;
                if Trim(local_results[result_idx].comment) <> '' then
                begin
                    Continue;
                end;

                candidate_text := Trim(local_results[result_idx].text);
                if (get_candidate_text_unit_count(candidate_text) <> 1) or
                    (not is_valid_cjk_phrase_text_local(candidate_text, 1)) then
                begin
                    Continue;
                end;
                if not match_single_char_candidate_for_syllable(
                    exact_subspan_cache_syllables[local_start_idx].text,
                    candidate_text, candidate_is_preferred) then
                begin
                    Continue;
                end;

                candidate_weight := local_results[result_idx].score;
                if local_results[result_idx].has_dict_weight and
                    (local_results[result_idx].dict_weight > candidate_weight) then
                begin
                    candidate_weight := local_results[result_idx].dict_weight;
                end;
                Inc(candidate_weight, get_preferred_query_phrase_bonus_local(
                    query_key, candidate_text));
                if candidate_is_preferred then
                begin
                    Inc(candidate_weight, 256);
                end;

                existing_idx := -1;
                for insert_idx := 0 to High(out_texts) do
                begin
                    if SameText(out_texts[insert_idx], candidate_text) then
                    begin
                        existing_idx := insert_idx;
                        Break;
                    end;
                end;

                if existing_idx >= 0 then
                begin
                    if candidate_weight <= out_weights[existing_idx] then
                    begin
                        Continue;
                    end;
                    out_weights[existing_idx] := candidate_weight;
                    insert_idx := existing_idx;
                end
                else
                begin
                    if Length(out_texts) < max_options then
                    begin
                        SetLength(out_texts, Length(out_texts) + 1);
                        SetLength(out_weights, Length(out_weights) + 1);
                        insert_idx := High(out_texts);
                        out_texts[insert_idx] := candidate_text;
                        out_weights[insert_idx] := candidate_weight;
                    end
                    else
                    begin
                        insert_idx := High(out_texts);
                        if (candidate_weight < out_weights[insert_idx]) or
                            ((candidate_weight = out_weights[insert_idx]) and
                            (CompareText(candidate_text, out_texts[insert_idx]) >= 0)) then
                        begin
                            Continue;
                        end;
                        out_texts[insert_idx] := candidate_text;
                        out_weights[insert_idx] := candidate_weight;
                    end;
                end;

                while (insert_idx > 0) and
                    ((out_weights[insert_idx] > out_weights[insert_idx - 1]) or
                    ((out_weights[insert_idx] = out_weights[insert_idx - 1]) and
                    (CompareText(out_texts[insert_idx], out_texts[insert_idx - 1]) < 0))) do
                begin
                    swap_text := out_texts[insert_idx - 1];
                    out_texts[insert_idx - 1] := out_texts[insert_idx];
                    out_texts[insert_idx] := swap_text;
                    swap_weight := out_weights[insert_idx - 1];
                    out_weights[insert_idx - 1] := out_weights[insert_idx];
                    out_weights[insert_idx] := swap_weight;
                    Dec(insert_idx);
                end;
            end;
        end;

        function normalize_long_sentence_chunk_weight_local(
            const raw_weight: Integer; const chunk_syllables_local: Integer): Integer;
        begin
            Result := raw_weight;
            case chunk_syllables_local of
                1:
                    if Result > 180 then
                    begin
                        Result := 180 + ((Result - 180) div 12);
                    end;
                2:
                    if Result > 240 then
                    begin
                        Result := 240 + ((Result - 240) div 10);
                    end;
            end;
        end;

        function is_preferred_phrase_match_local(const local_start_idx: Integer;
            const local_span_syllables: Integer; const preferred_text: string): Boolean;
        var
            preferred_units: TArray<string>;
            preferred_unit_idx: Integer;
            preferred_is_preferred: Boolean;
        begin
            Result := False;
            preferred_units := split_text_units(preferred_text);
            if Length(preferred_units) <> local_span_syllables then
            begin
                Exit;
            end;

            for preferred_unit_idx := 0 to High(preferred_units) do
            begin
                if not match_single_char_candidate_for_syllable(
                    exact_subspan_cache_syllables[local_start_idx + preferred_unit_idx].text,
                    preferred_units[preferred_unit_idx], preferred_is_preferred) then
                begin
                    Exit(False);
                end;
            end;

            Result := True;
        end;

        procedure store_cache_result_local(const local_start_idx: Integer;
            const local_span_syllables: Integer; const resolved: Boolean;
            const resolved_text: string; const resolved_score: Integer;
            const resolved_segments: Integer; const resolved_path: string;
            const resolved_has_anchor: Boolean; const resolved_anchor_units: Integer);
        begin
            if (not exact_subspan_cache_prepared) or
                (m_disable_subspan_standalone_oracle > 0) then
            begin
                Exit;
            end;
            exact_subspan_cache_states[local_start_idx][local_span_syllables] :=
                IfThen(resolved, c_state_hit, c_state_miss);
            if resolved then
            begin
                exact_subspan_cache_scores[local_start_idx][local_span_syllables] :=
                    resolved_score;
                exact_subspan_cache_segments[local_start_idx][local_span_syllables] :=
                    resolved_segments;
                exact_subspan_cache_anchor_units[local_start_idx][local_span_syllables] :=
                    resolved_anchor_units;
                exact_subspan_cache_has_anchor[local_start_idx][local_span_syllables] :=
                    resolved_has_anchor;
                exact_subspan_cache_texts[local_start_idx][local_span_syllables] :=
                    resolved_text;
                exact_subspan_cache_paths[local_start_idx][local_span_syllables] :=
                    resolved_path;
            end;
        end;

        var
            best_scores: TArray<Integer>;
            best_segments: TArray<Integer>;
            best_anchor_units: TArray<Integer>;
            best_has_anchor: TArray<Boolean>;
        best_texts: TArray<string>;
        best_paths: TArray<string>;
        pos: Integer;
        global_idx: Integer;
        chunk_syllables: Integer;
        next_pos: Integer;
        query_key: string;
        exact_results: TncCandidateList;
        result_idx: Integer;
        candidate_text: string;
        candidate_units: Integer;
        weight_value: Integer;
        fixed_text: string;
        fixed_weight: Integer;
        single_text_options: TArray<string>;
        single_weight_options: TArray<Integer>;
        single_option_idx: Integer;
        preferred_text: string;
        preferred_bonus: Integer;
        total_score: Integer;
        total_segments: Integer;
        total_anchor_units: Integer;
        total_has_anchor: Boolean;
        combined_text: string;
        combined_path: string;
        better_candidate: Boolean;
        local_has_anchor: Boolean;
        exact_phrase_bonus: Integer;
        direct_text: string;
            direct_score: Integer;
            direct_has_anchor: Boolean;
            direct_anchor_units: Integer;
        direct_exact_bonus: Integer;
        direct_units: TArray<string>;
        best_units: TArray<string>;
        same_first_unit_local: Boolean;
        boundary_resolved_text: string;
        boundary_resolved_score: Integer;
        boundary_resolved_has_anchor: Boolean;
        boundary_resolved_anchor_units: Integer;
        boundary_preferred_bonus: Integer;
        current_preferred_bonus_local: Integer;
        procedure try_update_with_candidate(const local_pos: Integer;
            const local_chunk_syllables: Integer; const chunk_text: string;
            const base_weight: Integer);
        begin
            candidate_text := Trim(chunk_text);
            if candidate_text = '' then
            begin
                Exit;
            end;
            candidate_units := get_candidate_text_unit_count(candidate_text);
            if candidate_units <> local_chunk_syllables then
            begin
                Exit;
            end;

            next_pos := local_pos + local_chunk_syllables;
            total_score := base_weight +
                (local_chunk_syllables * local_chunk_syllables * c_chunk_length_bonus);
            local_has_anchor := local_chunk_syllables >= 3;
            if local_has_anchor then
            begin
                Inc(total_score, c_chunk_anchor_bonus);
            end;

            total_segments := 1;
            total_has_anchor := local_has_anchor;
            if local_has_anchor then
            begin
                total_anchor_units := local_chunk_syllables;
            end
            else
            begin
                total_anchor_units := 0;
            end;
            combined_text := candidate_text;
            combined_path := candidate_text;

            if next_pos < span_syllables then
            begin
                Inc(total_score, best_scores[next_pos]);
                Inc(total_score, get_suffix_context_bonus_local(candidate_text,
                    best_paths[next_pos]));
                Inc(total_score, get_suffix_base_prefix_bonus_local(candidate_text,
                    best_paths[next_pos]));
                Inc(total_segments, best_segments[next_pos]);
                if best_has_anchor[next_pos] then
                begin
                    total_has_anchor := True;
                    if best_anchor_units[next_pos] > total_anchor_units then
                    begin
                        total_anchor_units := best_anchor_units[next_pos];
                    end;
                end;
                combined_text := combined_text + best_texts[next_pos];
                if best_paths[next_pos] <> '' then
                begin
                    combined_path := combined_path + c_segment_path_separator +
                        best_paths[next_pos];
                end;
            end;

            better_candidate := False;
            if total_score > best_scores[local_pos] then
            begin
                better_candidate := True;
            end
            else if total_score = best_scores[local_pos] then
            begin
                if total_has_anchor and (not best_has_anchor[local_pos]) then
                begin
                    better_candidate := True;
                end
                else if total_has_anchor = best_has_anchor[local_pos] then
                begin
                    if total_anchor_units > best_anchor_units[local_pos] then
                    begin
                        better_candidate := True;
                    end
                    else if total_anchor_units = best_anchor_units[local_pos] then
                    begin
                        if total_segments < best_segments[local_pos] then
                        begin
                            better_candidate := True;
                        end
                        else if (total_segments = best_segments[local_pos]) and
                            ((best_texts[local_pos] = '') or
                            (CompareText(combined_text, best_texts[local_pos]) < 0)) then
                        begin
                            better_candidate := True;
                        end;
                    end;
                end;
            end;

            if better_candidate then
            begin
                best_scores[local_pos] := total_score;
                best_segments[local_pos] := total_segments;
                best_anchor_units[local_pos] := total_anchor_units;
                best_has_anchor[local_pos] := total_has_anchor;
                best_texts[local_pos] := combined_text;
                best_paths[local_pos] := combined_path;
            end;
        end;

    begin
        out_text := '';
        out_score := 0;
        out_segments := 0;
        out_path := '';
        out_has_anchor := False;
        out_anchor_units := -1;

        if (span_syllables <= 0) or (span_syllables > c_span_max_syllables) then
        begin
            Exit(False);
        end;
        if (start_idx < 0) or
            (start_idx + span_syllables - 1 >= input_syllable_count) or
            (not is_full_pinyin_key(lookup_text)) then
        begin
            Exit(False);
        end;

        prepare_exact_subspan_cache_local;
        if not exact_subspan_cache_prepared then
        begin
            Exit(False);
        end;
        if (start_idx > High(exact_subspan_cache_syllables)) or
            (exact_subspan_cache_states = nil) then
        begin
            Exit(False);
        end;

        if exact_subspan_cache_states[start_idx][span_syllables] = c_state_hit then
        begin
            out_text := exact_subspan_cache_texts[start_idx][span_syllables];
            out_score := exact_subspan_cache_scores[start_idx][span_syllables];
            out_segments := exact_subspan_cache_segments[start_idx][span_syllables];
            out_path := exact_subspan_cache_paths[start_idx][span_syllables];
            out_has_anchor := exact_subspan_cache_has_anchor[start_idx][span_syllables];
            out_anchor_units := exact_subspan_cache_anchor_units[start_idx][span_syllables];
            Exit(True);
        end;
        if exact_subspan_cache_states[start_idx][span_syllables] = c_state_miss then
        begin
            Exit(False);
        end;

        SetLength(best_scores, span_syllables + 1);
        SetLength(best_segments, span_syllables + 1);
        SetLength(best_anchor_units, span_syllables + 1);
        SetLength(best_has_anchor, span_syllables + 1);
        SetLength(best_texts, span_syllables + 1);
        SetLength(best_paths, span_syllables + 1);
        for pos := 0 to span_syllables do
        begin
            best_scores[pos] := Low(Integer);
            best_segments[pos] := MaxInt;
            best_anchor_units[pos] := -1;
            best_has_anchor[pos] := False;
            best_texts[pos] := '';
            best_paths[pos] := '';
        end;
        best_scores[span_syllables] := 0;
        best_segments[span_syllables] := 0;
        best_anchor_units[span_syllables] := -1;
        best_has_anchor[span_syllables] := False;
        best_texts[span_syllables] := '';
        best_paths[span_syllables] := '';

        for pos := span_syllables - 1 downto 0 do
        begin
            global_idx := start_idx + pos;
            fixed_text := get_fixed_boundary_single_char_local(
                exact_subspan_cache_syllables[global_idx].text);
            if (fixed_text <> '') and ((pos + 1 = span_syllables) or
                (best_scores[pos + 1] > Low(Integer))) then
            begin
                if not try_get_exact_single_char_weight_local(global_idx, fixed_text,
                    fixed_weight) then
                begin
                    fixed_weight := 520;
                end;
                Inc(fixed_weight, get_preferred_query_phrase_bonus_local(
                    normalize_pinyin_text(exact_subspan_cache_syllables[global_idx].text),
                    fixed_text));
                try_update_with_candidate(pos, 1, fixed_text,
                    normalize_long_sentence_chunk_weight_local(
                    fixed_weight + c_fixed_single_bonus, 1));
            end;

            if ((pos + 1 = span_syllables) or (best_scores[pos + 1] > Low(Integer))) then
            begin
                collect_exact_single_char_candidates_local(global_idx, 6,
                    single_text_options, single_weight_options);
                for single_option_idx := 0 to High(single_text_options) do
                begin
                    if SameText(single_text_options[single_option_idx], fixed_text) then
                    begin
                        Continue;
                    end;
                    try_update_with_candidate(pos, 1,
                        single_text_options[single_option_idx],
                        normalize_long_sentence_chunk_weight_local(
                        single_weight_options[single_option_idx], 1));
                end;
            end;

            for chunk_syllables := 2 to Min(c_span_max_syllables, span_syllables - pos) do
            begin
                next_pos := pos + chunk_syllables;
                if (next_pos < span_syllables) and
                    (best_scores[next_pos] = Low(Integer)) then
                begin
                    Continue;
                end;

                query_key := build_query_key_local(global_idx, chunk_syllables);
                if query_key = '' then
                begin
                    Continue;
                end;

                preferred_text := '';
                preferred_bonus := 0;
                if try_get_preferred_query_phrase_text_local(query_key, preferred_text,
                    preferred_bonus) and
                    is_valid_cjk_phrase_text_local(preferred_text,
                    chunk_syllables) then
                begin
                    try_update_with_candidate(pos, chunk_syllables, preferred_text,
                        preferred_bonus + 12000);
                end;

                if (m_dictionary = nil) or
                    (not lookup_exact_full_pinyin_cached_local(query_key, exact_results)) then
                begin
                    if (chunk_syllables > 2) or
                        (not m_dictionary.lookup(query_key, exact_results)) then
                    begin
                        Continue;
                    end;
                end;

                for result_idx := 0 to High(exact_results) do
                begin
                    if result_idx >= c_probe_limit then
                    begin
                        Break;
                    end;
                    if Trim(exact_results[result_idx].comment) <> '' then
                    begin
                        Continue;
                    end;
                    if is_runtime_chain_candidate(exact_results[result_idx]) or
                        is_runtime_common_pattern_candidate(exact_results[result_idx]) or
                        is_runtime_redup_candidate(exact_results[result_idx]) then
                    begin
                        Continue;
                    end;

                    candidate_text := Trim(exact_results[result_idx].text);
                    if get_candidate_text_unit_count(candidate_text) <> chunk_syllables then
                    begin
                        Continue;
                    end;
                    if not is_valid_cjk_phrase_text_local(candidate_text,
                        chunk_syllables) then
                    begin
                        Continue;
                    end;

                    weight_value := get_candidate_effective_weight_local(
                        exact_results[result_idx], chunk_syllables);
                    exact_phrase_bonus := get_preferred_exact_subspan_bonus_local(
                        query_key, candidate_text);
                    Inc(weight_value, get_preferred_query_phrase_bonus_local(
                        query_key, candidate_text));
                    Inc(weight_value, exact_phrase_bonus);
                    if (chunk_syllables >= 3) and (exact_phrase_bonus > 0) then
                    begin
                        Inc(weight_value, 12000);
                    end;
                    weight_value := normalize_long_sentence_chunk_weight_local(
                        weight_value, chunk_syllables);
                    try_update_with_candidate(pos, chunk_syllables, candidate_text,
                        weight_value);
                end;
            end;
        end;

        if (best_scores[0] = Low(Integer)) or (best_texts[0] = '') then
        begin
            store_cache_result_local(start_idx, span_syllables, False, '', 0, 0, '',
                False, -1);
            Exit(False);
        end;

        if try_get_best_direct_exact_candidate_local(start_idx, span_syllables,
            direct_text, direct_score, direct_has_anchor, direct_anchor_units,
            direct_exact_bonus) and
            (direct_text <> '') and
            ((best_segments[0] > 1) or
            ((direct_exact_bonus > 0) and (not SameText(direct_text, best_texts[0])))) then
        begin
            same_first_unit_local := False;
            if span_syllables = 2 then
            begin
                direct_units := split_text_units(direct_text);
                best_units := split_text_units(best_texts[0]);
                same_first_unit_local := (Length(direct_units) > 0) and
                    (Length(best_units) > 0) and
                    SameText(direct_units[0], best_units[0]);
            end;

            if SameText(direct_text, best_texts[0]) then
            begin
                // Keep the DP result when it already resolves to the same text.
            end
            else if (direct_exact_bonus > 0) or
                ((span_syllables = 2) and
                (best_segments[0] > 1) and
                (direct_score >= best_scores[0] - 512) and
                same_first_unit_local) or
                ((best_segments[0] >= 3) and
                (direct_score >= best_scores[0] + 2048)) then
            begin
                best_texts[0] := direct_text;
                best_scores[0] := direct_score;
                best_segments[0] := 1;
                best_has_anchor[0] := direct_has_anchor;
                best_anchor_units[0] := direct_anchor_units;
                best_paths[0] := direct_text;
            end;
        end;

        query_key := build_query_key_local(start_idx, span_syllables);

        if (span_syllables = 3) and
            try_get_best_three_syllable_fixed_boundary_compound_local(start_idx,
            boundary_resolved_text, boundary_resolved_score,
            boundary_resolved_has_anchor, boundary_resolved_anchor_units) and
            (boundary_resolved_text <> '') then
        begin
            if m_config.debug_mode then
            begin
                m_last_full_path_debug_info := m_last_full_path_debug_info +
                    Format(' tfix3=[text=%s score=%d]',
                    [boundary_resolved_text, boundary_resolved_score]);
            end;
            current_preferred_bonus_local := 0;
            if (query_key <> '') and (best_texts[0] <> '') then
            begin
                current_preferred_bonus_local :=
                    get_preferred_exact_subspan_bonus_local(query_key,
                    best_texts[0]);
            end;
            boundary_preferred_bonus := 0;
            if query_key <> '' then
            begin
                boundary_preferred_bonus :=
                    get_preferred_exact_subspan_bonus_local(query_key,
                    boundary_resolved_text);
            end;

            if (best_texts[0] = '') or
                SameText(boundary_resolved_text, best_texts[0]) or
                ((best_segments[0] > 1) and
                (boundary_resolved_score >= best_scores[0] - 1024)) or
                ((not best_has_anchor[0]) and
                (boundary_resolved_score >= best_scores[0] - 512)) or
                ((boundary_preferred_bonus > current_preferred_bonus_local) and
                (boundary_resolved_score >= best_scores[0] - 2048)) or
                (boundary_resolved_score > best_scores[0] + 2048) then
            begin
                best_texts[0] := boundary_resolved_text;
                best_scores[0] := Max(best_scores[0], boundary_resolved_score);
                best_segments[0] := 1;
                best_has_anchor[0] := boundary_resolved_has_anchor;
                best_anchor_units[0] := Max(best_anchor_units[0],
                    boundary_resolved_anchor_units);
                best_paths[0] := boundary_resolved_text;
            end;
        end;

        oracle_preferred_text := '';
        oracle_preferred_bonus := 0;
        if query_key <> '' then
        begin
            oracle_preferred_text := '';
            oracle_preferred_bonus := 0;
            try_get_preferred_query_phrase_text_local(query_key,
                oracle_preferred_text, oracle_preferred_bonus);
            standalone_promote_bonus_local := 4096;
            if (span_syllables >= 4) and
                (start_idx + span_syllables >= input_syllable_count - 1) then
            begin
                standalone_promote_bonus_local := 49152;
            end
            else if span_syllables >= 6 then
            begin
                standalone_promote_bonus_local := 32768;
            end
            else if subspan_has_fixed_boundary_local(start_idx, span_syllables) then
            begin
                standalone_promote_bonus_local := 16384;
            end;
            if ((((span_syllables >= 4) and
                (start_idx + span_syllables >= input_syllable_count - 1)) or
                (span_syllables >= 6) or
                subspan_has_fixed_boundary_local(start_idx, span_syllables)) and
                try_get_best_subspan_standalone_query_candidate_local(query_key,
                span_syllables, direct_text, direct_score)) and
                (direct_text <> '') then
            begin
                direct_exact_bonus := get_preferred_exact_subspan_bonus_local(
                    query_key, direct_text);
                if (best_texts[0] = '') or
                    SameText(direct_text, best_texts[0]) or
                    (direct_exact_bonus > 0) or
                    (best_segments[0] > 1) or
                    ((span_syllables >= 4) and
                    (direct_score + standalone_promote_bonus_local >=
                    best_scores[0] - 512)) or
                    (direct_score + standalone_promote_bonus_local >=
                    best_scores[0] + 512) or
                    ((not best_has_anchor[0]) and
                    (direct_score + standalone_promote_bonus_local >=
                    best_scores[0] - 1024)) then
                begin
                    best_texts[0] := direct_text;
                    best_scores[0] := Max(best_scores[0],
                        direct_score + standalone_promote_bonus_local);
                    best_segments[0] := 1;
                    best_has_anchor[0] := True;
                    best_anchor_units[0] := span_syllables;
                    best_paths[0] := direct_text;
                end;
            end;
        end;

        out_text := best_texts[0];
        out_score := best_scores[0];
        out_segments := best_segments[0];
        out_path := best_paths[0];
        out_has_anchor := best_has_anchor[0];
        out_anchor_units := best_anchor_units[0];
        store_cache_result_local(start_idx, span_syllables, True, out_text, out_score,
            out_segments, out_path, out_has_anchor, out_anchor_units);
        Result := True;
    end;

    procedure promote_preferred_query_phrase_candidate_for_query(
        const query_key: string; var candidates: TncCandidateList);
    var
        idx: Integer;
        best_idx: Integer;
        best_bonus: Integer;
        current_top_bonus: Integer;
        best_is_complete: Boolean;
        current_is_complete: Boolean;
        tmp: TncCandidate;
        candidate_text: string;
        preferred_text: string;
        preferred_bonus: Integer;
        preferred_units: TArray<string>;
        query_syllables: TncPinyinParseResult;
        can_insert_preferred: Boolean;
    begin
        if (Length(candidates) = 0) or (query_key = '') then
        begin
            Exit;
        end;

        preferred_text := '';
        preferred_bonus := 0;
        query_syllables := get_effective_compact_pinyin_syllables(query_key);
        can_insert_preferred :=
            try_get_preferred_query_phrase_text_local(query_key,
            preferred_text, preferred_bonus);
        if can_insert_preferred then
        begin
            preferred_units := split_text_units(preferred_text);
            can_insert_preferred :=
                (Length(query_syllables) > 0) and
                (Length(preferred_units) = Length(query_syllables)) and
                is_full_pinyin_key(query_key);
        end;

        best_idx := -1;
        best_bonus := 0;
        best_is_complete := False;
        current_top_bonus := get_preferred_query_phrase_bonus_local(query_key,
            Trim(candidates[0].text));

        for idx := 0 to High(candidates) do
        begin
            if Trim(candidates[idx].comment) <> '' then
            begin
                Continue;
            end;

            candidate_text := Trim(candidates[idx].text);
            if candidate_text = '' then
            begin
                Continue;
            end;

            current_is_complete := Pos('/', candidate_text) = 0;
            if idx = 0 then
            begin
                best_is_complete := current_is_complete;
            end;

            if get_preferred_query_phrase_bonus_local(query_key, candidate_text) >
                best_bonus then
            begin
                best_idx := idx;
                best_bonus := get_preferred_query_phrase_bonus_local(query_key,
                    candidate_text);
                best_is_complete := current_is_complete;
                Continue;
            end;

            if (best_idx >= 0) and
                (get_preferred_query_phrase_bonus_local(query_key, candidate_text) =
                best_bonus) and (best_bonus > 0) then
            begin
                if current_is_complete and (not best_is_complete) then
                begin
                    best_idx := idx;
                    best_is_complete := True;
                end
                else if current_is_complete = best_is_complete then
                begin
                    if get_candidate_text_unit_count(candidate_text) >
                        get_candidate_text_unit_count(Trim(candidates[best_idx].text)) then
                    begin
                        best_idx := idx;
                    end;
                end;
            end;
        end;

        if (best_idx < 0) and can_insert_preferred and (preferred_bonus > 0) then
        begin
            if SameText(Trim(candidates[0].text), preferred_text) then
            begin
                Exit;
            end;

            FillChar(tmp, SizeOf(tmp), 0);
            tmp.text := preferred_text;
            tmp.comment := '';
            tmp.source := cs_rule;
            tmp.has_dict_weight := False;
            tmp.dict_weight := 0;
            tmp.score := Max(candidates[0].score + 2048,
                preferred_bonus + 50000);

            SetLength(candidates, Length(candidates) + 1);
            for idx := High(candidates) downto 1 do
            begin
                candidates[idx] := candidates[idx - 1];
            end;
            candidates[0] := tmp;
            Exit;
        end;

        if (best_idx <= 0) or (best_bonus <= 0) then
        begin
            Exit;
        end;

        if best_bonus < current_top_bonus then
        begin
            Exit;
        end;

        tmp := candidates[best_idx];
        for idx := best_idx downto 1 do
        begin
            candidates[idx] := candidates[idx - 1];
        end;
        candidates[0] := tmp;
    end;

