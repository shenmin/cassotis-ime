        procedure maybe_promote_fixed_boundary_variant_candidate_local;
        const
            c_front_limit = 6;
            c_chunk_slack = 4096;
            c_rerank_slack = 12000;
        var
            top_units_local: TArray<string>;
            local_units_local: TArray<string>;
            local_idx: Integer;
            local_text_local: string;
            local_support_score_local: Integer;
            local_chunk_alignment_score_local: Integer;
            local_rerank_score_local: Integer;
            local_boundary_score_local: Integer;
            best_idx_local: Integer;
            best_boundary_score_local: Integer;
            best_chunk_local: Integer;
            best_rerank_local: Integer;
            picked_candidate_local: TncCandidate;

            function get_boundary_score_local(
                const units_local: TArray<string>): Integer;
            var
                unit_idx_local: Integer;
                fixed_text_local: string;
                normalized_syllable_local: string;
                match_bonus_local: Integer;
                mismatch_penalty_local: Integer;
            begin
                Result := 0;
                if Length(units_local) <> input_syllable_count then
                begin
                    Exit(Low(Integer));
                end;

                for unit_idx_local := 0 to input_syllable_count - 1 do
                begin
                    fixed_text_local := get_fixed_boundary_single_char_for_query_syllable_local(
                        effective_syllables[unit_idx_local].text);
                    if fixed_text_local = '' then
                    begin
                        Continue;
                    end;

                    normalized_syllable_local := normalize_pinyin_text(
                        effective_syllables[unit_idx_local].text);
                    if (normalized_syllable_local = 'er') or
                        (normalized_syllable_local = 'yu') then
                    begin
                        match_bonus_local := 480;
                        mismatch_penalty_local := 720;
                    end
                    else if normalized_syllable_local = 'de' then
                    begin
                        match_bonus_local := 800;
                        mismatch_penalty_local := 1200;
                    end
                    else
                    begin
                        match_bonus_local := 1600;
                        mismatch_penalty_local := 2400;
                    end;

                    if SameText(Trim(units_local[unit_idx_local]),
                        fixed_text_local) then
                    begin
                        Inc(Result, match_bonus_local);
                    end
                    else
                    begin
                        Dec(Result, mismatch_penalty_local);
                    end;
                end;
            end;
        begin
            if best_text = '' then
            begin
                Exit;
            end;
            if get_candidate_text_unit_count(best_text) <> input_syllable_count then
            begin
                Exit;
            end;

            top_units_local := split_text_units(best_text);
            if Length(top_units_local) <> input_syllable_count then
            begin
                Exit;
            end;

            best_boundary_score_local := get_boundary_score_local(top_units_local);
            best_idx_local := -1;
            best_chunk_local := best_chunk_alignment_score;
            best_rerank_local := best_rerank_score;
            for local_idx := 0 to Min(c_front_limit - 1, High(candidates)) do
            begin
                if Trim(candidates[local_idx].comment) <> '' then
                begin
                    Continue;
                end;

                local_text_local := Trim(candidates[local_idx].text);
                if SameText(local_text_local, best_text) or
                    (get_candidate_text_unit_count(local_text_local) <>
                    input_syllable_count) then
                begin
                    Continue;
                end;

                local_units_local := split_text_units(local_text_local);
                if Length(local_units_local) <> input_syllable_count then
                begin
                    Continue;
                end;

                local_boundary_score_local := get_boundary_score_local(
                    local_units_local);
                if local_boundary_score_local <= best_boundary_score_local then
                begin
                    Continue;
                end;

                local_support_score_local := get_full_query_support_score_local(
                    local_text_local);
                local_chunk_alignment_score_local :=
                    get_full_query_chunk_alignment_score_fast_local(
                    local_text_local, local_support_score_local);
                local_rerank_score_local := build_full_query_rerank_score_local(
                    candidates[local_idx].score, local_chunk_alignment_score_local,
                    local_support_score_local, local_boundary_score_local);

                if (best_support_score > -960) and
                    (local_support_score_local <= -960) then
                begin
                    Continue;
                end;
                if (best_support_score > -960) and
                    (local_support_score_local + 4096 < best_support_score) then
                begin
                    Continue;
                end;

                if has_material_support_advantage(best_support_score,
                    local_support_score_local) and
                    (local_boundary_score_local < best_boundary_score_local + 3200) then
                begin
                    Continue;
                end;

                if (local_chunk_alignment_score_local + c_chunk_slack <
                    best_chunk_alignment_score) and
                    (local_rerank_score_local + c_rerank_slack <
                    best_rerank_score) then
                begin
                    Continue;
                end;

                if (best_idx_local < 0) or
                    (local_boundary_score_local > best_boundary_score_local) or
                    ((local_boundary_score_local = best_boundary_score_local) and
                    (local_chunk_alignment_score_local > best_chunk_local)) or
                    ((local_boundary_score_local = best_boundary_score_local) and
                    (local_chunk_alignment_score_local = best_chunk_local) and
                    (local_rerank_score_local > best_rerank_local)) then
                begin
                    best_idx_local := local_idx;
                    best_boundary_score_local := local_boundary_score_local;
                    best_chunk_local := local_chunk_alignment_score_local;
                    best_rerank_local := local_rerank_score_local;
                end;
            end;

            if best_idx_local < 0 then
            begin
                Exit;
            end;

            picked_candidate_local := candidates[best_idx_local];
            best_candidate := picked_candidate_local;
            best_text := Trim(picked_candidate_local.text);
            best_weight := picked_candidate_local.dict_weight;
            best_score := picked_candidate_local.score;
            best_phrase_bonus := get_preferred_query_phrase_bonus_local(
                lookup_text, best_text);
            best_head_boundary_score := get_fixed_boundary_head_score_local(
                best_text);
            best_support_score := get_full_query_support_score_local(best_text);
            best_chunk_alignment_score :=
                get_full_query_chunk_alignment_score_fast_local(best_text,
                best_support_score);
            best_rerank_score := build_full_query_rerank_score_local(
                picked_candidate_local.score, best_chunk_alignment_score,
                best_support_score, best_head_boundary_score);
            best_path_confidence_score := get_candidate_path_confidence_score(
                picked_candidate_local);
            best_path_preference_score := get_segment_path_preference_score(
                get_segment_path_for_candidate(picked_candidate_local,
                best_idx_local));
            if m_config.debug_mode then
            begin
                m_last_full_path_debug_info := m_last_full_path_debug_info +
                    Format(' fqvfix=[boundary text=%s]', [best_text]);
            end;
        end;

