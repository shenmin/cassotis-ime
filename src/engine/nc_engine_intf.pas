        function get_exact_chunk_effective_weight_local(
            const local_candidate: TncCandidate): Integer;
        var
            local_units: Integer;
        begin
            if local_candidate.has_dict_weight then
            begin
                Result := local_candidate.dict_weight;
            end
            else
            begin
                Result := local_candidate.score;
            end;

            local_units := get_candidate_text_unit_count(Trim(local_candidate.text));
            case local_units of
                1:
                    if Result > 180 then
                    begin
                        Result := 180 + ((Result - 180) div 12);
                    end;
                2:
                    if Result > 240 then
                    begin
                        Result := 240 + ((Result - 240) div 10);
                    end;
                3:
                    if Result > 300 then
                    begin
                        Result := 300 + ((Result - 300) div 24);
                    end;
                4:
                    if Result > 360 then
                    begin
                        Result := 360 + ((Result - 360) div 32);
                    end;
            else
                if Result > 420 then
                begin
                    Result := 420 + ((Result - 420) div 40);
                end;
            end;
        end;

