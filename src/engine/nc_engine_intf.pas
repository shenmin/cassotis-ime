        end
        else if normalized_syllable = 'bing' then
        begin
            Result := string(Char($5E76));
        end
        else if normalized_syllable = 'qie' then
        begin
            Result := string(Char($4E14));
        end;
    end;

    function build_resolved_sentence_candidate_local(
        out out_candidate: TncCandidate; out out_path: string): Boolean;
    const
        c_min_syllables = 6;
        c_max_chunk_syllables = 5;
        c_probe_limit = 6;
        c_single_probe_limit = 6;
        c_single_weight_floor = 120;
        c_fixed_single_score = 1200;
        c_single_penalty = 1600;
        c_chunk_length_bonus = 1400;
        c_chunk_anchor_bonus = 3600;
        c_join_penalty = 220;
        c_context_scale = 4;
        c_prefix_scale = 2;
    type
        TResolvedSentenceState = record
            valid: Boolean;
            score: Integer;
            segments: Integer;
            text: string;
            path: string;
            first_chunk: string;
        end;
    var
        syllables_local: TncPinyinParseResult;
        states_local: array of TResolvedSentenceState;
        pos_local: Integer;
        seg_len_local: Integer;
        next_pos_local: Integer;
        fixed_text_local: string;
        query_key_local: string;
        exact_results_local: TncCandidateList;
        candidate_idx_local: Integer;
        candidate_text_local: string;
        candidate_score_local: Integer;
        candidate_has_anchor_local: Boolean;
        candidate_anchor_units_local: Integer;
        candidate_local: TncCandidate;
        reach_pos_local: Integer;
        preferred_text_local: string;
        preferred_bonus_local: Integer;

        function lookup_exact_resolved_cached_local(const pinyin_key: string;
            out out_results: TncCandidateList): Boolean;
        var
            cache_key_local: string;
            phase_start_tick_local: UInt64;
        begin
            SetLength(out_results, 0);
            if (m_dictionary = nil) or (pinyin_key = '') then
            begin
                Exit(False);
            end;

            cache_key_local := '#preferred_exact#' + pinyin_key;
            if (lookup_cache <> nil) and
                lookup_cache.TryGetValue(cache_key_local, out_results) then
            begin
                Inc(lookup_cache_hits);
                Exit(Length(out_results) > 0);
            end;

            Inc(lookup_cache_misses);
            phase_start_tick_local := GetTickCount64;
            if not m_dictionary.lookup_exact_full_pinyin(pinyin_key,
                out_results) then
            begin
                SetLength(out_results, 0);
            end;
            Inc(lookup_elapsed_ms, Int64(GetTickCount64 -
                phase_start_tick_local));
            if lookup_cache <> nil then
            begin
                lookup_cache.AddOrSetValue(cache_key_local, out_results);
            end;
            Result := Length(out_results) > 0;
        end;

        function build_query_key_local(const start_idx: Integer;
            const syllable_count_local: Integer): string;
        var
            local_idx: Integer;
        begin
            Result := '';
            if (start_idx < 0) or (syllable_count_local <= 0) or
                (start_idx + syllable_count_local - 1 > High(syllables_local)) then
            begin
                Exit;
            end;

            for local_idx := start_idx to
                start_idx + syllable_count_local - 1 do
            begin
                Result := Result + normalize_pinyin_text(
                    syllables_local[local_idx].text);
            end;
        end;

        function candidate_respects_fixed_boundaries_local(
            const start_idx: Integer; const syllable_count_local: Integer;
            const text_value: string): Boolean;
        var
            units_local: TArray<string>;
            local_idx: Integer;
            fixed_char_local: string;
        begin
            Result := False;
            if (start_idx < 0) or (syllable_count_local <= 0) or
                (start_idx + syllable_count_local - 1 > High(syllables_local)) then
            begin
                Exit;
            end;

            units_local := split_text_units(Trim(text_value));
            if Length(units_local) <> syllable_count_local then
            begin
                Exit(False);
            end;

            for local_idx := 0 to syllable_count_local - 1 do
            begin
                fixed_char_local := get_fixed_resolved_boundary_char_local(
                    syllables_local[start_idx + local_idx].text);
                if (fixed_char_local <> '') and
                    (not SameText(units_local[local_idx], fixed_char_local)) then
                begin
                    Exit(False);
                end;
            end;

            Result := True;
        end;

        function get_effective_weight_local(const candidate: TncCandidate): Integer;
        begin
            Result := candidate.score;
            if candidate.has_dict_weight and
                (candidate.dict_weight > Result) then
            begin
                Result := candidate.dict_weight;
            end;
        end;

        function is_better_state_local(const left_state: TResolvedSentenceState;
            const right_state: TResolvedSentenceState): Boolean;
        begin
            Result := False;
            if not left_state.valid then
            begin
                Exit(False);
            end;
            if not right_state.valid then
            begin
                Exit(True);
            end;
            if left_state.score > right_state.score then
            begin
                Exit(True);
            end;
            if left_state.score < right_state.score then
            begin
                Exit(False);
            end;
            if get_candidate_text_unit_count(left_state.first_chunk) >
                get_candidate_text_unit_count(right_state.first_chunk) then
            begin
                Exit(True);
            end;
            if get_candidate_text_unit_count(left_state.first_chunk) <
                get_candidate_text_unit_count(right_state.first_chunk) then
            begin
                Exit(False);
            end;
            if left_state.segments < right_state.segments then
            begin
                Exit(True);
            end;
            if left_state.segments > right_state.segments then
            begin
                Exit(False);
            end;
            if (left_state.text <> '') and
                ((right_state.text = '') or
                (CompareText(left_state.text, right_state.text) < 0)) then
            begin
                Exit(True);
            end;
        end;

        procedure try_update_state_local(const start_idx: Integer;
            const syllable_count_local: Integer; const chunk_text: string;
            const chunk_path: string; const base_score: Integer;
            const has_anchor_local: Boolean; const anchor_units_local: Integer);
        var
            local_state: TResolvedSentenceState;
            next_state_local: TResolvedSentenceState;
            total_score_local: Integer;
            total_path_local: string;
            local_pair_units: Integer;
            local_pair_key: string;
            local_pair_text: string;
        begin
            if (chunk_text = '') or
                (get_candidate_text_unit_count(Trim(chunk_text)) <>
                syllable_count_local) then
            begin
                Exit;
            end;

            next_pos_local := start_idx + syllable_count_local;
            if (next_pos_local < input_syllable_count) and
                (not states_local[next_pos_local].valid) then
            begin
                Exit;
            end;

            total_score_local := base_score +
                (syllable_count_local * c_chunk_length_bonus);
            if has_anchor_local then
            begin
                Inc(total_score_local, c_chunk_anchor_bonus +
                    (anchor_units_local * 192));
            end;
            if syllable_count_local = 1 then
            begin
                Dec(total_score_local, c_single_penalty);
            end;

            local_state.valid := True;
            local_state.segments := 1;
            local_state.first_chunk := Trim(chunk_text);
            local_state.text := Trim(chunk_text);
            if Trim(chunk_path) <> '' then
            begin
                total_path_local := Trim(chunk_path);
            end
            else
            begin
                total_path_local := Trim(chunk_text);
            end;
            local_state.path := total_path_local;

            if next_pos_local < input_syllable_count then
            begin
                next_state_local := states_local[next_pos_local];
                Inc(total_score_local, next_state_local.score);
                Dec(total_score_local, c_join_penalty);
                local_state.segments := local_state.segments +
                    next_state_local.segments;
                local_state.text := local_state.text + next_state_local.text;
                if next_state_local.path <> '' then
                begin
                    local_state.path := local_state.path + c_segment_path_separator +
                        next_state_local.path;
                end;
                if (m_dictionary <> nil) and
                    (next_state_local.first_chunk <> '') then
                begin
                    Inc(total_score_local,
                        m_dictionary.get_context_bonus(
                        Trim(chunk_text), next_state_local.first_chunk) *
                        c_context_scale);
                    Inc(total_score_local,
                        m_dictionary.get_base_text_prefix_bonus(
                        Trim(chunk_text) + next_state_local.first_chunk) *
                        c_prefix_scale);

                    local_pair_units := syllable_count_local +
                        get_candidate_text_unit_count(next_state_local.first_chunk);
                    if (local_pair_units > syllable_count_local) and
                        (local_pair_units <= 6) then
                    begin
                        local_pair_key := build_query_key_local(start_idx,
                            local_pair_units);
                        local_pair_text := Trim(chunk_text) +
                            next_state_local.first_chunk;
                        Inc(total_score_local,
                            get_preferred_query_phrase_bonus_local(
                            local_pair_key, local_pair_text));
                    end;
                end;
            end;

            if start_idx = 0 then
            begin
                Inc(total_score_local,
                    get_preferred_query_phrase_bonus_local(lookup_text,
                    local_state.text));
            end;

            local_state.score := total_score_local;
            if is_better_state_local(local_state, states_local[start_idx]) then
            begin
                states_local[start_idx] := local_state;
            end;
        end;
    begin
        Result := False;
        FillChar(out_candidate, SizeOf(out_candidate), 0);
        out_path := '';
        if (m_dictionary = nil) or (input_syllable_count < c_min_syllables) or
            (not is_full_pinyin_key(lookup_text)) or
            (m_disable_subspan_standalone_oracle > 0) then
        begin
            Exit;
        end;

        syllables_local := get_effective_compact_pinyin_syllables(lookup_text);
        if Length(syllables_local) <> input_syllable_count then
        begin
            Exit;
        end;

        SetLength(states_local, input_syllable_count + 1);
        states_local[0].valid := True;
        states_local[input_syllable_count].score := 0;
        states_local[input_syllable_count].segments := 0;
        states_local[input_syllable_count].text := '';
        states_local[input_syllable_count].path := '';
        states_local[input_syllable_count].first_chunk := '';

        for pos_local := input_syllable_count - 1 downto 0 do
        begin
            fixed_text_local := get_fixed_resolved_boundary_char_local(
                syllables_local[pos_local].text);
            if fixed_text_local <> '' then
            begin
                candidate_score_local := c_fixed_single_score;
                query_key_local := build_query_key_local(pos_local, 1);
                if lookup_exact_resolved_cached_local(query_key_local,
                    exact_results_local) then
                begin
                    for candidate_idx_local := 0 to High(exact_results_local) do
                    begin
                        if candidate_idx_local >= c_probe_limit then
                        begin
                            Break;
                        end;
                        if (Trim(exact_results_local[candidate_idx_local].comment) = '') and
                            SameText(Trim(exact_results_local[candidate_idx_local].text),
                            fixed_text_local) then
                        begin
                            candidate_score_local := Max(candidate_score_local,
                                get_effective_weight_local(
                                exact_results_local[candidate_idx_local]));
                        end;
                    end;
                end;
                try_update_state_local(pos_local, 1, fixed_text_local,
                    fixed_text_local, candidate_score_local, False, 0);
            end
            else
            begin
                query_key_local := build_query_key_local(pos_local, 1);
                if (query_key_local <> '') and
                    lookup_exact_resolved_cached_local(query_key_local,
                    exact_results_local) then
                begin
                    for candidate_idx_local := 0 to High(exact_results_local) do
                    begin
                        if candidate_idx_local >= c_single_probe_limit then
                        begin
                            Break;
                        end;
                        candidate_local := exact_results_local[candidate_idx_local];
                        if Trim(candidate_local.comment) <> '' then
                        begin
                            Continue;
                        end;

                        candidate_text_local := Trim(candidate_local.text);
                        if get_candidate_text_unit_count(candidate_text_local) <> 1 then
                        begin
                            Continue;
                        end;

                        candidate_score_local := get_effective_weight_local(
                            candidate_local);
                        if candidate_score_local < c_single_weight_floor then
                        begin
                            Continue;
                        end;

                        Dec(candidate_score_local, candidate_idx_local * 24);
                        try_update_state_local(pos_local, 1,
                            candidate_text_local, candidate_text_local,
                            candidate_score_local, False, 0);
                    end;
                end;
            end;

            for seg_len_local := 2 to Min(c_max_chunk_syllables,
                input_syllable_count - pos_local) do
            begin
                query_key_local := build_query_key_local(pos_local,
                    seg_len_local);

                if query_key_local = '' then
                begin
                    Continue;
                end;

                preferred_text_local := '';
                preferred_bonus_local := 0;
                if try_get_preferred_query_phrase_text_local(query_key_local,
                    preferred_text_local, preferred_bonus_local) and
                    (get_candidate_text_unit_count(preferred_text_local) =
                    seg_len_local) and
                    candidate_respects_fixed_boundaries_local(pos_local,
                    seg_len_local, preferred_text_local) then
                begin
                    candidate_score_local := preferred_bonus_local +
                        (seg_len_local * c_chunk_length_bonus) + 2048;
                    candidate_has_anchor_local := seg_len_local >= 3;
                    if candidate_has_anchor_local then
                    begin
                        candidate_anchor_units_local := seg_len_local;
                    end
                    else
                    begin
                        candidate_anchor_units_local := 0;
                    end;
                    try_update_state_local(pos_local, seg_len_local,
                        preferred_text_local, preferred_text_local,
                        candidate_score_local, candidate_has_anchor_local,
                        candidate_anchor_units_local);
                end;

                if not lookup_exact_resolved_cached_local(query_key_local,
                    exact_results_local) then
                begin
                    Continue;
                end;

                for candidate_idx_local := 0 to High(exact_results_local) do
                begin
                    if candidate_idx_local >= c_probe_limit then
                    begin
                        Break;
                    end;
                    candidate_local := exact_results_local[candidate_idx_local];
                    if Trim(candidate_local.comment) <> '' then
                    begin
                        Continue;
                    end;
                    if is_runtime_chain_candidate(candidate_local) or
                        is_runtime_common_pattern_candidate(candidate_local) or
                        is_runtime_redup_candidate(candidate_local) then
                    begin
                        Continue;
                    end;

                    candidate_text_local := Trim(candidate_local.text);
                    if (get_candidate_text_unit_count(candidate_text_local) <>
                        seg_len_local) or
                        (not candidate_respects_fixed_boundaries_local(pos_local,
                        seg_len_local, candidate_text_local)) then
                    begin
                        Continue;
                    end;

                    candidate_score_local := get_effective_weight_local(
                        candidate_local);
                    Inc(candidate_score_local,
                        get_preferred_query_phrase_bonus_local(query_key_local,
                        candidate_text_local));
                    if seg_len_local >= 4 then
                    begin
                        Inc(candidate_score_local, 2048);
                    end;
                    if seg_len_local >= 5 then
                    begin
                        Inc(candidate_score_local, 2048);
                    end;
                    if seg_len_local >= 3 then
                    begin
                        Inc(candidate_score_local,
                            m_dictionary.get_base_text_prefix_bonus(
                            candidate_text_local) * c_prefix_scale);
                    end;

                    candidate_has_anchor_local := seg_len_local >= 3;
                    if candidate_has_anchor_local then
                    begin
                        candidate_anchor_units_local := seg_len_local;
                    end
                    else
                    begin
                        candidate_anchor_units_local := 0;
                    end;

                    try_update_state_local(pos_local, seg_len_local,
                        candidate_text_local, candidate_text_local,
                        candidate_score_local, candidate_has_anchor_local,
                        candidate_anchor_units_local);
                end;
            end;
        end;

        if (not states_local[0].valid) or
            (get_candidate_text_unit_count(Trim(states_local[0].text)) <>
            input_syllable_count) then
        begin
            if m_config.debug_mode then
            begin
                reach_pos_local := 0;
                for pos_local := input_syllable_count downto 0 do
                begin
                    if states_local[pos_local].valid then
                    begin
                        reach_pos_local := pos_local;
                        Break;
                    end;
                end;
                m_last_full_path_debug_info := m_last_full_path_debug_info +
                    Format(' vrsmiss=[reach=%d/%d text=%s]',
                    [reach_pos_local, input_syllable_count,
                    Trim(states_local[reach_pos_local].text)]);
            end;
            Exit;
        end;

        out_candidate.text := Trim(states_local[0].text);
        out_candidate.comment := '';
        out_candidate.score := states_local[0].score;
        out_candidate.source := cs_rule;
        out_candidate.has_dict_weight := False;
        out_candidate.dict_weight := 0;
        out_path := Trim(states_local[0].path);
        Result := out_candidate.text <> '';
    end;

    function ensure_best_resolved_sentence_candidate_visible(
        var candidates: TncCandidateList): Boolean;
    const
        c_promote_margin = 2048;
    var
        resolved_candidate_local: TncCandidate;
        resolved_path_local: string;
        idx_local: Integer;
        existing_index_local: Integer;
        top_score_local: Integer;
        resolved_score_local: Integer;
        support_score_local: Integer;
        support_segments_local: Integer;
        support_path_local: string;
    begin
        Result := False;
        if not build_resolved_sentence_candidate_local(
            resolved_candidate_local, resolved_path_local) then
        begin
            if m_config.debug_mode then
            begin
                m_last_full_path_debug_info := m_last_full_path_debug_info +
                    ' vrs=[miss]';
            end;
            Exit;
        end;

        support_path_local := infer_segment_path_for_query_text_with_score(
            lookup_text, Trim(resolved_candidate_local.text),
            support_score_local, support_segments_local);
        if (Trim(resolved_path_local) = '') and
            (Trim(support_path_local) <> '') then
        begin
            resolved_path_local := Trim(support_path_local);
        end;
        if Trim(resolved_path_local) <> '' then
        begin
            remember_segment_path_for_candidate(Trim(resolved_candidate_local.text),
                '', Trim(resolved_path_local),
                resolved_candidate_local.score + support_score_local);
        end;

        existing_index_local := -1;
        for idx_local := 0 to High(candidates) do
        begin
            if (Trim(candidates[idx_local].comment) = '') and
                SameText(Trim(candidates[idx_local].text),
                Trim(resolved_candidate_local.text)) then
            begin
                existing_index_local := idx_local;
                Break;
            end;
        end;

        resolved_score_local := resolved_candidate_local.score +
            support_score_local;
        if (Length(candidates) > 0) and
            (Trim(candidates[0].comment) = '') and
            (get_candidate_text_unit_count(Trim(candidates[0].text)) =
            input_syllable_count) then
        begin
            top_score_local := get_rank_score(candidates[0]);
            if infer_segment_path_for_query_text_with_score(lookup_text,
                Trim(candidates[0].text), support_score_local,
                support_segments_local) <> '' then
            begin
                Inc(top_score_local, support_score_local);
            end;
            if (not is_problematic_single_char_chain_candidate_for_query(
                lookup_text, candidates[0])) and
                (resolved_score_local <= top_score_local + c_promote_margin) and
                (existing_index_local <> 0) then
            begin
                if m_config.debug_mode then
                begin
                    m_last_full_path_debug_info := m_last_full_path_debug_info +
                        Format(' vrs=[keep text=%s score=%d top=%d]',
                        [Trim(candidates[0].text), resolved_score_local,
                        top_score_local]);
                end;
                Exit(False);
            end;
        end;

        if existing_index_local = 0 then
        begin
            Exit(True);
        end;

        if existing_index_local > 0 then
        begin
            resolved_candidate_local := candidates[existing_index_local];
            for idx_local := existing_index_local downto 1 do
            begin
                candidates[idx_local] := candidates[idx_local - 1];
            end;
            candidates[0] := resolved_candidate_local;
        end
        else
        begin
            SetLength(candidates, Length(candidates) + 1);
            for idx_local := High(candidates) downto 1 do
            begin
                candidates[idx_local] := candidates[idx_local - 1];
            end;
            candidates[0] := resolved_candidate_local;
        end;

        if m_config.debug_mode then
        begin
            m_last_full_path_debug_info := m_last_full_path_debug_info +
                Format(' vrs=[promote text=%s score=%d]',
                [Trim(candidates[0].text), resolved_score_local]);
        end;
        Result := True;
    end;

    function ensure_best_resolved_sentence_candidate_visible_aggressive(
        var candidates: TncCandidateList): Boolean;
    var
        resolved_candidate_local: TncCandidate;
        resolved_path_local: string;
        idx_local: Integer;
        existing_index_local: Integer;
        support_score_local: Integer;
        support_segments_local: Integer;
        support_path_local: string;
    begin
        Result := False;
        if (input_syllable_count < 8) or (not is_full_pinyin_key(lookup_text)) then
        begin
            Exit;
        end;
        if not build_resolved_sentence_candidate_local(
            resolved_candidate_local, resolved_path_local) then
        begin
            Exit;
        end;

        support_path_local := infer_segment_path_for_query_text_with_score(
            lookup_text, Trim(resolved_candidate_local.text),
            support_score_local, support_segments_local);
        if (Trim(resolved_path_local) = '') and
            (Trim(support_path_local) <> '') then
        begin
            resolved_path_local := Trim(support_path_local);
        end;
        if Trim(resolved_path_local) <> '' then
        begin
            remember_segment_path_for_candidate(Trim(resolved_candidate_local.text),
                '', Trim(resolved_path_local),
                resolved_candidate_local.score + support_score_local);
        end;

        existing_index_local := -1;
        for idx_local := 0 to High(candidates) do
        begin
            if (Trim(candidates[idx_local].comment) = '') and
                SameText(Trim(candidates[idx_local].text),
                Trim(resolved_candidate_local.text)) then
            begin
                existing_index_local := idx_local;
                Break;
            end;
        end;

        if existing_index_local = 0 then
        begin
            Exit(True);
        end;

        if existing_index_local > 0 then
        begin
            resolved_candidate_local := candidates[existing_index_local];
            for idx_local := existing_index_local downto 1 do
            begin
                candidates[idx_local] := candidates[idx_local - 1];
            end;
            candidates[0] := resolved_candidate_local;
        end
        else
        begin
            SetLength(candidates, Length(candidates) + 1);
            for idx_local := High(candidates) downto 1 do
            begin
                candidates[idx_local] := candidates[idx_local - 1];
            end;
            candidates[0] := resolved_candidate_local;
        end;

        if m_config.debug_mode then
        begin
            m_last_full_path_debug_info := m_last_full_path_debug_info +
                Format(' vra=[promote text=%s]', [Trim(candidates[0].text)]);
        end;
        Result := True;
    end;

    procedure ensure_best_late_exact_chunk_consensus_complete_candidate_visible(
        var candidates: TncCandidateList);
    const
        c_min_syllables = 8;
        c_min_window_syllables = 3;
        c_max_window_syllables = 6;
        c_probe_limit = 4;
        c_candidate_limit = 3;
        c_complete_rank_scale = 64;
        c_match_unit_weight = 640;
        c_mismatch_unit_weight = 896;
        c_fixed_match_bonus = 2048;
        c_fixed_mismatch_penalty = 4096;
        c_promote_margin = 512;
    var
        syllables_local: TncPinyinParseResult;
        cached_chunk_texts_local: TDictionary<string, string>;
        cached_chunk_scores_local: TDictionary<string, Integer>;
        cached_chunk_states_local: TDictionary<string, Byte>;
        candidate_units_local: array of TArray<string>;
        complete_indexes_local: TArray<Integer>;
        idx_local: Integer;
        candidate_idx_local: Integer;
        top_eval_score_local: Integer;
        best_eval_score_local: Integer;
        best_index_local: Integer;
        top_index_local: Integer;
        eval_score_local: Integer;

        function build_query_key_local(const start_idx: Integer;
            const syllable_count_local: Integer): string;
        var
            local_idx: Integer;
        begin
            Result := '';
            if (start_idx < 0) or (syllable_count_local <= 0) or
                (start_idx + syllable_count_local - 1 > High(syllables_local)) then
            begin
                Exit;
            end;
            for local_idx := start_idx to
                start_idx + syllable_count_local - 1 do
            begin
                Result := Result + normalize_pinyin_text(
                    syllables_local[local_idx].text);
            end;
        end;

        function window_has_fixed_boundary_local(const start_idx: Integer;
            const syllable_count_local: Integer): Boolean;
        var
            local_idx: Integer;
        begin
            Result := False;
            if (start_idx < 0) or (syllable_count_local <= 0) or
                (start_idx + syllable_count_local - 1 > High(syllables_local)) then
            begin
                Exit;
            end;
            for local_idx := 0 to syllable_count_local - 1 do
            begin
                if get_fixed_resolved_boundary_char_local(
                    syllables_local[start_idx + local_idx].text) <> '' then
                begin
                    Exit(True);
                end;
            end;
        end;

        function candidate_respects_fixed_boundaries_local(
            const start_idx: Integer; const syllable_count_local: Integer;
            const text_value: string): Boolean;
        var
            units_local: TArray<string>;
            local_idx: Integer;
            fixed_char_local: string;
        begin
            units_local := split_text_units(Trim(text_value));
            if Length(units_local) <> syllable_count_local then
            begin
                Exit(False);
            end;
            for local_idx := 0 to syllable_count_local - 1 do
            begin
                fixed_char_local := get_fixed_resolved_boundary_char_local(
                    syllables_local[start_idx + local_idx].text);
                if (fixed_char_local <> '') and
                    (not SameText(units_local[local_idx], fixed_char_local)) then
                begin
                    Exit(False);
                end;
            end;
            Result := True;
        end;

        function get_effective_weight_local(const candidate: TncCandidate): Integer;
        begin
            Result := candidate.score;
            if candidate.has_dict_weight and
                (candidate.dict_weight > Result) then
            begin
                Result := candidate.dict_weight;
            end;
        end;

        function try_get_best_exact_chunk_local(const start_idx: Integer;
            const syllable_count_local: Integer; out out_text: string;
            out out_score: Integer): Boolean;
        var
            query_key_local: string;
            cached_state_local: Byte;
            exact_results_local: TncCandidateList;
            local_idx: Integer;
            candidate_text_local: string;
            candidate_score_local: Integer;
            best_text_local: string;
            best_score_local: Integer;
            resolved_text_local: string;
            resolved_path_local: string;
            resolved_score_local: Integer;
            resolved_segments_local: Integer;
            resolved_anchor_units_local: Integer;
            resolved_has_anchor_local: Boolean;
        begin
            Result := False;
            out_text := '';
            out_score := 0;
            query_key_local := build_query_key_local(start_idx,
                syllable_count_local);
            if (query_key_local = '') or (m_dictionary = nil) then
            begin
                Exit;
            end;

            if cached_chunk_states_local.TryGetValue(query_key_local,
                cached_state_local) then
            begin
                if cached_state_local = 1 then
                begin
                    cached_chunk_texts_local.TryGetValue(query_key_local, out_text);
                    cached_chunk_scores_local.TryGetValue(query_key_local, out_score);
                    Exit(out_text <> '');
                end;
                Exit(False);
            end;

            best_text_local := '';
            best_score_local := Low(Integer);
            if (syllable_count_local >= 3) and
                try_resolve_best_exact_subspan_local(start_idx,
                syllable_count_local, resolved_text_local,
                resolved_score_local, resolved_segments_local,
                resolved_path_local, resolved_has_anchor_local,
                resolved_anchor_units_local) and
                (resolved_text_local <> '') and
                candidate_respects_fixed_boundaries_local(start_idx,
                syllable_count_local, resolved_text_local) then
            begin
                best_text_local := resolved_text_local;
                best_score_local := resolved_score_local;
                if resolved_segments_local <= 1 then
                begin
                    Inc(best_score_local, 2048);
                end;
                if resolved_has_anchor_local then
                begin
                    Inc(best_score_local, 1024 + (resolved_anchor_units_local * 96));
                end;
            end;

            if m_dictionary.lookup_exact_full_pinyin(query_key_local,
                exact_results_local) then
            begin
                for local_idx := 0 to High(exact_results_local) do
                begin
                    if local_idx >= c_probe_limit then
                    begin
                        Break;
                    end;
                    if Trim(exact_results_local[local_idx].comment) <> '' then
                    begin
                        Continue;
                    end;

                    candidate_text_local := Trim(exact_results_local[local_idx].text);
                    if (get_candidate_text_unit_count(candidate_text_local) <>
                        syllable_count_local) or
                        (not candidate_respects_fixed_boundaries_local(start_idx,
                        syllable_count_local, candidate_text_local)) then
                    begin
                        Continue;
                    end;

                    candidate_score_local := get_effective_weight_local(
                        exact_results_local[local_idx]);
                    Inc(candidate_score_local,
                        get_preferred_query_phrase_bonus_local(query_key_local,
                        candidate_text_local));
                    if syllable_count_local >= 4 then
                    begin
                        Inc(candidate_score_local, 1024);
                    end;
                    if syllable_count_local >= 5 then
                    begin
                        Inc(candidate_score_local, 1024);
                    end;

                    if candidate_score_local > best_score_local then
                    begin
                        best_score_local := candidate_score_local;
                        best_text_local := candidate_text_local;
                    end;
                end;
            end;

            if best_text_local <> '' then
            begin
                cached_chunk_states_local.AddOrSetValue(query_key_local, 1);
                cached_chunk_texts_local.AddOrSetValue(query_key_local,
                    best_text_local);
                cached_chunk_scores_local.AddOrSetValue(query_key_local,
                    best_score_local);
                out_text := best_text_local;
                out_score := best_score_local;
                Exit(True);
            end;

            cached_chunk_states_local.AddOrSetValue(query_key_local, 2);
        end;

        function extract_candidate_window_local(const units_local: TArray<string>;
            const start_idx: Integer; const syllable_count_local: Integer): string;
        var
            local_idx: Integer;
        begin
            Result := '';
            if (Length(units_local) <> input_syllable_count) or
                (start_idx < 0) or (syllable_count_local <= 0) or
                (start_idx + syllable_count_local > Length(units_local)) then
            begin
                Exit;
            end;
            for local_idx := start_idx to
                start_idx + syllable_count_local - 1 do
            begin
                Result := Result + units_local[local_idx];
            end;
        end;

        function evaluate_complete_candidate_local(
            const candidate_index_local: Integer): Integer;
        var
            start_idx_local: Integer;
            syllable_count_part_local: Integer;
            chunk_text_local: string;
            chunk_score_local: Integer;
            candidate_chunk_local: string;
            fixed_boundary_local: Boolean;
        begin
            Result := get_rank_score(candidates[candidate_index_local]) div
                c_complete_rank_scale;
            for start_idx_local := 0 to input_syllable_count - 1 do
            begin
                for syllable_count_part_local := c_min_window_syllables to
                    Min(c_max_window_syllables,
                    input_syllable_count - start_idx_local) do
                begin
                    if not try_get_best_exact_chunk_local(start_idx_local,
                        syllable_count_part_local, chunk_text_local,
                        chunk_score_local) then
                    begin
                        Continue;
                    end;
                    candidate_chunk_local := extract_candidate_window_local(
                        candidate_units_local[candidate_index_local],
                        start_idx_local, syllable_count_part_local);
                    if candidate_chunk_local = '' then
                    begin
                        Continue;
                    end;
                    fixed_boundary_local := window_has_fixed_boundary_local(
                        start_idx_local, syllable_count_part_local);
                    if SameText(candidate_chunk_local, chunk_text_local) then
                    begin
                        Inc(Result, syllable_count_part_local *
                            c_match_unit_weight);
                        if fixed_boundary_local then
                        begin
                            Inc(Result, c_fixed_match_bonus);
                        end;
                    end
                    else
                    begin
                        Dec(Result, syllable_count_part_local *
                            c_mismatch_unit_weight);
                        if fixed_boundary_local then
                        begin
                            Dec(Result, c_fixed_mismatch_penalty);
                        end;
                    end;
                end;
            end;
        end;

        procedure promote_existing_candidate_local(const existing_index_local: Integer);
        var
            picked_local: TncCandidate;
            local_idx: Integer;
        begin
            if existing_index_local <= 0 then
            begin
                Exit;
            end;
            picked_local := candidates[existing_index_local];
            for local_idx := existing_index_local downto 1 do
            begin
                candidates[local_idx] := candidates[local_idx - 1];
            end;
            candidates[0] := picked_local;
        end;
    begin
        if (Length(candidates) <= 1) or (m_dictionary = nil) or
            (input_syllable_count < c_min_syllables) or
            (not is_full_pinyin_key(lookup_text)) then
        begin
            Exit;
        end;

        syllables_local := get_effective_compact_pinyin_syllables(lookup_text);
        if Length(syllables_local) <> input_syllable_count then
        begin
            Exit;
        end;

        cached_chunk_texts_local := TDictionary<string, string>.Create;
        cached_chunk_scores_local := TDictionary<string, Integer>.Create;
        cached_chunk_states_local := TDictionary<string, Byte>.Create;
        try
            SetLength(candidate_units_local, Length(candidates));
            SetLength(complete_indexes_local, 0);
            for idx_local := 0 to High(candidates) do
            begin
                candidate_units_local[idx_local] := split_text_units(
                    Trim(candidates[idx_local].text));
                if (Trim(candidates[idx_local].comment) = '') and
                    (Length(candidate_units_local[idx_local]) =
                    input_syllable_count) then
                begin
                    SetLength(complete_indexes_local,
                        Length(complete_indexes_local) + 1);
                    complete_indexes_local[High(complete_indexes_local)] := idx_local;
                    if Length(complete_indexes_local) >= c_candidate_limit then
                    begin
                        Break;
                    end;
                end;
            end;

            if Length(complete_indexes_local) <= 1 then
            begin
                Exit;
            end;

            best_index_local := complete_indexes_local[0];
            top_index_local := complete_indexes_local[0];
            best_eval_score_local := evaluate_complete_candidate_local(
                best_index_local);
            top_eval_score_local := best_eval_score_local;
            for idx_local := 1 to High(complete_indexes_local) do
            begin
                candidate_idx_local := complete_indexes_local[idx_local];
                eval_score_local := evaluate_complete_candidate_local(
                    candidate_idx_local);
                if eval_score_local > best_eval_score_local then
                begin
                    best_eval_score_local := eval_score_local;
                    best_index_local := candidate_idx_local;
                end;
            end;

            if (best_index_local > 0) and
                (best_eval_score_local >= top_eval_score_local +
                c_promote_margin) then
            begin
                if m_config.debug_mode then
                begin
                    m_last_full_path_debug_info := m_last_full_path_debug_info +
                        Format(' vlc=[promote text=%s score=%d top=%d]',
                        [Trim(candidates[best_index_local].text),
                        best_eval_score_local, top_eval_score_local]);
                end;
                promote_existing_candidate_local(best_index_local);
            end
            else if m_config.debug_mode then
            begin
                m_last_full_path_debug_info := m_last_full_path_debug_info +
                    Format(' vlc=[keep text=%s score=%d top=%d]',
                    [Trim(candidates[top_index_local].text),
                    best_eval_score_local, top_eval_score_local]);
            end;
        finally
            cached_chunk_states_local.Free;
            cached_chunk_scores_local.Free;
            cached_chunk_texts_local.Free;
        end;
    end;

    function try_lookup_preferred_exact_phrase_candidate_local(
        const query_key: string; out out_candidate: TncCandidate;
        out out_syllable_count: Integer): Boolean;
    const
        c_min_preferred_phrase_syllables = 2;
        c_max_preferred_phrase_syllables = 4;
        c_min_preferred_phrase_weight = 80;
        c_regular_lookup_preferred_source_bonus = 0;
    var
        normalized_query: string;
        syllables_local: TncPinyinParseResult;
        exact_results_local: TncCandidateList;
        lookup_results_local: TncCandidateList;
        candidate_pool_local: TncCandidateList;
        candidate_pool_source_bonuses_local: TArray<Integer>;
        cache_key_local: string;
        phase_start_tick_local: UInt64;
        idx_local: Integer;
        candidate_text_local: string;
        candidate_units_local: Integer;
        candidate_weight_local: Integer;
        best_idx_local: Integer;
        best_weight_local: Integer;
        best_raw_weight_local: Integer;
        cached_state_local: Byte;
        has_valid_exact_candidate_local: Boolean;

        function get_candidate_effective_weight_local(const local_candidate: TncCandidate;
            const local_source_bonus: Integer): Integer;
        begin
            if local_candidate.has_dict_weight then
            begin
                Result := local_candidate.dict_weight;
            end
            else
            begin
                Result := local_candidate.score;
            end;
            Inc(Result, local_source_bonus);
        end;

        procedure append_candidate_pool_local(const source_candidates: TncCandidateList;
            const source_bonus: Integer);
        var
            source_idx_local: Integer;
            existing_idx_local: Integer;
            source_text_local: string;
            duplicate_found_local: Boolean;
            source_weight_local: Integer;
            existing_weight_local: Integer;
        begin
            for source_idx_local := 0 to High(source_candidates) do
            begin
                source_text_local := Trim(source_candidates[source_idx_local].text);
                if source_text_local = '' then
                begin
                    Continue;
                end;

                duplicate_found_local := False;
                source_weight_local := get_candidate_effective_weight_local(
                    source_candidates[source_idx_local], source_bonus);
                for existing_idx_local := 0 to High(candidate_pool_local) do
                begin
                    if SameText(Trim(candidate_pool_local[existing_idx_local].text),
                        source_text_local) then
                    begin
                        duplicate_found_local := True;
                        existing_weight_local := get_candidate_effective_weight_local(
                            candidate_pool_local[existing_idx_local],
                            candidate_pool_source_bonuses_local[existing_idx_local]);
                        if source_weight_local > existing_weight_local then
                        begin
                            candidate_pool_local[existing_idx_local] :=
                                source_candidates[source_idx_local];
                            candidate_pool_source_bonuses_local[existing_idx_local] :=
                                source_bonus;
                        end;
                        Break;
                    end;
                end;
                if duplicate_found_local then
                begin
                    Continue;
                end;

                SetLength(candidate_pool_local,
                    Length(candidate_pool_local) + 1);
                SetLength(candidate_pool_source_bonuses_local,
                    Length(candidate_pool_source_bonuses_local) + 1);
                candidate_pool_local[High(candidate_pool_local)] :=
                    source_candidates[source_idx_local];
                candidate_pool_source_bonuses_local[
                    High(candidate_pool_source_bonuses_local)] := source_bonus;
            end;
        end;

        function build_sub_query_key_local(const start_idx_local: Integer;
            const count_local: Integer): string;
        var
            key_idx_local: Integer;
        begin
            Result := '';
            if (start_idx_local < 0) or (count_local <= 0) or
                (start_idx_local + count_local - 1 > High(syllables_local)) then
            begin
                Exit;
            end;
            for key_idx_local := start_idx_local to
                start_idx_local + count_local - 1 do
            begin
                Result := Result + normalize_pinyin_text(
                    syllables_local[key_idx_local].text);
            end;
        end;

        function get_best_exact_weight_for_split_local(
            const split_query_key: string; const split_syllable_count: Integer;
            out out_weight: Integer): Boolean;
        var
            split_results_local: TncCandidateList;
            split_cache_key_local: string;
            split_phase_start_tick_local: UInt64;
            split_idx_local: Integer;
            split_text_local: string;
            split_weight_local: Integer;
        begin
            Result := False;
            out_weight := 0;
            if (split_query_key = '') or (split_syllable_count <= 0) then
            begin
                Exit;
            end;

            split_cache_key_local := '#preferred_split#' + split_query_key;
            if (lookup_cache <> nil) and
                lookup_cache.TryGetValue(split_cache_key_local,
                split_results_local) then
            begin
                Inc(lookup_cache_hits);
            end
            else
            begin
                Inc(lookup_cache_misses);
                split_phase_start_tick_local := GetTickCount64;
                if not m_dictionary.lookup_exact_full_pinyin(split_query_key,
                    split_results_local) then
                begin
                    SetLength(split_results_local, 0);
                end;
                Inc(lookup_elapsed_ms, Int64(GetTickCount64 -
                    split_phase_start_tick_local));
                if lookup_cache <> nil then
                begin
                    lookup_cache.AddOrSetValue(split_cache_key_local,
                        split_results_local);
                end;
            end;

            for split_idx_local := 0 to High(split_results_local) do
            begin
                if Trim(split_results_local[split_idx_local].comment) <> '' then
                begin
                    Continue;
                end;
                split_text_local := Trim(split_results_local[split_idx_local].text);
                if (split_text_local = '') or
                    (get_candidate_text_unit_count(split_text_local) <>
                    split_syllable_count) then
                begin
                    Continue;
                end;
                if split_results_local[split_idx_local].has_dict_weight then
                begin
                    split_weight_local :=
                        split_results_local[split_idx_local].dict_weight;
                end
                else
                begin
                    split_weight_local := split_results_local[split_idx_local].score;
                end;
                if split_weight_local > out_weight then
                begin
                    out_weight := split_weight_local;
                    Result := True;
                end;
            end;
        end;

        function has_much_stronger_split_local(
            const exact_weight_local: Integer): Boolean;
        const
            c_exact_phrase_protection_weight = 260;
            c_split_override_margin = 700;
            c_split_strong_chunk_weight = 360;
        var
            split_pos_local: Integer;
            left_key_local: string;
            right_key_local: string;
            left_weight_local: Integer;
            right_weight_local: Integer;
            split_weight_local: Integer;
        begin
            Result := False;
            if out_syllable_count < 3 then
            begin
                Exit;
            end;
            if exact_weight_local >= c_exact_phrase_protection_weight then
            begin
                Exit;
            end;

            for split_pos_local := 1 to out_syllable_count - 1 do
            begin
                left_key_local := build_sub_query_key_local(0,
                    split_pos_local);
                right_key_local := build_sub_query_key_local(split_pos_local,
                    out_syllable_count - split_pos_local);
                if (not get_best_exact_weight_for_split_local(left_key_local,
                    split_pos_local, left_weight_local)) or
                    (not get_best_exact_weight_for_split_local(right_key_local,
                    out_syllable_count - split_pos_local,
                    right_weight_local)) then
                begin
                    Continue;
                end;

                split_weight_local := left_weight_local + right_weight_local;
                if (Max(left_weight_local, right_weight_local) >=
                    c_split_strong_chunk_weight) and
                    (split_weight_local >= exact_weight_local +
                    c_split_override_margin) then
                begin
                    Exit(True);
                end;
            end;
        end;
    begin
        Result := False;
        out_candidate.text := '';
        out_candidate.comment := '';
        out_candidate.score := 0;
        out_candidate.source := cs_rule;
        out_candidate.has_dict_weight := False;
        out_candidate.dict_weight := 0;
        out_syllable_count := 0;

        normalized_query := normalize_pinyin_text(query_key);
        if (normalized_query = '') or (m_dictionary = nil) or
            (not is_full_pinyin_key(normalized_query)) then
        begin
            Exit;
        end;

        if (preferred_exact_state_cache <> nil) and
            preferred_exact_state_cache.TryGetValue(normalized_query,
            cached_state_local) then
        begin
            if (preferred_exact_syllable_count_cache <> nil) and
                (not preferred_exact_syllable_count_cache.TryGetValue(
                normalized_query, out_syllable_count)) then
            begin
                out_syllable_count := 0;
            end;
            if cached_state_local <> 0 then
            begin
                if (preferred_exact_candidate_cache <> nil) and
                    preferred_exact_candidate_cache.TryGetValue(
                    normalized_query, out_candidate) then
                begin
                    Exit(True);
                end;
            end;
            Exit(False);
        end;

        syllables_local := get_effective_compact_pinyin_syllables(
            normalized_query);
        out_syllable_count := Length(syllables_local);
        if (out_syllable_count < c_min_preferred_phrase_syllables) or
            (out_syllable_count > c_max_preferred_phrase_syllables) then
        begin
            Exit;
        end;

        cache_key_local := '#preferred_exact#' + normalized_query;
        if (lookup_cache <> nil) and
            lookup_cache.TryGetValue(cache_key_local, exact_results_local) then
        begin
            Inc(lookup_cache_hits);
        end
        else
        begin
            Inc(lookup_cache_misses);
            phase_start_tick_local := GetTickCount64;
            if not m_dictionary.lookup_exact_full_pinyin(normalized_query,
                exact_results_local) then
            begin
                SetLength(exact_results_local, 0);
            end;
            Inc(lookup_elapsed_ms, Int64(GetTickCount64 -
                phase_start_tick_local));
            if lookup_cache <> nil then
            begin
                lookup_cache.AddOrSetValue(cache_key_local,
                    exact_results_local);
            end;
        end;

        cache_key_local := '#preferred_lookup#' + normalized_query;
        if (lookup_cache <> nil) and
            lookup_cache.TryGetValue(cache_key_local, lookup_results_local) then
        begin
            Inc(lookup_cache_hits);
        end
        else
        begin
            Inc(lookup_cache_misses);
            phase_start_tick_local := GetTickCount64;
            if not m_dictionary.lookup(normalized_query, lookup_results_local) then
            begin
                SetLength(lookup_results_local, 0);
            end;
            Inc(lookup_elapsed_ms, Int64(GetTickCount64 -
                phase_start_tick_local));
            if lookup_cache <> nil then
            begin
                lookup_cache.AddOrSetValue(cache_key_local,
                    lookup_results_local);
            end;
        end;

        has_valid_exact_candidate_local := False;
        for idx_local := 0 to High(exact_results_local) do
        begin
            if Trim(exact_results_local[idx_local].comment) <> '' then
            begin
                Continue;
            end;
            candidate_text_local := Trim(exact_results_local[idx_local].text);
            if (candidate_text_local = '') or
                (get_candidate_text_unit_count(candidate_text_local) <>
                out_syllable_count) then
            begin
                Continue;
            end;
            if exact_results_local[idx_local].has_dict_weight then
            begin
                candidate_weight_local := exact_results_local[idx_local].dict_weight;
            end
            else
            begin
                candidate_weight_local := exact_results_local[idx_local].score;
            end;
            if candidate_weight_local >= c_min_preferred_phrase_weight then
            begin
                has_valid_exact_candidate_local := True;
                Break;
            end;
        end;

        SetLength(candidate_pool_local, 0);
        SetLength(candidate_pool_source_bonuses_local, 0);
        if has_valid_exact_candidate_local then
        begin
            append_candidate_pool_local(exact_results_local, 0);
        end
        else if out_syllable_count <= 2 then
        begin
            append_candidate_pool_local(lookup_results_local,
                c_regular_lookup_preferred_source_bonus);
        end
        else
        begin
            append_candidate_pool_local(lookup_results_local, 0);
        end;

        best_idx_local := -1;
        best_weight_local := Low(Integer);
        best_raw_weight_local := 0;
        for idx_local := 0 to High(candidate_pool_local) do
        begin
            if Trim(candidate_pool_local[idx_local].comment) <> '' then
            begin
                Continue;
            end;
            candidate_text_local := Trim(candidate_pool_local[idx_local].text);
            if candidate_text_local = '' then
            begin
                Continue;
            end;
            candidate_units_local := get_candidate_text_unit_count(
                candidate_text_local);
            if candidate_units_local <> out_syllable_count then
            begin
                Continue;
            end;

            if candidate_pool_local[idx_local].has_dict_weight then
            begin
                candidate_weight_local := candidate_pool_local[idx_local].dict_weight;
            end
            else
            begin
                candidate_weight_local := candidate_pool_local[idx_local].score;
            end;
            Inc(candidate_weight_local,
                candidate_pool_source_bonuses_local[idx_local]);
            if candidate_weight_local < c_min_preferred_phrase_weight then
            begin
                Continue;
            end;

            if candidate_weight_local > best_weight_local then
            begin
                best_weight_local := candidate_weight_local;
                best_raw_weight_local := candidate_weight_local -
                    candidate_pool_source_bonuses_local[idx_local];
                best_idx_local := idx_local;
            end;
        end;

        if best_idx_local >= 0 then
        begin
            if not has_much_stronger_split_local(best_raw_weight_local) then
            begin
                out_candidate := candidate_pool_local[best_idx_local];
                Result := True;
            end;
        end;

        if (preferred_exact_state_cache <> nil) then
        begin
            preferred_exact_state_cache.AddOrSetValue(normalized_query,
                Byte(Ord(Result)));
            if preferred_exact_syllable_count_cache <> nil then
            begin
                preferred_exact_syllable_count_cache.AddOrSetValue(
                    normalized_query, out_syllable_count);
            end;
            if Result and (preferred_exact_candidate_cache <> nil) then
            begin
                preferred_exact_candidate_cache.AddOrSetValue(normalized_query,
                    out_candidate);
            end;
        end;
    end;

    function has_learned_query_choice_override_local(const query_key: string;
        const candidate_text: string): Boolean;
    var
        normalized_query_local: string;
        text_key_local: string;
        latest_text_local: string;
        cache_key_local: string;
        cached_state_local: Byte;
    begin
        Result := False;
        normalized_query_local := normalize_pinyin_text(query_key);
        text_key_local := Trim(candidate_text);
        if (normalized_query_local = '') or (text_key_local = '') then
        begin
            Exit;
        end;

        cache_key_local := normalized_query_local + #1 + text_key_local;
        if (learned_query_choice_override_cache <> nil) and
            learned_query_choice_override_cache.TryGetValue(cache_key_local,
            cached_state_local) then
        begin
            Exit(cached_state_local <> 0);
        end;

        if (m_session_query_latest_text <> nil) and
            m_session_query_latest_text.TryGetValue(normalized_query_local,
            latest_text_local) and (Trim(latest_text_local) <> '') then
        begin
            Result := not SameText(text_key_local, Trim(latest_text_local));
            if learned_query_choice_override_cache <> nil then
            begin
                learned_query_choice_override_cache.AddOrSetValue(
                    cache_key_local, Byte(Ord(Result)));
            end;
            Exit;
        end;

        if m_dictionary = nil then
        begin
            Exit;
        end;

        latest_text_local := '';
        if (m_lookup_query_latest_text_cache <> nil) and
            m_lookup_query_latest_text_cache.TryGetValue(normalized_query_local,
            latest_text_local) then
        begin
        end
        else
        begin
            latest_text_local := Trim(
                m_dictionary.get_query_latest_choice_text(normalized_query_local));
            if m_lookup_query_latest_text_cache <> nil then
            begin
                m_lookup_query_latest_text_cache.AddOrSetValue(
                    normalized_query_local, latest_text_local);
            end;
        end;

        Result := (latest_text_local <> '') and
            (not SameText(text_key_local, latest_text_local));
        if learned_query_choice_override_cache <> nil then
        begin
            learned_query_choice_override_cache.AddOrSetValue(cache_key_local,
                Byte(Ord(Result)));
        end;
    end;

    function has_stronger_query_choice_bonus_competitor_local(
        const query_key: string; const candidate_text: string): Boolean;
    var
        normalized_query_local: string;
        text_key_local: string;
        exact_results_local: TncCandidateList;
        cache_key_local: string;
        phase_start_tick_local: UInt64;
        idx_local: Integer;
        competitor_text_local: string;
        candidate_bonus_local: Integer;
        competitor_bonus_local: Integer;
        candidate_units_local: Integer;
        cached_state_local: Byte;
    begin
        Result := False;
        normalized_query_local := normalize_pinyin_text(query_key);
        text_key_local := Trim(candidate_text);
        if (normalized_query_local = '') or (text_key_local = '') or
            (m_dictionary = nil) then
        begin
            Exit;
        end;

        cache_key_local := normalized_query_local + #1 + text_key_local;
        if (stronger_query_choice_competitor_cache <> nil) and
            stronger_query_choice_competitor_cache.TryGetValue(cache_key_local,
            cached_state_local) then
        begin
            Exit(cached_state_local <> 0);
        end;

        candidate_bonus_local := m_dictionary.get_query_choice_bonus(
            normalized_query_local, text_key_local);
        candidate_units_local := get_candidate_text_unit_count(text_key_local);

        cache_key_local := '#choice_override#' + normalized_query_local;
        if (lookup_cache <> nil) and
            lookup_cache.TryGetValue(cache_key_local, exact_results_local) then
        begin
            Inc(lookup_cache_hits);
        end
        else
        begin
            Inc(lookup_cache_misses);
            phase_start_tick_local := GetTickCount64;
            if not m_dictionary.lookup_exact_full_pinyin(normalized_query_local,
                exact_results_local) then
            begin
                SetLength(exact_results_local, 0);
            end;
            Inc(lookup_elapsed_ms, Int64(GetTickCount64 -
                phase_start_tick_local));
            if lookup_cache <> nil then
            begin
                lookup_cache.AddOrSetValue(cache_key_local,
                    exact_results_local);
            end;
        end;

        for idx_local := 0 to High(exact_results_local) do
        begin
            if Trim(exact_results_local[idx_local].comment) <> '' then
            begin
                Continue;
            end;
            competitor_text_local := Trim(exact_results_local[idx_local].text);
            if (competitor_text_local = '') or
                SameText(competitor_text_local, text_key_local) or
                (get_candidate_text_unit_count(competitor_text_local) <>
                candidate_units_local) then
            begin
                Continue;
            end;

            competitor_bonus_local := m_dictionary.get_query_choice_bonus(
                normalized_query_local, competitor_text_local);
            if competitor_bonus_local > candidate_bonus_local then
            begin
                Result := True;
                Break;
            end;
        end;
        if stronger_query_choice_competitor_cache <> nil then
        begin
            stronger_query_choice_competitor_cache.AddOrSetValue(
                normalized_query_local + #1 + text_key_local, Byte(Ord(Result)));
        end;
    end;

    function get_preferred_query_phrase_bonus_local(const query_key: string;
        const candidate_text: string): Integer;
    var
        preferred_candidate_local: TncCandidate;
        preferred_syllables_local: Integer;
        preferred_text_local: string;
        weight_value_local: Integer;
        normalized_query_local: string;
        text_key_local: string;
        cache_key_local: string;
        cached_bonus_local: Integer;
    begin
        Result := 0;
        normalized_query_local := normalize_pinyin_text(query_key);
        text_key_local := Trim(candidate_text);
        if (normalized_query_local = '') or (text_key_local = '') then
        begin
            Exit;
        end;

        cache_key_local := normalized_query_local + #1 + text_key_local;
        if (preferred_query_phrase_bonus_cache <> nil) and
            preferred_query_phrase_bonus_cache.TryGetValue(cache_key_local,
            cached_bonus_local) then
        begin
            Exit(cached_bonus_local);
        end;

        if has_learned_query_choice_override_local(normalized_query_local,
            text_key_local) then
        begin
            preferred_query_phrase_bonus_cache.AddOrSetValue(cache_key_local,
                Result);
            Exit;
        end;
        if has_stronger_query_choice_bonus_competitor_local(normalized_query_local,
            text_key_local) then
        begin
            preferred_query_phrase_bonus_cache.AddOrSetValue(cache_key_local,
                Result);
            Exit;
        end;
        if not try_lookup_preferred_exact_phrase_candidate_local(
            normalized_query_local, preferred_candidate_local,
            preferred_syllables_local) then
        begin
            preferred_query_phrase_bonus_cache.AddOrSetValue(cache_key_local,
                Result);
            Exit;
        end;

        preferred_text_local := Trim(preferred_candidate_local.text);
        if not SameText(text_key_local, preferred_text_local) then
        begin
            preferred_query_phrase_bonus_cache.AddOrSetValue(cache_key_local,
                Result);
            Exit;
        end;

        if preferred_candidate_local.has_dict_weight then
        begin
            weight_value_local := preferred_candidate_local.dict_weight;
        end
        else
        begin
            weight_value_local := preferred_candidate_local.score;
        end;
        Result := 1600 + Min(1800, Max(0, weight_value_local)) +
            preferred_syllables_local * 160;
        preferred_query_phrase_bonus_cache.AddOrSetValue(cache_key_local,
            Result);
    end;
    procedure apply_preferred_query_phrase_bonus_for_query(const query_key: string;
        var candidates: TncCandidateList);
    var
        idx: Integer;
        bonus: Integer;
    begin
        if normalize_pinyin_text(query_key) = '' then
        begin
            Exit;
        end;

        for idx := 0 to High(candidates) do
        begin
            if Trim(candidates[idx].comment) <> '' then
            begin
                Continue;
            end;

            bonus := get_preferred_query_phrase_bonus_local(query_key,
                Trim(candidates[idx].text));
            if bonus <> 0 then
            begin
                Inc(candidates[idx].score, bonus);
            end;
        end;
    end;

    function try_get_preferred_query_phrase_text_local(const query_key: string;
        out out_text: string; out out_bonus: Integer): Boolean;
    const
        c_no_preferred_phrase_text = #0;
    var
        preferred_candidate_local: TncCandidate;
        preferred_syllables_local: Integer;
        weight_value_local: Integer;
        normalized_query_local: string;
        cached_text_local: string;
    begin
        out_text := '';
        out_bonus := 0;
        normalized_query_local := normalize_pinyin_text(query_key);
        if normalized_query_local = '' then
        begin
            Result := False;
            Exit;
        end;

        if (preferred_query_phrase_text_cache <> nil) and
            preferred_query_phrase_text_cache.TryGetValue(normalized_query_local,
            cached_text_local) then
        begin
            if SameText(cached_text_local, c_no_preferred_phrase_text) then
            begin
                Result := False;
                Exit;
            end;
            out_text := cached_text_local;
            out_bonus := 0;
            if preferred_query_phrase_text_bonus_cache <> nil then
            begin
                preferred_query_phrase_text_bonus_cache.TryGetValue(
                    normalized_query_local, out_bonus);
            end;
            Result := True;
            Exit;
        end;

        Result := try_lookup_preferred_exact_phrase_candidate_local(
            normalized_query_local, preferred_candidate_local,
            preferred_syllables_local);
        if not Result then
        begin
            preferred_query_phrase_text_cache.AddOrSetValue(
                normalized_query_local, c_no_preferred_phrase_text);
            preferred_query_phrase_text_bonus_cache.AddOrSetValue(
                normalized_query_local, 0);
            Exit;
        end;

        out_text := Trim(preferred_candidate_local.text);
        if has_learned_query_choice_override_local(normalized_query_local,
            out_text) then
        begin
            out_text := '';
            Result := False;
            preferred_query_phrase_text_cache.AddOrSetValue(
                normalized_query_local, c_no_preferred_phrase_text);
            preferred_query_phrase_text_bonus_cache.AddOrSetValue(
                normalized_query_local, 0);
            Exit;
        end;
        if has_stronger_query_choice_bonus_competitor_local(
            normalized_query_local, out_text) then
        begin
            out_text := '';
            Result := False;
            preferred_query_phrase_text_cache.AddOrSetValue(
                normalized_query_local, c_no_preferred_phrase_text);
            preferred_query_phrase_text_bonus_cache.AddOrSetValue(
                normalized_query_local, 0);
            Exit;
        end;
        if preferred_candidate_local.has_dict_weight then
        begin
            weight_value_local := preferred_candidate_local.dict_weight;
        end
        else
        begin
            weight_value_local := preferred_candidate_local.score;
        end;
        out_bonus := 1800 + Min(2000, Max(0, weight_value_local)) +
            preferred_syllables_local * 180;
        preferred_query_phrase_text_cache.AddOrSetValue(normalized_query_local,
            out_text);
        preferred_query_phrase_text_bonus_cache.AddOrSetValue(
            normalized_query_local, out_bonus);
    end;
