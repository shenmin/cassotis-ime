        function solver_segment_has_fixed_boundary_local(const start_idx: Integer;
            const syllable_count_part: Integer): Boolean;
        var
            local_idx: Integer;
        begin
            Result := False;
            if (start_idx < 0) or (syllable_count_part <= 0) or
                (start_idx + syllable_count_part > syllable_count_local) then
            begin
                Exit;
            end;

            for local_idx := 0 to syllable_count_part - 1 do
            begin
                if get_fixed_boundary_single_char_for_solver_local(
                    effective_syllables[start_idx + local_idx].text) <> '' then
                begin
                    Exit(True);
                end;
            end;
        end;

        function solver_candidate_respects_fixed_boundaries_local(
            const start_idx: Integer; const syllable_count_part: Integer;
            const candidate_text: string): Boolean;
        var
            text_units_local: TArray<string>;
            local_idx: Integer;
            fixed_text_local: string;
        begin
            Result := False;
            if (start_idx < 0) or (syllable_count_part <= 0) or
                (start_idx + syllable_count_part > syllable_count_local) then
            begin
                Exit;
            end;

            text_units_local := split_text_units(Trim(candidate_text));
            if Length(text_units_local) <> syllable_count_part then
            begin
                Exit(not solver_segment_has_fixed_boundary_local(start_idx,
                    syllable_count_part));
            end;

            for local_idx := 0 to syllable_count_part - 1 do
            begin
                fixed_text_local := get_fixed_boundary_single_char_for_solver_local(
                    effective_syllables[start_idx + local_idx].text);
                if (fixed_text_local <> '') and
                    (not SameText(text_units_local[local_idx], fixed_text_local)) then
                begin
                    Exit(False);
                end;
            end;

            Result := True;
        end;

