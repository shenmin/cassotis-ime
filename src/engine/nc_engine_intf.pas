            input_syllable_count) then
        begin
            Exit;
        end;

        if (Length(candidates) <= 1) or (input_syllable_count < 2) or
            ((m_dictionary = nil) and (Length(candidates) <= 1)) then
        begin
            Exit;
        end;

        effective_syllables := get_effective_compact_pinyin_syllables(lookup_text);
        if Length(effective_syllables) <> input_syllable_count then
        begin
            Exit;
        end;
        last_syllable_text := Trim(effective_syllables[High(effective_syllables)].text);
        if (input_syllable_count >= 6) and (last_syllable_text <> '') and
