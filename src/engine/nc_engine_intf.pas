        for suffix_ch_local := 'a' to 'z' do
        begin
            extended_tail_local := tail_text_local + suffix_ch_local;
            if is_full_pinyin_key(extended_tail_local) and
                (get_effective_compact_pinyin_unit_count(
                extended_tail_local) = 1) then
