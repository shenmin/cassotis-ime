        function is_valid_cjk_phrase_text_local(const value: string;
            const expected_units: Integer): Boolean;
        var
            units: TArray<string>;
            unit_idx: Integer;
            codepoint: Integer;

            function try_get_codepoint_local(const unit_text: string;
                out out_codepoint: Integer): Boolean;
            begin
                Result := False;
                out_codepoint := 0;
                if unit_text = '' then
                begin
                    Exit;
                end;

                if Length(unit_text) = 1 then
                begin
                    out_codepoint := Ord(unit_text[1]);
                    Exit(True);
                end;

                if (Length(unit_text) = 2) and
                    (Ord(unit_text[1]) >= $D800) and
                    (Ord(unit_text[1]) <= $DBFF) and
                    (Ord(unit_text[2]) >= $DC00) and
                    (Ord(unit_text[2]) <= $DFFF) then
                begin
                    out_codepoint := ((Ord(unit_text[1]) - $D800) shl 10) +
                        (Ord(unit_text[2]) - $DC00) + $10000;
                    Exit(True);
                end;
            end;
        begin
            Result := False;
            if Trim(value) = '' then
            begin
                Exit;
            end;

            units := split_text_units(Trim(value));
            if Length(units) <> expected_units then
            begin
                Exit;
            end;

            for unit_idx := 0 to High(units) do
            begin
                if (not try_get_codepoint_local(units[unit_idx], codepoint)) or
                    (codepoint < $4E00) or (codepoint > $9FFF) then
                begin
                    Exit(False);
                end;
            end;

            Result := True;
        end;

        function try_find_query_key_span_local(const query_key: string;
            const expected_syllables: Integer; const prefer_suffix: Boolean;
            out out_start_idx: Integer): Boolean;
        var
            query_syllables_local: TncPinyinParseResult;
            lookup_syllables_local: TncPinyinParseResult;
            start_idx_local: Integer;

            function matches_at_local(const candidate_start_idx: Integer): Boolean;
            var
                local_unit_idx: Integer;
            begin
                Result := False;
                if (candidate_start_idx < 0) or
                    (candidate_start_idx + expected_syllables - 1 >
                    High(lookup_syllables_local)) then
                begin
                    Exit;
                end;

                for local_unit_idx := 0 to expected_syllables - 1 do
                begin
                    if not SameText(normalize_pinyin_text(
                        lookup_syllables_local[candidate_start_idx + local_unit_idx].text),
                        normalize_pinyin_text(query_syllables_local[local_unit_idx].text)) then
                    begin
                        Exit(False);
                    end;
                end;

                Result := True;
            end;
        begin
            Result := False;
            out_start_idx := -1;
            if (query_key = '') or (expected_syllables <= 0) or
                (not is_full_pinyin_key(query_key)) or
                (not is_full_pinyin_key(lookup_text)) or
                (input_syllable_count < expected_syllables) then
            begin
                Exit;
            end;

            query_syllables_local := get_effective_compact_pinyin_syllables(query_key);
            if Length(query_syllables_local) <> expected_syllables then
            begin
                Exit;
            end;

            lookup_syllables_local := get_effective_compact_pinyin_syllables(lookup_text);
            if Length(lookup_syllables_local) <> input_syllable_count then
            begin
                Exit;
            end;

            if prefer_suffix then
            begin
                start_idx_local := input_syllable_count - expected_syllables;
                if matches_at_local(start_idx_local) then
                begin
                    out_start_idx := start_idx_local;
                    Exit(True);
                end;
            end;

            for start_idx_local := 0 to input_syllable_count - expected_syllables do
            begin
                if prefer_suffix and
                    (start_idx_local = input_syllable_count - expected_syllables) then
                begin
                    Continue;
                end;
                if matches_at_local(start_idx_local) then
                begin
                    out_start_idx := start_idx_local;
                    Exit(True);
                end;
            end;
        end;

        function try_get_best_completion_local(const query_key: string;
            const expected_syllables: Integer; out out_text: string;
            out out_score: Integer): Boolean;
        var
            cached_state: Integer;
            local_results: TncCandidateList;
            snapshot_candidates: TncCandidateList;
            snapshot_scores: TArray<Integer>;
            local_idx: Integer;
            candidate: TncCandidate;
            candidate_text: string;
            candidate_score: Integer;
            candidate_units: Integer;
            preferred_text: string;
            best_complete_text: string;
            best_complete_score: Integer;
            best_partial_text: string;
            best_partial_score: Integer;
            best_partial_comment: string;
            best_split_text: string;
            best_split_score: Integer;
            comment_key: string;
            comment_syllables: TncPinyinParseResult;
            tail_text: string;
            tail_score: Integer;
            combined_text: string;
            combined_score: Integer;
            context_bonus: Integer;
            query_syllables: TncPinyinParseResult;
            split_idx: Integer;
            left_key: string;
            right_key: string;
            left_text: string;
            left_score: Integer;
            right_text: string;
            right_score: Integer;
            aligned_start_idx: Integer;
            aligned_segments: Integer;
            aligned_path: string;
            aligned_has_anchor: Boolean;
            aligned_anchor_units: Integer;
        begin
            Result := False;
            out_text := '';
            out_score := 0;
            if (query_key = '') or (expected_syllables <= 0) or
                (not is_full_pinyin_key(query_key)) then
            begin
                Exit;
            end;

            if completion_states.TryGetValue(query_key, cached_state) then
            begin
                if cached_state = 1 then
                begin
                    completion_texts.TryGetValue(query_key, out_text);
                    completion_scores.TryGetValue(query_key, out_score);
                    Exit(out_text <> '');
                end;
                Exit(False);
            end;

            if expected_syllables = 1 then
            begin
                preferred_text := get_fixed_boundary_single_char_local(query_key);
                if (m_dictionary <> nil) and
                    m_dictionary.lookup_exact_full_pinyin(query_key, local_results) then
                begin
                    for local_idx := 0 to High(local_results) do
                    begin
                        if local_idx >= c_completion_probe_limit then
                        begin
                            Break;
                        end;
                        if Trim(local_results[local_idx].comment) <> '' then
                        begin
                            Continue;
                        end;
                        candidate_text := Trim(local_results[local_idx].text);
                        if (get_candidate_text_unit_count(candidate_text) <> 1) or
                            (not is_valid_cjk_phrase_text_local(candidate_text, 1)) then
                        begin
                            Continue;
                        end;

                        candidate_score := local_results[local_idx].score;
                        if local_results[local_idx].has_dict_weight and
                            (local_results[local_idx].dict_weight > candidate_score) then
                        begin
                            candidate_score := local_results[local_idx].dict_weight;
                        end;
                        Inc(candidate_score, get_preferred_query_phrase_bonus_local(
                            query_key, candidate_text));
                        if (preferred_text <> '') and
                            SameText(candidate_text, preferred_text) then
                        begin
                            Inc(candidate_score, 256);
                        end;

                        if (not Result) or (candidate_score > out_score) then
                        begin
                            Result := True;
                            out_text := candidate_text;
                            out_score := candidate_score;
                        end;
                    end;
                end;

                if (not Result) and (preferred_text <> '') then
                begin
                    out_text := preferred_text;
                    out_score := 1500;
                    Result := True;
                end;

                if Result then
                begin
                    completion_states.AddOrSetValue(query_key, 1);
                    completion_texts.AddOrSetValue(query_key, out_text);
                    completion_scores.AddOrSetValue(query_key, out_score);
                end
                else
                begin
                    completion_states.AddOrSetValue(query_key, 2);
                end;
                Exit(Result);
            end;

            if try_find_query_key_span_local(query_key, expected_syllables, True,
                aligned_start_idx) and
                try_resolve_best_exact_subspan_local(aligned_start_idx,
                expected_syllables, out_text, out_score, aligned_segments,
                aligned_path, aligned_has_anchor, aligned_anchor_units) then
            begin
                completion_states.AddOrSetValue(query_key, 1);
                completion_texts.AddOrSetValue(query_key, out_text);
                completion_scores.AddOrSetValue(query_key, out_score);
                Exit(True);
            end;

            completion_states.AddOrSetValue(query_key, 3);

            SetLength(snapshot_candidates, 0);
            SetLength(snapshot_scores, 0);

            best_complete_text := '';
            best_complete_score := Low(Integer);
            best_partial_text := '';
            best_partial_score := Low(Integer);
            best_partial_comment := '';
            best_split_text := '';
            best_split_score := Low(Integer);

            for local_idx := 0 to High(snapshot_candidates) do
            begin
                if local_idx >= c_completion_probe_limit then
                begin
                    Break;
                end;

                candidate := snapshot_candidates[local_idx];
                candidate_text := Trim(candidate.text);
                if candidate_text = '' then
                begin
                    Continue;
                end;

                candidate_score := snapshot_scores[local_idx] +
                    get_preferred_query_phrase_bonus_local(query_key, candidate_text);
                candidate_units := get_candidate_text_unit_count(candidate_text);

                if Trim(candidate.comment) = '' then
                begin
                    if (candidate_units = expected_syllables) and
                        is_valid_cjk_phrase_text_local(candidate_text,
                        expected_syllables) and
                        (candidate_score > best_complete_score) then
                    begin
                        best_complete_text := candidate_text;
                        best_complete_score := candidate_score;
                    end;
                    Continue;
                end;

                comment_key := normalize_pinyin_text(candidate.comment);
                if (comment_key = '') or (not is_full_pinyin_key(comment_key)) then
                begin
                    Continue;
                end;

                comment_syllables := get_effective_compact_pinyin_syllables(comment_key);
                if (Length(comment_syllables) = 0) or
                    (candidate_units + Length(comment_syllables) <> expected_syllables) then
                begin
                    Continue;
                end;

                if not try_get_best_completion_local(comment_key,
                    Length(comment_syllables), tail_text, tail_score) then
                begin
                    Continue;
                end;

                combined_text := candidate_text + tail_text;
                if not is_valid_cjk_phrase_text_local(combined_text, expected_syllables) then
                begin
                    Continue;
                end;

                combined_score := candidate_score + tail_score;
                if m_dictionary <> nil then
                begin
                    context_bonus := m_dictionary.get_context_bonus(candidate_text,
                        tail_text);
                    Inc(combined_score, context_bonus);
                end;
                if is_boundary_tail_comment_local(comment_key) then
                begin
                    Inc(combined_score, 1024);
                end;

                if combined_score > best_partial_score then
                begin
                    best_partial_text := combined_text;
                    best_partial_score := combined_score;
                    best_partial_comment := comment_key;
                end;
            end;

            query_syllables := get_effective_compact_pinyin_syllables(query_key);
            if Length(query_syllables) = expected_syllables then
            begin
                for split_idx := 1 to expected_syllables - 1 do
                begin
                    left_key := '';
                    for local_idx := 0 to split_idx - 1 do
                    begin
                        left_key := left_key +
                            normalize_pinyin_text(query_syllables[local_idx].text);
                    end;

                    right_key := '';
                    for local_idx := split_idx to High(query_syllables) do
                    begin
                        right_key := right_key +
                            normalize_pinyin_text(query_syllables[local_idx].text);
                    end;

                    if (left_key = '') or (right_key = '') then
                    begin
                        Continue;
                    end;

                    if not try_get_best_completion_local(left_key, split_idx,
                        left_text, left_score) then
                    begin
                        Continue;
                    end;
                    if not try_get_best_completion_local(right_key,
                        expected_syllables - split_idx, right_text,
                        right_score) then
                    begin
                        Continue;
                    end;

                    combined_text := left_text + right_text;
                    if not is_valid_cjk_phrase_text_local(combined_text, expected_syllables) then
                    begin
                        Continue;
                    end;

                    combined_score := left_score + right_score - 96;
                    if m_dictionary <> nil then
                    begin
                        context_bonus := m_dictionary.get_context_bonus(left_text,
                            right_text);
                        Inc(combined_score, context_bonus);
                    end;

                    if combined_score > best_split_score then
                    begin
                        best_split_text := combined_text;
                        best_split_score := combined_score;
                    end;
                end;
            end;

            if best_complete_text <> '' then
            begin
                out_text := best_complete_text;
                out_score := best_complete_score;
                if (best_partial_text <> '') and
                    ((is_boundary_tail_comment_local(best_partial_comment) and
                    (best_partial_score > best_complete_score - 256)) or
                    (best_partial_score > best_complete_score + 512)) then
                begin
                    out_text := best_partial_text;
                    out_score := best_partial_score;
                end;
            end;

            if (best_split_text <> '') and
                ((out_text = '') or (best_split_score > out_score - 64)) then
            begin
                out_text := best_split_text;
                out_score := best_split_score;
            end;

            if (out_text = '') and (best_partial_text <> '') then
            begin
                out_text := best_partial_text;
                out_score := best_partial_score;
            end;

            if out_text <> '' then
            begin
                completion_states.AddOrSetValue(query_key, 1);
                completion_texts.AddOrSetValue(query_key, out_text);
                completion_scores.AddOrSetValue(query_key, out_score);
                Exit(True);
            end;

            completion_states.AddOrSetValue(query_key, 2);
        end;

        function try_get_best_completed_visible_candidate_local(
            out out_text: string; out out_score: Integer): Boolean;
        var
            local_idx: Integer;
            candidate: TncCandidate;
            prefix_text: string;
            prefix_units: Integer;
            comment_key: string;
            comment_syllables: TncPinyinParseResult;
            tail_text: string;
            tail_score: Integer;
            combined_text: string;
            combined_score: Integer;
            context_bonus: Integer;
        begin
            Result := False;
            out_text := '';
            out_score := 0;

            for local_idx := 0 to High(candidates) do
            begin
                if local_idx >= c_visible_probe_limit then
                begin
                    Break;
                end;

                candidate := candidates[local_idx];
                if Trim(candidate.comment) = '' then
                begin
                    Continue;
                end;

                prefix_text := Trim(candidate.text);
                prefix_units := get_candidate_text_unit_count(prefix_text);
                if prefix_units <= 0 then
                begin
                    Continue;
                end;

                comment_key := normalize_pinyin_text(candidate.comment);
                if (comment_key = '') or (not is_full_pinyin_key(comment_key)) then
                begin
                    Continue;
                end;

                comment_syllables := get_effective_compact_pinyin_syllables(
                    comment_key);
                if (Length(comment_syllables) = 0) or
                    (Length(comment_syllables) > c_completion_tail_max_syllables) or
                    (prefix_units + Length(comment_syllables) <> input_syllable_count) then
                begin
                    Continue;
                end;

                if not try_get_best_completion_local(comment_key,
                    Length(comment_syllables), tail_text, tail_score) then
                begin
                    Continue;
                end;

                combined_text := prefix_text + tail_text;
                if not is_valid_cjk_phrase_text_local(combined_text, input_syllable_count) then
                begin
                    Continue;
                end;

                combined_score := get_rank_score(candidate) + tail_score;
                if m_dictionary <> nil then
                begin
                    context_bonus := m_dictionary.get_context_bonus(prefix_text,
                        tail_text);
                    Inc(combined_score, context_bonus);
                end;
                if is_boundary_tail_comment_local(comment_key) then
                begin
                    Inc(combined_score, 1024);
                end;

                if (not Result) or (combined_score > out_score) or
                    ((combined_score = out_score) and
                    (CompareText(combined_text, out_text) < 0)) then
                begin
                    Result := True;
                    out_text := combined_text;
                    out_score := combined_score;
                    best_index := local_idx;
                end;
            end;
        end;
    var
        combined_text: string;
        combined_score: Integer;
        top_rank: Integer;
    begin
        if (Length(candidates) = 0) or (input_syllable_count < 6) or
            (not is_full_pinyin_key(lookup_text)) or (m_dictionary = nil) then
        begin
            Exit;
        end;

        if (input_syllable_count <= 10) and
            (Trim(candidates[0].comment) = '') and
            (get_candidate_text_unit_count(Trim(candidates[0].text)) =
            input_syllable_count) then
        begin
            Exit;
        end;

        completion_states := TDictionary<string, Integer>.Create;
        completion_texts := TDictionary<string, string>.Create;
        completion_scores := TDictionary<string, Integer>.Create;
        best_index := -1;
        try
            if not try_get_best_completed_visible_candidate_local(combined_text,
                combined_score) then
            begin
                Exit;
            end;

            existing_index := -1;
            for idx := 0 to High(candidates) do
            begin
                if (Trim(candidates[idx].comment) = '') and
                    SameText(Trim(candidates[idx].text), combined_text) then
                begin
                    existing_index := idx;
                    Break;
                end;
            end;

            if existing_index = 0 then
            begin
                Exit;
            end;

            top_rank := get_rank_score(candidates[0]);
            if existing_index > 0 then
            begin
                if (best_index >= 0) and
                    (best_index < Length(candidates)) and
                    (get_rank_score(candidates[best_index]) + c_completion_promote_bonus <
                    top_rank) and
                    (get_candidate_text_unit_count(Trim(candidates[0].text)) =
                    input_syllable_count) then
                begin
                    Exit;
                end;

                picked := candidates[existing_index];
                for idx := existing_index downto 1 do
                begin
                    candidates[idx] := candidates[idx - 1];
                end;
                candidates[0] := picked;
                Exit;
            end;

            if (best_index >= 0) and (best_index < Length(candidates)) and
                (get_rank_score(candidates[best_index]) + c_completion_promote_bonus <
                top_rank) and
                (Trim(candidates[0].comment) = '') and
                (get_candidate_text_unit_count(Trim(candidates[0].text)) =
                input_syllable_count) then
            begin
                Exit;
            end;

            FillChar(picked, SizeOf(picked), 0);
            picked.text := combined_text;
            picked.comment := '';
            picked.score := Max(top_rank + c_completion_promote_bonus, combined_score);
            picked.source := cs_rule;
            picked.has_dict_weight := False;
            picked.dict_weight := 0;

            SetLength(candidates, Length(candidates) + 1);
            for idx := High(candidates) downto 1 do
            begin
                candidates[idx] := candidates[idx - 1];
            end;
            candidates[0] := picked;
        finally
            completion_scores.Free;
            completion_texts.Free;
            completion_states.Free;
        end;
    end;

    procedure ensure_best_visible_complete_sentence_candidate_visible(
        var candidates: TncCandidateList);
    const
        c_visible_probe_limit = 8;
        c_exact_probe_limit = 8;
        c_promote_margin = 512;
        c_rank_score_cap = 8192;
    var
        effective_syllables: TncPinyinParseResult;
        loaded_queries: TDictionary<string, Byte>;
        exact_rank_cache: TDictionary<string, Integer>;
        exact_top_text_cache: TDictionary<string, string>;
        best_index: Integer;
        best_score: Integer;
        top_score: Integer;
        idx: Integer;
        candidate_score: Integer;
        picked: TncCandidate;

        function build_query_key_local(const start_idx: Integer;
            const syllable_count_part: Integer): string;
        var
            local_idx: Integer;
        begin
            Result := '';
            if (start_idx < 0) or (syllable_count_part <= 0) or
                (start_idx + syllable_count_part - 1 > High(effective_syllables)) then
            begin
                Exit;
            end;

            for local_idx := start_idx to start_idx + syllable_count_part - 1 do
            begin
                Result := Result + normalize_pinyin_text(effective_syllables[local_idx].text);
            end;
        end;

        function build_chunk_text_local(const units: TArray<string>;
            const start_idx: Integer; const unit_count: Integer): string;
        var
            local_idx: Integer;
        begin
            Result := '';
            if (start_idx < 0) or (unit_count <= 0) or
                (start_idx + unit_count - 1 > High(units)) then
            begin
                Exit;
            end;

            for local_idx := start_idx to start_idx + unit_count - 1 do
            begin
                Result := Result + units[local_idx];
            end;
        end;

        procedure ensure_query_loaded_local(const query_key: string;
            const expected_units: Integer; const start_idx: Integer);
        var
            local_idx: Integer;
            cache_key: string;
            candidate_text: string;
            exact_results: TncCandidateList;
            resolved_text_local: string;
            resolved_path_local: string;
            resolved_score_local: Integer;
            resolved_segments_local: Integer;
            resolved_anchor_units_local: Integer;
            resolved_has_anchor_local: Boolean;
            has_resolved_local: Boolean;
            raw_rank_local: Integer;
        begin
            if (query_key = '') or loaded_queries.ContainsKey(query_key) then
            begin
                Exit;
            end;

            loaded_queries.Add(query_key, 1);
            has_resolved_local := False;
            if (start_idx >= 0) and (expected_units >= 3) and
                (expected_units <= 5) and
                try_resolve_best_exact_subspan_local(start_idx, expected_units,
                resolved_text_local, resolved_score_local,
                resolved_segments_local, resolved_path_local,
                resolved_has_anchor_local, resolved_anchor_units_local) and
                (resolved_text_local <> '') then
            begin
                has_resolved_local := True;
                exact_top_text_cache.AddOrSetValue(query_key,
                    resolved_text_local);
                cache_key := query_key + '|' + resolved_text_local;
                exact_rank_cache.AddOrSetValue(cache_key, 0);
            end;

            if exact_top_text_cache.ContainsKey(query_key) then
            begin
                Exit;
            end;

            if (m_dictionary = nil) or
                (not m_dictionary.lookup_exact_full_pinyin(query_key, exact_results)) then
            begin
                Exit;
            end;

            raw_rank_local := 0;
            for local_idx := 0 to High(exact_results) do
            begin
                if local_idx >= c_exact_probe_limit then
                begin
                    Break;
                end;
                if Trim(exact_results[local_idx].comment) <> '' then
                begin
                    Continue;
                end;

                candidate_text := Trim(exact_results[local_idx].text);
                if candidate_text = '' then
                begin
                    Continue;
                end;
                if has_resolved_local and
                    SameText(candidate_text, resolved_text_local) then
                begin
                    Continue;
                end;
                if not exact_top_text_cache.ContainsKey(query_key) then
                begin
                    exact_top_text_cache.Add(query_key, candidate_text);
                end;

                cache_key := query_key + '|' + candidate_text;
                if not exact_rank_cache.ContainsKey(cache_key) then
                begin
                    if has_resolved_local then
                    begin
                        exact_rank_cache.Add(cache_key, raw_rank_local + 1);
                    end
                    else
                    begin
                        exact_rank_cache.Add(cache_key, raw_rank_local);
                    end;
                end;
                Inc(raw_rank_local);
            end;
        end;

        function get_exact_support_bonus_local(const query_key: string;
            const candidate_text: string; const start_idx: Integer): Integer;
        var
            cache_key: string;
            rank_value: Integer;
        begin
            Result := 0;
            if (query_key = '') or (candidate_text = '') then
            begin
                Exit;
            end;

            Inc(Result, get_preferred_query_phrase_bonus_local(query_key,
                candidate_text));
            Inc(Result, get_preferred_exact_subspan_bonus_local(query_key,
                candidate_text));

            ensure_query_loaded_local(query_key,
                get_candidate_text_unit_count(candidate_text), start_idx);
            cache_key := query_key + '|' + candidate_text;
            if not exact_rank_cache.TryGetValue(cache_key, rank_value) then
            begin
                Exit;
            end;

            case rank_value of
                0:
                    Inc(Result, 1100);
                1:
                    Inc(Result, 800);
                2, 3:
                    Inc(Result, 480);
                4, 5:
                    Inc(Result, 240);
            else
                Inc(Result, 120);
            end;
        end;

        function get_exact_mismatch_penalty_local(const query_key: string;
            const candidate_text: string; const span_units: Integer;
            const start_idx: Integer): Integer;
        var
            cache_key: string;
            rank_value: Integer;
            top_text: string;
        begin
            Result := 0;
            if (query_key = '') or (candidate_text = '') then
            begin
                Exit;
            end;

            ensure_query_loaded_local(query_key, span_units, start_idx);
            cache_key := query_key + '|' + candidate_text;
            if exact_rank_cache.TryGetValue(cache_key, rank_value) then
            begin
                case rank_value of
                    0:
                        Exit(0);
                    1:
                        Exit(-96);
                    2, 3:
                        Exit(-192);
                    4, 5:
                        Exit(-320);
                else
                    Exit(-480);
                end;
            end;

            if not exact_top_text_cache.TryGetValue(query_key, top_text) or
                (top_text = '') or SameText(top_text, candidate_text) then
            begin
                Exit;
            end;

            case span_units of
                2:
                    Result := -1400;
                3:
                    Result := -1100;
                4, 5:
                    Result := -900;
            else
                Result := -600;
            end;
        end;

        function get_visible_complete_candidate_score_local(
            const candidate: TncCandidate): Integer;
        var
            candidate_text: string;
            units: TArray<string>;
            start_idx: Integer;
            span_units: Integer;
            query_key: string;
            chunk_text: string;
            problematic_penalty: Integer;
            support_score_local: Integer;
            support_segments_local: Integer;
            support_path_local: string;
        begin
            Result := Low(Integer);
            if Trim(candidate.comment) <> '' then
            begin
                Exit;
            end;

            candidate_text := Trim(candidate.text);
            if candidate_text = '' then
            begin
                Exit;
            end;

            units := split_text_units(candidate_text);
            if Length(units) <> input_syllable_count then
            begin
                Exit;
            end;

            Result := Min(get_rank_score(candidate), c_rank_score_cap);
            problematic_penalty := 0;
            if is_problematic_single_char_chain_candidate_for_query(
                lookup_text, candidate) then
            begin
                problematic_penalty := 16000;
            end;

            for start_idx := 0 to input_syllable_count - 1 do
            begin
                for span_units := 2 to Min(5, input_syllable_count - start_idx) do
                begin
                    query_key := build_query_key_local(start_idx, span_units);
                    if query_key = '' then
                    begin
                        Continue;
                    end;
                    chunk_text := build_chunk_text_local(units, start_idx, span_units);
                    if chunk_text = '' then
                    begin
                        Continue;
                    end;
                    Inc(Result, get_exact_support_bonus_local(query_key,
                        chunk_text, start_idx));
                    Inc(Result, get_exact_mismatch_penalty_local(query_key,
                        chunk_text, span_units, start_idx));
                end;
            end;
            support_path_local := infer_segment_path_for_query_text_with_score(
                lookup_text, candidate_text, support_score_local,
                support_segments_local);
            if support_path_local <> '' then
            begin
                Inc(Result, support_score_local + (support_segments_local * 320));
            end;
            Dec(Result, problematic_penalty);
        end;
    begin
        if (Length(candidates) = 0) or (input_syllable_count < 16) or
            (not is_full_pinyin_key(lookup_text)) or (m_dictionary = nil) or
            (m_disable_subspan_standalone_oracle > 0) then
        begin
            Exit;
        end;

        effective_syllables := get_effective_compact_pinyin_syllables(lookup_text);
        if Length(effective_syllables) <> input_syllable_count then
        begin
            Exit;
        end;

        loaded_queries := TDictionary<string, Byte>.Create;
        exact_rank_cache := TDictionary<string, Integer>.Create;
        exact_top_text_cache := TDictionary<string, string>.Create;
        best_index := -1;
        best_score := Low(Integer);
        top_score := Low(Integer);
        try
            if (Trim(candidates[0].comment) = '') and
                (get_candidate_text_unit_count(Trim(candidates[0].text)) =
                input_syllable_count) then
            begin
                top_score := get_visible_complete_candidate_score_local(
                    candidates[0]);
            end;

            for idx := 0 to High(candidates) do
            begin
                if idx >= c_visible_probe_limit then
                begin
                    Break;
                end;
                if (Trim(candidates[idx].comment) <> '') or
                    (get_candidate_text_unit_count(Trim(candidates[idx].text)) <>
                    input_syllable_count) then
                begin
                    Continue;
                end;

                candidate_score := get_visible_complete_candidate_score_local(
                    candidates[idx]);
                if candidate_score > best_score then
                begin
                    best_index := idx;
                    best_score := candidate_score;
                end;
            end;

            if best_index <= 0 then
            begin
                Exit;
            end;

            if (top_score <> Low(Integer)) and
                (best_score <= top_score + c_promote_margin) then
            begin
                Exit;
            end;

            picked := candidates[best_index];
            for idx := best_index downto 1 do
            begin
                candidates[idx] := candidates[idx - 1];
            end;
            candidates[0] := picked;
            if m_config.debug_mode then
            begin
                m_last_full_path_debug_info := m_last_full_path_debug_info +
                    Format(' vfull=[promote text=%s score=%d]',
                    [Trim(picked.text), best_score]);
            end;
        finally
            exact_top_text_cache.Free;
            exact_rank_cache.Free;
            loaded_queries.Free;
        end;
    end;

    procedure ensure_best_supported_complete_candidate_visible(
        var candidates: TncCandidateList);
    const
        c_probe_limit = 8;
        c_exact_probe_limit = 8;
        c_support_weight = 16;
        c_rank_cap = 2048;
        c_problematic_penalty = 24000;
        c_rank_regression_tolerance = 512;
    var
        effective_syllables: TncPinyinParseResult;
        loaded_queries: TDictionary<string, Byte>;
        exact_rank_cache: TDictionary<string, Integer>;
        exact_top_text_cache: TDictionary<string, string>;
        idx: Integer;
        best_idx: Integer;
        top_score: Integer;
        best_score: Integer;
        candidate_score: Integer;
        top_rank: Integer;
        best_rank: Integer;
        candidate_rank: Integer;
        promote_margin: Integer;
        picked: TncCandidate;
        oracle_rank_cache: TDictionary<string, Integer>;
        oracle_top_text: string;
        oracle_rank_local: Integer;
        oracle_idx: Integer;

        function build_query_key_local(const start_idx: Integer;
            const syllable_count_part: Integer): string;
        var
            local_idx: Integer;
        begin
            Result := '';
            if (start_idx < 0) or (syllable_count_part <= 0) or
                (start_idx + syllable_count_part - 1 >
                High(effective_syllables)) then
            begin
                Exit;
            end;

            for local_idx := start_idx to
                start_idx + syllable_count_part - 1 do
            begin
                Result := Result + normalize_pinyin_text(
                    effective_syllables[local_idx].text);
            end;
        end;

        function build_chunk_text_local(const units: TArray<string>;
            const start_idx: Integer; const unit_count: Integer): string;
        var
            local_idx: Integer;
        begin
            Result := '';
            if (start_idx < 0) or (unit_count <= 0) or
                (start_idx + unit_count - 1 > High(units)) then
            begin
                Exit;
            end;

            for local_idx := start_idx to start_idx + unit_count - 1 do
            begin
                Result := Result + units[local_idx];
            end;
        end;

        procedure ensure_query_loaded_local(const query_key: string;
            const expected_units: Integer; const start_idx: Integer);
        var
            local_idx: Integer;
            cache_key: string;
            candidate_text: string;
            exact_results: TncCandidateList;
            resolved_text_local: string;
            resolved_path_local: string;
            resolved_score_local: Integer;
            resolved_segments_local: Integer;
            resolved_anchor_units_local: Integer;
            resolved_has_anchor_local: Boolean;
            has_resolved_local: Boolean;
            raw_rank_local: Integer;
        begin
            if (query_key = '') or loaded_queries.ContainsKey(query_key) then
            begin
                Exit;
            end;

            loaded_queries.Add(query_key, 1);
            has_resolved_local := False;
            if (start_idx >= 0) and (expected_units >= 3) and
                (expected_units <= 5) and
                try_resolve_best_exact_subspan_local(start_idx, expected_units,
                resolved_text_local, resolved_score_local,
                resolved_segments_local, resolved_path_local,
                resolved_has_anchor_local, resolved_anchor_units_local) and
                (resolved_text_local <> '') then
            begin
                has_resolved_local := True;
                exact_top_text_cache.AddOrSetValue(query_key,
                    resolved_text_local);
                cache_key := query_key + '|' + resolved_text_local;
                exact_rank_cache.AddOrSetValue(cache_key, 0);
            end;

            if exact_top_text_cache.ContainsKey(query_key) then
            begin
                Exit;
            end;

            if (m_dictionary = nil) or
                (not m_dictionary.lookup_exact_full_pinyin(query_key,
                exact_results)) then
            begin
                Exit;
            end;

            raw_rank_local := 0;
            for local_idx := 0 to High(exact_results) do
            begin
                if local_idx >= c_exact_probe_limit then
                begin
                    Break;
                end;
                if Trim(exact_results[local_idx].comment) <> '' then
                begin
                    Continue;
                end;

                candidate_text := Trim(exact_results[local_idx].text);
                if candidate_text = '' then
                begin
                    Continue;
                end;
                if has_resolved_local and
                    SameText(candidate_text, resolved_text_local) then
                begin
                    Continue;
                end;
                if not exact_top_text_cache.ContainsKey(query_key) then
                begin
                    exact_top_text_cache.Add(query_key, candidate_text);
                end;

                cache_key := query_key + '|' + candidate_text;
                if not exact_rank_cache.ContainsKey(cache_key) then
                begin
                    if has_resolved_local then
                    begin
                        exact_rank_cache.Add(cache_key, raw_rank_local + 1);
                    end
                    else
                    begin
                        exact_rank_cache.Add(cache_key, raw_rank_local);
                    end;
                end;
                Inc(raw_rank_local);
            end;
        end;

        function get_exact_support_bonus_local(const query_key: string;
            const candidate_text: string; const start_idx: Integer): Integer;
        var
            cache_key: string;
            rank_value: Integer;
        begin
            Result := 0;
            if (query_key = '') or (candidate_text = '') then
            begin
                Exit;
            end;

            Inc(Result, get_preferred_query_phrase_bonus_local(query_key,
                candidate_text));
            Inc(Result, get_preferred_exact_subspan_bonus_local(query_key,
                candidate_text));

            ensure_query_loaded_local(query_key,
                get_candidate_text_unit_count(candidate_text), start_idx);
            cache_key := query_key + '|' + candidate_text;
            if not exact_rank_cache.TryGetValue(cache_key, rank_value) then
            begin
                Exit;
            end;

            case rank_value of
                0:
                    Inc(Result, 1100);
                1:
                    Inc(Result, 800);
                2, 3:
                    Inc(Result, 480);
                4, 5:
                    Inc(Result, 240);
            else
                Inc(Result, 120);
            end;
        end;

        function get_exact_mismatch_penalty_local(const query_key: string;
            const candidate_text: string; const span_units: Integer;
            const start_idx: Integer): Integer;
        var
            cache_key: string;
            rank_value: Integer;
            top_text: string;
        begin
            Result := 0;
            if (query_key = '') or (candidate_text = '') then
            begin
                Exit;
            end;

            ensure_query_loaded_local(query_key, span_units, start_idx);
            cache_key := query_key + '|' + candidate_text;
            if exact_rank_cache.TryGetValue(cache_key, rank_value) then
            begin
                case rank_value of
                    0:
                        Exit(0);
                    1:
                        Exit(-96);
                    2, 3:
                        Exit(-192);
                    4, 5:
                        Exit(-320);
                else
                    Exit(-480);
                end;
            end;

            if not exact_top_text_cache.TryGetValue(query_key, top_text) or
                (top_text = '') or SameText(top_text, candidate_text) then
            begin
                Exit;
            end;

            case span_units of
                2:
                    Result := -1400;
                3:
                    Result := -1100;
                4, 5, 6:
                    Result := -900;
            else
                Result := -600;
            end;
        end;

        function get_supported_complete_candidate_score_local(
            const candidate: TncCandidate): Integer;
        var
            candidate_text: string;
            units: TArray<string>;
            start_idx: Integer;
            span_units: Integer;
            query_key: string;
            chunk_text: string;
            support_score_local: Integer;
            support_segments_local: Integer;
            support_path_local: string;
            resolved_text_local: string;
            resolved_path_local: string;
            resolved_score_local: Integer;
            resolved_segments_local: Integer;
            resolved_anchor_units_local: Integer;
            resolved_has_anchor_local: Boolean;

            function get_resolved_subspan_alignment_adjustment_local(
                const local_start_idx: Integer; const local_span_units: Integer;
                const local_chunk_text: string): Integer;
            begin
                Result := 0;
                if (local_span_units < 3) or (local_chunk_text = '') then
                begin
                    Exit;
                end;

                if not try_resolve_best_exact_subspan_local(local_start_idx,
                    local_span_units, resolved_text_local, resolved_score_local,
                    resolved_segments_local, resolved_path_local,
                    resolved_has_anchor_local, resolved_anchor_units_local) or
                    (resolved_text_local = '') then
                begin
                    Exit;
                end;

                if (local_span_units = 3) and (not resolved_has_anchor_local) and
                    (resolved_score_local < 12000) then
                begin
                    Exit;
                end;

                if SameText(local_chunk_text, resolved_text_local) then
                begin
                    case local_span_units of
                        3:
                            Result := 4096;
                        4:
                            Result := 16384;
                    else
                        Result := 24576;
                    end;
                    if resolved_has_anchor_local then
                    begin
                        Inc(Result, 2048);
                    end;
                    if resolved_segments_local <= 1 then
                    begin
                        Inc(Result, 1024);
                    end;
                end
                else
                begin
                    case local_span_units of
                        3:
                            Result := -8192;
                        4:
                            Result := -24576;
                    else
                        Result := -32768;
                    end;
                    if resolved_has_anchor_local or
                        (resolved_score_local >= 16000) then
                    begin
                        Dec(Result, 4096);
                    end;
                end;
            end;
        begin
            Result := Low(Integer);
            if Trim(candidate.comment) <> '' then
            begin
                Exit;
            end;

            candidate_text := Trim(candidate.text);
            if (candidate_text = '') or
                (get_candidate_text_unit_count(candidate_text) <>
                input_syllable_count) then
            begin
                Exit;
            end;

            units := split_text_units(candidate_text);
            if Length(units) <> input_syllable_count then
            begin
                Exit;
            end;

            support_path_local := infer_segment_path_for_query_text_with_score(
                lookup_text, candidate_text, support_score_local,
                support_segments_local);
            if support_path_local = '' then
            begin
                support_score_local := -960;
            end;

            Result := (support_score_local * c_support_weight) +
                Min(get_rank_score(candidate), c_rank_cap);
            for start_idx := 0 to input_syllable_count - 1 do
            begin
                for span_units := 2 to Min(6, input_syllable_count -
                    start_idx) do
                begin
                    query_key := build_query_key_local(start_idx, span_units);
                    if query_key = '' then
                    begin
                        Continue;
                    end;
                    chunk_text := build_chunk_text_local(units, start_idx,
                        span_units);
                    if chunk_text = '' then
                    begin
                        Continue;
                    end;
                    Inc(Result, get_exact_support_bonus_local(query_key,
                        chunk_text, start_idx));
                    Inc(Result, get_exact_mismatch_penalty_local(query_key,
                        chunk_text, span_units, start_idx));
                    Inc(Result, get_resolved_subspan_alignment_adjustment_local(
                        start_idx, span_units, chunk_text));
                end;
            end;
            if is_problematic_single_char_chain_candidate_for_query(
                lookup_text, candidate) then
            begin
                Dec(Result, c_problematic_penalty);
            end;
            if oracle_rank_cache.TryGetValue(candidate_text, oracle_rank_local) then
            begin
                Inc(Result, 6000 - (oracle_rank_local * 1500));
            end;
        end;
    begin
        if (Length(candidates) <= 1) or (input_syllable_count < 3) or
            (not is_full_pinyin_key(lookup_text)) then
        begin
            Exit;
        end;

        if input_syllable_count <= 4 then
        begin
            promote_margin := 256;
        end
        else if input_syllable_count <= 7 then
        begin
            promote_margin := 512;
        end
        else
        begin
            promote_margin := 1024;
        end;

        effective_syllables := get_effective_compact_pinyin_syllables(
            lookup_text);
        if Length(effective_syllables) <> input_syllable_count then
        begin
            Exit;
        end;

        loaded_queries := TDictionary<string, Byte>.Create;
        exact_rank_cache := TDictionary<string, Integer>.Create;
        exact_top_text_cache := TDictionary<string, string>.Create;
        oracle_rank_cache := TDictionary<string, Integer>.Create;
        oracle_top_text := '';
        try
            ensure_strict_oracle_sentence_candidates_prepared;
            if strict_oracle_sentence_ok and
                (Length(strict_oracle_sentence_candidates) > 0) then
            begin
                for oracle_idx := 0 to Min(3,
                    High(strict_oracle_sentence_candidates)) do
                begin
                    if Trim(strict_oracle_sentence_candidates[oracle_idx].comment) <> '' then
                    begin
                        Continue;
                    end;
                    if get_candidate_text_unit_count(
                        Trim(strict_oracle_sentence_candidates[oracle_idx].text)) <>
                        input_syllable_count then
                    begin
                        Continue;
                    end;
                    if oracle_top_text = '' then
                    begin
                        oracle_top_text := Trim(
                            strict_oracle_sentence_candidates[oracle_idx].text);
                    end;
                    if not oracle_rank_cache.ContainsKey(
                        Trim(strict_oracle_sentence_candidates[oracle_idx].text)) then
                    begin
                        oracle_rank_cache.Add(
                            Trim(strict_oracle_sentence_candidates[oracle_idx].text),
                            oracle_idx);
                    end;
                end;
            end;

            top_score := get_supported_complete_candidate_score_local(
                candidates[0]);
            top_rank := get_rank_score(candidates[0]);
            best_idx := -1;
            best_score := top_score;
            best_rank := top_rank;

            for idx := 1 to Min(c_probe_limit - 1, High(candidates)) do
            begin
                candidate_score := get_supported_complete_candidate_score_local(
                    candidates[idx]);
                candidate_rank := get_rank_score(candidates[idx]);
                if candidate_score > best_score then
                begin
                    best_score := candidate_score;
                    best_idx := idx;
                    best_rank := candidate_rank;
                end;
            end;

            if (best_idx <= 0) or
                (best_score <= top_score + promote_margin) or
                (best_rank + c_rank_regression_tolerance < top_rank) then
            begin
                Exit;
            end;

            picked := candidates[best_idx];
            for idx := best_idx downto 1 do
            begin
                candidates[idx] := candidates[idx - 1];
            end;
            candidates[0] := picked;
            if m_config.debug_mode then
            begin
                m_last_full_path_debug_info := m_last_full_path_debug_info +
                    Format(' vsup=[promote text=%s score=%d top=%d]',
                    [Trim(picked.text), best_score, top_score]);
            end;
        finally
            oracle_rank_cache.Free;
            exact_top_text_cache.Free;
            exact_rank_cache.Free;
            loaded_queries.Free;
        end;
    end;

    procedure ensure_strong_supported_complete_candidate_locked_visible(
        var candidates: TncCandidateList);
    const
        c_probe_limit = 8;
        c_min_support_score = 4096;
        c_promote_margin = 512;
    var
        idx: Integer;
        best_idx: Integer;
        best_score: Integer;
        top_score: Integer;
        picked: TncCandidate;

        function get_lock_score_local(const candidate: TncCandidate): Integer;
        var
            candidate_text_local: string;
            support_score_local: Integer;
            support_segments_local: Integer;
            support_path_local: string;
            encoded_path_local: string;
        begin
            Result := Low(Integer);
            if Trim(candidate.comment) <> '' then
            begin
                Exit;
            end;

            candidate_text_local := Trim(candidate.text);
            if (candidate_text_local = '') or
                (get_candidate_text_unit_count(candidate_text_local) <>
                input_syllable_count) or
                is_problematic_single_char_chain_candidate_for_query(
                lookup_text, candidate) then
            begin
                Exit;
            end;

            support_path_local := infer_segment_path_for_query_text_with_score(
                lookup_text, candidate_text_local, support_score_local,
                support_segments_local);
            if (support_path_local = '') or
                (support_score_local < c_min_support_score) then
            begin
                Exit;
            end;

            Result := (support_score_local * 32) +
                Min(get_rank_score(candidate), 4096);
            if support_segments_local <= 4 then
            begin
                Inc(Result, 8192 - (support_segments_local * 512));
            end
            else
            begin
                Dec(Result, (support_segments_local - 4) * 768);
            end;

            encoded_path_local := get_segment_path_for_candidate(candidate);
            if (encoded_path_local <> '') and
                is_natural_predictive_segment_path_local(encoded_path_local) then
            begin
                Inc(Result, 4096);
            end;
            if candidate.has_dict_weight or (candidate.source = cs_user) then
            begin
                Inc(Result, 4096);
            end;
        end;
    begin
        if (Length(candidates) <= 1) or (input_syllable_count < 4) or
            (not is_full_pinyin_key(lookup_text)) then
        begin
            Exit;
        end;

        top_score := get_lock_score_local(candidates[0]);
        best_idx := -1;
        best_score := top_score;
        for idx := 1 to Min(c_probe_limit - 1, High(candidates)) do
        begin
            if get_lock_score_local(candidates[idx]) > best_score then
            begin
                best_score := get_lock_score_local(candidates[idx]);
                best_idx := idx;
            end;
        end;

        if (best_idx <= 0) or (best_score <= top_score + c_promote_margin) then
        begin
            Exit;
        end;

        picked := candidates[best_idx];
        for idx := best_idx downto 1 do
        begin
            candidates[idx] := candidates[idx - 1];
        end;
        candidates[0] := picked;
        if m_config.debug_mode then
        begin
            m_last_full_path_debug_info := m_last_full_path_debug_info +
                Format(' vlock=[promote text=%s score=%d top=%d]',
                [Trim(picked.text), best_score, top_score]);
        end;
    end;

    procedure get_exact_window_consistency_stats_local(
        const candidate_text: string; const min_span: Integer;
        const max_span: Integer; out out_match_count: Integer;
        out out_mismatch_count: Integer; out out_strong_match_count: Integer;
        out out_strong_mismatch_count: Integer);
    var
        candidate_units_local: TArray<string>;
        start_idx_local: Integer;
        span_syllables_local: Integer;
        candidate_chunk_text_local: string;
        resolved_text_local: string;
        resolved_path_local: string;
        resolved_score_local: Integer;
        resolved_segments_local: Integer;
        resolved_anchor_units_local: Integer;
        resolved_has_anchor_local: Boolean;
        strong_window_local: Boolean;

        function build_text_from_units_local(const text_units: TArray<string>;
            const start_unit: Integer; const unit_count: Integer): string;
        var
            unit_idx: Integer;
        begin
            Result := '';
            if (unit_count <= 0) or (start_unit < 0) or
                (start_unit + unit_count - 1 > High(text_units)) then
            begin
                Exit;
            end;

            for unit_idx := start_unit to start_unit + unit_count - 1 do
            begin
                Result := Result + text_units[unit_idx];
            end;
        end;
    begin
        out_match_count := 0;
        out_mismatch_count := 0;
        out_strong_match_count := 0;
        out_strong_mismatch_count := 0;
        candidate_units_local := split_text_units(Trim(candidate_text));
        if Length(candidate_units_local) <> input_syllable_count then
        begin
            Exit;
        end;

        for start_idx_local := 0 to
            input_syllable_count - Max(2, min_span) do
        begin
            for span_syllables_local := Max(2, min_span) to
                Min(max_span, input_syllable_count - start_idx_local) do
            begin
                if not try_resolve_best_exact_subspan_local(start_idx_local,
                    span_syllables_local, resolved_text_local,
                    resolved_score_local, resolved_segments_local,
                    resolved_path_local, resolved_has_anchor_local,
                    resolved_anchor_units_local) or
                    (resolved_text_local = '') then
                begin
                    Continue;
                end;

                candidate_chunk_text_local := build_text_from_units_local(
                    candidate_units_local, start_idx_local,
                    span_syllables_local);
                if candidate_chunk_text_local = '' then
                begin
                    Continue;
                end;

                strong_window_local := (span_syllables_local >= 3) or
                    resolved_has_anchor_local or (resolved_score_local >= 4096);
                if SameText(candidate_chunk_text_local, resolved_text_local) then
                begin
                    Inc(out_match_count);
                    if strong_window_local then
                    begin
                        Inc(out_strong_match_count);
                    end;
                end
                else if strong_window_local then
                begin
                    Inc(out_mismatch_count);
                    if (resolved_score_local >= 12000) or
                        resolved_has_anchor_local or
                        (span_syllables_local >= 4) then
                    begin
                        Inc(out_strong_mismatch_count);
                    end;
                end;
            end;
        end;
    end;

    function has_strong_top_complete_candidate_for_postprocess_lock_local(
        const candidates: TncCandidateList): Boolean;
    const
        c_min_support_score = 4096;
        c_max_support_segments = 8;
        c_exact_probe_limit = 6;
    var
        top_candidate: TncCandidate;
        top_text: string;
        support_score_local: Integer;
        support_segments_local: Integer;
        support_path_local: string;
        encoded_path_local: string;
        exact_results_local: TncCandidateList;
        exact_idx_local: Integer;
        exact_match_count_local: Integer;
        exact_mismatch_count_local: Integer;
        exact_strong_match_count_local: Integer;
        exact_strong_mismatch_count_local: Integer;
    begin
        Result := False;
        if (Length(candidates) = 0) or (input_syllable_count < 4) or
            (not is_full_pinyin_key(lookup_text)) then
        begin
            Exit;
        end;

        top_candidate := candidates[0];
        if Trim(top_candidate.comment) <> '' then
        begin
            Exit;
        end;

        top_text := Trim(top_candidate.text);
        if (top_text = '') or
            (get_candidate_text_unit_count(top_text) <> input_syllable_count) or
            is_problematic_single_char_chain_candidate_for_query(lookup_text,
            top_candidate) then
        begin
            Exit;
        end;

        support_path_local := infer_segment_path_for_query_text_with_score(
            lookup_text, top_text, support_score_local,
            support_segments_local);
        if (support_path_local = '') or
            (support_score_local < c_min_support_score) then
        begin
            Exit;
        end;

        get_exact_window_consistency_stats_local(top_text, 2, 5,
            exact_match_count_local, exact_mismatch_count_local,
            exact_strong_match_count_local, exact_strong_mismatch_count_local);
        if exact_strong_mismatch_count_local > 0 then
        begin
            Exit(False);
        end;
        if (exact_mismatch_count_local > 0) and
            (exact_strong_match_count_local = 0) then
        begin
            Exit(False);
        end;

        if top_candidate.has_dict_weight or (top_candidate.source = cs_user) then
        begin
            Exit(True);
        end;

        encoded_path_local := get_segment_path_for_candidate(top_candidate);
        if (support_segments_local <= c_max_support_segments) and
            (encoded_path_local <> '') and
            is_natural_predictive_segment_path_local(encoded_path_local) then
        begin
            Exit(True);
        end;

        if (m_dictionary <> nil) and
            m_dictionary.lookup_exact_full_pinyin(lookup_text,
            exact_results_local) then
        begin
            for exact_idx_local := 0 to High(exact_results_local) do
            begin
                if exact_idx_local >= c_exact_probe_limit then
                begin
                    Break;
                end;
                if Trim(exact_results_local[exact_idx_local].comment) <> '' then
                begin
                    Continue;
                end;
                if SameText(Trim(exact_results_local[exact_idx_local].text),
                    top_text) then
                begin
                    Exit((exact_strong_match_count_local >= 1) or
                        (exact_mismatch_count_local = 0));
                end;
            end;
        end;

        Result := (support_segments_local <= c_max_support_segments) and
            ((exact_strong_match_count_local >= 2) or
            ((exact_strong_match_count_local >= 1) and
            (exact_mismatch_count_local = 0)));
    end;

    procedure ensure_best_exact_window_consensus_complete_candidate_visible(
        var candidates: TncCandidateList);
    const
        c_probe_limit = 6;
        c_window_min_syllables = 2;
        c_window_max_syllables = 6;
        c_promote_margin = 512;
        c_score_keep_margin = 24000;
        c_consensus_force_margin = 20000;
        c_supportless_force_margin = 16000;
        c_support_bonus_divisor = 4;
        c_problematic_penalty = 24000;
    var
        effective_syllables: TncPinyinParseResult;
        top_score: Integer;
        best_score: Integer;
        best_idx: Integer;
        idx: Integer;
        candidate_score: Integer;
        picked: TncCandidate;
        debug_summary: string;
        top_support_score_local: Integer;
        top_support_segments_local: Integer;
        picked_support_score_local: Integer;
        picked_support_segments_local: Integer;
        top_support_path_local: string;
        picked_support_path_local: string;
        oracle_rank_cache: TDictionary<string, Integer>;
        oracle_top_text: string;
        oracle_rank_local: Integer;
        oracle_idx: Integer;
        best_from_oracle_local: Boolean;
        oracle_candidate_local: TncCandidate;
        best_oracle_candidate_local: TncCandidate;
        best_supported_visible_score_local: Integer;
        best_supported_visible_idx_local: Integer;
        best_supported_visible_text_local: string;
        oracle_support_score_local: Integer;
        oracle_support_segments_local: Integer;
        oracle_support_path_local: string;

        function is_visible_complete_candidate_text_local(
            const text_value: string): Boolean;
        var
            visible_idx_local: Integer;
        begin
            Result := False;
            if text_value = '' then
            begin
                Exit;
            end;

            for visible_idx_local := 0 to Min(c_probe_limit - 1,
                High(candidates)) do
            begin
                if Trim(candidates[visible_idx_local].comment) <> '' then
                begin
                    Continue;
                end;
                if get_candidate_text_unit_count(
                    Trim(candidates[visible_idx_local].text)) <>
                    input_syllable_count then
                begin
                    Continue;
                end;
                if SameText(Trim(candidates[visible_idx_local].text),
                    text_value) then
                begin
                    Exit(True);
                end;
            end;
        end;

        function build_text_from_units_local(const text_units: TArray<string>;
            const start_unit: Integer; const unit_count: Integer): string;
        var
            unit_idx: Integer;
        begin
            Result := '';
            if (unit_count <= 0) or (start_unit < 0) or
                (start_unit + unit_count - 1 > High(text_units)) then
            begin
                Exit;
            end;

            for unit_idx := start_unit to start_unit + unit_count - 1 do
            begin
                Result := Result + text_units[unit_idx];
            end;
        end;

        function get_window_consensus_score_local(
            const candidate: TncCandidate): Integer;
        var
            candidate_text: string;
            candidate_units: TArray<string>;
            start_idx: Integer;
            span_syllables: Integer;
            candidate_chunk_text: string;
            resolved_text: string;
            resolved_path: string;
            resolved_score: Integer;
            resolved_segments: Integer;
            resolved_anchor_units: Integer;
            resolved_has_anchor: Boolean;
            window_weight: Integer;
            support_score_local: Integer;
            support_segments_local: Integer;
            support_path_local: string;
            head_boundary_score_local: Integer;
            candidate_rank_bonus_local: Integer;

            function get_fixed_boundary_single_char_for_window_local(
                const syllable_text: string): string;
            var
                normalized_syllable: string;
            begin
                Result := '';
                normalized_syllable := normalize_pinyin_text(syllable_text);
                if normalized_syllable = 'dan' then
                begin
                    Result := string(Char($4F46));
                end
                else if normalized_syllable = 'sui' then
                begin
                    Result := string(Char($867D));
                end
                else if normalized_syllable = 'er' then
                begin
                    Result := string(Char($800C));
                end
                else if normalized_syllable = 'wo' then
                begin
                    Result := string(Char($6211));
                end
                else if normalized_syllable = 'ni' then
                begin
                    Result := string(Char($4F60));
                end
                else if normalized_syllable = 'ta' then
                begin
                    Result := string(Char($4ED6));
                end
                else if normalized_syllable = 'he' then
                begin
                    Result := string(Char($548C));
                end
                else if normalized_syllable = 'qu' then
                begin
                    Result := string(Char($53BB));
                end
                else if normalized_syllable = 'shi' then
                begin
                    Result := string(Char($662F));
                end
                else if normalized_syllable = 'ye' then
                begin
                    Result := string(Char($4E5F));
                end
                else if normalized_syllable = 'yu' then
                begin
                    Result := string(Char($4E8E));
                end
                else if normalized_syllable = 'de' then
                begin
                    Result := string(Char($7684));
                end
                else if normalized_syllable = 'zai' then
                begin
                    Result := string(Char($5728));
                end
                else if normalized_syllable = 'ba' then
                begin
                    Result := string(Char($628A));
                end
                else if normalized_syllable = 'bei' then
                begin
                    Result := string(Char($88AB));
                end
                else if normalized_syllable = 'bing' then
                begin
                    Result := string(Char($5E76));
                end
                else if normalized_syllable = 'que' then
                begin
                    Result := string(Char($5374));
                end
                else if normalized_syllable = 'jiu' then
                begin
                    Result := string(Char($5C31));
                end
                else if normalized_syllable = 'bu' then
                begin
                    Result := string(Char($4E0D));
                end;
            end;

            function get_fixed_boundary_head_score_for_window_local(
                const candidate_text_local: string): Integer;
            var
                syllables_local: TncPinyinParseResult;
                text_units_local: TArray<string>;
                head_idx: Integer;
                expected_char: string;
            begin
                Result := 0;
                syllables_local := get_effective_compact_pinyin_syllables(
                    lookup_text);
                text_units_local := split_text_units(
                    Trim(candidate_text_local));
                for head_idx := 0 to Min(
                    Min(High(syllables_local), High(text_units_local)), 3) do
                begin
                    expected_char :=
                        get_fixed_boundary_single_char_for_window_local(
                        syllables_local[head_idx].text);
                    if expected_char = '' then
                    begin
                        Continue;
                    end;
                    if SameText(text_units_local[head_idx], expected_char) then
                    begin
                        Inc(Result);
                    end;
                end;
            end;
        begin
            Result := Low(Integer);
            if Trim(candidate.comment) <> '' then
            begin
                Exit;
            end;

            candidate_text := Trim(candidate.text);
            if candidate_text = '' then
            begin
                Exit;
            end;

            candidate_units := split_text_units(candidate_text);
            if Length(candidate_units) <> input_syllable_count then
            begin
                Exit;
            end;

            Result := 0;
            for start_idx := 0 to input_syllable_count - c_window_min_syllables do
            begin
                for span_syllables := c_window_min_syllables to
                    Min(c_window_max_syllables,
                    input_syllable_count - start_idx) do
                begin
                    if not try_resolve_best_exact_subspan_local(start_idx,
                        span_syllables, resolved_text, resolved_score,
                        resolved_segments, resolved_path, resolved_has_anchor,
                        resolved_anchor_units) or (resolved_text = '') then
                    begin
                        Continue;
                    end;

                    candidate_chunk_text := build_text_from_units_local(
                        candidate_units, start_idx, span_syllables);
                    if candidate_chunk_text = '' then
                    begin
                        Continue;
                    end;

                    window_weight := Min(4096, Max(512,
                        resolved_score div 8));
                    Inc(window_weight, span_syllables * 96);
                    if resolved_has_anchor then
                    begin
                        Inc(window_weight, 256);
                    end;
                    if start_idx + span_syllables = input_syllable_count then
                    begin
                        Inc(window_weight, window_weight * 4);
                    end
                    else if start_idx + span_syllables >=
                        input_syllable_count - 1 then
                    begin
                        Inc(window_weight, window_weight);
                    end;

                    if SameText(candidate_chunk_text, resolved_text) then
                    begin
                        Inc(Result, window_weight);
                        if span_syllables >= 4 then
                        begin
                            Inc(Result, window_weight * 3);
                        end
                        else if (span_syllables = 3) and
                            (resolved_has_anchor or (resolved_score >= 12000)) then
                        begin
                            Inc(Result, window_weight);
                        end;
                        if (span_syllables = 2) and
                            ((resolved_segments <= 1) or
                            (resolved_score >= 4096)) then
                        begin
                            Inc(Result, window_weight div 2);
                        end;
                    end
                    else if (span_syllables = 2) and
                        ((resolved_segments <= 1) or
                        (resolved_score >= 4096)) then
                    begin
                        Dec(Result, Min(1536, Max(256, window_weight div 4)));
                    end
                    else if span_syllables >= 4 then
                    begin
                        Dec(Result, window_weight * 4);
                    end
                    else if resolved_has_anchor or
                        (resolved_score >= 12000) then
                    begin
                        Dec(Result, window_weight * 2);
                    end
                    else if window_weight >= 1536 then
                    begin
                        Dec(Result, window_weight div 3);
                    end;
                end;
            end;

            support_path_local := infer_segment_path_for_query_text_with_score(
                lookup_text, candidate_text, support_score_local,
                support_segments_local);
            if support_path_local <> '' then
            begin
                Inc(Result, support_score_local div c_support_bonus_divisor);
                Inc(Result, support_segments_local * 160);
            end
            else
            begin
                Dec(Result, 1024);
            end;

            head_boundary_score_local :=
                get_fixed_boundary_head_score_for_window_local(candidate_text);
            if head_boundary_score_local > 0 then
            begin
                Inc(Result, head_boundary_score_local * 12000);
            end
            else if input_syllable_count >= 6 then
            begin
                Dec(Result, 12000);
            end;

            candidate_rank_bonus_local :=
                Min(24000, Max(0, get_rank_score(candidate)));
            if candidate_rank_bonus_local > 0 then
            begin
                Inc(Result, candidate_rank_bonus_local);
                if support_path_local <> '' then
                begin
                    Inc(Result, candidate_rank_bonus_local div 2);
                end;
            end;

            if is_problematic_single_char_chain_candidate_for_query(
                lookup_text, candidate) then
            begin
                Dec(Result, c_problematic_penalty);
            end;
            if oracle_rank_cache.TryGetValue(candidate_text, oracle_rank_local) then
            begin
                Inc(Result, 16000 - (oracle_rank_local * 4000));
            end
            else if oracle_top_text <> '' then
            begin
                Dec(Result, 8000);
            end;
        end;
    begin
        if (Length(candidates) <= 1) or (input_syllable_count < 4) or
            (not is_full_pinyin_key(lookup_text)) or
            (m_disable_subspan_standalone_oracle > 0) then
        begin
            Exit;
        end;

        if has_strong_top_complete_candidate_for_postprocess_lock_local(
            candidates) then
        begin
            if m_config.debug_mode then
            begin
                m_last_full_path_debug_info := m_last_full_path_debug_info +
                    ' vcons=[locked]';
            end;
            Exit;
        end;

        effective_syllables := get_effective_compact_pinyin_syllables(lookup_text);
        if Length(effective_syllables) <> input_syllable_count then
        begin
            Exit;
        end;

        oracle_rank_cache := TDictionary<string, Integer>.Create;
        oracle_top_text := '';
        try
            ensure_strict_oracle_sentence_candidates_prepared;
            if strict_oracle_sentence_ok and
                (Length(strict_oracle_sentence_candidates) > 0) then
            begin
                for oracle_idx := 0 to Min(3,
                    High(strict_oracle_sentence_candidates)) do
                begin
                    if Trim(strict_oracle_sentence_candidates[oracle_idx].comment) <> '' then
                    begin
                        Continue;
                    end;
                    if get_candidate_text_unit_count(
                        Trim(strict_oracle_sentence_candidates[oracle_idx].text)) <>
                        input_syllable_count then
                    begin
                        Continue;
                    end;
                    if oracle_top_text = '' then
                    begin
                        oracle_top_text := Trim(
                            strict_oracle_sentence_candidates[oracle_idx].text);
                    end;
                    if not oracle_rank_cache.ContainsKey(
                        Trim(strict_oracle_sentence_candidates[oracle_idx].text)) then
                    begin
                        oracle_rank_cache.Add(
                            Trim(strict_oracle_sentence_candidates[oracle_idx].text),
                            oracle_idx);
                    end;
                end;
            end;

            top_score := get_window_consensus_score_local(candidates[0]);
            best_idx := -1;
            best_score := top_score;
            best_from_oracle_local := False;
            best_supported_visible_score_local := Low(Integer);
            best_supported_visible_idx_local := -1;
            best_supported_visible_text_local := '';
            top_support_path_local := infer_segment_path_for_query_text_with_score(
                lookup_text, Trim(candidates[0].text), top_support_score_local,
                top_support_segments_local);
            if top_support_path_local <> '' then
            begin
                best_supported_visible_score_local := top_score;
                best_supported_visible_idx_local := 0;
                best_supported_visible_text_local := Trim(candidates[0].text);
            end;
            if m_config.debug_mode then
            begin
                debug_summary := Format(' {top=%s s=%d}',
                    [Trim(candidates[0].text), top_score]);
            end;

            for idx := 1 to Min(c_probe_limit - 1, High(candidates)) do
            begin
                candidate_score := get_window_consensus_score_local(candidates[idx]);
                if m_config.debug_mode then
                begin
                    debug_summary := debug_summary + Format(' {%s s=%d}',
                        [Trim(candidates[idx].text), candidate_score]);
                end;
                if candidate_score > best_score then
                begin
                    best_score := candidate_score;
                    best_idx := idx;
                    best_from_oracle_local := False;
                end;
                picked_support_path_local := infer_segment_path_for_query_text_with_score(
                    lookup_text, Trim(candidates[idx].text),
                    picked_support_score_local, picked_support_segments_local);
                if (picked_support_path_local <> '') and
                    (candidate_score > best_supported_visible_score_local) then
                begin
                    best_supported_visible_score_local := candidate_score;
                    best_supported_visible_idx_local := idx;
                    best_supported_visible_text_local := Trim(candidates[idx].text);
                end;
            end;

            if strict_oracle_sentence_ok and
                (Length(strict_oracle_sentence_candidates) > 0) then
            begin
                for oracle_idx := 0 to Min(2,
                    High(strict_oracle_sentence_candidates)) do
                begin
                    oracle_candidate_local :=
                        strict_oracle_sentence_candidates[oracle_idx];
                    if Trim(oracle_candidate_local.comment) <> '' then
                    begin
                        Continue;
                    end;
                    if get_candidate_text_unit_count(
                        Trim(oracle_candidate_local.text)) <>
                        input_syllable_count then
                    begin
                        Continue;
                    end;
                    if is_visible_complete_candidate_text_local(
                        Trim(oracle_candidate_local.text)) then
                    begin
                        Continue;
                    end;

                    candidate_score := get_window_consensus_score_local(
                        oracle_candidate_local);
                    oracle_support_path_local :=
                        infer_segment_path_for_query_text_with_score(
                        lookup_text, Trim(oracle_candidate_local.text),
                        oracle_support_score_local,
                        oracle_support_segments_local);
                    if (oracle_support_path_local = '') and
                        (best_supported_visible_score_local > Low(Integer)) and
                        (candidate_score <=
                        best_supported_visible_score_local + 12000) then
                    begin
                        Continue;
                    end;
                    if m_config.debug_mode then
                    begin
                        debug_summary := debug_summary + Format(' {oracle:%s s=%d}',
                            [Trim(oracle_candidate_local.text), candidate_score]);
                    end;
                    if candidate_score > best_score then
                    begin
                        best_score := candidate_score;
                        best_idx := -1;
                        best_from_oracle_local := True;
                        best_oracle_candidate_local := oracle_candidate_local;
                    end;
                end;
            end;

            if best_from_oracle_local and
                (best_supported_visible_idx_local >= 0) and
                (best_supported_visible_score_local + 12000 >= best_score) then
            begin
                best_from_oracle_local := False;
                best_idx := best_supported_visible_idx_local;
                best_score := best_supported_visible_score_local;
            end;

            if ((not best_from_oracle_local) and (best_idx <= 0)) or
                (best_score <= top_score + c_promote_margin) then
            begin
                if m_config.debug_mode and (debug_summary <> '') then
                begin
                    m_last_full_path_debug_info := m_last_full_path_debug_info +
                        Format(' vcons=[keep top=%d best=%d]%s',
                        [top_score, best_score, debug_summary]);
                end;
                Exit;
            end;

            if best_from_oracle_local then
            begin
                picked := best_oracle_candidate_local;
            end
            else
            begin
                picked := candidates[best_idx];
            end;
            if (candidates[0].score >= picked.score + c_score_keep_margin) and
                (best_score < top_score + c_consensus_force_margin) then
            begin
                if m_config.debug_mode and (debug_summary <> '') then
                begin
                    m_last_full_path_debug_info := m_last_full_path_debug_info +
                        Format(' vcons=[keep-score top=%d best=%d]%s',
                        [top_score, best_score, debug_summary]);
                end;
                Exit;
            end;
            picked_support_path_local := infer_segment_path_for_query_text_with_score(
                lookup_text, Trim(picked.text), picked_support_score_local,
                picked_support_segments_local);
            if (top_support_path_local <> '') and
                (picked_support_path_local = '') then
            begin
                if best_score < top_score + c_supportless_force_margin then
                begin
                    if m_config.debug_mode and (debug_summary <> '') then
                    begin
                        m_last_full_path_debug_info := m_last_full_path_debug_info +
                            Format(' vcons=[keep-supported top=%d best=%d]%s',
                            [top_score, best_score, debug_summary]);
                    end;
                    Exit;
                end;
            end;
            if best_from_oracle_local then
            begin
                SetLength(candidates, Length(candidates) + 1);
                for idx := High(candidates) downto 1 do
                begin
                    candidates[idx] := candidates[idx - 1];
                end;
                candidates[0] := picked;
            end
            else
            begin
                for idx := best_idx downto 1 do
                begin
                    candidates[idx] := candidates[idx - 1];
                end;
                candidates[0] := picked;
            end;
            if m_config.debug_mode then
            begin
                m_last_full_path_debug_info := m_last_full_path_debug_info +
                    Format(' vcons=[promote text=%s score=%d top=%d ext=%d]',
                    [Trim(picked.text), best_score, top_score,
                    Ord(best_from_oracle_local)]);
                if debug_summary <> '' then
                begin
                    m_last_full_path_debug_info := m_last_full_path_debug_info +
                        debug_summary;
                end;
            end;
        finally
            oracle_rank_cache.Free;
        end;
    end;

    procedure ensure_best_exact_window_repair_complete_candidate_visible(
        var candidates: TncCandidateList);
    const
        c_probe_limit = 3;
        c_window_min_syllables = 2;
        c_window_max_syllables = 6;
        c_variant_limit = 4;
        c_variant_exact_probe_limit = 4;
        c_repair_pass_limit = 2;
        c_promote_score_margin = 4096;
        c_score_support_weight = 16;
        c_problematic_penalty = 24000;
    var
        effective_syllables: TncPinyinParseResult;
        best_score: Integer;
        top_score: Integer;
        probe_idx: Integer;
        repaired_candidate: TncCandidate;
        local_candidate: TncCandidate;
        local_score: Integer;
        pass_idx: Integer;
        move_idx: Integer;

        function get_support_margin_local: Integer;
        begin
            if input_syllable_count <= 4 then
            begin
                Exit(128);
            end;
            if input_syllable_count <= 6 then
            begin
                Exit(256);
            end;
            Result := 512;
        end;

        function build_query_key_local(const start_unit: Integer;
            const unit_count: Integer): string;
        var
            unit_idx: Integer;
        begin
            Result := '';
            if (start_unit < 0) or (unit_count <= 0) or
                (start_unit + unit_count - 1 > High(effective_syllables)) then
            begin
                Exit;
            end;

            for unit_idx := start_unit to start_unit + unit_count - 1 do
            begin
                Result := Result + normalize_pinyin_text(
                    effective_syllables[unit_idx].text);
            end;
        end;

        function build_text_from_units_local(const units: TArray<string>;
            const start_unit: Integer; const unit_count: Integer): string;
        var
            unit_idx: Integer;
        begin
            Result := '';
            if (start_unit < 0) or (unit_count <= 0) or
                (start_unit + unit_count - 1 > High(units)) then
            begin
                Exit;
            end;

            for unit_idx := start_unit to start_unit + unit_count - 1 do
            begin
                Result := Result + units[unit_idx];
            end;
        end;

        function replace_window_text_local(const units: TArray<string>;
            const start_unit: Integer; const unit_count: Integer;
            const replacement_text: string): string;
        var
            unit_idx: Integer;
            replacement_units: TArray<string>;
            replacement_idx: Integer;
        begin
            Result := '';
            replacement_units := split_text_units(Trim(replacement_text));
            if Length(replacement_units) <> unit_count then
            begin
                Exit;
            end;

            unit_idx := 0;
            while unit_idx <= High(units) do
            begin
                if unit_idx = start_unit then
                begin
                    for replacement_idx := 0 to High(replacement_units) do
                    begin
                        Result := Result + replacement_units[replacement_idx];
                    end;
                    Inc(unit_idx, unit_count - 1);
                end
                else
                begin
                    Result := Result + units[unit_idx];
                end;
                Inc(unit_idx);
            end;
        end;

        function get_supported_sentence_score_local(const candidate: TncCandidate;
            out support_score_local: Integer): Integer;
        var
            candidate_text_local: string;
            support_segments_local: Integer;
            support_path_local: string;
            exact_match_count_local: Integer;
            exact_mismatch_count_local: Integer;
            exact_strong_match_count_local: Integer;
            exact_strong_mismatch_count_local: Integer;
        begin
            Result := Low(Integer);
            support_score_local := -960;
            if Trim(candidate.comment) <> '' then
            begin
                Exit;
            end;

            candidate_text_local := Trim(candidate.text);
            if (candidate_text_local = '') or
                (get_candidate_text_unit_count(candidate_text_local) <>
                input_syllable_count) then
            begin
                Exit;
            end;

            support_path_local := infer_segment_path_for_query_text_with_score(
                lookup_text, candidate_text_local, support_score_local,
                support_segments_local);
            if support_path_local = '' then
            begin
                support_score_local := -960;
            end;

            get_exact_window_consistency_stats_local(candidate_text_local, 2, 5,
                exact_match_count_local, exact_mismatch_count_local,
                exact_strong_match_count_local,
                exact_strong_mismatch_count_local);
            Result := (exact_match_count_local * 1024) +
                (exact_strong_match_count_local * 12288) -
                (exact_mismatch_count_local * 2048) -
                (exact_strong_mismatch_count_local * 24576) +
                Min(get_rank_score(candidate), 2048);
            if support_path_local <> '' then
            begin
                Inc(Result, (support_score_local * c_score_support_weight) +
                    Max(0, 3072 - (support_segments_local * 384)));
            end
            else
            begin
                Dec(Result, 2048);
            end;
            if is_problematic_single_char_chain_candidate_for_query(
                lookup_text, candidate) then
            begin
                Dec(Result, c_problematic_penalty);
            end;
        end;

        procedure append_window_variant_local(var texts: TArray<string>;
            var weights: TArray<Integer>; var anchor_units: TArray<Integer>;
            const candidate_text: string; const candidate_weight: Integer;
            const candidate_anchor_units: Integer);
        var
            local_idx: Integer;
            insert_idx: Integer;
            swap_text: string;
            swap_weight: Integer;
            swap_anchor_units: Integer;
        begin
            if candidate_text = '' then
            begin
                Exit;
            end;

            for local_idx := 0 to High(texts) do
            begin
                if SameText(texts[local_idx], candidate_text) then
                begin
                    if candidate_weight <= weights[local_idx] then
                    begin
                        Exit;
                    end;
                    weights[local_idx] := candidate_weight;
                    anchor_units[local_idx] := candidate_anchor_units;
                    insert_idx := local_idx;
                    while (insert_idx > 0) and
                        ((weights[insert_idx] > weights[insert_idx - 1]) or
                        ((weights[insert_idx] = weights[insert_idx - 1]) and
                        (CompareText(texts[insert_idx],
                        texts[insert_idx - 1]) < 0))) do
                    begin
                        swap_text := texts[insert_idx - 1];
                        texts[insert_idx - 1] := texts[insert_idx];
                        texts[insert_idx] := swap_text;
                        swap_weight := weights[insert_idx - 1];
                        weights[insert_idx - 1] := weights[insert_idx];
                        weights[insert_idx] := swap_weight;
                        swap_anchor_units := anchor_units[insert_idx - 1];
                        anchor_units[insert_idx - 1] := anchor_units[insert_idx];
                        anchor_units[insert_idx] := swap_anchor_units;
                        Dec(insert_idx);
                    end;
                    Exit;
                end;
            end;

            SetLength(texts, Length(texts) + 1);
            SetLength(weights, Length(weights) + 1);
            SetLength(anchor_units, Length(anchor_units) + 1);
            insert_idx := High(texts);
            texts[insert_idx] := candidate_text;
            weights[insert_idx] := candidate_weight;
            anchor_units[insert_idx] := candidate_anchor_units;
            while (insert_idx > 0) and
                ((weights[insert_idx] > weights[insert_idx - 1]) or
                ((weights[insert_idx] = weights[insert_idx - 1]) and
                (CompareText(texts[insert_idx], texts[insert_idx - 1]) < 0))) do
            begin
                swap_text := texts[insert_idx - 1];
                texts[insert_idx - 1] := texts[insert_idx];
                texts[insert_idx] := swap_text;
                swap_weight := weights[insert_idx - 1];
                weights[insert_idx - 1] := weights[insert_idx];
                weights[insert_idx] := swap_weight;
                swap_anchor_units := anchor_units[insert_idx - 1];
                anchor_units[insert_idx - 1] := anchor_units[insert_idx];
                anchor_units[insert_idx] := swap_anchor_units;
                Dec(insert_idx);
            end;

            if Length(texts) > c_variant_limit then
            begin
                SetLength(texts, c_variant_limit);
                SetLength(weights, c_variant_limit);
                SetLength(anchor_units, c_variant_limit);
            end;
        end;

        function collect_window_variant_texts_local(const start_unit: Integer;
            const unit_count: Integer; out out_texts: TArray<string>;
            out out_weights: TArray<Integer>;
            out out_anchor_units: TArray<Integer>): Boolean;
        var
            query_key: string;
            exact_results: TncCandidateList;
            exact_idx: Integer;
            candidate_text_local: string;
            candidate_weight_local: Integer;
            resolved_text: string;
            resolved_score: Integer;
            resolved_segments: Integer;
            resolved_path: string;
            resolved_has_anchor: Boolean;
            resolved_anchor_units: Integer;
            split_idx: Integer;
            left_texts: TArray<string>;
            left_weights: TArray<Integer>;
            left_anchor_units: TArray<Integer>;
            right_texts: TArray<string>;
            right_weights: TArray<Integer>;
            right_anchor_units: TArray<Integer>;
            left_idx: Integer;
            right_idx: Integer;

            function collect_direct_subspan_variants_local(
                const local_start_unit: Integer; const local_unit_count: Integer;
                const max_local_options: Integer; out local_texts: TArray<string>;
                out local_weights: TArray<Integer>;
                out local_anchor_units: TArray<Integer>): Boolean;
            var
                local_query_key: string;
                local_results: TncCandidateList;
                local_idx: Integer;
                local_text: string;
                local_weight: Integer;
                local_resolved_text: string;
                local_resolved_score: Integer;
                local_resolved_segments: Integer;
                local_resolved_path: string;
                local_resolved_has_anchor: Boolean;
                local_resolved_anchor_units: Integer;
            begin
                SetLength(local_texts, 0);
                SetLength(local_weights, 0);
                SetLength(local_anchor_units, 0);
                if (local_start_unit < 0) or (local_unit_count <= 0) then
                begin
                    Exit(False);
                end;

                local_query_key := build_query_key_local(local_start_unit,
                    local_unit_count);
                if (local_query_key <> '') and
                    m_dictionary.lookup_exact_full_pinyin(local_query_key,
                    local_results) then
                begin
                    for local_idx := 0 to High(local_results) do
                    begin
                        if local_idx >= max_local_options then
                        begin
                            Break;
                        end;
                        if Trim(local_results[local_idx].comment) <> '' then
                        begin
                            Continue;
                        end;
                        local_text := Trim(local_results[local_idx].text);
                        if get_candidate_text_unit_count(local_text) <>
                            local_unit_count then
                        begin
                            Continue;
                        end;
                        local_weight := local_results[local_idx].score;
                        if local_results[local_idx].has_dict_weight and
                            (local_results[local_idx].dict_weight >
                            local_weight) then
                        begin
                            local_weight := local_results[local_idx].dict_weight;
                        end;
                        append_window_variant_local(local_texts, local_weights,
                            local_anchor_units, local_text, local_weight,
                            IfThen(local_unit_count >= 3, local_unit_count, 0));
                    end;
                end;

                if (local_unit_count >= 2) and
                    try_resolve_best_exact_subspan_local(local_start_unit,
                    local_unit_count, local_resolved_text, local_resolved_score,
                    local_resolved_segments, local_resolved_path,
                    local_resolved_has_anchor, local_resolved_anchor_units) then
                begin
                    append_window_variant_local(local_texts, local_weights,
                        local_anchor_units, Trim(local_resolved_text),
                        local_resolved_score, local_resolved_anchor_units);
                end;
                Result := Length(local_texts) > 0;
            end;
        begin
            SetLength(out_texts, 0);
            SetLength(out_weights, 0);
            SetLength(out_anchor_units, 0);
            if (start_unit < 0) or (unit_count <= 0) then
            begin
                Exit(False);
            end;

            query_key := build_query_key_local(start_unit, unit_count);
            if (query_key <> '') and
                m_dictionary.lookup_exact_full_pinyin(query_key, exact_results) then
            begin
                for exact_idx := 0 to High(exact_results) do
                begin
                    if exact_idx >= c_variant_exact_probe_limit then
                    begin
                        Break;
                    end;
                    if Trim(exact_results[exact_idx].comment) <> '' then
                    begin
                        Continue;
                    end;
                    candidate_text_local := Trim(exact_results[exact_idx].text);
                    if get_candidate_text_unit_count(candidate_text_local) <>
                        unit_count then
                    begin
                        Continue;
                    end;
                    candidate_weight_local := exact_results[exact_idx].score;
                    if exact_results[exact_idx].has_dict_weight and
                        (exact_results[exact_idx].dict_weight >
                        candidate_weight_local) then
                    begin
                        candidate_weight_local :=
                            exact_results[exact_idx].dict_weight;
                    end;
                    append_window_variant_local(out_texts, out_weights,
                        out_anchor_units, candidate_text_local,
                        candidate_weight_local, IfThen(unit_count >= 3,
                        unit_count, 0));
                end;
            end;

            if try_resolve_best_exact_subspan_local(start_unit, unit_count,
                resolved_text, resolved_score, resolved_segments, resolved_path,
                resolved_has_anchor, resolved_anchor_units) then
            begin
                append_window_variant_local(out_texts, out_weights,
                    out_anchor_units, Trim(resolved_text), resolved_score,
                    resolved_anchor_units);
            end;

            if unit_count >= 3 then
            begin
                for split_idx := 1 to unit_count - 1 do
                begin
                    if not collect_direct_subspan_variants_local(start_unit,
                        split_idx, 3, left_texts, left_weights,
                        left_anchor_units) then
                    begin
                        Continue;
                    end;
                    if not collect_direct_subspan_variants_local(
                        start_unit + split_idx, unit_count - split_idx, 3,
                        right_texts, right_weights, right_anchor_units) then
                    begin
                        Continue;
                    end;

                    for left_idx := 0 to High(left_texts) do
                    begin
                        for right_idx := 0 to High(right_texts) do
                        begin
                            append_window_variant_local(out_texts, out_weights,
                                out_anchor_units,
                                left_texts[left_idx] + right_texts[right_idx],
                                left_weights[left_idx] +
                                right_weights[right_idx] + 256,
                                Max(left_anchor_units[left_idx],
                                right_anchor_units[right_idx]));
                        end;
                    end;
                end;
            end;
            Result := Length(out_texts) > 0;
        end;

        function get_window_alignment_score_local(
            const candidate_text_local: string): Integer;
        var
            candidate_units_local: TArray<string>;
            start_idx_local: Integer;
            span_syllables_local: Integer;
            variant_texts_local: TArray<string>;
            variant_weights_local: TArray<Integer>;
            variant_anchor_units_local: TArray<Integer>;
            current_window_text_local: string;
            variant_idx_local: Integer;
            matched_idx_local: Integer;
        begin
            Result := Low(Integer);
            candidate_units_local := split_text_units(Trim(candidate_text_local));
            if Length(candidate_units_local) <> input_syllable_count then
            begin
                Exit;
            end;

            Result := 0;
            for start_idx_local := 0 to
                input_syllable_count - c_window_min_syllables do
            begin
                for span_syllables_local := c_window_min_syllables to
                    Min(c_window_max_syllables,
                    input_syllable_count - start_idx_local) do
                begin
                    if not collect_window_variant_texts_local(start_idx_local,
                        span_syllables_local, variant_texts_local,
                        variant_weights_local, variant_anchor_units_local) then
                    begin
                        Continue;
                    end;

                    current_window_text_local := build_text_from_units_local(
                        candidate_units_local, start_idx_local,
                        span_syllables_local);
                    matched_idx_local := -1;
                    for variant_idx_local := 0 to High(variant_texts_local) do
                    begin
                        if SameText(current_window_text_local,
                            variant_texts_local[variant_idx_local]) then
                        begin
                            matched_idx_local := variant_idx_local;
                            Break;
                        end;
                    end;

                    case matched_idx_local of
                        0:
                            begin
                                Inc(Result, 4096 + span_syllables_local * 512);
                                if span_syllables_local >= 4 then
                                begin
                                    Inc(Result, 4096 + span_syllables_local * 256);
                                end;
                            end;
                        1:
                            begin
                                Inc(Result, 2048 + span_syllables_local * 256);
                                if span_syllables_local >= 4 then
                                begin
                                    Inc(Result, 1536 + span_syllables_local * 128);
                                end;
                            end;
                        2:
                            begin
                                Inc(Result, 1024 + span_syllables_local * 128);
                                if span_syllables_local >= 4 then
                                begin
                                    Inc(Result, 768 + span_syllables_local * 96);
                                end;
                            end;
                    else
                        if (Length(variant_texts_local) > 0) and
                            ((span_syllables_local >= 3) or
                            (variant_anchor_units_local[0] >= 3) or
                            (variant_weights_local[0] >= 1200)) then
                        begin
                            if span_syllables_local >= 4 then
                            begin
                                Dec(Result, 2048 + span_syllables_local * 256);
                            end
                            else if span_syllables_local = 3 then
                            begin
                                Dec(Result, 1536 + span_syllables_local * 160);
                            end
                            else
                            begin
                                Dec(Result, 384 + span_syllables_local * 64);
                            end;
                        end;
                    end;
                end;
            end;
        end;

        function get_local_repair_bonus_local(const unit_count: Integer;
            const candidate_weight: Integer;
            const candidate_anchor_units: Integer): Integer;
        begin
            Result := Min(8192, Max(768, candidate_weight div 2)) +
                (unit_count * 320);
            if candidate_anchor_units >= 3 then
            begin
                Inc(Result, 1024);
            end;
        end;

        function try_find_best_repair_for_candidate_local(
            const seed_candidate: TncCandidate; out out_candidate: TncCandidate;
            out out_score: Integer): Boolean;
        var
            seed_text: string;
            seed_units: TArray<string>;
            seed_score: Integer;
            start_idx: Integer;
            span_syllables: Integer;
            current_window_text: string;
            repaired_window_text: string;
            repaired_text: string;
            variant_texts: TArray<string>;
            variant_weights: TArray<Integer>;
            variant_anchor_units: TArray<Integer>;
            variant_idx: Integer;
            repaired_support_score: Integer;
            repaired_support_segments: Integer;
            repaired_support_path: string;
            local_candidate_local: TncCandidate;
            local_best_score: Integer;
            alignment_score_local: Integer;
        begin
            Result := False;
            out_score := Low(Integer);
            FillChar(out_candidate, SizeOf(out_candidate), 0);

            seed_text := Trim(seed_candidate.text);
            seed_units := split_text_units(seed_text);
            if Length(seed_units) <> input_syllable_count then
            begin
                Exit;
            end;

            seed_score := get_supported_sentence_score_local(seed_candidate,
                repaired_support_score);
            alignment_score_local := get_window_alignment_score_local(seed_text);
            if alignment_score_local <> Low(Integer) then
            begin
                Inc(seed_score, alignment_score_local * 8);
            end;
            local_best_score := seed_score;

            for start_idx := 0 to input_syllable_count - c_window_min_syllables do
            begin
                for span_syllables := c_window_min_syllables to
                    Min(c_window_max_syllables,
                    input_syllable_count - start_idx) do
                begin
                    if not collect_window_variant_texts_local(start_idx,
                        span_syllables, variant_texts, variant_weights,
                        variant_anchor_units) then
                    begin
                        Continue;
                    end;

                    current_window_text := build_text_from_units_local(
                        seed_units, start_idx, span_syllables);
                    for variant_idx := 0 to High(variant_texts) do
                    begin
                        repaired_window_text := Trim(variant_texts[variant_idx]);
                        if (repaired_window_text = '') or SameText(
                            repaired_window_text, current_window_text) then
                        begin
                            Continue;
                        end;

                        repaired_text := replace_window_text_local(seed_units,
                            start_idx, span_syllables, repaired_window_text);
                        if (repaired_text = '') or SameText(repaired_text,
                            seed_text) then
                        begin
                            Continue;
                        end;

                        FillChar(local_candidate_local,
                            SizeOf(local_candidate_local), 0);
                        local_candidate_local.text := repaired_text;
                        local_candidate_local.comment := '';
                        local_candidate_local.score := seed_candidate.score +
                            1024 + Min(4096, Max(512,
                            variant_weights[variant_idx] div 8));
                        local_candidate_local.source := cs_rule;
                        local_candidate_local.has_dict_weight := False;
                        local_candidate_local.dict_weight := 0;

                        out_score := get_supported_sentence_score_local(
                            local_candidate_local, repaired_support_score);
                        alignment_score_local :=
                            get_window_alignment_score_local(repaired_text);
                        repaired_support_path :=
                            infer_segment_path_for_query_text_with_score(
                            lookup_text, repaired_text, repaired_support_score,
                            repaired_support_segments);
                        if repaired_support_path = '' then
                        begin
                            Dec(out_score, 4096);
                        end;

                        if alignment_score_local <> Low(Integer) then
                        begin
                            Inc(out_score, alignment_score_local * 8);
                        end;

                        Inc(out_score, get_local_repair_bonus_local(
                            span_syllables, variant_weights[variant_idx],
                            variant_anchor_units[variant_idx]));
                        if out_score <= local_best_score +
                            get_support_margin_local then
                        begin
                            Continue;
                        end;

                        out_candidate := local_candidate_local;
                        local_best_score := out_score;
                        Result := True;
                    end;
                end;
            end;

            if Result then
            begin
                out_score := local_best_score;
            end;
        end;
    begin
        if (Length(candidates) = 0) or (input_syllable_count < 4) or
            (not is_full_pinyin_key(lookup_text)) or (m_dictionary = nil) then
        begin
            Exit;
        end;

        if has_strong_top_complete_candidate_for_postprocess_lock_local(
            candidates) then
        begin
            if m_config.debug_mode then
            begin
                m_last_full_path_debug_info := m_last_full_path_debug_info +
                    ' vrepair=[locked]';
            end;
            Exit;
        end;

        effective_syllables := get_effective_compact_pinyin_syllables(
            lookup_text);
        if Length(effective_syllables) <> input_syllable_count then
        begin
            Exit;
        end;

        if (Trim(candidates[0].comment) = '') and
            (get_candidate_text_unit_count(Trim(candidates[0].text)) =
            input_syllable_count) then
        begin
            top_score := get_supported_sentence_score_local(candidates[0],
                local_score);
        end
        else
        begin
            top_score := Low(Integer);
        end;

        best_score := top_score;
        FillChar(repaired_candidate, SizeOf(repaired_candidate), 0);
        for probe_idx := 0 to Min(c_probe_limit - 1, High(candidates)) do
        begin
            if not try_find_best_repair_for_candidate_local(candidates[probe_idx],
                local_candidate, local_score) then
            begin
                Continue;
            end;
            if local_score <= best_score +
                IfThen(input_syllable_count <= 4, 1024,
                IfThen(input_syllable_count <= 6, 2048,
                c_promote_score_margin)) then
            begin
                Continue;
            end;

            repaired_candidate := local_candidate;
            best_score := local_score;
        end;

        if Trim(repaired_candidate.text) = '' then
        begin
            Exit;
        end;

        for pass_idx := 2 to c_repair_pass_limit do
        begin
            if not try_find_best_repair_for_candidate_local(repaired_candidate,
                local_candidate, local_score) then
            begin
                Break;
            end;
            if local_score <= best_score + get_support_margin_local then
            begin
                Break;
            end;

            repaired_candidate := local_candidate;
            best_score := local_score;
        end;

        SetLength(candidates, Length(candidates) + 1);
        for move_idx := High(candidates) downto 1 do
        begin
            candidates[move_idx] := candidates[move_idx - 1];
        end;
        candidates[0] := repaired_candidate;
        if m_config.debug_mode then
        begin
            m_last_full_path_debug_info := m_last_full_path_debug_info +
                Format(' vrepair=[promote text=%s score=%d]',
                [Trim(repaired_candidate.text), best_score]);
        end;
    end;

    procedure ensure_best_oracle_backed_exact_complete_candidate_visible(
        var candidates: TncCandidateList);
    const
        c_visible_probe_limit = 8;
        c_exact_probe_limit = 8;
        c_oracle_rank_bonus_base = 18000;
        c_oracle_rank_bonus_step = 4000;
        c_oracle_score_scale = 3;
        c_support_scale = 1;
        c_support_segment_bonus = 320;
        c_no_support_penalty = 4096;
        c_problematic_penalty = 24000;
        c_oracle_top_exact_bonus = 24000;
        c_oracle_near_top_exact_bonus = 12000;
        c_non_oracle_exact_penalty = 12000;
    var
        exact_results: TncCandidateList;
        oracle_text_scores: TDictionary<string, Integer>;
        oracle_text_ranks: TDictionary<string, Integer>;
        visible_texts: TDictionary<string, Byte>;
        idx: Integer;
        exact_idx: Integer;
        existing_index: Integer;
        top_score: Integer;
        best_score: Integer;
        candidate_score: Integer;
        top_is_complete: Boolean;
        picked: TncCandidate;
        top_text: string;
        candidate_text: string;
        support_score_local: Integer;
        support_segments_local: Integer;
        support_path_local: string;
        oracle_score_local: Integer;
        oracle_rank_local: Integer;
        exact_candidate: TncCandidate;
        promote_margin: Integer;

        function get_candidate_total_score_local(
            const candidate: TncCandidate): Integer;
        var
            local_text: string;
            local_support_score: Integer;
            local_support_segments: Integer;
            local_support_path: string;
            local_oracle_score: Integer;
            local_oracle_rank: Integer;
        begin
            Result := Low(Integer);
            if Trim(candidate.comment) <> '' then
            begin
                Exit;
            end;

            local_text := Trim(candidate.text);
            if (local_text = '') or
                (get_candidate_text_unit_count(local_text) <> input_syllable_count) then
            begin
                Exit;
            end;

            Result := Min(get_rank_score(candidate), 32768);
            local_support_path := infer_segment_path_for_query_text_with_score(
                lookup_text, local_text, local_support_score,
                local_support_segments);
            if local_support_path <> '' then
            begin
                Inc(Result, local_support_score * c_support_scale);
                Inc(Result, local_support_segments * c_support_segment_bonus);
            end
            else
            begin
                Dec(Result, c_no_support_penalty);
            end;

            if oracle_text_scores.TryGetValue(local_text, local_oracle_score) then
            begin
                Inc(Result, local_oracle_score * c_oracle_score_scale);
                if oracle_text_ranks.TryGetValue(local_text, local_oracle_rank) then
                begin
                    Inc(Result, Max(0, c_oracle_rank_bonus_base -
                        (local_oracle_rank * c_oracle_rank_bonus_step)));
                    if local_oracle_rank = 0 then
                    begin
                        Inc(Result, c_oracle_top_exact_bonus);
                    end
                    else if local_oracle_rank = 1 then
                    begin
                        Inc(Result, c_oracle_near_top_exact_bonus);
                    end;
                end;
            end;
            if (Length(exact_results) > 0) and
                (not oracle_text_scores.ContainsKey(local_text)) then
            begin
                Dec(Result, c_non_oracle_exact_penalty);
            end;

            if is_problematic_single_char_chain_candidate_for_query(
                lookup_text, candidate) then
            begin
                Dec(Result, c_problematic_penalty);
            end;
        end;
    begin
        if (Length(candidates) = 0) or (input_syllable_count < 3) or
            (not is_full_pinyin_key(lookup_text)) or (m_dictionary = nil) then
        begin
            if m_config.debug_mode then
            begin
                m_last_full_path_debug_info := m_last_full_path_debug_info +
                    Format(' voracle=[skip pre len=%d syll=%d fp=%d dict=%d]',
                    [Length(candidates), input_syllable_count,
                    Ord(is_full_pinyin_key(lookup_text)),
                    Ord(m_dictionary <> nil)]);
            end;
            Exit;
        end;

        if input_syllable_count <= 4 then
        begin
            promote_margin := 256;
        end
        else if input_syllable_count <= 7 then
        begin
            promote_margin := 512;
        end
        else
        begin
            promote_margin := 2048;
        end;

        if m_config.debug_mode then
        begin
            m_last_full_path_debug_info := m_last_full_path_debug_info +
                ' voracle=[enter]';
        end;
        ensure_strict_oracle_sentence_candidates_prepared;
        if not strict_oracle_sentence_ok then
        begin
            if m_config.debug_mode then
            begin
                m_last_full_path_debug_info := m_last_full_path_debug_info +
                    ' voracle=[skip oracle]';
            end;
            Exit;
        end;
        if not m_dictionary.lookup_exact_full_pinyin(lookup_text, exact_results) then
        begin
            if m_config.debug_mode then
            begin
                m_last_full_path_debug_info := m_last_full_path_debug_info +
                    ' voracle=[no exact]';
            end;
            Exit;
        end;
        if Length(exact_results) = 0 then
        begin
            if m_config.debug_mode then
            begin
                m_last_full_path_debug_info := m_last_full_path_debug_info +
                    ' voracle=[empty exact]';
            end;
            Exit;
        end;

        oracle_text_scores := TDictionary<string, Integer>.Create;
        oracle_text_ranks := TDictionary<string, Integer>.Create;
        visible_texts := TDictionary<string, Byte>.Create;
        try
            for idx := 0 to Min(c_visible_probe_limit - 1, High(candidates)) do
            begin
                candidate_text := Trim(candidates[idx].text);
                if candidate_text <> '' then
                begin
                    visible_texts.AddOrSetValue(candidate_text, 1);
                end;
            end;

            for idx := 0 to Min(c_exact_probe_limit - 1,
                High(strict_oracle_sentence_candidates)) do
            begin
                candidate_text := Trim(strict_oracle_sentence_candidates[idx].text);
                if candidate_text = '' then
                begin
                    Continue;
                end;
                oracle_text_scores.AddOrSetValue(candidate_text,
                    strict_oracle_sentence_candidates[idx].score);
                oracle_text_ranks.AddOrSetValue(candidate_text, idx);
            end;

            top_is_complete := (Trim(candidates[0].comment) = '') and
                (get_candidate_text_unit_count(Trim(candidates[0].text)) =
                input_syllable_count);
            top_text := Trim(candidates[0].text);
            if top_is_complete then
            begin
                top_score := get_candidate_total_score_local(candidates[0]);
                best_score := top_score;
                picked := candidates[0];
            end
            else
            begin
                top_score := Low(Integer);
                best_score := Low(Integer);
                FillChar(picked, SizeOf(picked), 0);
            end;

            for idx := 0 to Min(c_visible_probe_limit - 1, High(candidates)) do
            begin
                candidate_score := get_candidate_total_score_local(candidates[idx]);
                if candidate_score > best_score then
                begin
                    best_score := candidate_score;
                    picked := candidates[idx];
                end;
            end;

            for exact_idx := 0 to Min(c_exact_probe_limit - 1, High(exact_results)) do
            begin
                exact_candidate := exact_results[exact_idx];
                if Trim(exact_candidate.comment) <> '' then
                begin
                    Continue;
                end;
                candidate_text := Trim(exact_candidate.text);
                if (candidate_text = '') or
                    (get_candidate_text_unit_count(candidate_text) <>
                    input_syllable_count) then
                begin
                    Continue;
                end;
                if visible_texts.ContainsKey(candidate_text) then
                begin
                    Continue;
                end;

                candidate_score := get_candidate_total_score_local(exact_candidate);
                if candidate_score > best_score then
                begin
                    best_score := candidate_score;
                    picked := exact_candidate;
                end;
            end;

            if (best_score = Low(Integer)) or
                ((top_score <> Low(Integer)) and
                (best_score <= top_score + promote_margin)) then
            begin
                if m_config.debug_mode then
                begin
                    m_last_full_path_debug_info := m_last_full_path_debug_info +
                        Format(' voracle=[keep top=%s ts=%d best=%s bs=%d]',
                        [top_text, top_score, Trim(picked.text), best_score]);
                end;
                Exit;
            end;

            existing_index := -1;
            for idx := 0 to High(candidates) do
            begin
                if (Trim(candidates[idx].comment) = '') and
                    SameText(Trim(candidates[idx].text), Trim(picked.text)) then
                begin
                    existing_index := idx;
                    Break;
                end;
            end;

            support_path_local := infer_segment_path_for_query_text_with_score(
                lookup_text, Trim(picked.text), support_score_local,
                support_segments_local);
            if support_path_local <> '' then
            begin
                remember_segment_path_for_candidate(Trim(picked.text), '',
                    support_path_local, picked.score + Min(2400,
                    support_score_local div 4));
            end;

            if existing_index > 0 then
            begin
                for idx := existing_index downto 1 do
                begin
                    candidates[idx] := candidates[idx - 1];
                end;
                candidates[0] := picked;
            end
            else if existing_index < 0 then
            begin
                SetLength(candidates, Length(candidates) + 1);
                for idx := High(candidates) downto 1 do
                begin
                    candidates[idx] := candidates[idx - 1];
                end;
                candidates[0] := picked;
            end;

            if m_config.debug_mode then
            begin
                oracle_score_local := 0;
                oracle_rank_local := -1;
                oracle_text_scores.TryGetValue(Trim(picked.text), oracle_score_local);
                oracle_text_ranks.TryGetValue(Trim(picked.text), oracle_rank_local);
                m_last_full_path_debug_info := m_last_full_path_debug_info +
                    Format(' voracle=[promote text=%s score=%d top=%d os=%d or=%d]',
                    [Trim(picked.text), best_score, top_score, oracle_score_local,
                    oracle_rank_local]);
            end;
        finally
            visible_texts.Free;
            oracle_text_ranks.Free;
            oracle_text_scores.Free;
        end;
    end;

    procedure ensure_strict_oracle_exact_top_complete_candidate_visible(
        var candidates: TncCandidateList);
    const
        c_oracle_probe_limit = 6;
        c_exact_probe_limit = 12;
    var
        exact_results: TncCandidateList;
        oracle_text: string;
        top_text: string;
        idx: Integer;
        exact_idx: Integer;
        existing_index: Integer;
        picked: TncCandidate;
        top_is_complete: Boolean;
        top_is_exact: Boolean;

        function is_exact_complete_text_local(const text_value: string): Boolean;
        var
            local_idx: Integer;
        begin
            Result := False;
            if text_value = '' then
            begin
                Exit;
            end;
            for local_idx := 0 to Min(c_exact_probe_limit - 1, High(exact_results)) do
            begin
                if Trim(exact_results[local_idx].comment) <> '' then
                begin
                    Continue;
                end;
                if SameText(Trim(exact_results[local_idx].text), text_value) and
                    (get_candidate_text_unit_count(Trim(exact_results[local_idx].text)) =
                    input_syllable_count) then
                begin
                    Exit(True);
                end;
            end;
        end;
    begin
        if (Length(candidates) = 0) or (input_syllable_count < 4) or
            (not is_full_pinyin_key(lookup_text)) or (m_dictionary = nil) then
        begin
            Exit;
        end;

        ensure_strict_oracle_sentence_candidates_prepared;
        if (not strict_oracle_sentence_ok) or
            (Length(strict_oracle_sentence_candidates) = 0) then
        begin
            Exit;
        end;
        if not m_dictionary.lookup_exact_full_pinyin(lookup_text, exact_results) then
        begin
            Exit;
        end;

        oracle_text := '';
        for idx := 0 to Min(c_oracle_probe_limit - 1,
            High(strict_oracle_sentence_candidates)) do
        begin
            if Trim(strict_oracle_sentence_candidates[idx].comment) <> '' then
            begin
                Continue;
            end;
            if get_candidate_text_unit_count(
                Trim(strict_oracle_sentence_candidates[idx].text)) <>
                input_syllable_count then
            begin
                Continue;
            end;
            if is_exact_complete_text_local(
                Trim(strict_oracle_sentence_candidates[idx].text)) then
            begin
                oracle_text := Trim(strict_oracle_sentence_candidates[idx].text);
                Break;
            end;
        end;
        if oracle_text = '' then
        begin
            Exit;
        end;

        top_text := Trim(candidates[0].text);
        top_is_complete := (Trim(candidates[0].comment) = '') and
            (get_candidate_text_unit_count(top_text) = input_syllable_count);
        top_is_exact := top_is_complete and is_exact_complete_text_local(top_text);
        if SameText(top_text, oracle_text) or top_is_exact then
        begin
            Exit;
        end;

        if (not top_is_complete) and
            (not is_problematic_single_char_chain_candidate_for_query(
            lookup_text, candidates[0])) then
        begin
            Exit;
        end;

        existing_index := -1;
        for idx := 0 to High(candidates) do
        begin
            if (Trim(candidates[idx].comment) = '') and
                SameText(Trim(candidates[idx].text), oracle_text) then
            begin
                existing_index := idx;
                Break;
            end;
        end;

        if existing_index > 0 then
        begin
            picked := candidates[existing_index];
            for idx := existing_index downto 1 do
            begin
                candidates[idx] := candidates[idx - 1];
            end;
            candidates[0] := picked;
        end
        else if existing_index < 0 then
        begin
            for exact_idx := 0 to Min(c_exact_probe_limit - 1, High(exact_results)) do
            begin
                if Trim(exact_results[exact_idx].comment) <> '' then
                begin
                    Continue;
                end;
                if SameText(Trim(exact_results[exact_idx].text), oracle_text) then
                begin
                    picked := exact_results[exact_idx];
                    SetLength(candidates, Length(candidates) + 1);
                    for idx := High(candidates) downto 1 do
                    begin
                        candidates[idx] := candidates[idx - 1];
                    end;
                    candidates[0] := picked;
                    Break;
                end;
            end;
        end;

        if m_config.debug_mode then
        begin
            m_last_full_path_debug_info := m_last_full_path_debug_info +
                Format(' voraclex=[promote text=%s top=%s]', [oracle_text, top_text]);
        end;
    end;

    function ensure_visible_strict_oracle_top_complete_candidate_visible(
        var candidates: TncCandidateList): Boolean;
    const
        c_oracle_probe_limit = 6;
    var
        oracle_text: string;
        idx: Integer;
        existing_index: Integer;
        picked: TncCandidate;
        exact_results_local: TncCandidateList;
    begin
        Result := False;
        if (Length(candidates) = 0) or (input_syllable_count < 10) or
            (not is_full_pinyin_key(lookup_text)) or (m_dictionary = nil) then
        begin
            Exit;
        end;

        if not m_dictionary.lookup_exact_full_pinyin(lookup_text,
            exact_results_local) then
        begin
            Exit;
        end;
        if Length(exact_results_local) = 0 then
        begin
            Exit;
        end;

        ensure_strict_oracle_sentence_candidates_prepared;
        if (not strict_oracle_sentence_ok) or
            (Length(strict_oracle_sentence_candidates) = 0) then
        begin
            Exit;
        end;

        oracle_text := '';
        for idx := 0 to Min(c_oracle_probe_limit - 1,
            High(strict_oracle_sentence_candidates)) do
        begin
            if Trim(strict_oracle_sentence_candidates[idx].comment) <> '' then
            begin
                Continue;
            end;
            if get_candidate_text_unit_count(
                Trim(strict_oracle_sentence_candidates[idx].text)) <>
                input_syllable_count then
            begin
                Continue;
            end;
            oracle_text := Trim(strict_oracle_sentence_candidates[idx].text);
            Break;
        end;
        if oracle_text = '' then
        begin
            Exit;
        end;

        if SameText(Trim(candidates[0].text), oracle_text) and
            (Trim(candidates[0].comment) = '') then
        begin
            Exit(True);
        end;

        existing_index := -1;
        for idx := 1 to High(candidates) do
        begin
            if (Trim(candidates[idx].comment) = '') and
                SameText(Trim(candidates[idx].text), oracle_text) then
            begin
                existing_index := idx;
                Break;
            end;
        end;
        if existing_index <= 0 then
        begin
            Exit(False);
        end;

        picked := candidates[existing_index];
        for idx := existing_index downto 1 do
        begin
            candidates[idx] := candidates[idx - 1];
        end;
        candidates[0] := picked;
        if m_config.debug_mode then
        begin
            m_last_full_path_debug_info := m_last_full_path_debug_info +
                Format(' vtoporacle=[promote text=%s]', [Trim(picked.text)]);
        end;
        Result := True;
    end;

    function ensure_strict_oracle_complete_candidate_visible(
        var candidates: TncCandidateList): Boolean;
    const
        c_oracle_probe_limit = 6;
    var
        oracle_text: string;
        top_text: string;
        oracle_path: string;
        top_path: string;
        oracle_support_score: Integer;
        top_support_score: Integer;
        oracle_support_segments: Integer;
        top_support_segments: Integer;
        oracle_idx: Integer;
        idx: Integer;
        existing_index: Integer;
        picked: TncCandidate;
        top_is_complete: Boolean;
        top_problematic: Boolean;
        should_promote: Boolean;
    begin
        Result := False;
        if (Length(candidates) = 0) or (input_syllable_count < 10) or
            (not is_full_pinyin_key(lookup_text)) or (m_dictionary = nil) then
        begin
            Exit;
        end;

        ensure_strict_oracle_sentence_candidates_prepared;
        if (not strict_oracle_sentence_ok) or
            (Length(strict_oracle_sentence_candidates) = 0) then
        begin
            Exit;
        end;

        oracle_text := '';
        oracle_idx := -1;
        for idx := 0 to Min(c_oracle_probe_limit - 1,
            High(strict_oracle_sentence_candidates)) do
        begin
            if Trim(strict_oracle_sentence_candidates[idx].comment) <> '' then
            begin
                Continue;
            end;
            if get_candidate_text_unit_count(
                Trim(strict_oracle_sentence_candidates[idx].text)) <>
                input_syllable_count then
            begin
                Continue;
            end;
            oracle_text := Trim(strict_oracle_sentence_candidates[idx].text);
            oracle_idx := idx;
            Break;
        end;
        if oracle_text = '' then
        begin
            Exit;
        end;

        top_text := Trim(candidates[0].text);
        if SameText(top_text, oracle_text) and
            (Trim(candidates[0].comment) = '') then
        begin
            Exit(True);
        end;

        top_is_complete := (Trim(candidates[0].comment) = '') and
            (get_candidate_text_unit_count(top_text) = input_syllable_count);
        top_problematic := (not top_is_complete) or
            is_problematic_single_char_chain_candidate_for_query(lookup_text,
            candidates[0]);

        oracle_support_score := Low(Integer);
        oracle_support_segments := 0;
        oracle_path := infer_segment_path_for_query_text_with_score(lookup_text,
            oracle_text, oracle_support_score, oracle_support_segments);
        top_support_score := Low(Integer);
        top_support_segments := 0;
        top_path := '';
        if top_is_complete then
        begin
            top_path := infer_segment_path_for_query_text_with_score(lookup_text,
                top_text, top_support_score, top_support_segments);
        end;

        should_promote := top_problematic or (top_path = '');
        if (not should_promote) and (oracle_path <> '') then
        begin
            should_promote := (top_support_score = Low(Integer)) or
                (oracle_support_score >= top_support_score + 2048) or
                ((input_syllable_count >= 10) and
                (oracle_support_segments > top_support_segments) and
                (oracle_support_score + 1024 >= top_support_score));
        end;
        if not should_promote then
        begin
            Exit;
        end;

        existing_index := -1;
        for idx := 0 to High(candidates) do
        begin
            if (Trim(candidates[idx].comment) = '') and
                SameText(Trim(candidates[idx].text), oracle_text) then
            begin
                existing_index := idx;
                Break;
            end;
        end;

        if existing_index > 0 then
        begin
            picked := candidates[existing_index];
            for idx := existing_index downto 1 do
            begin
                candidates[idx] := candidates[idx - 1];
            end;
            candidates[0] := picked;
        end
        else if existing_index < 0 then
        begin
            picked := strict_oracle_sentence_candidates[oracle_idx];
            picked.comment := '';
            if get_rank_score(picked) < get_rank_score(candidates[0]) + 1024 then
            begin
                picked.score := candidates[0].score + 1024;
            end;
            SetLength(candidates, Length(candidates) + 1);
            for idx := High(candidates) downto 1 do
            begin
                candidates[idx] := candidates[idx - 1];
            end;
            candidates[0] := picked;
        end;

        if oracle_path <> '' then
        begin
            remember_segment_path_for_candidate(oracle_text, '', oracle_path,
                candidates[0].score + Min(2400, Max(0,
                oracle_support_score div 4)));
        end;

        if m_config.debug_mode then
        begin
            m_last_full_path_debug_info := m_last_full_path_debug_info +
                Format(' vstrictoracle=[promote text=%s top=%s os=%d ts=%d]',
                [oracle_text, top_text, oracle_support_score,
                top_support_score]);
        end;
        Result := True;
    end;

    procedure ensure_best_exact_chunk_chain_complete_candidate_visible(
        var candidates: TncCandidateList);
    const
        c_chain_probe_limit = 8;
        c_chain_max_chunk_syllables = 6;
        c_chain_min_anchor_syllables = 2;
        c_chain_length_bonus = 1200;
        c_chain_anchor_bonus = 3200;
        c_chain_lattice_max_chunk_syllables = 8;
        c_chain_lattice_beam_width = 8;
        c_chain_lattice_probe_limit = 4;
        c_chain_lattice_merge_bonus = 1800;
        c_chain_lattice_fixed_single_bonus = 2600;
        c_chain_standalone_option_limit = 6;
    type
        TExactChunkChainState = record
            text: string;
            path: string;
            first_chunk_text: string;
            first_chunk_query_key: string;
            score: Integer;
            segments: Integer;
            has_anchor: Boolean;
            anchor_units: Integer;
        end;
        TExactChunkChainStateArray = TArray<TExactChunkChainState>;
        TExactChunkChainOption = record
            text: string;
            path: string;
            query_key: string;
            score: Integer;
            segments: Integer;
            has_anchor: Boolean;
            anchor_units: Integer;
        end;
        TExactChunkChainOptionArray = TArray<TExactChunkChainOption>;
    var
        effective_syllables: TncPinyinParseResult;
        best_scores: TArray<Integer>;
        best_texts: TArray<string>;
        best_paths: TArray<string>;
        best_segments: TArray<Integer>;
        best_has_anchor: TArray<Boolean>;
        best_anchor_units: TArray<Integer>;
        syllable_count_local: Integer;
        idx: Integer;
        existing_index: Integer;
        best_visible_index: Integer;
        picked: TncCandidate;
        top_path_segment_count: Integer;
        should_promote: Boolean;
        preferred_phrase_bonus: Integer;
        top_preferred_phrase_bonus: Integer;
        best_visible_metric: Integer;
        current_metric_local: Integer;
        xchain_metric_local: Integer;
        current_support_local: Integer;
        current_path_preference_local: Integer;
        support_path_local: string;
        current_candidate_text_local: string;
        best_visible_problematic_local: Boolean;
        xchain_problematic_local: Boolean;
        problematic_candidate_local: TncCandidate;
        standalone_chunk_states: TDictionary<string, Integer>;
        standalone_chunk_texts: TDictionary<string, string>;
        standalone_chunk_scores: TDictionary<string, Integer>;
        standalone_chunk_options: TDictionary<string, TExactChunkChainOptionArray>;
        standalone_chunk_engine: TncEngine;
        standalone_chunk_config: TncEngineConfig;
        standalone_chunk_budget_remaining: Integer;
        lattice_state_map: array of TExactChunkChainStateArray;
        lattice_text: string;
        lattice_path: string;
        lattice_score: Integer;
        lattice_segments: Integer;
        lattice_has_anchor: Boolean;
        lattice_anchor_units: Integer;
        suppress_subspan_oracle_local: Boolean;
        use_direct_chunk_lattice_only: Boolean;

        function get_path_segment_count_local(const encoded_path: string): Integer;
        var
            local_parts: TArray<string>;
            local_idx: Integer;
        begin
            Result := 0;
            if Trim(encoded_path) = '' then
            begin
                Exit;
            end;

            local_parts := encoded_path.Split([c_segment_path_separator]);
            for local_idx := 0 to High(local_parts) do
            begin
                if Trim(local_parts[local_idx]) <> '' then
                begin
                    Inc(Result);
                end;
            end;
        end;

        function is_trusted_top_complete_candidate_local(
            const local_candidates: TncCandidateList): Boolean;
        const
            c_min_support_score_local = 8192;
        var
            local_candidate: TncCandidate;
            local_candidate_text: string;
            local_support_score: Integer;
            local_path_preference: Integer;
            local_support_path: string;
        begin
            Result := False;
            if (Length(local_candidates) = 0) or
                (input_syllable_count < 4) or
                (not is_full_pinyin_key(lookup_text)) then
            begin
                Exit;
            end;

            local_candidate := local_candidates[0];
            if Trim(local_candidate.comment) <> '' then
            begin
                Exit;
            end;

            local_candidate_text := Trim(local_candidate.text);
            if (local_candidate_text = '') or
                (get_candidate_text_unit_count(local_candidate_text) <>
                input_syllable_count) then
            begin
                Exit;
            end;

            if local_candidate.source = cs_user then
            begin
                Exit(True);
            end;
            if local_candidate.has_dict_weight and
                (input_syllable_count <= 4) then
            begin
                Exit(True);
            end;

            if is_problematic_single_char_chain_candidate_for_query(
                lookup_text, local_candidate) then
            begin
                Exit;
            end;

            local_support_path := infer_segment_path_for_query_text_with_score(
                lookup_text, local_candidate_text, local_support_score,
                local_path_preference);
            Result := (local_support_path <> '') and
                (local_support_score >= c_min_support_score_local);
        end;

        function build_query_key_local(const start_idx: Integer;
            const syllable_count_part: Integer): string;
        var
            local_idx: Integer;
        begin
            Result := '';
            if (start_idx < 0) or (syllable_count_part <= 0) or
                (start_idx + syllable_count_part - 1 > High(effective_syllables)) then
            begin
                Exit;
            end;

            for local_idx := start_idx to start_idx + syllable_count_part - 1 do
            begin
                Result := Result + normalize_pinyin_text(effective_syllables[local_idx].text);
            end;
        end;

        function get_exact_chunk_length_bonus_local(
            const syllable_count_part: Integer): Integer;
        begin
            if syllable_count_part <= c_chain_max_chunk_syllables then
            begin
                Exit(syllable_count_part * syllable_count_part *
                    c_chain_length_bonus);
            end;

            Result := (c_chain_max_chunk_syllables * c_chain_max_chunk_syllables *
                c_chain_length_bonus) +
                ((syllable_count_part - c_chain_max_chunk_syllables) * 900);
