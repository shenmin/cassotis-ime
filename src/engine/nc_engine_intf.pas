            best_chunk_local := top_chunk_local;
            best_rerank_local := top_rerank_local;
            for local_idx := 0 to Min(c_front_limit - 1, High(candidates)) do
            begin
                if Trim(candidates[local_idx].comment) <> '' then
                begin
                    Continue;
                end;

                local_text := Trim(candidates[local_idx].text);
                if get_candidate_text_unit_count(local_text) <>
                    input_syllable_count then
                begin
                    Continue;
                end;
                if SameText(local_text, top_text_local) then
                begin
                    Continue;
                end;

                local_units := split_text_units(local_text);
                if Length(local_units) <> Length(top_units) then
                begin
                    Continue;
                end;

                diff_start := -1;
                diff_end := -1;
                diff_count := 0;
                for unit_idx := 0 to High(top_units) do
                begin
                    if SameText(top_units[unit_idx], local_units[unit_idx]) then
                    begin
                        Continue;
                    end;

                    if diff_start < 0 then
                    begin
                        diff_start := unit_idx;
                    end;
                    diff_end := unit_idx;
                    Inc(diff_count);
                end;

                if (diff_count <= 0) or (diff_count > 2) or
                    ((diff_end - diff_start + 1) > 2) then
                begin
                    Continue;
                end;

                local_support_score := get_full_query_support_score_local(local_text);
