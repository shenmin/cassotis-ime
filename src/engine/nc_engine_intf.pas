        function get_cross_boundary_swallow_penalty_local(
            const local_pos: Integer; const local_chunk_syllables: Integer;
            const local_chunk_text: string): Integer;
        var
            local_chunk_units: TArray<string>;
            head_text_local: string;
            head_path_local: string;
            head_score_local: Integer;
            head_segments_local: Integer;
            head_anchor_units_local: Integer;
            head_has_anchor_local: Boolean;
            head_units_local: TArray<string>;
            unit_idx_local: Integer;
            overlap_start_local: Integer;
            overlap_syllables_local: Integer;
            overlap_max_local: Integer;
            overlap_text_local: string;
            overlap_path_local: string;
            overlap_score_local: Integer;
            overlap_segments_local: Integer;
            overlap_anchor_units_local: Integer;
            overlap_has_anchor_local: Boolean;
            overlap_units_local: TArray<string>;
        begin
            Result := 0;
            if (local_chunk_syllables < 5) or
                (local_pos + local_chunk_syllables >= input_syllable_count) then
            begin
                Exit;
            end;

            local_chunk_units := split_text_units(Trim(local_chunk_text));
            if Length(local_chunk_units) <> local_chunk_syllables then
            begin
                Exit;
            end;

            if not try_resolve_best_exact_subspan_local(local_pos,
                local_chunk_syllables - 1, head_text_local, head_score_local,
                head_segments_local, head_path_local, head_has_anchor_local,
                head_anchor_units_local) then
            begin
                Exit;
            end;
            head_units_local := split_text_units(Trim(head_text_local));
            if Length(head_units_local) <> local_chunk_syllables - 1 then
            begin
                Exit;
            end;
            for unit_idx_local := 0 to High(head_units_local) do
            begin
                if not SameText(head_units_local[unit_idx_local],
                    local_chunk_units[unit_idx_local]) then
                begin
                    Exit;
                end;
            end;
            if (head_score_local < 12000) and
                ((not head_has_anchor_local) or (head_segments_local > 2)) then
            begin
                Exit;
            end;

            overlap_start_local := local_pos + local_chunk_syllables - 1;
            overlap_max_local := Min(c_max_chunk_syllables,
                input_syllable_count - overlap_start_local);
            if overlap_max_local < 3 then
            begin
                Exit;
            end;

            for overlap_syllables_local := 3 to overlap_max_local do
            begin
                if not try_resolve_best_exact_subspan_local(overlap_start_local,
                    overlap_syllables_local, overlap_text_local,
                    overlap_score_local, overlap_segments_local,
                    overlap_path_local, overlap_has_anchor_local,
                    overlap_anchor_units_local) then
                begin
                    Continue;
                end;
                overlap_units_local := split_text_units(Trim(overlap_text_local));
                if Length(overlap_units_local) <> overlap_syllables_local then
                begin
                    Continue;
                end;
                if SameText(overlap_units_local[0],
                    local_chunk_units[High(local_chunk_units)]) then
                begin
                    Continue;
                end;
                if (overlap_score_local < 12000) and
                    (not overlap_has_anchor_local) then
                begin
                    Continue;
                end;
                Exit(c_cross_boundary_swallow_penalty +
                    overlap_syllables_local * 1200);
            end;
        end;

        function build_window_query_key_local(const local_pos: Integer;
            const local_chunk_syllables: Integer): string;
        var
            local_idx: Integer;
        begin
            Result := '';
            if (local_pos < 0) or (local_chunk_syllables <= 0) or
                (local_pos + local_chunk_syllables - 1 >
                High(effective_syllables_local)) then
            begin
                Exit;
            end;

            for local_idx := local_pos to
                local_pos + local_chunk_syllables - 1 do
            begin
                Result := Result +
                    normalize_pinyin_text(effective_syllables_local[local_idx].text);
            end;
        end;

        function is_valid_cjk_phrase_text_outer_local(const value: string;
            const expected_units: Integer): Boolean;
        var
            units: TArray<string>;
            unit_idx: Integer;
            codepoint: Integer;

            function try_get_codepoint_local(const unit_text: string;
                out out_codepoint: Integer): Boolean;
            begin
                Result := False;
                out_codepoint := 0;
                if unit_text = '' then
                begin
                    Exit;
                end;

                if Length(unit_text) = 1 then
                begin
                    out_codepoint := Ord(unit_text[1]);
                    Exit(True);
                end;

                if (Length(unit_text) = 2) and
                    (Ord(unit_text[1]) >= $D800) and
                    (Ord(unit_text[1]) <= $DBFF) and
                    (Ord(unit_text[2]) >= $DC00) and
                    (Ord(unit_text[2]) <= $DFFF) then
                begin
                    out_codepoint := ((Ord(unit_text[1]) - $D800) shl 10) +
                        (Ord(unit_text[2]) - $DC00) + $10000;
                    Exit(True);
                end;
            end;
        begin
            Result := False;
            if Trim(value) = '' then
            begin
                Exit;
            end;

            units := split_text_units(Trim(value));
            if Length(units) <> expected_units then
            begin
                Exit;
            end;

            for unit_idx := 0 to High(units) do
            begin
                if (not try_get_codepoint_local(units[unit_idx], codepoint)) or
                    (codepoint < $4E00) or (codepoint > $9FFF) then
                begin
                    Exit(False);
                end;
            end;

            Result := True;
        end;

        procedure get_window_consistency_stats_for_text_local(
            const candidate_text_local: string; out out_match_count: Integer;
            out out_mismatch_count: Integer; out out_strong_match_count: Integer;
            out out_strong_mismatch_count: Integer);
        var
            candidate_units_local: TArray<string>;
            local_start_idx: Integer;
            local_span_syllables: Integer;
            local_chunk_text: string;
            local_resolved_text: string;
            local_resolved_path: string;
            local_resolved_score: Integer;
            local_resolved_segments: Integer;
            local_resolved_anchor_units: Integer;
            local_resolved_has_anchor: Boolean;
            strong_window_local: Boolean;

            function build_text_from_units_local(const text_units: TArray<string>;
                const start_unit: Integer; const unit_count: Integer): string;
            var
                unit_idx: Integer;
            begin
                Result := '';
                if (unit_count <= 0) or (start_unit < 0) or
                    (start_unit + unit_count - 1 > High(text_units)) then
                begin
                    Exit;
                end;

                for unit_idx := start_unit to start_unit + unit_count - 1 do
                begin
                    Result := Result + text_units[unit_idx];
                end;
            end;
        begin
            out_match_count := 0;
            out_mismatch_count := 0;
            out_strong_match_count := 0;
            out_strong_mismatch_count := 0;
            candidate_units_local := split_text_units(Trim(candidate_text_local));
            if Length(candidate_units_local) <> input_syllable_count then
            begin
                Exit;
            end;

            for local_start_idx := 0 to input_syllable_count - 2 do
            begin
                for local_span_syllables := 2 to
                    Min(5, input_syllable_count - local_start_idx) do
                begin
                    if not try_resolve_best_exact_subspan_local(local_start_idx,
                        local_span_syllables, local_resolved_text,
                        local_resolved_score, local_resolved_segments,
                        local_resolved_path, local_resolved_has_anchor,
                        local_resolved_anchor_units) or
                        (local_resolved_text = '') then
                    begin
                        Continue;
                    end;

                    local_chunk_text := build_text_from_units_local(
                        candidate_units_local, local_start_idx,
                        local_span_syllables);
                    if local_chunk_text = '' then
                    begin
                        Continue;
                    end;

                    strong_window_local := (local_span_syllables >= 3) or
                        local_resolved_has_anchor or
                        (local_resolved_score >= 4096);
                    if SameText(local_chunk_text, local_resolved_text) then
                    begin
                        Inc(out_match_count);
                        if strong_window_local then
                        begin
                            Inc(out_strong_match_count);
                        end;
                    end
                    else if strong_window_local then
                    begin
                        Inc(out_mismatch_count);
                        if (local_resolved_score >= 12000) or
                            local_resolved_has_anchor or
                            (local_span_syllables >= 4) then
                        begin
                            Inc(out_strong_mismatch_count);
                        end;
                    end;
                end;
            end;
        end;

        procedure try_update_candidate_state_local(const local_pos: Integer;
            const local_chunk_syllables: Integer; const local_chunk_text: string;
            const local_chunk_score: Integer; const local_chunk_segments: Integer;
            const local_has_anchor_value: Boolean;
            const local_chunk_anchor_units: Integer;
            const local_strong_chunk_len: Integer;
            const apply_short_chunk_penalty: Boolean);
        begin
            next_pos := local_pos + local_chunk_syllables;
            if (next_pos < input_syllable_count) and
                (dp_scores[next_pos] = Low(Integer)) then
            begin
                Exit;
            end;

            total_score := local_chunk_score +
                (local_chunk_syllables * local_chunk_syllables *
                c_chunk_cover_bonus) -
                Max(0, local_chunk_segments - 1) * c_segment_penalty;
            if local_has_anchor_value or (local_chunk_syllables >= 3) then
            begin
                Inc(total_score, c_anchor_bonus);
            end;
            if (local_strong_chunk_len >= 4) and
                (local_chunk_syllables = local_strong_chunk_len) then
            begin
                Inc(total_score, c_strong_chunk_bonus);
            end;
            if apply_short_chunk_penalty then
            begin
                Dec(total_score, c_short_chunk_under_strong_penalty);
            end;
            Dec(total_score, get_cross_boundary_swallow_penalty_local(local_pos,
                local_chunk_syllables, local_chunk_text));
            total_segments := local_chunk_segments;
            total_has_anchor := local_has_anchor_value;
            total_anchor_units := local_chunk_anchor_units;
            if total_anchor_units < 0 then
            begin
                total_anchor_units := 0;
            end;
            combined_text := Trim(local_chunk_text);
            combined_path := combined_text;

            if next_pos < input_syllable_count then
            begin
                Inc(total_score, dp_scores[next_pos]);
                Inc(total_segments, dp_segments[next_pos]);
                if dp_has_anchor[next_pos] then
                begin
                    total_has_anchor := True;
                    if dp_anchor_units[next_pos] > total_anchor_units then
                    begin
                        total_anchor_units := dp_anchor_units[next_pos];
                    end;
                end;
                combined_text := combined_text + dp_texts[next_pos];
                if (combined_path <> '') and (dp_paths[next_pos] <> '') then
                begin
                    combined_path := combined_path + c_segment_path_separator +
                        dp_paths[next_pos];
                end
                else if dp_paths[next_pos] <> '' then
                begin
                    combined_path := dp_paths[next_pos];
                end;
            end;

            better_candidate := False;
            if total_score > dp_scores[local_pos] then
            begin
                better_candidate := True;
            end
            else if total_score = dp_scores[local_pos] then
            begin
                if total_has_anchor and (not dp_has_anchor[local_pos]) then
                begin
                    better_candidate := True;
                end
                else if total_has_anchor = dp_has_anchor[local_pos] then
                begin
                    if total_anchor_units > dp_anchor_units[local_pos] then
                    begin
                        better_candidate := True;
                    end
                    else if total_anchor_units = dp_anchor_units[local_pos] then
                    begin
                        if total_segments < dp_segments[local_pos] then
                        begin
                            better_candidate := True;
                        end
                        else if (total_segments = dp_segments[local_pos]) and
                            ((dp_texts[local_pos] = '') or
                            (CompareText(combined_text, dp_texts[local_pos]) < 0)) then
                        begin
                            better_candidate := True;
                        end;
                    end;
                end;
            end;

            if better_candidate then
            begin
                dp_scores[local_pos] := total_score;
                dp_segments[local_pos] := total_segments;
                dp_anchor_units[local_pos] := total_anchor_units;
                dp_has_anchor[local_pos] := total_has_anchor;
                dp_texts[local_pos] := combined_text;
                dp_paths[local_pos] := combined_path;
            end;
        end;

        procedure try_update_short_exact_variants_local(const local_pos: Integer;
            const local_chunk_syllables: Integer;
            const local_strong_chunk_len: Integer;
            const skip_text: string);
        var
            query_key_local: string;
            lookup_results_local: TncCandidateList;
            exact_only_results_local: TncCandidateList;
            exact_results_local: TncCandidateList;
            result_idx_local: Integer;
            merged_idx_local: Integer;
            duplicate_found_local: Boolean;
            candidate_text_local: string;
            candidate_units_local: Integer;
            candidate_weight_local: Integer;
            exact_bonus_local: Integer;
            probe_limit_local: Integer;
        begin
            if (local_chunk_syllables <= 0) or (local_chunk_syllables > 2) or
                (m_dictionary = nil) then
            begin
                Exit;
            end;

            query_key_local := build_window_query_key_local(local_pos,
                local_chunk_syllables);
            if query_key_local = '' then
            begin
                Exit;
            end;

            SetLength(exact_results_local, 0);
            if m_dictionary.lookup(query_key_local, lookup_results_local) then
            begin
                SetLength(exact_results_local, Length(lookup_results_local));
                for merged_idx_local := 0 to High(lookup_results_local) do
                begin
                    exact_results_local[merged_idx_local] :=
                        lookup_results_local[merged_idx_local];
                end;
            end;

            if m_dictionary.lookup_exact_full_pinyin(query_key_local,
                exact_only_results_local) then
            begin
                for result_idx_local := 0 to High(exact_only_results_local) do
                begin
                    duplicate_found_local := False;
                    for merged_idx_local := 0 to High(exact_results_local) do
                    begin
                        if SameText(Trim(exact_results_local[merged_idx_local].text),
                            Trim(exact_only_results_local[result_idx_local].text)) and
                            SameText(Trim(exact_results_local[merged_idx_local].comment),
                            Trim(exact_only_results_local[result_idx_local].comment)) then
                        begin
                            duplicate_found_local := True;
                            Break;
                        end;
                    end;
                    if duplicate_found_local then
                    begin
                        Continue;
                    end;
                    SetLength(exact_results_local, Length(exact_results_local) + 1);
                    exact_results_local[High(exact_results_local)] :=
                        exact_only_results_local[result_idx_local];
                end;
            end;

            if Length(exact_results_local) = 0 then
            begin
                Exit;
            end;

            probe_limit_local := Min(c_short_exact_variant_limit,
                Length(exact_results_local));
            for result_idx_local := 0 to probe_limit_local - 1 do
            begin
                if Trim(exact_results_local[result_idx_local].comment) <> '' then
                begin
                    Continue;
                end;
                if is_runtime_chain_candidate(exact_results_local[result_idx_local]) or
                    is_runtime_common_pattern_candidate(exact_results_local[result_idx_local]) or
                    is_runtime_redup_candidate(exact_results_local[result_idx_local]) then
                begin
                    Continue;
                end;

                candidate_text_local := Trim(exact_results_local[result_idx_local].text);
                if SameText(candidate_text_local, Trim(skip_text)) then
                begin
                    Continue;
                end;
                candidate_units_local := get_candidate_text_unit_count(
                    candidate_text_local);
                if candidate_units_local <> local_chunk_syllables then
                begin
                    Continue;
                end;
                if not is_valid_cjk_phrase_text_outer_local(candidate_text_local,
                    local_chunk_syllables) then
                begin
                    Continue;
                end;

                candidate_weight_local := exact_results_local[result_idx_local].score;
                if exact_results_local[result_idx_local].has_dict_weight and
                    (exact_results_local[result_idx_local].dict_weight >
                    candidate_weight_local) then
                begin
                    candidate_weight_local :=
                        exact_results_local[result_idx_local].dict_weight;
                end;
                Inc(candidate_weight_local,
                    (probe_limit_local - result_idx_local) * 240);
                Inc(candidate_weight_local, get_preferred_query_phrase_bonus_local(
                    query_key_local, candidate_text_local));
                exact_bonus_local := get_preferred_exact_subspan_bonus_local(
                    query_key_local, candidate_text_local);
                Inc(candidate_weight_local, exact_bonus_local);

                try_update_candidate_state_local(local_pos, local_chunk_syllables,
                    candidate_text_local, candidate_weight_local, 1, False, 0,
                    local_strong_chunk_len,
                    (local_strong_chunk_len >= 4) and
                    (local_chunk_syllables < 3));
            end;
        end;
    begin
        if (Length(candidates) = 0) or (m_dictionary = nil) or
            (not is_full_pinyin_key(lookup_text)) or
            (input_syllable_count < c_min_query_syllables) then
        begin
            Exit;
        end;

        top_text := Trim(candidates[0].text);
        if (Trim(candidates[0].comment) = '') and
            (get_candidate_text_unit_count(top_text) = input_syllable_count) then
        begin
            top_support_path_local := infer_segment_path_for_query_text_with_score(
                lookup_text, top_text, top_support_local,
                top_support_segments_local);
            if top_support_path_local <> '' then
            begin
                get_window_consistency_stats_for_text_local(top_text,
                    top_exact_match_count_local,
                    top_exact_mismatch_count_local,
                    top_exact_strong_match_count_local,
                    top_exact_strong_mismatch_count_local);
                if (top_exact_strong_mismatch_count_local = 0) and
                    ((top_exact_strong_match_count_local >= 2) or
                    ((top_exact_strong_match_count_local >= 1) and
                    (top_exact_mismatch_count_local = 0))) then
                begin
                    Exit;
                end;
            end;
        end;

        effective_syllables_local := get_effective_compact_pinyin_syllables(
            lookup_text);
        if Length(effective_syllables_local) <> input_syllable_count then
        begin
            Exit;
        end;

        SetLength(dp_scores, input_syllable_count + 1);
        SetLength(dp_segments, input_syllable_count + 1);
        SetLength(dp_anchor_units, input_syllable_count + 1);
        SetLength(dp_has_anchor, input_syllable_count + 1);
        SetLength(dp_texts, input_syllable_count + 1);
        SetLength(dp_paths, input_syllable_count + 1);
        for pos := 0 to input_syllable_count do
        begin
            dp_scores[pos] := Low(Integer);
            dp_segments[pos] := MaxInt;
            dp_anchor_units[pos] := -1;
            dp_has_anchor[pos] := False;
            dp_texts[pos] := '';
            dp_paths[pos] := '';
        end;
        dp_scores[input_syllable_count] := 0;
        dp_segments[input_syllable_count] := 0;
        dp_anchor_units[input_syllable_count] := -1;

        for pos := input_syllable_count - 1 downto 0 do
        begin
            max_chunk_local := Min(c_max_chunk_syllables,
                input_syllable_count - pos);
            strong_chunk_len_local := 0;
            for chunk_syllables := 1 to max_chunk_local do
            begin
                pre_ok_local[chunk_syllables] :=
                    try_resolve_best_exact_subspan_local(pos, chunk_syllables,
                    pre_text_local[chunk_syllables],
                    pre_score_local[chunk_syllables],
                    pre_segments_local[chunk_syllables],
                    pre_path_local[chunk_syllables],
                    pre_has_anchor_local[chunk_syllables],
                    pre_anchor_units_local[chunk_syllables]);
                if (not pre_ok_local[chunk_syllables]) or
                    (Trim(pre_text_local[chunk_syllables]) = '') or
                    (get_candidate_text_unit_count(
                    Trim(pre_text_local[chunk_syllables])) <> chunk_syllables) then
                begin
                    pre_ok_local[chunk_syllables] := False;
                    Continue;
                end;
                if chunk_syllables >= 4 then
                begin
                    strong_chunk_len_local := Max(strong_chunk_len_local,
                        chunk_syllables);
                end;
            end;

            for chunk_syllables := 1 to max_chunk_local do
            begin
                if not pre_ok_local[chunk_syllables] then
                begin
                    Continue;
                end;
                chunk_text := pre_text_local[chunk_syllables];
                chunk_score := pre_score_local[chunk_syllables];
                chunk_segments := pre_segments_local[chunk_syllables];
                chunk_path := pre_path_local[chunk_syllables];
                local_has_anchor := pre_has_anchor_local[chunk_syllables];
                chunk_anchor_units := pre_anchor_units_local[chunk_syllables];

                try_update_candidate_state_local(pos, chunk_syllables,
                    chunk_text, chunk_score, chunk_segments, local_has_anchor,
                    chunk_anchor_units, strong_chunk_len_local,
                    (strong_chunk_len_local >= 4) and
                    (chunk_syllables < 3));
            end;
        end;

        best_text_local := Trim(dp_texts[0]);
        best_score_local := dp_scores[0];
        if m_config.debug_mode and (best_text_local <> '') then
        begin
            m_last_full_path_debug_info := m_last_full_path_debug_info +
                Format(' ldptry=[text=%s seg=%d score=%d]',
                [best_text_local, dp_segments[0], best_score_local]);
        end;
        if (best_score_local = Low(Integer)) or (best_text_local = '') or
            (get_candidate_text_unit_count(best_text_local) <> input_syllable_count) then
        begin
            Exit;
        end;

        oracle_top_text := '';
        oracle_existing_index := -1;
        ensure_strict_oracle_sentence_candidates_prepared;
        if strict_oracle_sentence_ok and
            (Length(strict_oracle_sentence_candidates) > 0) then
        begin
            for oracle_idx := 0 to Min(3,
                High(strict_oracle_sentence_candidates)) do
            begin
                if Trim(strict_oracle_sentence_candidates[oracle_idx].comment) <> '' then
                begin
                    Continue;
                end;
                if get_candidate_text_unit_count(
                    Trim(strict_oracle_sentence_candidates[oracle_idx].text)) <>
                    input_syllable_count then
                begin
                    Continue;
                end;
                oracle_top_text := Trim(
                    strict_oracle_sentence_candidates[oracle_idx].text);
                Break;
            end;
        end;
        if oracle_top_text <> '' then
        begin
            for idx := 0 to High(candidates) do
            begin
                if (Trim(candidates[idx].comment) = '') and
                    SameText(Trim(candidates[idx].text), oracle_top_text) then
                begin
                    oracle_existing_index := idx;
                    Break;
                end;
            end;
        end;

        top_text := Trim(candidates[0].text);
        if SameText(top_text, best_text_local) then
        begin
            Exit;
        end;

        best_support_path_local := infer_segment_path_for_query_text_with_score(
            lookup_text, best_text_local, best_support_local,
            best_support_segments_local);

        if (Trim(candidates[0].comment) = '') and
            (get_candidate_text_unit_count(top_text) = input_syllable_count) then
        begin
            top_support_path_local := infer_segment_path_for_query_text_with_score(
                lookup_text, top_text, top_support_local,
                top_support_segments_local);
        end;

        existing_index := -1;
        FillChar(picked_candidate, SizeOf(picked_candidate), 0);
        for idx := 0 to High(candidates) do
        begin
            if (Trim(candidates[idx].comment) = '') and
                SameText(Trim(candidates[idx].text), best_text_local) then
            begin
                existing_index := idx;
                picked_candidate := candidates[idx];
                Break;
            end;
        end;

        if existing_index < 0 then
        begin
            picked_candidate.text := best_text_local;
            picked_candidate.comment := '';
            picked_candidate.score := Max(best_score_local, 4096);
            picked_candidate.source := cs_rule;
            picked_candidate.has_dict_weight := True;
            picked_candidate.dict_weight := picked_candidate.score;
            existing_index := Length(candidates);
            SetLength(candidates, existing_index + 1);
        end
        else if picked_candidate.score < best_score_local then
        begin
            picked_candidate.score := best_score_local;
        end;

        for idx := existing_index downto 1 do
        begin
            candidates[idx] := candidates[idx - 1];
        end;
        candidates[0] := picked_candidate;
        remember_segment_path_for_candidate(best_text_local, '', dp_paths[0],
            Max(candidates[0].dict_weight, best_score_local));
        if m_config.debug_mode then
        begin
            m_last_full_path_debug_info := m_last_full_path_debug_info +
                Format(' ldp=[text=%s seg=%d score=%d sup=%d path=%s]',
                [best_text_local, dp_segments[0], best_score_local,
                best_support_local, best_support_path_local]);
        end;
    end;

    procedure ensure_best_exact_tail_complete_candidate_visible(
        var candidates: TncCandidateList);
    const
        c_tail_probe_limit = 8;
    var
        effective_syllables: TncPinyinParseResult;
        tail_syllables: Integer;
        tail_key: string;
        candidate_text: string;
        candidate_units: Integer;
        weight_value: Integer;
        best_tail_text: string;
        best_tail_score: Integer;
        idx: Integer;
        picked: TncCandidate;
        head_syllable_count: Integer;
        head_key: string;
        head_results: TncCandidateList;
        head_text: string;
        head_score: Integer;
        combined_text: string;
        existing_index: Integer;

        function ends_with_text_local(const full_value: string;
            const suffix_value: string): Boolean;
        begin
            Result := (full_value <> '') and (suffix_value <> '') and
                (Length(suffix_value) <= Length(full_value)) and
                SameText(Copy(full_value,
                Length(full_value) - Length(suffix_value) + 1, Length(suffix_value)),
                suffix_value);
        end;

        function build_tail_query_key_local(const tail_syllable_count: Integer): string;
        var
            local_idx: Integer;
        begin
            Result := '';
            if (tail_syllable_count <= 0) or
                (tail_syllable_count > Length(effective_syllables)) then
            begin
                Exit;
            end;

            for local_idx := Length(effective_syllables) - tail_syllable_count
                to High(effective_syllables) do
            begin
                Result := Result +
                    normalize_pinyin_text(effective_syllables[local_idx].text);
            end;
        end;

        function build_head_query_key_local(const head_syllable_count_local: Integer): string;
        var
            local_idx: Integer;
        begin
            Result := '';
            if (head_syllable_count_local <= 0) or
                (head_syllable_count_local > Length(effective_syllables)) then
            begin
                Exit;
            end;

            for local_idx := 0 to head_syllable_count_local - 1 do
            begin
                Result := Result +
                    normalize_pinyin_text(effective_syllables[local_idx].text);
            end;
        end;

        function try_get_best_exact_tail_text_local(
            const tail_syllable_count: Integer; out out_text: string;
            out out_score: Integer): Boolean;
        var
            local_results: TncCandidateList;
            local_result_idx: Integer;
            preferred_text: string;
            preferred_bonus: Integer;
            preferred_units: TArray<string>;
            preferred_start_idx: Integer;
            preferred_unit_idx: Integer;
            preferred_is_preferred: Boolean;
            preferred_match_ok: Boolean;
            resolved_text_local: string;
            resolved_path_local: string;
            resolved_score_local: Integer;
            resolved_segments_local: Integer;
            resolved_anchor_units_local: Integer;
            resolved_has_anchor_local: Boolean;
        begin
            Result := False;
            out_text := '';
            out_score := Low(Integer);

            if (tail_syllable_count >= 2) and (tail_syllable_count <= 5) and
                try_resolve_best_exact_subspan_local(
                input_syllable_count - tail_syllable_count, tail_syllable_count,
                resolved_text_local, resolved_score_local,
                resolved_segments_local, resolved_path_local,
                resolved_has_anchor_local, resolved_anchor_units_local) then
            begin
                out_text := resolved_text_local;
                out_score := resolved_score_local;
                Exit(True);
            end;

            tail_key := build_tail_query_key_local(tail_syllable_count);
            if (tail_key = '') or (m_dictionary = nil) or
                (not m_dictionary.lookup(tail_key, local_results)) then
            begin
                Exit;
            end;

            for local_result_idx := 0 to High(local_results) do
            begin
                if local_result_idx >= c_tail_probe_limit then
                begin
                    Break;
                end;
                if Trim(local_results[local_result_idx].comment) <> '' then
                begin
                    Continue;
                end;
                if is_runtime_chain_candidate(local_results[local_result_idx]) or
                    is_runtime_common_pattern_candidate(local_results[local_result_idx]) or
                    is_runtime_redup_candidate(local_results[local_result_idx]) then
                begin
                    Continue;
                end;

                candidate_text := Trim(local_results[local_result_idx].text);
                candidate_units := get_candidate_text_unit_count(candidate_text);
                if candidate_units <> tail_syllable_count then
                begin
                    Continue;
                end;

                weight_value := local_results[local_result_idx].score;
                if (weight_value <= 0) and local_results[local_result_idx].has_dict_weight then
                begin
                    weight_value := local_results[local_result_idx].dict_weight;
                end;
                Inc(weight_value, get_preferred_query_phrase_bonus_local(
                    tail_key, candidate_text));

                if weight_value > out_score then
                begin
                    out_score := weight_value;
                    out_text := candidate_text;
                    Result := True;
                end;
            end;

            if try_get_preferred_query_phrase_text_local(tail_key, preferred_text,
                preferred_bonus) then
            begin
                preferred_units := split_text_units(preferred_text);
                if Length(preferred_units) = tail_syllable_count then
                begin
                    preferred_start_idx := Length(effective_syllables) - tail_syllable_count;
                    preferred_match_ok := True;
                    for preferred_unit_idx := 0 to High(preferred_units) do
                    begin
                        if not match_single_char_candidate_for_syllable(
                            effective_syllables[preferred_start_idx + preferred_unit_idx].text,
                            preferred_units[preferred_unit_idx], preferred_is_preferred) then
                        begin
                            preferred_match_ok := False;
                            Break;
                        end;
                    end;

                    if preferred_match_ok and (preferred_bonus > out_score) then
                    begin
                        out_score := preferred_bonus;
                        out_text := preferred_text;
                        Result := True;
                    end;
                end;
            end;
        end;

        function try_get_best_head_complete_text_local(
            const head_syllable_count_local: Integer; out out_text: string;
            out out_score: Integer): Boolean;
        var
            local_head_idx: Integer;
            fixed_text: string;
            fixed_score: Integer;
            resolved_text_local: string;
            resolved_path_local: string;
            resolved_score_local: Integer;
            resolved_segments_local: Integer;
            resolved_anchor_units_local: Integer;
            resolved_has_anchor_local: Boolean;

            function get_fixed_single_char_for_head_local(
                const query_key_local: string): string;
            begin
                Result := '';
                if query_key_local = 'de' then
                begin
                    Result := string(Char($7684));
                end
                else if query_key_local = 'yu' then
                begin
                    Result := string(Char($4E8E));
                end
                else if query_key_local = 'zai' then
                begin
                    Result := string(Char($5728));
                end
                else if query_key_local = 'shi' then
                begin
                    Result := string(Char($662F));
                end
                else if query_key_local = 'ba' then
                begin
                    Result := string(Char($628A));
                end;
            end;
        begin
            Result := False;
            out_text := '';
            out_score := Low(Integer);

            if (head_syllable_count_local >= 2) and
                (head_syllable_count_local <= 5) and
                try_resolve_best_exact_subspan_local(0,
                head_syllable_count_local, resolved_text_local,
                resolved_score_local, resolved_segments_local,
                resolved_path_local, resolved_has_anchor_local,
                resolved_anchor_units_local) then
            begin
                out_text := resolved_text_local;
                out_score := resolved_score_local;
                Exit(True);
            end;

            head_key := build_head_query_key_local(head_syllable_count_local);
            if (head_syllable_count_local = 1) and (head_key <> '') then
            begin
                fixed_text := get_fixed_single_char_for_head_local(head_key);
                if fixed_text <> '' then
                begin
                    fixed_score := 520 +
                        get_preferred_query_phrase_bonus_local(head_key, fixed_text);
                    out_text := fixed_text;
                    out_score := fixed_score;
                    Result := True;
                end;
            end;

            if (head_key <> '') and (m_dictionary <> nil) and
                m_dictionary.lookup(head_key, head_results) then
            begin
                for local_head_idx := 0 to High(head_results) do
                begin
                    if local_head_idx >= c_tail_probe_limit then
                    begin
                        Break;
                    end;
                    if Trim(head_results[local_head_idx].comment) <> '' then
                    begin
                        Continue;
                    end;

                    candidate_text := Trim(head_results[local_head_idx].text);
                    candidate_units := get_candidate_text_unit_count(candidate_text);
                    if candidate_units <> head_syllable_count_local then
                    begin
                        Continue;
                    end;

                    weight_value := head_results[local_head_idx].score;
                    if (weight_value <= 0) and head_results[local_head_idx].has_dict_weight then
                    begin
                        weight_value := head_results[local_head_idx].dict_weight;
                    end;
                    Inc(weight_value, get_preferred_query_phrase_bonus_local(
                        head_key, candidate_text));
                    if weight_value > out_score then
                    begin
                        out_score := weight_value;
                        out_text := candidate_text;
                        Result := True;
                    end;
                end;
            end;

            if Result then
            begin
                Exit;
            end;

            for local_head_idx := 0 to High(candidates) do
            begin
                if Trim(candidates[local_head_idx].comment) <> '' then
                begin
                    if not SameText(normalize_pinyin_text(
                        Trim(candidates[local_head_idx].comment)), tail_key) then
                    begin
                        Continue;
                    end;
                end;

                candidate_text := Trim(candidates[local_head_idx].text);
                candidate_units := get_candidate_text_unit_count(candidate_text);
                if candidate_units <> head_syllable_count_local then
                begin
                    Continue;
                end;

                weight_value := candidates[local_head_idx].score +
                    get_preferred_query_phrase_bonus_local(head_key, candidate_text);
                if weight_value > out_score then
                begin
                    out_score := weight_value;
                    out_text := candidate_text;
                    Result := True;
                end;
            end;
        end;

        function try_get_best_visible_complete_candidate_with_tail_local(
            const tail_text_local: string; out out_index: Integer): Boolean;
        var
            local_idx: Integer;
            local_score: Integer;
            local_best_score: Integer;
            local_units: Integer;
        begin
            Result := False;
            out_index := -1;
            local_best_score := Low(Integer);
            if tail_text_local = '' then
            begin
                Exit;
            end;

            for local_idx := 0 to High(candidates) do
            begin
                if Trim(candidates[local_idx].comment) <> '' then
                begin
                    Continue;
                end;

                local_units := get_candidate_text_unit_count(Trim(candidates[local_idx].text));
                if local_units <> input_syllable_count then
                begin
                    Continue;
                end;
                if not ends_with_text_local(Trim(candidates[local_idx].text), tail_text_local) then
                begin
                    Continue;
                end;

                local_score := candidates[local_idx].score;
                if (local_score > local_best_score) or
                    ((local_score = local_best_score) and (out_index < 0)) then
                begin
                    out_index := local_idx;
                    local_best_score := local_score;
                    Result := True;
                end;
            end;
        end;
    begin
        if (Length(candidates) <= 1) or
            (input_syllable_count < c_long_sentence_exact_min_syllables) or
            (not is_full_pinyin_key(lookup_text)) then
        begin
            Exit;
        end;

        effective_syllables := get_effective_compact_pinyin_syllables(
            normalize_pinyin_text(lookup_text));
        if Length(effective_syllables) <> input_syllable_count then
        begin
            Exit;
        end;

        for tail_syllables := Min(4, input_syllable_count - 1) downto 1 do
        begin
            if not try_get_best_exact_tail_text_local(
                tail_syllables, best_tail_text, best_tail_score) then
            begin
                Continue;
            end;

            head_syllable_count := input_syllable_count - tail_syllables;
            if not try_get_best_head_complete_text_local(
                head_syllable_count, head_text, head_score) then
            begin
                if try_get_best_visible_complete_candidate_with_tail_local(
                    best_tail_text, existing_index) then
                begin
                    if existing_index = 0 then
                    begin
                        Exit;
                    end;

                    picked := candidates[existing_index];
                    for idx := existing_index downto 1 do
                    begin
                        candidates[idx] := candidates[idx - 1];
                    end;
                    candidates[0] := picked;
                    Exit;
                end;
                Continue;
            end;

            combined_text := head_text + best_tail_text;
            existing_index := -1;
            for idx := 0 to High(candidates) do
            begin
                if (Trim(candidates[idx].comment) = '') and
                    SameText(Trim(candidates[idx].text), combined_text) then
                begin
                    existing_index := idx;
                    Break;
                end;
            end;

            if existing_index = 0 then
            begin
                Exit;
            end;

            if existing_index > 0 then
            begin
                picked := candidates[existing_index];
                for idx := existing_index downto 1 do
                begin
                    candidates[idx] := candidates[idx - 1];
                end;
                candidates[0] := picked;
                Exit;
            end;

            picked.text := combined_text;
            picked.comment := '';
            picked.score := head_score + best_tail_score + 960;
            picked.source := cs_rule;
            picked.has_dict_weight := False;
            picked.dict_weight := 0;
            remember_segment_path_for_candidate(picked.text, '', head_text +
                c_segment_path_separator + best_tail_text, picked.score);

            SetLength(candidates, Length(candidates) + 1);
            for idx := High(candidates) downto 1 do
            begin
                candidates[idx] := candidates[idx - 1];
            end;
            candidates[0] := picked;
            Exit;
        end;
    end;

    procedure ensure_best_short_exact_prefix_tail_candidate_visible(
        var candidates: TncCandidateList);
    const
        c_probe_limit = 8;
        c_prefix_tail_bonus = 4096;
        c_quantity_tail_bonus = 4200;
        c_fixed_tail_bonus = 2600;
        c_exact_tail_span_bonus = 16384;
        c_weak_direct_exact_split_weight = 300;
    var
        syllables_local: TncPinyinParseResult;
        syllable_count_local: Integer;
        tail_len: Integer;
        head_len: Integer;
        best_text: string;
        best_path: string;
        best_score: Integer;
        best_reliable: Boolean;
        head_text: string;
        head_score: Integer;
        head_reliable: Boolean;
        tail_text: string;
        tail_score: Integer;
        tail_reliable: Boolean;
        combined_text: string;
        combined_score: Integer;
