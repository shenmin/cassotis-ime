    function has_extendable_same_syllable_tail_local(const pinyin_key: string;
        const expected_syllable_count: Integer): Boolean;
    var
        suffix_ch: Char;
        extended_key: string;
    begin
        Result := False;
        if (pinyin_key = '') or (expected_syllable_count < 4) then
        begin
            Exit;
        end;

        for suffix_ch := 'a' to 'z' do
        begin
            extended_key := pinyin_key + suffix_ch;
            if get_effective_compact_pinyin_unit_count(extended_key) =
                expected_syllable_count then
            begin
                Exit(True);
            end;
        end;
