        function get_lightweight_sentence_path_adjustment(const candidate: TncCandidate;
            const text_units: Integer): Integer;
        var
            encoded_path: string;
            segment_parts: TArray<string>;
            segment_idx: Integer;
            syllable_idx: Integer;
            segment_text: string;
            next_segment_text: string;
            segment_units: Integer;
            next_segment_units: Integer;
            fixed_left: string;
            fixed_right: string;
            fixed_third: string;
            combined_text: string;
            exact_two_text: string;
            exact_two_weight: Integer;
            exact_three_text: string;
            exact_three_weight: Integer;
        begin
            Result := 0;
            if (candidate.comment <> '') or candidate.has_dict_weight or
                (candidate.source = cs_user) or (text_units < 2) then
            begin
                Exit;
            end;

            prepare_lightweight_query_cache;
            if Length(lightweight_query_syllables) <> input_syllable_count then
            begin
                Exit;
            end;

            encoded_path := get_segment_path_for_candidate(candidate);
            if get_encoded_path_segment_count_local(encoded_path) <= 1 then
            begin
                Exit;
            end;

            segment_parts := encoded_path.Split([c_segment_path_separator]);
            syllable_idx := 0;
            for segment_idx := 0 to High(segment_parts) do
            begin
                segment_text := Trim(segment_parts[segment_idx]);
                segment_units := get_candidate_text_unit_count(segment_text);
                if (segment_units = 2) and (syllable_idx + 1 <= High(lightweight_query_syllables)) then
                begin
                    exact_two_text := '';
                    exact_two_weight := 0;
                    if try_get_best_exact_two_syllable_text_local(
                        syllable_idx, exact_two_text, exact_two_weight) then
                    begin
                        if segment_text = exact_two_text then
                        begin
                            Inc(Result, 720);
                        end
                        else if SameText(segment_text,
                            get_fixed_sentence_single_char_local(
                            lightweight_query_syllables[syllable_idx].text) +
                            get_fixed_sentence_single_char_local(
                            lightweight_query_syllables[syllable_idx + 1].text)) then
                        begin
                            Dec(Result, 1600);
                        end;
                    end;

                    fixed_left := get_fixed_sentence_single_char_local(
                        lightweight_query_syllables[syllable_idx].text);
                    fixed_right := get_fixed_sentence_single_char_local(
                        lightweight_query_syllables[syllable_idx + 1].text);
                    if (fixed_left <> '') and (fixed_right <> '') and
                        SameText(segment_text, fixed_left + fixed_right) and
                        (exact_two_text <> '') and
                        (not SameText(segment_text, exact_two_text)) then
                    begin
                        Dec(Result, 1600);
                    end;

                    if (segment_idx < High(segment_parts)) and
                        (syllable_idx + 2 <= High(lightweight_query_syllables)) then
                    begin
                        next_segment_text := Trim(segment_parts[segment_idx + 1]);
                        next_segment_units := get_candidate_text_unit_count(next_segment_text);
                        if next_segment_units >= 1 then
                        begin
                            combined_text := segment_text + split_text_units(next_segment_text)[0];
                            fixed_third := get_fixed_sentence_single_char_local(
                                lightweight_query_syllables[syllable_idx + 2].text);
                            exact_three_text := '';
                            exact_three_weight := 0;
                            if try_get_best_exact_three_syllable_text_local(
                                syllable_idx, exact_three_text, exact_three_weight) then
                            begin
                                if combined_text = exact_three_text then
                                begin
                                    Inc(Result, 520);
                                end
                                else if (fixed_left <> '') and (fixed_right <> '') and
                                    (fixed_third <> '') and
                                    SameText(combined_text,
                                    fixed_left + fixed_right + fixed_third) then
                                begin
                                    Dec(Result, 880);
                                end;
                            end;
                        end;
                    end;
                end;
                Inc(syllable_idx, segment_units);
            end;
        end;

        function get_long_dict_prefix_partial_adjustment(const candidate: TncCandidate;
            const text_units: Integer): Integer;
        var
            remaining_syllables: Integer;
            next_syllable_key: string;
        begin
            Result := 0;
            if (candidate.comment = '') or (not candidate.has_dict_weight) or
                (candidate.source = cs_user) or (text_units < 4) or
                (input_syllable_count < 6) then
            begin
                Exit;
            end;

            prepare_lightweight_query_cache;
            if Length(lightweight_query_syllables) <> input_syllable_count then
            begin
                Exit;
            end;

            remaining_syllables := input_syllable_count - text_units;
            if remaining_syllables <= 0 then
            begin
                Exit;
            end;

            Result := 5600 + (text_units * 520) -
                (remaining_syllables * 80) +
                Min(1600, candidate.dict_weight div 2);

            if text_units <= High(lightweight_query_syllables) then
            begin
                next_syllable_key := normalize_pinyin_text(
                    lightweight_query_syllables[text_units].text);
                if get_fixed_sentence_single_char_local(next_syllable_key) <> '' then
                begin
                    Inc(Result, 2200);
                end;
            end;

            if has_exact_complete_phrase_candidate then
            begin
                Result := Result div 3;
            end;
        end;

        function get_suspicious_swallowed_fixed_boundary_penalty(
            const candidate: TncCandidate; const text_units: Integer): Integer;
        var
            encoded_path: string;
            segment_parts: TArray<string>;
            segment_idx: Integer;
            syllable_idx: Integer;
            segment_text: string;
            segment_units: Integer;
            fixed_left: string;
            fixed_right: string;
            exact_two_text: string;
            exact_three_text: string;
            exact_two_weight: Integer;
            exact_three_weight: Integer;
            follow_two_text: string;
            follow_three_text: string;
            follow_two_weight: Integer;
            follow_three_weight: Integer;
            has_preceding_phrase: Boolean;
            has_following_phrase: Boolean;
        begin
            Result := 0;
            if candidate.has_dict_weight or (candidate.source = cs_user) or
                (text_units < 2) then
            begin
                Exit;
            end;

            prepare_lightweight_query_cache;
            if Length(lightweight_query_syllables) <> input_syllable_count then
            begin
                Exit;
            end;

            encoded_path := get_segment_path_for_candidate(candidate);
            if get_encoded_path_segment_count_local(encoded_path) <= 1 then
            begin
                Exit;
            end;

            segment_parts := encoded_path.Split([c_segment_path_separator]);
            syllable_idx := 0;
            for segment_idx := 0 to High(segment_parts) do
            begin
                segment_text := Trim(segment_parts[segment_idx]);
                segment_units := get_candidate_text_unit_count(segment_text);
                if (segment_units = 2) and
                    (syllable_idx + 1 <= High(lightweight_query_syllables)) then
                begin
                    fixed_left := get_fixed_sentence_single_char_local(
                        lightweight_query_syllables[syllable_idx].text);
                    fixed_right := get_fixed_sentence_single_char_local(
                        lightweight_query_syllables[syllable_idx + 1].text);

                    has_preceding_phrase := False;
                    exact_two_text := '';
                    exact_two_weight := 0;
                    if (syllable_idx >= 1) and
                        try_get_best_exact_two_syllable_text_local(
                        syllable_idx - 1, exact_two_text, exact_two_weight) then
                    begin
                        has_preceding_phrase := True;
                    end;
                    exact_three_text := '';
                    exact_three_weight := 0;
                    if (syllable_idx >= 2) and
                        try_get_best_exact_three_syllable_text_local(
                        syllable_idx - 2, exact_three_text, exact_three_weight) then
                    begin
                        has_preceding_phrase := True;
                    end;

                    has_following_phrase := False;
                    follow_two_text := '';
                    follow_two_weight := 0;
                    if (syllable_idx + 2 <= High(lightweight_query_syllables)) and
                        try_get_best_exact_two_syllable_text_local(
                        syllable_idx + 1, follow_two_text, follow_two_weight) then
                    begin
                        has_following_phrase := True;
                    end;
                    follow_three_text := '';
                    follow_three_weight := 0;
                    if (syllable_idx + 3 <= High(lightweight_query_syllables)) and
                        try_get_best_exact_three_syllable_text_local(
                        syllable_idx + 1, follow_three_text, follow_three_weight) then
                    begin
                        has_following_phrase := True;
                    end;

                    if (fixed_left <> '') and has_following_phrase then
                    begin
                        Inc(Result, 2400);
                    end;
                    if (fixed_right <> '') and has_preceding_phrase and
                        ((syllable_idx + 2 > High(lightweight_query_syllables)) or
                        has_following_phrase) then
                    begin
                        Inc(Result, 2400);
                    end;
                end;
                Inc(syllable_idx, segment_units);
            end;
        end;

        function get_complete_sentence_modal_tail_adjustment(
            const candidate: TncCandidate; const text_units: Integer): Integer;
        var
            encoded_path: string;
            segment_parts: TArray<string>;
            last_segment_text: string;
            expected_text: string;
            last_syllable_key: string;
        begin
            Result := 0;
            if (candidate.comment <> '') or (text_units < 4) then
            begin
                Exit;
            end;

            prepare_lightweight_query_cache;
            if Length(lightweight_query_syllables) <> input_syllable_count then
            begin
                Exit;
            end;

            encoded_path := get_segment_path_for_candidate(candidate);
            if get_encoded_path_segment_count_local(encoded_path) <= 1 then
            begin
                Exit;
            end;

            segment_parts := encoded_path.Split([c_segment_path_separator]);
            if Length(segment_parts) <= 1 then
            begin
                Exit;
            end;

            last_segment_text := Trim(segment_parts[High(segment_parts)]);
            if get_candidate_text_unit_count(last_segment_text) <> 1 then
            begin
                Exit;
            end;

            last_syllable_key := normalize_pinyin_text(
                lightweight_query_syllables[High(lightweight_query_syllables)].text);
            expected_text := '';
            if last_syllable_key = 'ba' then
            begin
                expected_text := string(Char($5427));
            end
            else if last_syllable_key = 'ma' then
            begin
                expected_text := string(Char($5417));
            end
            else if last_syllable_key = 'ne' then
            begin
                expected_text := string(Char($5462));
            end
            else if last_syllable_key = 'a' then
            begin
                expected_text := string(Char($554A));
            end
            else if last_syllable_key = 'ya' then
            begin
                expected_text := string(Char($5440));
            end
            else if last_syllable_key = 'la' then
            begin
                expected_text := string(Char($5566));
            end
            else if last_syllable_key = 'le' then
            begin
                expected_text := string(Char($4E86));
            end
            else if last_syllable_key = 'wa' then
            begin
                expected_text := string(Char($54C7));
            end;

            if expected_text = '' then
            begin
                Exit;
            end;

            if last_segment_text = expected_text then
            begin
                Exit(980);
            end;

            Exit(-920);
        end;

        function get_lightweight_rank(const candidate: TncCandidate;
            const text_units: Integer): Integer;
        begin
            Result := candidate.score;
            if (candidate.comment = '') and is_full_pinyin_key(lookup_text) and
                (input_syllable_count > 0) and
                (text_units > input_syllable_count) then
            begin
                Dec(Result, 20000 + (text_units - input_syllable_count) * 1600);
            end;
            if candidate.source = cs_user then
            begin
                Inc(Result, 1200);
            end;
            if candidate.comment = '' then
            begin
                Inc(Result, 320);
                if (input_syllable_count >= 4) and (text_units = input_syllable_count) then
                begin
                    Inc(Result, 1400);
                end
                else if text_units >= 2 then
                begin
                    Inc(Result, 220);
                end;
            end
            else if text_units >= 2 then
            begin
                Inc(Result, 640);
            end
            else if (input_syllable_count >= 3) then
            begin
                Dec(Result, 960);
            end;

            if candidate.has_dict_weight then
            begin
                Inc(Result, Min(360, candidate.dict_weight div 3));
            end;

            if is_complete_exact_phrase_candidate(candidate, text_units) then
            begin
                Inc(Result, 2200);
            end
            else if has_exact_complete_phrase_candidate and
                (input_syllable_count <= 6) and
                is_complete_composed_phrase_candidate(candidate, text_units) then
            begin
                Dec(Result, 1800);
            end;

            Inc(Result, get_lightweight_sentence_path_adjustment(candidate, text_units));
            Inc(Result, get_long_dict_prefix_partial_adjustment(candidate, text_units));
            Dec(Result, get_suspicious_swallowed_fixed_boundary_penalty(candidate, text_units));
            Inc(Result, get_complete_sentence_modal_tail_adjustment(candidate, text_units));
        end;
    begin
        if Length(candidates) <= 1 then
        begin
            Exit;
        end;

        has_exact_complete_phrase_candidate := False;
        for left_idx := 0 to High(candidates) do
        begin
            left_units := get_display_text_unit_count(candidates[left_idx].text);
            if is_complete_exact_phrase_candidate(candidates[left_idx], left_units) then
            begin
                has_exact_complete_phrase_candidate := True;
                Break;
            end;
        end;

        for left_idx := 0 to High(candidates) - 1 do
        begin
            left_units := get_display_text_unit_count(candidates[left_idx].text);
            left_score := get_lightweight_rank(candidates[left_idx], left_units);
            for right_idx := left_idx + 1 to High(candidates) do
            begin
                right_units := get_display_text_unit_count(candidates[right_idx].text);
                right_score := get_lightweight_rank(candidates[right_idx], right_units);
                if right_score > left_score then
                begin
                    tmp := candidates[left_idx];
                    candidates[left_idx] := candidates[right_idx];
                    candidates[right_idx] := tmp;
                    left_units := right_units;
                    left_score := right_score;
                    Continue;
                end;

                if right_score = left_score then
                begin
                    if right_units > left_units then
                    begin
                        tmp := candidates[left_idx];
                        candidates[left_idx] := candidates[right_idx];
                        candidates[right_idx] := tmp;
                        left_units := right_units;
                        Continue;
                    end;

                    if (right_units = left_units) and
                        (CompareText(candidates[right_idx].text, candidates[left_idx].text) < 0) then
                    begin
                        tmp := candidates[left_idx];
                        candidates[left_idx] := candidates[right_idx];
                        candidates[right_idx] := tmp;
                        Continue;
                    end;
                end;
            end;
        end;
    end;

    procedure filter_short_dictionary_hits_for_explicit_apostrophe(var candidates: TncCandidateList;
        const min_char_count: Integer);
    var
        idx: Integer;
        out_idx: Integer;
        text_units: TArray<string>;
    begin
        if min_char_count <= 1 then
        begin
            Exit;
        end;

        out_idx := 0;
        for idx := 0 to High(candidates) do
        begin
            text_units := split_text_units(Trim(candidates[idx].text));
            if Length(text_units) >= min_char_count then
            begin
                if out_idx <> idx then
                begin
                    candidates[out_idx] := candidates[idx];
                end;
                Inc(out_idx);
            end;
        end;
        SetLength(candidates, out_idx);
    end;

    procedure filter_explicit_apostrophe_single_char_complete_candidates(var candidates: TncCandidateList);
    var
        idx: Integer;
        out_idx: Integer;
        text_units: TArray<string>;
    begin
        out_idx := 0;
        for idx := 0 to High(candidates) do
        begin
            text_units := split_text_units(Trim(candidates[idx].text));
            if (candidates[idx].comment = '') and (Length(text_units) = 1) then
            begin
                Continue;
            end;

            if out_idx <> idx then
            begin
                candidates[out_idx] := candidates[idx];
            end;
            Inc(out_idx);
        end;
        SetLength(candidates, out_idx);
    end;

    function matches_explicit_apostrophe_unit_alignment(const candidate_text: string): Boolean;
    var
        parser_local: TncPinyinParser;
        text_units: TArray<string>;
        idx: Integer;
        is_preferred: Boolean;
    begin
        Result := False;
        if (not has_explicit_apostrophe_input) or (input_syllable_count <= 1) then
        begin
            Exit;
        end;

        text_units := split_text_units(Trim(candidate_text));
        if Length(text_units) <> input_syllable_count then
        begin
            Exit;
        end;

        if not explicit_apostrophe_query_parsed then
        begin
            explicit_apostrophe_query_parsed := True;
            parser_local := TncPinyinParser.Create;
            try
                explicit_apostrophe_query_syllables := parser_local.parse(m_composition_text);
            finally
                parser_local.Free;
            end;
        end;

        if Length(explicit_apostrophe_query_syllables) <> input_syllable_count then
        begin
            Exit;
        end;

        for idx := 0 to input_syllable_count - 1 do
        begin
            if not match_single_char_candidate_for_syllable(
                Trim(explicit_apostrophe_query_syllables[idx].text),
                text_units[idx],
                is_preferred) then
            begin
                Exit(False);
            end;
        end;

        Result := True;
    end;

    procedure filter_complete_candidates_for_explicit_apostrophe_boundary(
        var candidates: TncCandidateList; const aligned_candidates: TncCandidateList);
    var
        allowed_complete_texts: TDictionary<string, Byte>;
        idx: Integer;
        out_idx: Integer;
        key: string;
        candidate_text_units: Integer;
        encoded_path: string;
        has_aligned_boundary_candidate: Boolean;
        function contains_non_ascii_text(const value: string): Boolean;
        var
            ch: Char;
        begin
            Result := False;
            for ch in value do
            begin
                if Ord(ch) > $7F then
                begin
                    Exit(True);
                end;
            end;
        end;
    begin
        allowed_complete_texts := TDictionary<string, Byte>.Create;
        try
            has_aligned_boundary_candidate := has_explicit_apostrophe_input and
                (input_syllable_count > 1);
            for idx := 0 to High(aligned_candidates) do
            begin
                if aligned_candidates[idx].comment <> '' then
                begin
                    if contains_non_ascii_text(Trim(aligned_candidates[idx].text)) then
                    begin
                        has_aligned_boundary_candidate := True;
                    end;
                    Continue;
                end;

                candidate_text_units := get_candidate_text_unit_count(Trim(aligned_candidates[idx].text));
                if candidate_text_units < 2 then
                begin
                    Continue;
                end;

                if matches_explicit_apostrophe_unit_alignment(
                    aligned_candidates[idx].text) then
                begin
                    has_aligned_boundary_candidate := True;
                    key := LowerCase(Trim(aligned_candidates[idx].text));
                    if (key <> '') and
                        (not allowed_complete_texts.ContainsKey(key)) then
                    begin
                        allowed_complete_texts.Add(key, 1);
                    end;
                    Continue;
                end;

                encoded_path := get_segment_path_for_candidate(aligned_candidates[idx]);
                if get_encoded_path_segment_count_local(encoded_path) < input_syllable_count then
                begin
                    Continue;
                end;

                has_aligned_boundary_candidate := True;
                key := LowerCase(Trim(aligned_candidates[idx].text));
                if (key <> '') and (not allowed_complete_texts.ContainsKey(key)) then
                begin
                    allowed_complete_texts.Add(key, 1);
                end;
            end;

            if not has_aligned_boundary_candidate then
            begin
                Exit;
            end;

            out_idx := 0;
            for idx := 0 to High(candidates) do
            begin
                if candidates[idx].comment <> '' then
                begin
                    if out_idx <> idx then
                    begin
                        candidates[out_idx] := candidates[idx];
                    end;
                    Inc(out_idx);
                    Continue;
                end;

                candidate_text_units := get_candidate_text_unit_count(Trim(candidates[idx].text));
                if candidate_text_units < 2 then
                begin
                    if out_idx <> idx then
                    begin
                        candidates[out_idx] := candidates[idx];
                    end;
                    Inc(out_idx);
                    Continue;
                end;

                key := LowerCase(Trim(candidates[idx].text));
                if (key <> '') and allowed_complete_texts.ContainsKey(key) then
                begin
                    if out_idx <> idx then
                    begin
                        candidates[out_idx] := candidates[idx];
                    end;
                    Inc(out_idx);
                    Continue;
                end;

                if matches_explicit_apostrophe_unit_alignment(candidates[idx].text) then
                begin
                    if out_idx <> idx then
                    begin
                        candidates[out_idx] := candidates[idx];
                    end;
                    Inc(out_idx);
                end;
            end;
            SetLength(candidates, out_idx);
        finally
            allowed_complete_texts.Free;
        end;
    end;

    procedure prefer_relaxed_missing_apostrophe_boundary_partial(var candidates: TncCandidateList);
    var
        preferred_index: Integer;
        target_index: Integer;
        idx: Integer;
        preferred_candidate: TncCandidate;
        preferred_comment: string;
        primary_comment: string;

        function build_partial_tail_comment(const input_text: string;
            const allow_relaxed_split: Boolean): string;
        var
            parser: TncPinyinParser;
            parts: TncPinyinParseResult;
            part_idx: Integer;
        begin
            Result := '';
            if input_text = '' then
            begin
                Exit;
            end;

            parser := TncPinyinParser.Create;
            try
                if allow_relaxed_split then
                begin
                    parts := parse_pinyin_with_relaxed_missing_apostrophe(input_text);
                end
                else
                begin
                    parts := parser.parse(input_text);
                end;
            finally
                parser.Free;
            end;

            if Length(parts) <= 1 then
            begin
                Exit;
            end;

            for part_idx := 1 to High(parts) do
            begin
                Result := Result + parts[part_idx].text;
            end;
        end;

        function is_complete_multi_char_anchor(const candidate: TncCandidate): Boolean;
        var
            candidate_text_units: Integer;
        begin
            Result := False;
            if candidate.comment <> '' then
            begin
                Exit;
            end;

            candidate_text_units := get_candidate_text_unit_count(Trim(candidate.text));
            if candidate_text_units < 2 then
            begin
                Exit;
            end;

            if candidate.has_dict_weight or (candidate.source = cs_user) then
            begin
                Exit(True);
            end;

            Result := (candidate.source = cs_rule) and
                (not is_runtime_chain_candidate(candidate)) and
                (not is_runtime_common_pattern_candidate(candidate)) and
                (not is_runtime_redup_candidate(candidate));
        end;
    begin
        if (not has_relaxed_missing_apostrophe_partial) or
            (not has_relaxed_missing_apostrophe_boundary_shift) or
            (Length(candidates) <= 1) then
        begin
            Exit;
        end;

        preferred_comment := build_partial_tail_comment(m_composition_text, True);
        if preferred_comment = '' then
        begin
            preferred_comment := build_partial_tail_comment(lookup_text, True);
        end;
        primary_comment := build_partial_tail_comment(m_composition_text, False);
        if primary_comment = '' then
        begin
            primary_comment := build_partial_tail_comment(lookup_text, False);
        end;

        if (preferred_comment = '') or SameText(preferred_comment, primary_comment) then
        begin
            Exit;
        end;

        preferred_index := -1;
        for idx := 0 to High(candidates) do
        begin
            if SameText(candidates[idx].comment, preferred_comment) then
            begin
                preferred_index := idx;
                Break;
            end;
        end;

        if preferred_index < 0 then
        begin
            Exit;
        end;

        target_index := 0;
        while (target_index <= High(candidates)) and
            is_complete_multi_char_anchor(candidates[target_index]) do
        begin
            Inc(target_index);
        end;

        if (target_index > High(candidates)) or (preferred_index <= target_index) then
        begin
            Exit;
        end;

        preferred_candidate := candidates[preferred_index];
        for idx := preferred_index downto target_index + 1 do
        begin
            candidates[idx] := candidates[idx - 1];
        end;
        candidates[target_index] := preferred_candidate;
    end;

    procedure ensure_relaxed_missing_apostrophe_head_partial_visible(
        var candidates: TncCandidateList);
    var
        parts: TncPinyinParseResult;
        head_key: string;
        remaining_pinyin: string;
        head_lookup: TncCandidateList;
        part_idx: Integer;
        candidate_idx: Integer;
        existing_idx: Integer;
        target_idx: Integer;
        insert_idx: Integer;
        best_idx: Integer;
        best_score: Integer;
        source_item: TncCandidate;
        partial_item: TncCandidate;
        move_idx: Integer;

        function is_bmp_cjk_single_char_local(const candidate: TncCandidate): Boolean;
        var
            unit_text: string;
            codepoint: Integer;
        begin
            Result := False;
            unit_text := Trim(candidate.text);
            if Length(unit_text) = 1 then
            begin
                codepoint := Ord(unit_text[1]);
            end
            else if (Length(unit_text) = 2) and
                (Ord(unit_text[1]) >= $D800) and (Ord(unit_text[1]) <= $DBFF) and
                (Ord(unit_text[2]) >= $DC00) and (Ord(unit_text[2]) <= $DFFF) then
            begin
                codepoint := ((Ord(unit_text[1]) - $D800) shl 10) +
                    (Ord(unit_text[2]) - $DC00) + $10000;
            end
            else
            begin
                Exit;
            end;
            Result := (codepoint >= $4E00) and (codepoint <= $9FFF);
        end;
    begin
        if (m_dictionary = nil) or
            (not has_relaxed_missing_apostrophe_partial) or
            ((not has_relaxed_missing_apostrophe_boundary_shift) and
            has_multi_syllable_input) then
        begin
            Exit;
        end;

        parts := parse_pinyin_with_relaxed_missing_apostrophe(m_composition_text);
        if Length(parts) <= 1 then
        begin
            parts := parse_pinyin_with_relaxed_missing_apostrophe(lookup_text);
        end;
        if Length(parts) <= 1 then
        begin
            Exit;
        end;

        head_key := normalize_pinyin_text(parts[0].text);
        remaining_pinyin := '';
        for part_idx := 1 to High(parts) do
        begin
            remaining_pinyin := remaining_pinyin + normalize_pinyin_text(parts[part_idx].text);
        end;
        if (head_key = '') or (remaining_pinyin = '') then
        begin
            Exit;
        end;

        existing_idx := -1;
        for candidate_idx := 0 to High(candidates) do
        begin
            if SameText(Trim(candidates[candidate_idx].comment), remaining_pinyin) and
                (get_candidate_text_unit_count(Trim(candidates[candidate_idx].text)) = 1) then
            begin
                existing_idx := candidate_idx;
                Break;
            end;
        end;
        if existing_idx >= 0 then
        begin
            Exit;
        end;

        if not m_dictionary.lookup(head_key, head_lookup) then
        begin
            Exit;
        end;

        best_idx := -1;
        best_score := Low(Integer);
        for candidate_idx := 0 to High(head_lookup) do
        begin
            source_item := head_lookup[candidate_idx];
            if (Trim(source_item.comment) <> '') or
                (not is_bmp_cjk_single_char_local(source_item)) then
            begin
                Continue;
            end;
            if source_item.score > best_score then
            begin
                best_idx := candidate_idx;
                best_score := source_item.score;
            end;
        end;
        if best_idx < 0 then
        begin
            Exit;
        end;

        partial_item := head_lookup[best_idx];
        partial_item.comment := remaining_pinyin;
        Inc(partial_item.score, 64);

        target_idx := -1;
        for candidate_idx := 0 to High(candidates) do
        begin
            if (Trim(candidates[candidate_idx].comment) = '') and
                (get_candidate_text_unit_count(Trim(candidates[candidate_idx].text)) > 1) then
            begin
                target_idx := candidate_idx + 1;
                Break;
            end;
        end;
        if target_idx < 0 then
        begin
            target_idx := Min(Length(candidates), 1);
        end;

        SetLength(candidates, Length(candidates) + 1);
        insert_idx := Min(target_idx, High(candidates));
        for move_idx := High(candidates) downto insert_idx + 1 do
        begin
            candidates[move_idx] := candidates[move_idx - 1];
        end;
        candidates[insert_idx] := partial_item;
    end;

    function is_natural_predictive_segment_path_local(
        const encoded_path: string): Boolean; forward;

    procedure filter_long_query_nonlexicon_complete_candidates(var candidates: TncCandidateList);
    var
        idx: Integer;
        out_idx: Integer;
        candidate_text_units: Integer;
        segment_path: string;
    begin
        if (input_syllable_count < 2) or
            (not c_suppress_nonlexicon_complete_long_candidates) then
        begin
            Exit;
        end;

        out_idx := 0;
        for idx := 0 to High(candidates) do
        begin
            candidate_text_units := get_candidate_text_unit_count(Trim(candidates[idx].text));
            if (candidates[idx].comment <> '') or (candidate_text_units < 2) then
            begin
                if out_idx <> idx then
                begin
                    candidates[out_idx] := candidates[idx];
                end;
                Inc(out_idx);
                Continue;
            end;

            if candidates[idx].has_dict_weight or (candidates[idx].source = cs_user) then
            begin
                if out_idx <> idx then
                begin
                    candidates[out_idx] := candidates[idx];
                end;
                Inc(out_idx);
                Continue;
            end;

            if input_syllable_count >= c_long_sentence_exact_min_syllables then
            begin
                segment_path := get_segment_path_for_candidate(candidates[idx]);
                if (get_encoded_path_segment_count_local(segment_path) > 1) and
                    (not is_runtime_chain_candidate(candidates[idx])) and
                    (not is_runtime_common_pattern_candidate(candidates[idx])) and
                    (not is_runtime_redup_candidate(candidates[idx])) and
                    ((input_syllable_count >= c_long_sentence_full_path_min_syllables) or
                    (is_full_pinyin_key(lookup_text) and
                    is_natural_predictive_segment_path_local(segment_path))) then
                begin
                    if out_idx <> idx then
                    begin
                        candidates[out_idx] := candidates[idx];
                    end;
                    Inc(out_idx);
                    Continue;
                end;
            end;
        end;
        SetLength(candidates, out_idx);
    end;

    function should_enable_long_sentence_full_path_search_local: Boolean;
    begin
        Result := m_config.enable_segment_candidates and has_multi_syllable_input and
            (input_syllable_count >= c_long_sentence_full_path_min_syllables) and
            (not all_initial_compact_query) and
            (not has_internal_dangling_initial) and
            (not (has_extendable_same_syllable_tail_local(lookup_text,
            input_syllable_count) and (input_syllable_count < 10)));
    end;

    function should_enable_long_sentence_exact_search_local: Boolean;
    begin
        Result := m_config.enable_segment_candidates and has_multi_syllable_input and
            (input_syllable_count >= c_long_sentence_exact_min_syllables) and
            (not all_initial_compact_query) and
            (not has_internal_dangling_initial);
    end;

    function has_exact_complete_phrase_candidate_for_syllable_count(
        const candidates: TncCandidateList;
        const expected_syllables: Integer): Boolean; forward;
    function has_natural_complete_segment_path_candidate_for_syllable_count(
        const candidates: TncCandidateList;
        const expected_syllables: Integer): Boolean; forward;
    function has_useful_long_sentence_prediction_candidate(
        const candidates: TncCandidateList): Boolean; forward;
    function has_strong_delayed_long_decode_candidate(
        const candidates: TncCandidateList): Boolean; forward;

    function has_ultra_long_extendable_partial_anchor(
        const candidates: TncCandidateList): Boolean;
    var
        candidate_idx: Integer;
        candidate_text: string;
        candidate_comment: string;
        text_units: Integer;
        comment_units: Integer;
        min_anchor_units: Integer;
    begin
        Result := False;
        if input_syllable_count < 12 then
        begin
            Exit;
        end;

        min_anchor_units := input_syllable_count div 2;
        if min_anchor_units < 4 then
        begin
            min_anchor_units := 4;
        end;

        for candidate_idx := 0 to High(candidates) do
        begin
            candidate_text := Trim(candidates[candidate_idx].text);
            candidate_comment := Trim(candidates[candidate_idx].comment);
            if (candidate_text = '') or (candidate_comment = '') then
            begin
                Continue;
            end;

            if not (candidates[candidate_idx].has_dict_weight or
                (candidates[candidate_idx].source = cs_user)) then
            begin
                Continue;
            end;

            text_units := get_candidate_text_unit_count(candidate_text);
            if text_units < min_anchor_units then
            begin
                Continue;
            end;

            comment_units := get_effective_compact_pinyin_unit_count(
                normalize_pinyin_text(candidate_comment));
            if comment_units < 4 then
            begin
                Continue;
            end;

            if text_units + comment_units < input_syllable_count - 1 then
            begin
                Continue;
            end;

            Exit(True);
        end;
    end;

    function should_short_circuit_ultra_long_partial_query_local(
        const candidates: TncCandidateList): Boolean;
    begin
        Result := delayed_long_decode_mode and
            is_full_pinyin_key(lookup_text) and
            (input_syllable_count >= 12) and
            (not normalized_typo_long_query_fast_path) and
            (not has_exact_complete_phrase_candidate_for_syllable_count(
                candidates, input_syllable_count)) and
            (not has_natural_complete_segment_path_candidate_for_syllable_count(
                candidates, input_syllable_count)) and
            (not has_strong_delayed_long_decode_candidate(candidates)) and
            has_ultra_long_extendable_partial_anchor(candidates);
    end;

    function has_strong_long_sentence_prediction_local(
        const candidates: TncCandidateList): Boolean;
    begin
        Result := has_useful_long_sentence_prediction_candidate(candidates) or
            (should_enable_long_sentence_exact_search_local and
            is_full_pinyin_key(lookup_text) and
            (input_syllable_count >= 10) and
            has_exact_complete_phrase_candidate_for_syllable_count(
                candidates, input_syllable_count));
    end;

    function should_trim_strong_long_sentence_candidates_local(
        const candidates: TncCandidateList): Boolean;
    var
        candidate_idx: Integer;
    begin
        Result := False;
        if (not is_full_pinyin_key(lookup_text)) or
            (input_syllable_count < 12) or
            (Length(candidates) <= get_candidate_limit * 2) then
        begin
            Exit;
        end;

        for candidate_idx := 0 to High(candidates) do
        begin
            if candidates[candidate_idx].comment <> '' then
            begin
                Continue;
            end;
            if get_candidate_text_unit_count(Trim(candidates[candidate_idx].text)) <>
                input_syllable_count then
            begin
                Continue;
            end;
            Exit(True);
        end;
    end;

    function is_single_initial_token_local(const token_text: string): Boolean;
    var
        ch: Char;
    begin
        Result := False;
        if Length(token_text) <> 1 then
        begin
            Exit;
        end;

        ch := token_text[1];
        if (ch >= 'A') and (ch <= 'Z') then
        begin
            ch := Chr(Ord(ch) + 32);
        end;
        Result := CharInSet(ch, ['b', 'p', 'm', 'f', 'd', 't', 'n', 'l', 'g', 'k', 'h', 'j', 'q', 'x',
            'r', 'z', 'c', 's', 'y', 'w']);
    end;

    function detect_internal_dangling_initial(const text: string): Boolean;
    var
        parser: TncPinyinParser;
        parts: TncPinyinParseResult;
        idx: Integer;
    begin
        Result := False;
        if text = '' then
        begin
            Exit;
        end;

        parser := TncPinyinParser.create;
        try
            parts := parser.parse(text);
        finally
            parser.Free;
        end;

        if Length(parts) <= 1 then
        begin
            Exit;
        end;

        // Pattern like "cha + g + n" usually means malformed/typo input.
        // In this case segment fusion is often noisy and should not override
        // direct lookup/typo recovery results.
        for idx := 0 to High(parts) - 1 do
        begin
            if is_single_initial_token_local(parts[idx].text) then
            begin
                Result := True;
                Exit;
            end;
        end;
    end;

    function detect_safe_trailing_initial_typing_state(const text: string): Boolean;
    var
        normalized_text: string;
        parser: TncPinyinParser;
        parts: TncPinyinParseResult;
        prefix_text: string;
        suffix_start: Integer;
        suffix_count: Integer;
        idx: Integer;
        tail_cluster: string;
    begin
        Result := False;
        if text = '' then
        begin
            Exit;
        end;

        normalized_text := normalize_pinyin_text(text);
        if Length(normalized_text) >= 3 then
        begin
            prefix_text := Copy(normalized_text, 1, Length(normalized_text) - 1);
            if is_single_initial_token_local(Copy(normalized_text, Length(normalized_text), 1)) and
                is_full_pinyin_key(prefix_text) then
            begin
                Exit(True);
            end;
        end;
        if Length(normalized_text) >= 4 then
        begin
            tail_cluster := Copy(normalized_text, Length(normalized_text) - 1, 2);
            prefix_text := Copy(normalized_text, 1, Length(normalized_text) - 2);
            if ((tail_cluster = 'zh') or (tail_cluster = 'ch') or (tail_cluster = 'sh')) and
                is_full_pinyin_key(prefix_text) then
            begin
                Exit(True);
            end;
        end;

        parser := TncPinyinParser.create;
        try
            parts := parser.parse(text);
        finally
            parser.Free;
        end;

        if Length(parts) <= 1 then
        begin
            Exit;
        end;

        suffix_start := Length(parts);
        while (suffix_start > 0) and is_single_initial_token_local(parts[suffix_start - 1].text) do
        begin
            Dec(suffix_start);
        end;

        suffix_count := Length(parts) - suffix_start;
        if (suffix_count <= 0) or (suffix_count > 2) or (suffix_start <= 0) then
        begin
            Exit;
        end;

        for idx := 0 to suffix_start - 1 do
        begin
            if is_single_initial_token_local(parts[idx].text) then
            begin
                Exit;
            end;
        end;

        if suffix_count = 1 then
        begin
            Result := True;
            Exit;
        end;

        tail_cluster := LowerCase(parts[High(parts) - 1].text + parts[High(parts)].text);
        Result := (tail_cluster = 'zh') or (tail_cluster = 'ch') or (tail_cluster = 'sh');
    end;

    function detect_all_initial_compact_query(const text: string): Boolean;
    const
        c_all_initial_compact_query_syllable_min = 5;
    var
        parser: TncPinyinParser;
        parts: TncPinyinParseResult;
        idx: Integer;
    begin
        Result := False;
        if text = '' then
        begin
            Exit;
        end;

        parser := TncPinyinParser.create;
        try
            parts := parser.parse(text);
        finally
            parser.Free;
        end;

        if Length(parts) < c_all_initial_compact_query_syllable_min then
        begin
            Exit;
        end;

        for idx := 0 to High(parts) do
        begin
            if not is_single_initial_token_local(parts[idx].text) then
            begin
                Exit;
            end;
        end;

        Result := True;
    end;

    procedure ensure_partial_fallback_visible(var candidates: TncCandidateList; const visible_limit: Integer);
    var
        idx: Integer;
        partial_index: Integer;
        partial_candidate: TncCandidate;
    begin
        if (visible_limit <= 0) or (Length(candidates) <= visible_limit) then
        begin
            Exit;
        end;

        for idx := 0 to visible_limit - 1 do
        begin
            if candidates[idx].comment <> '' then
            begin
                Exit;
            end;
        end;

        partial_index := -1;
        for idx := visible_limit to High(candidates) do
        begin
            if candidates[idx].comment <> '' then
            begin
                partial_index := idx;
                Break;
            end;
        end;

        if partial_index < 0 then
        begin
            Exit;
        end;

        partial_candidate := candidates[partial_index];
        for idx := partial_index downto visible_limit do
        begin
            candidates[idx] := candidates[idx - 1];
        end;
        candidates[visible_limit - 1] := partial_candidate;
    end;

    function is_strong_exact_partial_candidate_for_visibility(
        const candidate: TncCandidate): Boolean;
    begin
        Result := (candidate.comment <> '') and
            (get_candidate_text_unit_count(Trim(candidate.text)) >= 2) and
            (candidate.has_dict_weight or (candidate.source = cs_user) or
            ((candidate.source = cs_rule) and
            (not is_runtime_chain_candidate(candidate)) and
            (not is_runtime_common_pattern_candidate(candidate)) and
            (not is_runtime_redup_candidate(candidate))));
    end;

    function is_supported_head_phrase_partial_for_visibility(
        const candidate: TncCandidate): Boolean;
    const
        c_supported_head_phrase_first_single_margin_local = 180;
        c_supported_head_phrase_tail_ratio_pct_local = 80;
    var
        candidate_text: string;
        partial_comment_syllables: Integer;
    begin
        Result := False;
        if (m_last_lookup_syllable_count <> 3) or (candidate.comment = '') then
        begin
            Exit;
        end;

        candidate_text := Trim(candidate.text);
        if (candidate_text = '') or
            (get_candidate_text_unit_count(candidate_text) < 2) then
        begin
            Exit;
        end;

        partial_comment_syllables := get_effective_compact_pinyin_unit_count(
            normalize_pinyin_text(candidate.comment));
        if partial_comment_syllables <> 1 then
        begin
            Exit;
        end;

        if (m_last_three_syllable_head_exact_text = '') or
            (candidate_text <> m_last_three_syllable_head_exact_text) then
        begin
            Exit;
        end;

        if not is_strong_exact_partial_candidate_for_visibility(candidate) then
        begin
            Exit;
        end;

        if m_last_three_syllable_head_strength <= 0 then
        begin
            Exit;
        end;
        if m_last_three_syllable_head_strength >=
            (m_last_three_syllable_first_single_strength +
            c_supported_head_phrase_first_single_margin_local) then
        begin
            Exit(True);
        end;

        if m_last_three_syllable_head_path_bonus > 0 then
        begin
            Exit(True);
        end;

        if m_last_three_syllable_tail_strength <= 0 then
        begin
            Exit(True);
        end;

        Result := (m_last_three_syllable_head_strength * 100) >=
            (m_last_three_syllable_tail_strength *
            c_supported_head_phrase_tail_ratio_pct_local);
    end;

    procedure ensure_strong_two_plus_one_partial_visible(var candidates: TncCandidateList;
        const visible_limit: Integer);
    var
        idx: Integer;
        partial_index: Integer;
        fallback_partial_index: Integer;
        target_index: Integer;
        partial_candidate: TncCandidate;
    begin
        if (m_last_lookup_syllable_count <> 3) or
            (visible_limit <= 0) or (Length(candidates) = 0) then
        begin
            Exit;
        end;

        for idx := 0 to Min(visible_limit - 1, High(candidates)) do
        begin
            if is_supported_head_phrase_partial_for_visibility(candidates[idx]) then
            begin
                Exit;
            end;
            if (m_last_three_syllable_partial_preference_kind = 1) and
                is_strong_exact_partial_candidate_for_visibility(candidates[idx]) then
            begin
                Exit;
            end;
        end;

        partial_index := -1;
        fallback_partial_index := -1;
        for idx := 0 to High(candidates) do
        begin
            if is_supported_head_phrase_partial_for_visibility(candidates[idx]) then
            begin
                partial_index := idx;
                Break;
            end;
            if (fallback_partial_index < 0) and
                (m_last_three_syllable_partial_preference_kind = 1) and
                is_strong_exact_partial_candidate_for_visibility(candidates[idx]) then
            begin
                fallback_partial_index := idx;
            end;
        end;

        if partial_index < 0 then
        begin
            partial_index := fallback_partial_index;
        end;

        if partial_index < 0 then
        begin
            Exit;
        end;

        target_index := 2;
        if target_index >= visible_limit then
        begin
            target_index := visible_limit - 1;
        end;
        if target_index >= Length(candidates) then
        begin
            target_index := Length(candidates) - 1;
        end;
        if (target_index < 0) or (partial_index <= target_index) then
        begin
            Exit;
        end;

        partial_candidate := candidates[partial_index];
        for idx := partial_index downto target_index + 1 do
        begin
            candidates[idx] := candidates[idx - 1];
        end;
        candidates[target_index] := partial_candidate;
    end;

    function is_long_sentence_prefix_partial_candidate_for_visibility(
        const candidate: TncCandidate): Boolean;
    var
        partial_comment_syllables: Integer;
        partial_text_units: Integer;
        segment_path: string;
    begin
        Result := False;
        if input_syllable_count < c_long_sentence_exact_min_syllables then
        begin
            Exit;
        end;

        if Trim(candidate.comment) = '' then
        begin
            Exit;
        end;

        partial_text_units := get_candidate_text_unit_count(Trim(candidate.text));
        if partial_text_units < 2 then
        begin
            Exit;
        end;

        partial_comment_syllables := get_effective_compact_pinyin_unit_count(
            normalize_pinyin_text(candidate.comment));
        if partial_comment_syllables <= 0 then
        begin
            Exit;
        end;

        if partial_text_units + partial_comment_syllables <> input_syllable_count then
        begin
            Exit;
        end;

        segment_path := get_segment_path_for_candidate(candidate);
        if (partial_text_units >= 3) and
            is_strong_exact_partial_candidate_for_visibility(candidate) then
        begin
            Exit(True);
        end;

        if get_encoded_path_segment_count_local(segment_path) <= 1 then
        begin
            Exit;
        end;

        Result := True;
    end;

    function has_long_sentence_extendable_tail_for_visibility_local: Boolean;
    var
        effective_syllables: TncPinyinParseResult;
        local_syllable_count: Integer;
        last_syllable_text: string;
        suffix_ch: Char;
        extended_key: string;
    begin
        Result := False;
        if lookup_text = '' then
        begin
            Exit;
        end;

        effective_syllables := get_effective_compact_pinyin_syllables(lookup_text);
        local_syllable_count := Length(effective_syllables);
        if local_syllable_count < c_long_sentence_exact_min_syllables then
        begin
            Exit;
        end;

        last_syllable_text := Trim(effective_syllables[High(effective_syllables)].text);
        if last_syllable_text = '' then
        begin
            Exit;
        end;

        for suffix_ch := 'a' to 'z' do
        begin
            extended_key := lookup_text + suffix_ch;
            if get_effective_compact_pinyin_unit_count(extended_key) = local_syllable_count then
            begin
                Exit(True);
            end;
        end;
    end;

    function is_predictive_tail_single_char_text_codepoint_for_visibility_local(
        const value: string): Boolean;
    begin
        Result := False;
        if Length(value) <> 1 then
        begin
            Exit;
        end;

        case Ord(value[1]) of
            $4E00, $6211, $4F60, $4ED6, $5979, $5B83, $4EEC, $548C, $53BB, $6765,
            $5728, $662F, $6709, $8981, $60F3, $4F1A, $80FD, $628A, $88AB, $8BA9,
            $7ED9, $5411, $8DDF, $540C, $4ECE, $4E0E, $5C31, $4E5F, $90FD, $8FD8,
            $53C8, $518D, $4E0D, $5F88, $592A, $6700, $5DF2, $5C06, $5230, $4E86,
            $7740, $8FC7:
                Result := True;
        end;
    end;

    function is_predictive_bridge_single_char_text_codepoint_for_visibility_local(
        const value: string): Boolean;
    begin
        Result := False;
        if Length(value) <> 1 then
        begin
            Exit;
        end;

        case Ord(value[1]) of
            $6211, $4F60, $4ED6, $5979, $5B83, $4EEC, $548C, $53BB, $6765, $5728,
            $662F, $6709, $8981, $60F3, $4F1A, $80FD, $628A, $88AB, $8BA9, $7ED9,
            $5411, $8DDF, $540C, $4ECE, $4E0E, $5C31, $4E5F, $90FD, $8FD8, $53C8,
            $518D, $4E0D, $5F88, $592A, $6700, $5DF2, $5C06, $5230:
                Result := True;
        end;
    end;

    function is_natural_predictive_segment_path_local(const encoded_path: string): Boolean;
    var
        segment_parts: TArray<string>;
        segment_idx: Integer;
        trailing_single_start: Integer;
        segment_text: string;
        segment_units: Integer;
        prev_units: Integer;
        next_units: Integer;
    begin
        Result := True;
        if Trim(encoded_path) = '' then
        begin
            Exit;
        end;

        segment_parts := encoded_path.Split([c_segment_path_separator]);
        if Length(segment_parts) <= 1 then
        begin
            Exit;
        end;

        trailing_single_start := Length(segment_parts);
        while trailing_single_start > 0 do
        begin
            if get_candidate_text_unit_count(
                Trim(segment_parts[trailing_single_start - 1])) <> 1 then
            begin
                Break;
            end;
            Dec(trailing_single_start);
        end;

        for segment_idx := trailing_single_start to High(segment_parts) do
        begin
            segment_text := Trim(segment_parts[segment_idx]);
            if not is_predictive_tail_single_char_text_codepoint_for_visibility_local(segment_text) then
            begin
                Exit(False);
            end;
        end;

        for segment_idx := 1 to High(segment_parts) - 1 do
        begin
            if segment_idx >= trailing_single_start then
            begin
                Break;
            end;

            segment_text := Trim(segment_parts[segment_idx]);
            segment_units := get_candidate_text_unit_count(segment_text);
            if segment_units <> 1 then
            begin
                Continue;
            end;

            prev_units := get_candidate_text_unit_count(Trim(segment_parts[segment_idx - 1]));
            next_units := get_candidate_text_unit_count(Trim(segment_parts[segment_idx + 1]));
            if (prev_units >= 2) and (next_units >= 2) and
                (not is_predictive_bridge_single_char_text_codepoint_for_visibility_local(segment_text)) then
            begin
                Exit(False);
            end;
        end;
    end;

    procedure ensure_long_sentence_prefix_partial_visible(var candidates: TncCandidateList;
        const visible_limit: Integer);
    var
        best_index: Integer;
        best_units: Integer;
        best_score: Integer;
        current_units: Integer;
        idx: Integer;
        picked: TncCandidate;
        function is_strong_long_exact_prefix_partial_local(
            const candidate: TncCandidate): Boolean;
        var
            local_text_units: Integer;
            local_comment_syllables: Integer;
        begin
            Result := False;
            if Trim(candidate.comment) = '' then
            begin
                Exit;
            end;

            local_text_units := get_candidate_text_unit_count(Trim(candidate.text));
            if local_text_units < 3 then
            begin
                Exit;
            end;

            local_comment_syllables := get_effective_compact_pinyin_unit_count(
                normalize_pinyin_text(candidate.comment));
            if local_comment_syllables <= 0 then
            begin
                Exit;
            end;

            if local_text_units + local_comment_syllables <> input_syllable_count then
            begin
                Exit;
            end;

            Result := is_strong_exact_partial_candidate_for_visibility(candidate);
        end;
    begin
        if (Length(candidates) = 0) or (visible_limit <= 0) or
            (not has_long_sentence_extendable_tail_for_visibility_local) then
        begin
            Exit;
        end;

        if (Trim(candidates[0].comment) = '') and
            (get_candidate_text_unit_count(Trim(candidates[0].text)) = input_syllable_count) and
            (get_encoded_path_segment_count_local(get_segment_path_for_candidate(candidates[0])) > 1) then
        begin
            Exit;
        end;

        if is_full_pinyin_key(lookup_text) and
            (Trim(candidates[0].comment) = '') and
            (get_candidate_text_unit_count(Trim(candidates[0].text)) >= 2) and
            (get_candidate_text_unit_count(Trim(candidates[0].text)) >=
            input_syllable_count - 1) and
            (candidates[0].has_dict_weight or
            (get_encoded_path_segment_count_local(
            get_segment_path_for_candidate(candidates[0])) <= 1)) then
        begin
            Exit;
        end;

        if is_long_sentence_prefix_partial_candidate_for_visibility(candidates[0]) then
        begin
            Exit;
        end;

        best_index := -1;
        best_units := -1;
        best_score := Low(Integer);
        for idx := 0 to High(candidates) do
        begin
            if not is_long_sentence_prefix_partial_candidate_for_visibility(candidates[idx]) then
            begin
                Continue;
            end;

            current_units := get_candidate_text_unit_count(Trim(candidates[idx].text));
            if (current_units > best_units) or
                ((current_units = best_units) and (candidates[idx].score > best_score)) then
            begin
                best_index := idx;
                best_units := current_units;
                best_score := candidates[idx].score;
            end;
        end;

        if best_index < 0 then
        begin
            for idx := 0 to High(candidates) do
            begin
                if not is_strong_long_exact_prefix_partial_local(candidates[idx]) then
                begin
                    Continue;
                end;

                current_units := get_candidate_text_unit_count(Trim(candidates[idx].text));
                if (current_units > best_units) or
                    ((current_units = best_units) and
                    (candidates[idx].score > best_score)) then
                begin
                    best_index := idx;
                    best_units := current_units;
                    best_score := candidates[idx].score;
                end;
            end;
        end;

        if best_index <= 0 then
        begin
            Exit;
        end;

        picked := candidates[best_index];
        for idx := best_index downto 1 do
        begin
            candidates[idx] := candidates[idx - 1];
        end;
        candidates[0] := picked;
    end;

    function is_long_sentence_exact_candidate_for_visibility(
        const candidate: TncCandidate): Boolean;
    var
        exact_text_units: Integer;
        segment_path: string;
    begin
        Result := False;
        if input_syllable_count < c_long_sentence_exact_min_syllables then
        begin
            Exit;
        end;

        if Trim(candidate.comment) <> '' then
        begin
            Exit;
        end;

        exact_text_units := get_candidate_text_unit_count(Trim(candidate.text));
        if exact_text_units <> input_syllable_count then
        begin
            Exit;
        end;

        segment_path := get_segment_path_for_candidate(candidate);
        if get_encoded_path_segment_count_local(segment_path) <= 0 then
        begin
            Exit;
        end;

        Result := True;
    end;

    function is_long_sentence_partial_exact_candidate_for_visibility(
        const candidate: TncCandidate): Boolean;
    var
        segment_path: string;
        segment_parts: TArray<string>;
    begin
        Result := False;
        if not is_long_sentence_exact_candidate_for_visibility(candidate) then
        begin
            Exit;
        end;

        segment_path := get_segment_path_for_candidate(candidate);
        if Trim(segment_path) = '' then
        begin
            Exit;
        end;
        segment_parts := segment_path.Split([c_segment_path_separator]);
        if Length(segment_parts) <= 1 then
        begin
            Exit;
        end;
        if get_candidate_text_unit_count(Trim(segment_parts[High(segment_parts)])) <> 1 then
        begin
            Exit;
        end;
        if not is_natural_predictive_segment_path_local(segment_path) then
        begin
            Exit;
        end;

        Result := True;
    end;

    procedure ensure_long_sentence_exact_candidate_visible(var candidates: TncCandidateList);
    var
        best_index: Integer;
        best_score: Integer;
        idx: Integer;
        picked: TncCandidate;
        debug_seen_count: Integer;
        debug_first_seen: string;
        debug_full_length_count: Integer;
        debug_first_full_text: string;
        debug_first_full_segments: Integer;
        debug_candidate_segments: Integer;
    begin
        if (Length(candidates) = 0) or (input_syllable_count < c_long_sentence_exact_min_syllables) or
            (not is_full_pinyin_key(lookup_text)) then
        begin
            Exit;
        end;

        best_index := -1;
        best_score := Low(Integer);
        debug_seen_count := 0;
        debug_first_seen := '';
        debug_full_length_count := 0;
        debug_first_full_text := '';
        debug_first_full_segments := 0;
        for idx := 0 to High(candidates) do
        begin
            if (Trim(candidates[idx].comment) = '') and
                (get_candidate_text_unit_count(Trim(candidates[idx].text)) =
                input_syllable_count) then
            begin
                Inc(debug_full_length_count);
                if debug_first_full_text = '' then
                begin
                    debug_first_full_text := Trim(candidates[idx].text);
                    debug_first_full_segments := get_encoded_path_segment_count_local(
                        get_segment_path_for_candidate(candidates[idx]));
                end;
            end;

            if not is_long_sentence_exact_candidate_for_visibility(candidates[idx]) then
            begin
                Continue;
            end;

            Inc(debug_seen_count);
            if debug_first_seen = '' then
            begin
                debug_first_seen := Trim(candidates[idx].text);
            end;

            if candidates[idx].score > best_score then
            begin
                best_index := idx;
                best_score := candidates[idx].score;
            end;
        end;

        if best_index <= 0 then
        begin
            if m_config.debug_mode then
            begin
                m_last_full_path_debug_info := m_last_full_path_debug_info +
                    Format(' texact=[none seen=%d first=%s full=%d firstfull=%s seg=%d]',
                    [debug_seen_count, debug_first_seen, debug_full_length_count,
                    debug_first_full_text, debug_first_full_segments]);
            end;
            Exit;
        end;

        picked := candidates[best_index];
        for idx := best_index downto 1 do
        begin
            candidates[idx] := candidates[idx - 1];
        end;
        candidates[0] := picked;
        if m_config.debug_mode then
        begin
            debug_candidate_segments := get_encoded_path_segment_count_local(
                get_segment_path_for_candidate(picked));
            m_last_full_path_debug_info := m_last_full_path_debug_info +
                Format(' texact=[idx=%d text=%s seg=%d]',
                [best_index, Trim(picked.text), debug_candidate_segments]);
        end;
    end;

    procedure ensure_best_full_length_pathless_candidate_visible(
        var candidates: TncCandidateList);
    const
        c_pathless_exact_visibility_margin = 480;
    var
        best_index: Integer;
        best_score: Integer;
        best_segment_count: Integer;
        best_path_confidence: Integer;
        best_path_tier: Integer;
        top_units: Integer;
        idx: Integer;
        picked: TncCandidate;
        top_path_segments: Integer;
        top_path_confidence: Integer;
        candidate_path_segments: Integer;
        candidate_path_confidence: Integer;
        candidate_path_tier: Integer;
    begin
        if (Length(candidates) <= 1) or
            (input_syllable_count < c_long_sentence_exact_min_syllables) or
        (not is_full_pinyin_key(lookup_text)) then
        begin
            Exit;
        end;

        top_units := get_candidate_text_unit_count(Trim(candidates[0].text));
        top_path_segments := get_encoded_path_segment_count_local(
            get_segment_path_for_candidate(candidates[0]));
        top_path_confidence := get_candidate_path_confidence_score(candidates[0]);
        if (Trim(candidates[0].comment) <> '') or
            (top_units <> input_syllable_count) then
        begin
            Exit;
        end;

        best_index := -1;
        best_score := Low(Integer);
        best_segment_count := MaxInt;
        best_path_confidence := Low(Integer);
        best_path_tier := -1;
        for idx := 1 to High(candidates) do
        begin
            if Trim(candidates[idx].comment) <> '' then
            begin
                Continue;
            end;
            if get_candidate_text_unit_count(Trim(candidates[idx].text)) <>
                input_syllable_count then
            begin
                Continue;
            end;
            if is_runtime_chain_candidate(candidates[idx]) or
                is_runtime_common_pattern_candidate(candidates[idx]) or
                is_runtime_redup_candidate(candidates[idx]) then
            begin
                Continue;
            end;

            candidate_path_segments := get_encoded_path_segment_count_local(
                get_segment_path_for_candidate(candidates[idx]));
            if candidate_path_segments <= 1 then
            begin
                Continue;
            end;
            candidate_path_confidence := get_candidate_path_confidence_score(
                candidates[idx]);
            candidate_path_tier := get_candidate_path_confidence_tier(
                candidates[idx]);

            if (top_path_segments > 1) and
                (candidate_path_segments >= top_path_segments) and
                (candidate_path_confidence <= top_path_confidence + 64) then
            begin
                Continue;
            end;
            if (candidate_path_segments * 3) > input_syllable_count then
            begin
                Continue;
            end;
            if (top_path_segments <= 1) and
                (candidate_path_tier <= 0) and
                (candidate_path_confidence < 640) then
            begin
                Continue;
            end;

            if (top_path_segments > 1) and
                (candidates[idx].score + c_pathless_exact_visibility_margin <
                candidates[0].score) then
            begin
                Continue;
            end;

            if (best_index < 0) or
                (candidate_path_tier > best_path_tier) or
                ((candidate_path_tier = best_path_tier) and
                (candidate_path_confidence > best_path_confidence)) or
                ((candidate_path_tier = best_path_tier) and
                (candidate_path_confidence = best_path_confidence) and
                (candidate_path_segments < best_segment_count)) or
                ((candidate_path_tier = best_path_tier) and
                (candidate_path_confidence = best_path_confidence) and
                (candidate_path_segments = best_segment_count) and
                (candidates[idx].score > best_score)) then
            begin
                best_index := idx;
                best_score := candidates[idx].score;
                best_segment_count := candidate_path_segments;
                best_path_confidence := candidate_path_confidence;
                best_path_tier := candidate_path_tier;
            end;
        end;

        if best_index <= 0 then
        begin
            Exit;
        end;

        picked := candidates[best_index];
        for idx := best_index downto 1 do
        begin
            candidates[idx] := candidates[idx - 1];
        end;
        candidates[0] := picked;
    end;

    procedure infer_paths_for_front_full_length_complete_candidates(
        var candidates: TncCandidateList);
    const
        c_infer_front_limit = 6;
    var
        idx: Integer;
        inferred_score: Integer;
        inferred_segment_count: Integer;
        inferred_path: string;
        candidate_text: string;
    begin
        if (Length(candidates) = 0) or
            (input_syllable_count < c_long_sentence_exact_min_syllables) or
            (not is_full_pinyin_key(lookup_text)) then
        begin
            Exit;
        end;

        for idx := 0 to Min(c_infer_front_limit - 1, High(candidates)) do
        begin
            if Trim(candidates[idx].comment) <> '' then
            begin
                Continue;
            end;

            candidate_text := Trim(candidates[idx].text);
            if (candidate_text = '') or
                (get_candidate_text_unit_count(candidate_text) <>
                input_syllable_count) then
            begin
                Continue;
            end;

            if get_encoded_path_segment_count_local(
                get_segment_path_for_candidate(candidates[idx])) > 1 then
            begin
                Continue;
            end;

            inferred_path := infer_segment_path_for_query_text_with_score(
                lookup_text, candidate_text, inferred_score, inferred_segment_count);
            if (inferred_path = '') or (inferred_segment_count <= 1) then
            begin
                Continue;
            end;

            remember_segment_path_for_candidate(candidate_text, '',
                inferred_path, candidates[idx].score + Min(2400, inferred_score div 4));
        end;
    end;

    procedure ensure_best_inferred_full_length_candidate_visible(
        var candidates: TncCandidateList);
    const
        c_infer_front_limit = 6;
        c_infer_promote_margin = 0;
    var
        idx: Integer;
        best_index: Integer;
        best_total_score: Integer;
        best_segment_count: Integer;
        best_path: string;
        current_total_score: Integer;
        current_inferred_score: Integer;
        current_segment_count: Integer;
        current_path: string;
        candidate_text: string;
        picked: TncCandidate;

        function build_total_score_local(const candidate_score: Integer;
            const inferred_score_local: Integer;
            const segment_count_local: Integer): Integer;
        begin
            Result := (inferred_score_local * 2) + (candidate_score div 10) -
                (segment_count_local * 64);
        end;
    begin
        if (Length(candidates) <= 1) or
            (input_syllable_count < c_long_sentence_exact_min_syllables) or
            (not is_full_pinyin_key(lookup_text)) then
        begin
            Exit;
        end;

        best_index := -1;
        best_total_score := Low(Integer);
        best_segment_count := MaxInt;
        best_path := '';
        for idx := 0 to Min(c_infer_front_limit - 1, High(candidates)) do
        begin
            if Trim(candidates[idx].comment) <> '' then
            begin
                Continue;
            end;

            candidate_text := Trim(candidates[idx].text);
            if (candidate_text = '') or
                (get_candidate_text_unit_count(candidate_text) <>
                input_syllable_count) then
            begin
                Continue;
            end;

            current_path := infer_segment_path_for_query_text_with_score(
                lookup_text, candidate_text, current_inferred_score,
                current_segment_count);
            if (current_path = '') or (current_segment_count <= 1) then
            begin
                Continue;
            end;

            remember_segment_path_for_candidate(candidate_text, '',
                current_path, candidates[idx].score + Min(2400,
                current_inferred_score div 4));
            current_total_score := build_total_score_local(candidates[idx].score,
                current_inferred_score, current_segment_count);

            if (best_index < 0) or
                (current_total_score > best_total_score) or
                ((current_total_score = best_total_score) and
                (current_segment_count < best_segment_count)) then
            begin
                best_index := idx;
                best_total_score := current_total_score;
                best_segment_count := current_segment_count;
                best_path := current_path;
            end;
        end;

        if best_index <= 0 then
        begin
            Exit;
        end;

        current_path := infer_segment_path_for_query_text_with_score(
            lookup_text, Trim(candidates[0].text), current_inferred_score,
            current_segment_count);
        if (current_path <> '') and (current_segment_count > 1) then
        begin
            current_total_score := build_total_score_local(candidates[0].score,
                current_inferred_score, current_segment_count);
            if best_total_score < current_total_score + c_infer_promote_margin then
            begin
                Exit;
            end;
        end;

        picked := candidates[best_index];
        for idx := best_index downto 1 do
        begin
            candidates[idx] := candidates[idx - 1];
        end;
        candidates[0] := picked;
    end;

    function is_exact_dict_complete_candidate_for_visibility(
        const candidate: TncCandidate): Boolean;
    begin
        Result := (Trim(candidate.comment) = '') and candidate.has_dict_weight;
    end;

    procedure ensure_exact_dict_complete_candidate_visible(var candidates: TncCandidateList);
    var
        best_index: Integer;
        best_score: Integer;
        best_dict_weight: Integer;
        idx: Integer;
        picked: TncCandidate;
    begin
        if (Length(candidates) = 0) or (input_syllable_count < 2) or
            (input_syllable_count > 4) or (not is_full_pinyin_key(lookup_text)) then
        begin
            Exit;
        end;

        if is_exact_dict_complete_candidate_for_visibility(candidates[0]) then
        begin
            Exit;
        end;

        best_index := -1;
        best_score := Low(Integer);
        best_dict_weight := Low(Integer);
        for idx := 0 to High(candidates) do
        begin
            if not is_exact_dict_complete_candidate_for_visibility(candidates[idx]) then
            begin
                Continue;
            end;

            if (candidates[idx].dict_weight > best_dict_weight) or
                ((candidates[idx].dict_weight = best_dict_weight) and
                (candidates[idx].score > best_score)) then
            begin
                best_index := idx;
                best_score := candidates[idx].score;
                best_dict_weight := candidates[idx].dict_weight;
            end;
        end;

        if best_index <= 0 then
        begin
            Exit;
        end;

        picked := candidates[best_index];
        for idx := best_index downto 1 do
        begin
            candidates[idx] := candidates[idx - 1];
        end;
        candidates[0] := picked;
    end;
