                        best_score := adjusted_score;
                        best_phrase_bonus :=
                            get_preferred_query_phrase_bonus_local(lookup_text,
                            best_text);
                        best_support_score := support_score;
                        best_chunk_alignment_score := current_chunk_alignment_score;
                        best_rerank_score := current_rerank_score;
                        best_path_confidence_score := 0;
                        best_path_preference_score := 0;
                        best_head_boundary_score := current_head_boundary_score;
                        best_exact_backed_local := support_score > -960;
                        if m_config.debug_mode and best_exact_backed_local then
                        begin
                            m_last_full_path_debug_info := m_last_full_path_debug_info +
                                Format(' fqvlock=[exact text=%s]',
                                [best_text]);
                        end;
                    end;
                end;
            end;
        end;

        try_promote_full_query_subspan_resolved_candidate_local;

        trust_exact_best_local := best_exact_backed_local and
            (best_support_score > -960) and
            (best_chunk_alignment_score >= input_syllable_count * 3072);

        if not trust_exact_best_local then
        begin
            for idx := 0 to High(candidates) do
            begin
                if Trim(candidates[idx].comment) <> '' then
                begin
                    Continue;
                end;
                if get_candidate_text_unit_count(Trim(candidates[idx].text)) <>
                    input_syllable_count then
                begin
                    Continue;
                end;
                if has_explicit_apostrophe_input and
                    (not matches_explicit_apostrophe_unit_alignment(
                    candidates[idx].text)) then
                begin
                    Continue;
                end;
                current_head_boundary_score := get_fixed_boundary_head_score_local(
                    Trim(candidates[idx].text));
                if top_requires_first_unit_match and
                    (not SameText(get_first_text_unit_local(candidates[idx].text),
                    top_first_unit)) and (current_head_boundary_score < 2) then
                begin
                    Continue;
                end;

                phrase_bonus := get_preferred_query_phrase_bonus_local(lookup_text,
                    Trim(candidates[idx].text));
                support_score := get_full_query_support_score_local(
                    Trim(candidates[idx].text));
                current_chunk_alignment_score :=
                    get_full_query_chunk_alignment_score_fast_local(
                    Trim(candidates[idx].text), support_score);
                current_rerank_score := build_full_query_rerank_score_local(
                    candidates[idx].score, current_chunk_alignment_score,
                    support_score, current_head_boundary_score);
                current_path_confidence_score :=
                    get_candidate_path_confidence_score(candidates[idx]);
                current_path_preference_score := get_segment_path_preference_score(
                    get_segment_path_for_candidate(candidates[idx], idx));
                if m_config.debug_mode and (debug_full_candidate_count < 4) then
                begin
                    debug_full_candidate_summary := debug_full_candidate_summary +
                        Format(' {%s s=%d sc=%d ch=%d rr=%d hb=%d pc=%d pp=%d}',
                        [Trim(candidates[idx].text), support_score,
                        candidates[idx].score, current_chunk_alignment_score,
                        current_rerank_score, current_head_boundary_score,
                        current_path_confidence_score,
                        current_path_preference_score]);
                    Inc(debug_full_candidate_count);
                end;

                if best_exact_backed_local and (best_support_score > -960) and
                    (not has_material_support_advantage(support_score,
                    best_support_score)) and
                    (current_head_boundary_score <= best_head_boundary_score) and
                    (current_chunk_alignment_score <=
                    best_chunk_alignment_score + 4096) and
                    (current_rerank_score <= best_rerank_score + 12000) then
                begin
                    Continue;
                end;

                if (best_text = '') or
                    ((current_head_boundary_score >= 2) and
                    (current_head_boundary_score > best_head_boundary_score)) or
                    has_material_support_advantage(support_score,
                    best_support_score) and
                    allow_support_priority_override_local(support_score,
                    best_support_score, current_rerank_score,
                    best_rerank_score) or
                    has_material_chunk_alignment_advantage_local(
                    current_chunk_alignment_score,
                    best_chunk_alignment_score, support_score,
                    best_support_score) or
                    prefer_long_same_prefix_score_override_local(
                    Trim(candidates[idx].text), support_score, current_rerank_score,
                    best_text, best_support_score, best_rerank_score) or
                    has_material_rerank_advantage_local(current_rerank_score,
                    best_rerank_score, support_score, best_support_score) or
                    (allow_supportless_override_local(support_score,
                    best_support_score, current_chunk_alignment_score,
                    best_chunk_alignment_score, current_rerank_score,
                    best_rerank_score) and
                    (current_chunk_alignment_score >
                    best_chunk_alignment_score + 1600)) or
                    ((not has_material_support_advantage(best_support_score,
                    support_score)) and
                    allow_supportless_override_local(support_score,
                    best_support_score, current_chunk_alignment_score,
                    best_chunk_alignment_score, current_rerank_score,
                    best_rerank_score) and
                    allow_path_priority_override_local(current_rerank_score,
                    best_rerank_score, support_score, best_support_score) and
                    (current_path_confidence_score > best_path_confidence_score)) or
                    ((not has_material_support_advantage(best_support_score,
                    support_score)) and
                    allow_supportless_override_local(support_score,
                    best_support_score, current_chunk_alignment_score,
                    best_chunk_alignment_score, current_rerank_score,
                    best_rerank_score) and
                    allow_path_priority_override_local(current_rerank_score,
                    best_rerank_score, support_score, best_support_score) and
                    (current_path_confidence_score = best_path_confidence_score) and
                    (current_path_preference_score > best_path_preference_score)) or
                    ((not has_material_support_advantage(best_support_score,
                    support_score)) and
                    allow_supportless_override_local(support_score,
                    best_support_score, current_chunk_alignment_score,
                    best_chunk_alignment_score, current_rerank_score,
                    best_rerank_score) and
                    allow_path_priority_override_local(current_rerank_score,
                    best_rerank_score, support_score, best_support_score) and
                    (current_path_confidence_score = best_path_confidence_score) and
                    (current_path_preference_score = best_path_preference_score) and
                    (current_rerank_score > best_rerank_score)) then
                begin
                    best_candidate := candidates[idx];
                    best_text := Trim(candidates[idx].text);
                    best_weight := candidates[idx].dict_weight;
                    best_score := candidates[idx].score;
                    best_phrase_bonus := phrase_bonus;
                    best_support_score := support_score;
                    best_chunk_alignment_score := current_chunk_alignment_score;
                    best_rerank_score := current_rerank_score;
                    best_path_confidence_score := current_path_confidence_score;
                    best_path_preference_score := current_path_preference_score;
                    best_head_boundary_score := current_head_boundary_score;
                    best_exact_backed_local := False;
                end;
            end;
        end;

        if (input_syllable_count <= 3) and
            try_build_preferred_query_phrase_candidate_local(preferred_candidate) and
            ((best_text = '') or
            (get_preferred_query_phrase_bonus_local(lookup_text, best_text) <
            get_preferred_query_phrase_bonus_local(lookup_text,
            preferred_candidate.text))) then
        begin
            best_candidate := preferred_candidate;
            best_text := Trim(preferred_candidate.text);
            best_weight := preferred_candidate.dict_weight;
            best_score := preferred_candidate.score;
            best_chunk_alignment_score := 0;
            best_rerank_score := preferred_candidate.score;
        end;

        if (not trust_exact_best_local) and
            (not ((best_text <> '') and (best_support_score >= 4096))) and
            is_full_pinyin_key(lookup_text) and
            (input_syllable_count >= 4) then
        begin
            ensure_strict_oracle_sentence_candidates_prepared;
            if strict_oracle_sentence_ok then
            begin
                oracle_candidates := strict_oracle_sentence_candidates;
                for idx := 0 to High(oracle_candidates) do
                begin
                    if Trim(oracle_candidates[idx].comment) <> '' then
                    begin
                        Continue;
                    end;
                    if get_candidate_text_unit_count(
                        Trim(oracle_candidates[idx].text)) <> input_syllable_count then
                    begin
                        Continue;
                    end;
                    if top_requires_first_unit_match and
                        (best_support_score > -960) and
                        (not SameText(get_first_text_unit_local(
                        oracle_candidates[idx].text), top_first_unit)) then
                    begin
                        Continue;
                    end;

                    support_score := get_full_query_support_score_local(
                        Trim(oracle_candidates[idx].text));
                    current_head_boundary_score :=
                        get_fixed_boundary_head_score_local(
                        Trim(oracle_candidates[idx].text));
                    current_chunk_alignment_score :=
                        get_full_query_chunk_alignment_score_fast_local(
                        Trim(oracle_candidates[idx].text), support_score);
                    current_rerank_score := build_full_query_rerank_score_local(
                        oracle_candidates[idx].score,
                        current_chunk_alignment_score, support_score,
                        current_head_boundary_score);
                    current_path_confidence_score :=
                        get_candidate_path_confidence_score(oracle_candidates[idx]);
                    current_path_preference_score :=
                        get_segment_path_preference_score(
                        get_segment_path_for_candidate(oracle_candidates[idx], idx));

                    if best_exact_backed_local and (best_support_score > -960) and
                        (not has_material_support_advantage(support_score,
                        best_support_score)) and
                        (current_head_boundary_score <= best_head_boundary_score) and
                        (current_chunk_alignment_score <=
                        best_chunk_alignment_score + 4096) and
                        (current_rerank_score <= best_rerank_score + 12000) then
                    begin
                        if m_config.debug_mode then
                        begin
                            m_last_full_path_debug_info :=
                                m_last_full_path_debug_info +
                                Format(' fqvlock=[skip_oracle best=%s over=%s]',
                                [best_text, Trim(oracle_candidates[idx].text)]);
                        end;
                        Continue;
                    end;

                    if (best_text = '') or
                        ((current_head_boundary_score >= 2) and
                        (current_head_boundary_score >
                        best_head_boundary_score)) or
                        has_material_support_advantage(support_score,
                        best_support_score) and
                        allow_support_priority_override_local(support_score,
                        best_support_score, current_rerank_score,
                        best_rerank_score) or
                        has_material_chunk_alignment_advantage_local(
                        current_chunk_alignment_score,
                        best_chunk_alignment_score, support_score,
                        best_support_score) or
                        prefer_long_same_prefix_score_override_local(
                        Trim(oracle_candidates[idx].text), support_score,
                        current_rerank_score, best_text,
                        best_support_score, best_rerank_score) or
                        has_material_rerank_advantage_local(
                        current_rerank_score, best_rerank_score,
                        support_score, best_support_score) or
                        (allow_supportless_override_local(support_score,
                        best_support_score, current_chunk_alignment_score,
                        best_chunk_alignment_score, current_rerank_score,
                        best_rerank_score) and
                        (current_chunk_alignment_score >
                        best_chunk_alignment_score + 1600)) or
                        ((not has_material_support_advantage(best_support_score,
                        support_score)) and
                        allow_supportless_override_local(support_score,
                        best_support_score, current_chunk_alignment_score,
                        best_chunk_alignment_score, current_rerank_score,
                        best_rerank_score) and
                        allow_path_priority_override_local(current_rerank_score,
                        best_rerank_score, support_score, best_support_score) and
                        (current_path_confidence_score >
                        best_path_confidence_score)) or
                        ((not has_material_support_advantage(best_support_score,
                        support_score)) and
                        allow_supportless_override_local(support_score,
                        best_support_score, current_chunk_alignment_score,
                        best_chunk_alignment_score, current_rerank_score,
                        best_rerank_score) and
                        allow_path_priority_override_local(current_rerank_score,
                        best_rerank_score, support_score, best_support_score) and
                        (current_path_confidence_score =
                        best_path_confidence_score) and
                        (current_path_preference_score >
                        best_path_preference_score)) or
                        ((not has_material_support_advantage(best_support_score,
                        support_score)) and
                        allow_supportless_override_local(support_score,
                        best_support_score, current_chunk_alignment_score,
                        best_chunk_alignment_score, current_rerank_score,
                        best_rerank_score) and
                        allow_path_priority_override_local(current_rerank_score,
                        best_rerank_score, support_score, best_support_score) and
                        (current_path_confidence_score =
                        best_path_confidence_score) and
                        (current_path_preference_score =
                        best_path_preference_score) and
                        (current_rerank_score > best_rerank_score)) then
                    begin
                        best_candidate := oracle_candidates[idx];
                        best_text := Trim(oracle_candidates[idx].text);
                        best_weight := oracle_candidates[idx].dict_weight;
                        best_score := oracle_candidates[idx].score;
                        best_phrase_bonus := get_preferred_query_phrase_bonus_local(
                            lookup_text, best_text);
                        best_support_score := support_score;
                        best_chunk_alignment_score := current_chunk_alignment_score;
                        best_rerank_score := current_rerank_score;
                        best_path_confidence_score :=
                            current_path_confidence_score;
                        best_path_preference_score :=
                            current_path_preference_score;
                        best_head_boundary_score := current_head_boundary_score;
                        best_exact_backed_local := False;
                    end;
                end;
            end;
        end;

        if not trust_exact_best_local then
        begin
            maybe_promote_best_supported_full_candidate_local;
            maybe_promote_best_rerank_complete_candidate_local;
            ensure_best_front_complete_chunk_rerank_candidate_local;
            ensure_best_nearby_variant_complete_candidate_visible_local;
            maybe_promote_fixed_boundary_variant_candidate_local;
            maybe_promote_modal_tail_complete_candidate_local;
            maybe_promote_high_score_complete_candidate_local;
        end;

        if best_text = '' then
        begin
            Exit;
        end;

        if m_config.debug_mode then
        begin
            m_last_full_path_debug_info := m_last_full_path_debug_info +
                Format(' fqv=[best text=%s support=%d phrase=%d score=%d chunk=%d rerank=%d pconf=%d ppref=%d]',
                [best_text, best_support_score, best_phrase_bonus, best_score,
                best_chunk_alignment_score, best_rerank_score,
                best_path_confidence_score, best_path_preference_score]);
            if debug_full_candidate_summary <> '' then
            begin
                m_last_full_path_debug_info := m_last_full_path_debug_info +
                    Format(' fqvcands=%s', [debug_full_candidate_summary]);
            end;
        end;

        existing_index := -1;
        for idx := 0 to High(candidates) do
        begin
            if (Trim(candidates[idx].comment) = '') and
                SameText(Trim(candidates[idx].text), best_text) then
            begin
                existing_index := idx;
                Break;
            end;
        end;

        if existing_index = 0 then
        begin
            full_query_exact_promoted := True;
            Exit;
        end;

        if existing_index > 0 then
        begin
            best_candidate := candidates[existing_index];
            if best_candidate.score < best_score then
            begin
                best_candidate.score := best_score;
            end;
            if best_candidate.has_dict_weight and (best_candidate.dict_weight < best_weight) then
            begin
                best_candidate.dict_weight := best_weight;
            end;
        end
        else
        begin
            existing_index := Length(candidates);
            SetLength(candidates, existing_index + 1);
        end;

        best_candidate.comment := '';
        for idx := existing_index downto 1 do
        begin
            candidates[idx] := candidates[idx - 1];
        end;
        candidates[0] := best_candidate;
        full_query_exact_promoted := True;
    end;

