        function has_exact_query_text_match_solver_local(const query_key: string;
            const candidate_text: string): Boolean;
        var
            local_results_local: TncCandidateList;
            result_idx_local: Integer;
        begin
            Result := False;
            if (m_dictionary = nil) or (query_key = '') or (candidate_text = '') then
            begin
                Exit;
            end;

            if not m_dictionary.lookup_exact_full_pinyin(query_key,
                local_results_local) then
            begin
                Exit;
            end;

            for result_idx_local := 0 to High(local_results_local) do
            begin
                if result_idx_local >= c_solver_probe_limit * 3 then
                begin
                    Break;
                end;
                if Trim(local_results_local[result_idx_local].comment) <> '' then
                begin
                    Continue;
                end;
                if SameText(Trim(local_results_local[result_idx_local].text),
                    candidate_text) then
                begin
                    Exit(True);
                end;
            end;
        end;

        function get_exact_query_text_bonus_solver_local(const query_key: string;
            const candidate_text: string): Integer;
        begin
            if has_exact_query_text_match_solver_local(query_key, candidate_text) then
            begin
                Exit(3072);
            end;
            Result := 0;
        end;

        function has_competing_exact_full_phrase_solver_local(
            const query_key: string; const candidate_text: string): Boolean;
        var
            local_results_local: TncCandidateList;
            local_syllables: TncPinyinParseResult;
            result_idx_local: Integer;
            exact_text_local: string;
            has_competing_exact: Boolean;
            candidate_is_exact: Boolean;
        begin
            Result := False;
            if (m_dictionary = nil) or (query_key = '') or
                (Trim(candidate_text) = '') then
            begin
                Exit;
            end;

            if m_dictionary.get_query_choice_bonus(query_key,
                candidate_text) > 0 then
            begin
                Exit;
            end;

            local_syllables := get_effective_compact_pinyin_syllables(query_key);
            if Length(local_syllables) <= 0 then
            begin
                Exit;
            end;

            if not m_dictionary.lookup_exact_full_pinyin(query_key,
                local_results_local) then
            begin
                Exit;
            end;

            has_competing_exact := False;
            candidate_is_exact := False;
            for result_idx_local := 0 to High(local_results_local) do
            begin
                if result_idx_local >= c_solver_probe_limit * 3 then
                begin
                    Break;
                end;
                if Trim(local_results_local[result_idx_local].comment) <> '' then
                begin
                    Continue;
                end;

                exact_text_local := Trim(local_results_local[result_idx_local].text);
                if get_candidate_text_unit_count(exact_text_local) <>
                    Length(local_syllables) then
                begin
                    Continue;
                end;

                if SameText(exact_text_local, Trim(candidate_text)) then
                begin
                    candidate_is_exact := True;
                end
                else
                begin
                    has_competing_exact := True;
                end;
            end;

            Result := has_competing_exact and (not candidate_is_exact);
        end;

        function get_trailing_context_free_single_char_penalty_solver_local(
            const query_key: string; const candidate_text: string): Integer;
        var
            query_syllables_local: TncPinyinParseResult;
            text_units_local: TArray<string>;
            tail_pinyin_local: string;
            tail_text_local: string;
        begin
            Result := 0;
            if (query_key = '') or (candidate_text = '') then
            begin
                Exit;
            end;

            query_syllables_local := get_effective_compact_pinyin_syllables(query_key);
            if Length(query_syllables_local) < 2 then
            begin
                Exit;
            end;

            text_units_local := split_text_units(candidate_text);
            if Length(text_units_local) <> Length(query_syllables_local) then
            begin
                Exit;
            end;

            tail_pinyin_local := normalize_pinyin_text(
                query_syllables_local[High(query_syllables_local)].text);
            tail_text_local := text_units_local[High(text_units_local)];
            if SameText(tail_text_local,
                get_fixed_boundary_single_char_for_solver_local(
                tail_pinyin_local)) then
            begin
                Result := get_context_free_single_char_penalty_solver_local(
                    tail_pinyin_local, tail_text_local) * 2;
            end;
        end;

        function is_valid_solver_cjk_phrase_text_local(const value: string;
            const expected_units: Integer): Boolean;
        var
            units: TArray<string>;
            unit_idx: Integer;
            codepoint: Integer;

            function try_get_codepoint_local(const unit_text: string;
                out out_codepoint: Integer): Boolean;
            begin
                Result := False;
                out_codepoint := 0;
                if unit_text = '' then
                begin
                    Exit;
                end;

                if Length(unit_text) = 1 then
                begin
                    out_codepoint := Ord(unit_text[1]);
                    Exit(True);
                end;

                if (Length(unit_text) = 2) and
                    (Ord(unit_text[1]) >= $D800) and
                    (Ord(unit_text[1]) <= $DBFF) and
                    (Ord(unit_text[2]) >= $DC00) and
                    (Ord(unit_text[2]) <= $DFFF) then
                begin
                    out_codepoint := ((Ord(unit_text[1]) - $D800) shl 10) +
                        (Ord(unit_text[2]) - $DC00) + $10000;
                    Exit(True);
                end;
            end;
        begin
            Result := False;
            if Trim(value) = '' then
            begin
                Exit;
            end;

            units := split_text_units(Trim(value));
            if Length(units) <> expected_units then
            begin
                Exit;
            end;

            for unit_idx := 0 to High(units) do
            begin
                if (not try_get_codepoint_local(units[unit_idx], codepoint)) or
                    (codepoint < $4E00) or (codepoint > $9FFF) then
                begin
                    Exit(False);
                end;
            end;

            Result := True;
        end;

        function is_solver_boundary_tail_local(const tail_query_key: string): Boolean;
        var
            tail_syllables: TncPinyinParseResult;
            first_tail: string;
        begin
            Result := False;
            if tail_query_key = '' then
            begin
                Exit;
            end;

            tail_syllables := get_effective_compact_pinyin_syllables(tail_query_key);
            if Length(tail_syllables) = 0 then
            begin
                Exit;
            end;

            first_tail := normalize_pinyin_text(tail_syllables[0].text);
            Result := (first_tail = 'de') or (first_tail = 'le') or
                (first_tail = 'ma') or (first_tail = 'ba') or
                (first_tail = 'ne') or (first_tail = 'a') or
                (first_tail = 'ya') or (first_tail = 'la') or
                (first_tail = 'wa');
        end;

        function get_first_solver_text_unit_local(const text: string): string;
        var
            units: TArray<string>;
        begin
            Result := '';
            units := split_text_units(text);
            if Length(units) > 0 then
            begin
                Result := units[0];
            end;
        end;

        function try_get_exact_single_char_candidate_local(const start_idx: Integer;
            out out_text: string; out out_score: Integer): Boolean;
        var
            query_key: string;
            local_results: TncCandidateList;
            result_idx: Integer;
            candidate_text: string;
            candidate_score: Integer;
            preferred_text: string;
        begin
            Result := False;
            out_text := '';
            out_score := 0;

            preferred_text := get_fixed_boundary_single_char_for_solver_local(
                effective_syllables[start_idx].text);
            query_key := normalize_pinyin_text(effective_syllables[start_idx].text);
            if (query_key = '') or (m_dictionary = nil) then
            begin
                if preferred_text <> '' then
                begin
                    out_text := preferred_text;
                    out_score := 1500;
                    Exit(True);
                end;
                Exit;
            end;

            if not m_dictionary.lookup_exact_full_pinyin(query_key, local_results) then
            begin
                if preferred_text <> '' then
                begin
                    out_text := preferred_text;
                    out_score := 1500;
                    Exit(True);
                end;
                Exit;
            end;

            for result_idx := 0 to High(local_results) do
            begin
                if result_idx >= c_solver_probe_limit then
                begin
                    Break;
                end;
                if Trim(local_results[result_idx].comment) <> '' then
                begin
                    Continue;
                end;
                candidate_text := Trim(local_results[result_idx].text);
                if get_candidate_text_unit_count(candidate_text) <> 1 then
                begin
                    Continue;
                end;

                candidate_score := local_results[result_idx].score;
                if local_results[result_idx].has_dict_weight and
                    (local_results[result_idx].dict_weight > candidate_score) then
                begin
                    candidate_score := local_results[result_idx].dict_weight;
                end;
                Dec(candidate_score,
                    get_context_free_single_char_penalty_solver_local(query_key,
                    candidate_text));

                if (preferred_text <> '') and SameText(candidate_text, preferred_text) then
                begin
                    Inc(candidate_score, 1800);
                end;

                if (not Result) or (candidate_score > out_score) then
                begin
                    Result := True;
                    out_text := candidate_text;
                    out_score := candidate_score;
                end;
            end;

            if (not Result) and (preferred_text <> '') then
            begin
                out_text := preferred_text;
                out_score := 1500;
                Result := True;
            end;
        end;

