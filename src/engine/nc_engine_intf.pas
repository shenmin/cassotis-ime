        function sentence_subspan_has_fixed_boundary(
            const segment_start: Integer; const segment_syllables: Integer): Boolean;
        var
            unit_idx_local: Integer;
        begin
            Result := False;
            if (segment_start < 0) or (segment_syllables <= 0) or
                (segment_start + segment_syllables > head_syllable_count) then
            begin
                Exit;
            end;

            for unit_idx_local := 0 to segment_syllables - 1 do
            begin
                if get_fixed_sentence_single_char(
                    normalize_pinyin_text(
                    syllables[segment_start + unit_idx_local].text)) <> '' then
                begin
                    Exit(True);
                end;
            end;
        end;

        function get_fixed_boundary_alignment_adjustment(
            const segment_start: Integer; const segment_syllables: Integer;
            const candidate_text: string): Integer;
        const
            c_match_bonus = 6000;
            c_full_match_bonus = 6000;
            c_mismatch_penalty = 24000;
            c_edge_mismatch_penalty = 8000;
        var
            text_units_local: TArray<string>;
            unit_idx_local: Integer;
            expected_text_local: string;
            checked_count_local: Integer;
            match_count_local: Integer;
        begin
            Result := 0;
            if (segment_start < 0) or (segment_syllables <= 0) or
                (segment_start + segment_syllables > head_syllable_count) or
                (candidate_text = '') then
            begin
                Exit;
            end;

            text_units_local := split_text_units(Trim(candidate_text));
            if Length(text_units_local) <> segment_syllables then
            begin
                Exit;
            end;

            checked_count_local := 0;
            match_count_local := 0;
            for unit_idx_local := 0 to segment_syllables - 1 do
            begin
                expected_text_local := get_fixed_sentence_single_char(
                    normalize_pinyin_text(
                    syllables[segment_start + unit_idx_local].text));
                if expected_text_local = '' then
                begin
                    Continue;
                end;

                Inc(checked_count_local);
                if SameText(text_units_local[unit_idx_local],
                    expected_text_local) then
                begin
                    Inc(match_count_local);
                    Inc(Result, c_match_bonus);
                end
                else
                begin
                    Dec(Result, c_mismatch_penalty);
                    if (unit_idx_local = 0) or
                        (unit_idx_local = segment_syllables - 1) then
                    begin
                        Dec(Result, c_edge_mismatch_penalty);
                    end;
                end;
            end;

            if (checked_count_local >= 2) and
                (match_count_local = checked_count_local) then
            begin
                Inc(Result, c_full_match_bonus);
            end;
        end;

        function try_get_best_sentence_subspan_standalone_candidate_local(
            const query_key_local: string; const expected_syllables: Integer;
            out out_text: string; out out_score: Integer): Boolean;
        const
            c_probe_limit = 6;
        var
            cached_state_local: Integer;
            snapshot_candidates_local: TncCandidateList;
            snapshot_scores_local: TArray<Integer>;
            candidate_idx_local: Integer;
            candidate_local: TncCandidate;
            candidate_text_local: string;
            candidate_units_local: Integer;
            candidate_score_local: Integer;
            best_text_local: string;
            best_score_local: Integer;
            preferred_bonus_local: Integer;
            preferred_exact_bonus_local: Integer;
            preferred_text_local: string;
        begin
            Result := False;
            out_text := '';
            out_score := 0;
            preferred_text_local := '';
            preferred_bonus_local := 0;
            if (query_key_local = '') or
                (not is_full_pinyin_key(query_key_local)) or
                (expected_syllables < 2) or (expected_syllables > 8) or
                (m_disable_subspan_standalone_oracle > 0) then
            begin
                Exit;
            end;

            try_get_preferred_query_phrase_text_local(query_key_local,
                preferred_text_local, preferred_bonus_local);

            if subspan_oracle_states = nil then
            begin
                subspan_oracle_states := TDictionary<string, Integer>.Create;
                subspan_oracle_texts := TDictionary<string, string>.Create;
                subspan_oracle_scores := TDictionary<string, Integer>.Create;
            end;

            if subspan_oracle_states.TryGetValue(query_key_local,
                cached_state_local) then
            begin
                if cached_state_local = 1 then
                begin
                    subspan_oracle_texts.TryGetValue(query_key_local, out_text);
                    subspan_oracle_scores.TryGetValue(query_key_local, out_score);
                    Exit(out_text <> '');
                end;
                Exit(False);
            end;

            if subspan_oracle_budget_remaining <= 0 then
            begin
                Exit;
            end;

            if subspan_oracle_engine = nil then
            begin
                subspan_oracle_config := m_config;
                subspan_oracle_config.debug_mode := False;
                subspan_oracle_config.max_candidates := 6;
                subspan_oracle_engine := TncEngine.Create(subspan_oracle_config);
            end;

            Dec(subspan_oracle_budget_remaining);
            subspan_oracle_states.AddOrSetValue(query_key_local, 3);
            subspan_oracle_engine.m_disable_subspan_standalone_oracle :=
                m_disable_subspan_standalone_oracle + 1;
            subspan_oracle_engine.reset;
            subspan_oracle_engine.m_composition_text := query_key_local;
            subspan_oracle_engine.build_candidates;

            SetLength(snapshot_candidates_local,
                Length(subspan_oracle_engine.m_candidates));
            SetLength(snapshot_scores_local,
                Length(subspan_oracle_engine.m_candidates));
            for candidate_idx_local := 0 to High(subspan_oracle_engine.m_candidates) do
            begin
                snapshot_candidates_local[candidate_idx_local] :=
                    subspan_oracle_engine.m_candidates[candidate_idx_local];
                snapshot_scores_local[candidate_idx_local] :=
                    subspan_oracle_engine.get_rank_score(
                    subspan_oracle_engine.m_candidates[candidate_idx_local]);
            end;

            best_text_local := '';
            best_score_local := Low(Integer);
            for candidate_idx_local := 0 to High(snapshot_candidates_local) do
            begin
                if candidate_idx_local >= c_probe_limit then
                begin
                    Break;
                end;

                candidate_local := snapshot_candidates_local[candidate_idx_local];
                if Trim(candidate_local.comment) <> '' then
                begin
                    Continue;
                end;

                candidate_text_local := Trim(candidate_local.text);
                candidate_units_local := get_candidate_text_unit_count(
                    candidate_text_local);
                if candidate_units_local <> expected_syllables then
                begin
                    Continue;
                end;

                candidate_score_local := snapshot_scores_local[candidate_idx_local] +
                    get_preferred_query_phrase_bonus_local(query_key_local,
                    candidate_text_local);
                preferred_exact_bonus_local :=
                    get_preferred_exact_subspan_bonus_local(query_key_local,
                    candidate_text_local);
                if preferred_exact_bonus_local > 0 then
                begin
                    Inc(candidate_score_local,
                        preferred_exact_bonus_local + 12000);
                end;

                if candidate_score_local > best_score_local then
                begin
                    best_score_local := candidate_score_local;
                    best_text_local := candidate_text_local;
                end;
            end;

            if best_text_local <> '' then
            begin
                out_text := best_text_local;
                out_score := best_score_local;
                subspan_oracle_states.AddOrSetValue(query_key_local, 1);
                subspan_oracle_texts.AddOrSetValue(query_key_local, out_text);
                subspan_oracle_scores.AddOrSetValue(query_key_local, out_score);
                Exit(True);
            end;

            subspan_oracle_states.AddOrSetValue(query_key_local, 2);
        end;

        function try_resolve_best_exact_sentence_subspan(
            const start_idx: Integer; const span_syllables: Integer;
            out out_text: string; out out_weight: Integer;
            out out_anchor_units: Integer): Boolean;
        const
            c_subspan_max_syllables = 5;
            c_subspan_beam_width = 6;
            c_subspan_chunk_probe_limit = 8;
            c_subspan_single_penalty = 120;
            c_subspan_additional_segment_penalty = 80;
            c_subspan_multi_bonus = 240;
            c_subspan_anchor_bonus = 420;
            c_subspan_preferred_bonus = 320;
            c_subspan_rank_step = 240;
        type
            TSubspanState = record
                score: Integer;
                weight: Integer;
                text: string;
                prev_text: string;
                anchor_units: Integer;
            end;
            TSubspanStateArray = TArray<TSubspanState>;
        var
            local_states: array of TSubspanStateArray;

            procedure add_subspan_state(var states: TSubspanStateArray;
                const candidate_state: TSubspanState);
            var
                idx_local: Integer;
                insert_idx_local: Integer;
                tmp_state_local: TSubspanState;
            begin
                for idx_local := 0 to High(states) do
                begin
                    if states[idx_local].text = candidate_state.text then
                    begin
                        if candidate_state.score > states[idx_local].score then
                        begin
                            states[idx_local] := candidate_state;
                        end;
                        Exit;
                    end;
                end;

                insert_idx_local := Length(states);
                SetLength(states, insert_idx_local + 1);
                states[insert_idx_local] := candidate_state;
                while (insert_idx_local > 0) and
                    (states[insert_idx_local].score > states[insert_idx_local - 1].score) do
                begin
                    tmp_state_local := states[insert_idx_local - 1];
                    states[insert_idx_local - 1] := states[insert_idx_local];
                    states[insert_idx_local] := tmp_state_local;
                    Dec(insert_idx_local);
                end;

                if Length(states) > c_subspan_beam_width then
                begin
                    SetLength(states, c_subspan_beam_width);
                end;
            end;

        var
            local_pos: Integer;
            state_idx_local: Integer;
            base_state_local: TSubspanState;
            next_state_local: TSubspanState;
            syllable_key_local: string;
            fixed_text_local: string;
            single_results_local: TncCandidateList;
            exact_results_local: TncCandidateList;
            lookup_results_local: TncCandidateList;
            exact_only_results_local: TncCandidateList;
            exact_idx_local: Integer;
            merged_idx_local: Integer;
            chunk_len_local: Integer;
            query_key_local: string;
            candidate_text_local: string;
            preferred_text_local: string;
            preferred_bonus_local: Integer;
            effective_weight_local: Integer;
            candidate_units_local: Integer;
            next_pos_local: Integer;
            duplicate_found_local: Boolean;
            standalone_text_local: string;
            standalone_score_local: Integer;
            standalone_candidate_local: TncCandidate;
        begin
            out_text := '';
            out_weight := 0;
            out_anchor_units := 0;
            Result := False;
            if (span_syllables <= 0) or (span_syllables > c_subspan_max_syllables) or
                (start_idx < 0) or (start_idx + span_syllables > head_syllable_count) then
            begin
                Exit;
            end;

            if not exact_sentence_subspan_cache_prepared then
            begin
                SetLength(exact_sentence_subspan_cache_ready, head_syllable_count);
                SetLength(exact_sentence_subspan_cache_weights, head_syllable_count);
                SetLength(exact_sentence_subspan_cache_anchor_units, head_syllable_count);
                SetLength(exact_sentence_subspan_cache_texts, head_syllable_count);
                for local_pos := 0 to head_syllable_count - 1 do
                begin
                    SetLength(exact_sentence_subspan_cache_ready[local_pos],
                        c_subspan_max_syllables + 1);
                    SetLength(exact_sentence_subspan_cache_weights[local_pos],
                        c_subspan_max_syllables + 1);
                    SetLength(exact_sentence_subspan_cache_anchor_units[local_pos],
                        c_subspan_max_syllables + 1);
                    SetLength(exact_sentence_subspan_cache_texts[local_pos],
                        c_subspan_max_syllables + 1);
                end;
                exact_sentence_subspan_cache_prepared := True;
            end;

            if exact_sentence_subspan_cache_ready[start_idx][span_syllables] then
            begin
                out_text := exact_sentence_subspan_cache_texts[start_idx][span_syllables];
                out_weight := exact_sentence_subspan_cache_weights[start_idx][span_syllables];
                out_anchor_units := exact_sentence_subspan_cache_anchor_units[start_idx][span_syllables];
                Exit(out_text <> '');
            end;

            SetLength(local_states, span_syllables + 1);
            SetLength(local_states[0], 1);
            local_states[0][0].score := 0;
            local_states[0][0].weight := 0;
            local_states[0][0].text := '';
            local_states[0][0].prev_text := '';
            local_states[0][0].anchor_units := 0;

            for local_pos := 0 to span_syllables - 1 do
            begin
                for state_idx_local := 0 to High(local_states[local_pos]) do
                begin
                    base_state_local := local_states[local_pos][state_idx_local];
                    syllable_key_local := normalize_pinyin_text(
                        syllables[start_idx + local_pos].text);
                    if syllable_key_local = '' then
                    begin
                        Continue;
                    end;

                    fixed_text_local := get_fixed_sentence_single_char(syllable_key_local);
                    if fixed_text_local <> '' then
                    begin
                        next_state_local.score := base_state_local.score + 960 +
                            c_subspan_anchor_bonus - c_subspan_single_penalty;
                        next_state_local.weight := base_state_local.weight + 960;
                        if base_state_local.text <> '' then
                        begin
                            Dec(next_state_local.score, c_subspan_additional_segment_penalty);
                            if m_dictionary <> nil then
                                begin
                                    Inc(next_state_local.score,
                                        get_sentence_context_bonus_scaled(
                                        base_state_local.prev_text,
                                        fixed_text_local));
                                end;
                            next_state_local.text := base_state_local.text + fixed_text_local;
                        end
                        else
                        begin
                            next_state_local.text := fixed_text_local;
                        end;
                        next_state_local.prev_text := fixed_text_local;
                        next_state_local.anchor_units := base_state_local.anchor_units + 1;
                        add_subspan_state(local_states[local_pos + 1], next_state_local);
                    end;

                    if dictionary_exact_lookup_cached(syllable_key_local, single_results_local) then
                    begin
                        for exact_idx_local := 0 to High(single_results_local) do
                        begin
                            if exact_idx_local >= c_subspan_chunk_probe_limit then
                            begin
                                Break;
                            end;
                            if Trim(single_results_local[exact_idx_local].comment) <> '' then
                            begin
                                Continue;
                            end;
                            candidate_text_local := Trim(single_results_local[exact_idx_local].text);
                            if get_candidate_text_unit_count(candidate_text_local) <> 1 then
                            begin
                                Continue;
                            end;
                            effective_weight_local := single_results_local[exact_idx_local].score;
                            if single_results_local[exact_idx_local].has_dict_weight and
                                (single_results_local[exact_idx_local].dict_weight >
                                effective_weight_local) then
                            begin
                                effective_weight_local :=
                                    single_results_local[exact_idx_local].dict_weight;
                            end;
                            if not is_extended_allowed_single_char_for_sentence(
                                syllable_key_local, candidate_text_local, effective_weight_local) then
                            begin
                                Continue;
                            end;

                            next_state_local.score := base_state_local.score +
                                effective_weight_local - c_subspan_single_penalty;
                            next_state_local.weight := base_state_local.weight +
                                effective_weight_local;
                            if base_state_local.text <> '' then
                            begin
                                Dec(next_state_local.score, c_subspan_additional_segment_penalty);
                                if m_dictionary <> nil then
                                begin
                                    Inc(next_state_local.score,
                                        get_sentence_context_bonus_scaled(
                                        base_state_local.prev_text,
                                        candidate_text_local));
                                end;
                                next_state_local.text := base_state_local.text + candidate_text_local;
                            end
                            else
                            begin
                                next_state_local.text := candidate_text_local;
                            end;
                            next_state_local.prev_text := candidate_text_local;
                            next_state_local.anchor_units := base_state_local.anchor_units;
                            add_subspan_state(local_states[local_pos + 1], next_state_local);
                        end;
                    end;

                    for chunk_len_local := 2 to Min(c_subspan_max_syllables,
                        span_syllables - local_pos) do
                    begin
                        query_key_local := build_syllable_query_key(start_idx + local_pos,
                            chunk_len_local);
                        if query_key_local = '' then
                        begin
                            Continue;
                        end;

                        SetLength(exact_results_local, 0);
                        if dictionary_lookup_cached(query_key_local,
                            lookup_results_local) then
                        begin
                            SetLength(exact_results_local, Length(lookup_results_local));
                            for merged_idx_local := 0 to High(lookup_results_local) do
                            begin
                                exact_results_local[merged_idx_local] :=
                                    lookup_results_local[merged_idx_local];
                            end;
                        end;

                        if dictionary_exact_lookup_cached(query_key_local,
                            exact_only_results_local) then
                        begin
                            for exact_idx_local := 0 to High(exact_only_results_local) do
                            begin
                                duplicate_found_local := False;
                                for merged_idx_local := 0 to High(exact_results_local) do
                                begin
                                    if SameText(Trim(exact_results_local[merged_idx_local].text),
                                        Trim(exact_only_results_local[exact_idx_local].text)) and
                                        SameText(Trim(exact_results_local[merged_idx_local].comment),
                                        Trim(exact_only_results_local[exact_idx_local].comment)) then
                                    begin
                                        duplicate_found_local := True;
                                        Break;
                                    end;
                                end;
                                if duplicate_found_local then
                                begin
                                    Continue;
                                end;
                                SetLength(exact_results_local, Length(exact_results_local) + 1);
                                exact_results_local[High(exact_results_local)] :=
                                    exact_only_results_local[exact_idx_local];
                            end;
                        end;

                        if Length(exact_results_local) = 0 then
                        begin
                            Continue;
                        end;

                        if sentence_subspan_has_fixed_boundary(
                            start_idx + local_pos, chunk_len_local) and
                            try_get_best_sentence_subspan_standalone_candidate_local(
                            query_key_local, chunk_len_local,
                            standalone_text_local, standalone_score_local) and
                            (standalone_text_local <> '') then
                        begin
                            duplicate_found_local := False;
                            for merged_idx_local := 0 to High(exact_results_local) do
                            begin
                                if SameText(
                                    Trim(exact_results_local[merged_idx_local].text),
                                    standalone_text_local) then
                                begin
                                    duplicate_found_local := True;
                                    Break;
                                end;
                            end;

                            if not duplicate_found_local then
                            begin
                                FillChar(standalone_candidate_local,
                                    SizeOf(standalone_candidate_local), 0);
                                standalone_candidate_local.text := standalone_text_local;
                                standalone_candidate_local.comment := '';
                                standalone_candidate_local.score := standalone_score_local;
                                standalone_candidate_local.source := cs_rule;
                                standalone_candidate_local.has_dict_weight := True;
                                standalone_candidate_local.dict_weight :=
                                    standalone_score_local;
                                SetLength(exact_results_local,
                                    Length(exact_results_local) + 1);
                                for merged_idx_local := High(exact_results_local)
                                    downto 1 do
                                begin
                                    exact_results_local[merged_idx_local] :=
                                        exact_results_local[merged_idx_local - 1];
                                end;
                                exact_results_local[0] :=
                                    standalone_candidate_local;
                            end;
                        end;

                        preferred_text_local := '';
                        preferred_bonus_local := 0;
                        try_get_preferred_query_phrase_text_local(query_key_local,
                            preferred_text_local, preferred_bonus_local);
                        next_pos_local := local_pos + chunk_len_local;
                        for exact_idx_local := 0 to High(exact_results_local) do
                        begin
                            if exact_idx_local >= c_subspan_chunk_probe_limit then
                            begin
                                Break;
                            end;
                            if Trim(exact_results_local[exact_idx_local].comment) <> '' then
                            begin
                                Continue;
                            end;
                            if is_runtime_chain_candidate(exact_results_local[exact_idx_local]) or
                                is_runtime_common_pattern_candidate(exact_results_local[exact_idx_local]) or
                                is_runtime_redup_candidate(exact_results_local[exact_idx_local]) then
                            begin
                                Continue;
                            end;

                            candidate_text_local := Trim(exact_results_local[exact_idx_local].text);
                            candidate_units_local := get_candidate_text_unit_count(
                                candidate_text_local);
                            if candidate_units_local < 2 then
                            begin
                                Continue;
                            end;
                            effective_weight_local := exact_results_local[exact_idx_local].score;
                            if exact_results_local[exact_idx_local].has_dict_weight and
                                (exact_results_local[exact_idx_local].dict_weight >
                                effective_weight_local) then
                            begin
                                effective_weight_local :=
                                    exact_results_local[exact_idx_local].dict_weight;
                            end;

                            next_state_local.score := base_state_local.score +
                                effective_weight_local + c_subspan_multi_bonus +
                                ((c_subspan_chunk_probe_limit - exact_idx_local) *
                                c_subspan_rank_step) +
                                (chunk_len_local * 24);
                            next_state_local.weight := base_state_local.weight +
                                effective_weight_local;
                            if base_state_local.text <> '' then
                            begin
                                Dec(next_state_local.score, c_subspan_additional_segment_penalty);
                                if m_dictionary <> nil then
                                begin
                                    Inc(next_state_local.score,
                                        get_sentence_context_bonus_scaled(
                                        base_state_local.prev_text,
                                        candidate_text_local));
                                end;
                                next_state_local.text := base_state_local.text + candidate_text_local;
                            end
                            else
                            begin
                                next_state_local.text := candidate_text_local;
                            end;
                            if chunk_len_local >= 3 then
                            begin
                                Inc(next_state_local.score, c_subspan_anchor_bonus);
                            end;
                            Inc(next_state_local.score,
                                get_fixed_boundary_alignment_adjustment(
                                start_idx + local_pos, chunk_len_local,
                                candidate_text_local));
                            if (preferred_text_local <> '') and
                                SameText(candidate_text_local, preferred_text_local) then
                            begin
                                Inc(next_state_local.score,
                                    c_subspan_preferred_bonus + preferred_bonus_local);
                            end;
                            next_state_local.prev_text := candidate_text_local;
                            next_state_local.anchor_units := base_state_local.anchor_units +
                                Ord((chunk_len_local >= 3) or
                                ((preferred_text_local <> '') and
                                SameText(candidate_text_local, preferred_text_local)));
                            add_subspan_state(local_states[next_pos_local], next_state_local);
                        end;
                    end;
                end;
            end;

            if Length(local_states[span_syllables]) > 0 then
            begin
                out_text := local_states[span_syllables][0].text;
                out_weight := local_states[span_syllables][0].weight;
                out_anchor_units := local_states[span_syllables][0].anchor_units;
                Result := out_text <> '';
            end;

            exact_sentence_subspan_cache_ready[start_idx][span_syllables] := True;
            exact_sentence_subspan_cache_texts[start_idx][span_syllables] := out_text;
            exact_sentence_subspan_cache_weights[start_idx][span_syllables] := out_weight;
            exact_sentence_subspan_cache_anchor_units[start_idx][span_syllables] :=
                out_anchor_units;
        end;

        function get_sentence_final_modal_particle_adjustment(
            const syllable_key: string; const candidate_text: string;
            const is_final_segment: Boolean): Integer;
        var
            normalized_key: string;
            expected_text: string;
            normalized_text: string;
        begin
            Result := 0;
            if (not is_final_segment) or (candidate_text = '') then
            begin
                Exit;
            end;

            normalized_key := normalize_pinyin_text(syllable_key);
            expected_text := '';
            if normalized_key = 'ba' then
            begin
                expected_text := string(Char($5427));
            end
            else if normalized_key = 'ma' then
            begin
                expected_text := string(Char($5417));
            end
            else if normalized_key = 'ne' then
            begin
                expected_text := string(Char($5462));
            end
            else if normalized_key = 'a' then
            begin
                expected_text := string(Char($554A));
            end
            else if normalized_key = 'ya' then
            begin
                expected_text := string(Char($5440));
            end
            else if normalized_key = 'la' then
            begin
                expected_text := string(Char($5566));
            end
            else if normalized_key = 'wa' then
            begin
                expected_text := string(Char($54C7));
            end;

            if expected_text = '' then
            begin
                Exit;
            end;

            normalized_text := Trim(candidate_text);
            if normalized_text = expected_text then
            begin
                Exit(760);
            end;

            if get_candidate_text_unit_count(normalized_text) = 1 then
            begin
                Exit(-720);
            end;
        end;

        function try_get_best_two_syllable_exact_sentence_segment(
            const segment_start: Integer; out out_text: string;
            out out_weight: Integer): Boolean;
        var
            anchor_units_local: Integer;
        begin
            Result := try_resolve_best_exact_sentence_subspan(segment_start, 2,
                out_text, out_weight, anchor_units_local);
            if Result and (get_candidate_text_unit_count(out_text) <> 2) then
            begin
                out_text := '';
                out_weight := 0;
                Result := False;
            end;
        end;

        function has_strong_two_syllable_exact_sentence_segment(
            const segment_start: Integer): Boolean;
        var
            best_text: string;
            best_weight: Integer;
        begin
            Result := try_get_best_two_syllable_exact_sentence_segment(segment_start,
                best_text, best_weight);
        end;

        function should_skip_two_single_rescue_segment(
            const segment_start: Integer): Boolean;
        var
            left_fixed: string;
            right_fixed: string;
        begin
            Result := False;
            if (segment_start < 0) or (segment_start + 1 >= head_syllable_count) then
            begin
                Exit;
            end;

            if has_strong_two_syllable_exact_sentence_segment(segment_start) then
            begin
                Exit(True);
            end;

            left_fixed := get_fixed_sentence_single_char(
                normalize_pinyin_text(syllables[segment_start].text));
            right_fixed := get_fixed_sentence_single_char(
                normalize_pinyin_text(syllables[segment_start + 1].text));

            if (left_fixed <> '') and (right_fixed = '') and
                (segment_start + 2 < head_syllable_count) and
                has_strong_two_syllable_exact_sentence_segment(segment_start + 1) then
            begin
                Exit(True);
            end;
        end;

        function is_allowed_sentence_segment_candidate(const candidate: TncCandidate;
            const segment_start: Integer; const segment_syllables: Integer): Boolean;
        var
            text_value: string;
            text_units: Integer;
            effective_weight: Integer;
            normalized_syllable: string;
            fixed_text: string;
            left_fixed: string;
            right_fixed: string;
            best_exact_text: string;
            best_exact_weight: Integer;
        begin
            Result := False;
            if Trim(candidate.comment) <> '' then
            begin
                Exit;
            end;

            text_value := Trim(candidate.text);
            if text_value = '' then
            begin
                Exit;
            end;

            if is_runtime_chain_candidate(candidate) or
                is_runtime_common_pattern_candidate(candidate) or
                is_runtime_redup_candidate(candidate) then
            begin
                Exit;
            end;

            text_units := get_candidate_text_unit_count(text_value);
            if segment_syllables <= 1 then
            begin
                effective_weight := candidate.score;
                if candidate.has_dict_weight and (candidate.dict_weight > effective_weight) then
                begin
                    effective_weight := candidate.dict_weight;
                end;
                normalized_syllable := normalize_pinyin_text(syllables[segment_start].text);
                fixed_text := get_fixed_sentence_single_char_for_filter(normalized_syllable);
                if has_strong_two_syllable_exact_sentence_segment(segment_start) then
                begin
                    Exit(False);
                end;
                Exit((text_units = 1) and
                    is_extended_allowed_single_char_for_sentence(
                        normalized_syllable,
                        text_value, effective_weight));
            end;

            if text_units >= 2 then
            begin
                if segment_syllables = 2 then
                begin
                    left_fixed := get_fixed_sentence_single_char(
                        normalize_pinyin_text(syllables[segment_start].text));
                    right_fixed := get_fixed_sentence_single_char(
                        normalize_pinyin_text(syllables[segment_start + 1].text));
                    if (left_fixed <> '') and (right_fixed <> '') and
                        SameText(text_value, left_fixed + right_fixed) and
                        try_get_best_two_syllable_exact_sentence_segment(segment_start,
                        best_exact_text, best_exact_weight) and
                        (not SameText(best_exact_text, text_value)) then
                    begin
                        Exit(False);
                    end;
                end;

                Exit(True);
            end;

            Result := False;
        end;

        function has_exact_merged_phrase_for_recent_transition(
            const base_state: TLightSentenceState; const current_pos: Integer;
            const current_seg_len: Integer): Boolean;
        var
            merged_start: Integer;
            merged_len: Integer;
            merged_text: string;
            merged_weight: Integer;
            merged_units: Integer;
            merged_anchor_units: Integer;
        begin
            Result := False;
            if (base_state.last_segment_syllable_count < 2) or (current_seg_len <> 1) then
            begin
                Exit;
            end;

            merged_start := current_pos - base_state.last_segment_syllable_count;
            if merged_start < 0 then
            begin
                Exit;
            end;

            merged_len := base_state.last_segment_syllable_count + current_seg_len;
            if merged_len < 3 then
            begin
                Exit;
            end;
            if not try_resolve_best_exact_sentence_subspan(merged_start, merged_len,
                merged_text, merged_weight, merged_anchor_units) then
            begin
                Exit;
            end;
            merged_units := get_candidate_text_unit_count(Trim(merged_text));
            Result := merged_units >= 2;
        end;

        function has_exact_merged_phrase_for_single_bridge(
            const base_state: TLightSentenceState; const current_pos: Integer;
            const current_seg_len: Integer): Boolean;
        var
            merged_text: string;
            merged_weight: Integer;
            merged_units: Integer;
            merged_anchor_units: Integer;
        begin
            Result := False;
            if (base_state.last_segment_syllable_count <> 1) or (current_seg_len <> 1) then
            begin
                Exit;
            end;

            if current_pos <= 0 then
            begin
                Exit;
            end;
            if not try_resolve_best_exact_sentence_subspan(current_pos - 1, 2,
                merged_text, merged_weight, merged_anchor_units) then
            begin
                Exit;
            end;
            merged_units := get_candidate_text_unit_count(Trim(merged_text));
            Result := merged_units >= 2;
        end;

        function try_get_best_sentence_single_char(const syllable_key: string;
            out out_text: string; out out_weight: Integer): Boolean;
        const
            c_probe_limit = 6;
        var
            single_results: TncCandidateList;
            single_idx: Integer;
            single_text: string;
            weight_value: Integer;
            fixed_text: string;
        begin
            Result := False;
            out_text := '';
            out_weight := 0;
            if syllable_key = '' then
            begin
                Exit;
            end;

            fixed_text := get_fixed_sentence_single_char(syllable_key);
            if (fixed_text <> '') and is_extended_allowed_single_char_for_sentence(
                syllable_key, fixed_text, 960) then
            begin
                out_text := fixed_text;
                out_weight := 960;
                Exit(True);
            end;

            if not dictionary_exact_lookup_cached(syllable_key, single_results) then
            begin
                Exit;
            end;

            for single_idx := 0 to High(single_results) do
            begin
                if single_idx >= c_probe_limit then
                begin
                    Break;
                end;
                single_text := Trim(single_results[single_idx].text);
                if (single_results[single_idx].comment <> '') or
                    (get_candidate_text_unit_count(single_text) <> 1) then
                begin
                    Continue;
                end;
                if single_results[single_idx].has_dict_weight then
                begin
                    weight_value := single_results[single_idx].dict_weight;
                end
                else
                begin
                    weight_value := single_results[single_idx].score;
                end;
                if not is_extended_allowed_single_char_for_sentence(
                    syllable_key, single_text, weight_value) then
                begin
                    Continue;
                end;
                if weight_value > out_weight then
                begin
                    out_text := single_text;
                    out_weight := weight_value;
                    Result := True;
                end;
            end;
        end;

        function get_weak_two_syllable_phrase_penalty(const segment_start: Integer;
            const segment_syllables: Integer; const candidate_text: string;
            const candidate_weight: Integer): Integer;
        const
            c_weak_phrase_weight_limit = 360;
        var
            left_text: string;
            right_text: string;
            left_weight: Integer;
            right_weight: Integer;
            split_weight: Integer;
        begin
            Result := 0;
            if (segment_syllables <> 2) or
                (get_candidate_text_unit_count(candidate_text) <> 2) or
                (candidate_weight >= c_weak_phrase_weight_limit) or
                (segment_start < 0) or (segment_start + 1 > High(syllables)) then
            begin
                Exit;
            end;

            if (not try_get_best_sentence_single_char(
                normalize_pinyin_text(syllables[segment_start].text), left_text, left_weight)) or
                (not try_get_best_sentence_single_char(
                normalize_pinyin_text(syllables[segment_start + 1].text), right_text, right_weight)) then
            begin
                Exit;
            end;

            split_weight := left_weight + right_weight;
            if split_weight >= candidate_weight + 700 then
            begin
                Result := 980;
            end
            else if split_weight >= candidate_weight + 500 then
            begin
                Result := 760;
            end
            else if split_weight >= candidate_weight + 320 then
            begin
                Result := 520;
            end;
        end;

        function get_exact_phrase_lookahead_bonus(const segment_start: Integer;
            const segment_syllables: Integer; const candidate_text: string): Integer;
        var
            combined_text: string;
            combined_units: Integer;
            candidate_units: Integer;
            combined_weight: Integer;
            candidate_prefix: string;
            combined_anchor_units: Integer;
        begin
            Result := 0;
            if (segment_syllables < 2) or
                (segment_start < 0) or
                (segment_start + segment_syllables > High(syllables)) then
            begin
                Exit;
            end;

            candidate_units := get_candidate_text_unit_count(candidate_text);
            if candidate_units < 2 then
            begin
                Exit;
            end;
            candidate_prefix := candidate_text;
            if not try_resolve_best_exact_sentence_subspan(segment_start,
                segment_syllables + 1, combined_text, combined_weight,
                combined_anchor_units) then
            begin
                Exit;
            end;
            combined_units := get_candidate_text_unit_count(combined_text);
            if (combined_units <> candidate_units + 1) or
                (Copy(combined_text, 1, Length(candidate_prefix)) <> candidate_prefix) then
            begin
                Exit;
            end;
            if combined_weight >= 760 then
            begin
                Exit(96);
            end
            else if combined_weight >= 560 then
            begin
                Exit(72);
            end
            else if combined_weight >= 360 then
            begin
                Exit(48);
            end;
        end;

        function ends_with_text_local(const full_value: string;
            const suffix_value: string): Boolean;
        begin
            Result := (full_value <> '') and (suffix_value <> '') and
                (Length(suffix_value) <= Length(full_value)) and
                SameText(Copy(full_value,
                Length(full_value) - Length(suffix_value) + 1, Length(suffix_value)),
                suffix_value);
        end;

        function get_exact_phrase_lookbehind_bonus(const segment_start: Integer;
            const segment_syllables: Integer; const candidate_text: string;
            const candidate_weight: Integer): Integer;
        var
            total_len: Integer;
            span_start: Integer;
            combined_text: string;
            combined_weight: Integer;
            combined_anchor_units: Integer;
            candidate_units: Integer;
            combined_units: Integer;
            best_weight: Integer;
        begin
            Result := 0;
            if (segment_syllables <= 0) or (candidate_text = '') or
                (segment_start <= 0) then
            begin
                Exit;
            end;

            candidate_units := get_candidate_text_unit_count(candidate_text);
            if candidate_units <= 0 then
            begin
                Exit;
            end;

            best_weight := Low(Integer);
            for total_len := segment_syllables + 1 to
                Min(max_segment_len, segment_start + segment_syllables) do
            begin
                span_start := segment_start - (total_len - segment_syllables);
                if span_start < 0 then
                begin
                    Continue;
                end;
                if not try_resolve_best_exact_sentence_subspan(span_start,
                    total_len, combined_text, combined_weight,
                    combined_anchor_units) then
                begin
                    Continue;
                end;
                combined_units := get_candidate_text_unit_count(combined_text);
                if (combined_units <= candidate_units) or
                    (not ends_with_text_local(combined_text, candidate_text)) then
                begin
                    Continue;
                end;
                if combined_weight > best_weight then
                begin
                    best_weight := combined_weight;
                end;
            end;

            if best_weight <= Low(Integer) div 4 then
            begin
                Exit;
            end;

            if best_weight >= candidate_weight + 240 then
            begin
                Exit(240);
            end
            else if best_weight >= candidate_weight + 80 then
            begin
                Exit(180);
            end
            else if best_weight >= candidate_weight - 80 then
            begin
                Exit(120);
            end
            else if best_weight >= candidate_weight - 240 then
            begin
                Exit(72);
            end;
        end;

        function get_longer_exact_prefix_penalty(const segment_start: Integer;
