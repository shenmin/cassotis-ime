        function try_get_best_three_syllable_two_plus_one_candidate_local(
            const start_idx: Integer; const query_key: string;
            out out_text: string; out out_score: Integer): Boolean;
        const
            c_head_probe_limit_local = 6;
            c_tail_probe_limit_local = 16;
            c_context_scale_local = 4;
            c_preferred_tail_bonus_local = 96;
            c_complete_promote_bonus_local = 1152;
        var
            head_key_local: string;
            tail_key_local: string;
            head_results_local: TncCandidateList;
            tail_results_local: TncCandidateList;
            head_texts_local: TArray<string>;
            head_scores_local: TArray<Integer>;
            head_option_idx_local: Integer;
            candidate_text_local: string;
            candidate_combined_text_local: string;
            best_tail_text_local: string;
            best_tail_score_local: Integer;
            candidate_score_local: Integer;
            context_bonus_local: Integer;
            prefix_popularity_local: Integer;
            query_bonus_local: Integer;
            exact_bonus_local: Integer;
            idx_local: Integer;
            candidate_units_local: Integer;
            resolved_text_local_321: string;
            resolved_path_local_321: string;
            resolved_score_local_321: Integer;
            resolved_segments_local_321: Integer;
            resolved_anchor_units_local_321: Integer;
            resolved_has_anchor_local_321: Boolean;
            is_preferred_local: Boolean;
            debug_tail_info_local: string;

            procedure add_head_option_local(const text_value: string;
                const score_value: Integer);
            var
                option_idx_local: Integer;
                insert_idx_local: Integer;
                tmp_text_local: string;
                tmp_score_local: Integer;
            begin
                if text_value = '' then
                begin
                    Exit;
                end;
                for option_idx_local := 0 to High(head_texts_local) do
                begin
                    if SameText(head_texts_local[option_idx_local], text_value) then
                    begin
                        if score_value > head_scores_local[option_idx_local] then
                        begin
                            head_scores_local[option_idx_local] := score_value;
                        end;
                        Exit;
                    end;
                end;

                insert_idx_local := Length(head_texts_local);
                SetLength(head_texts_local, insert_idx_local + 1);
                SetLength(head_scores_local, insert_idx_local + 1);
                head_texts_local[insert_idx_local] := text_value;
                head_scores_local[insert_idx_local] := score_value;

                while (insert_idx_local > 0) and
                    (head_scores_local[insert_idx_local] >
                    head_scores_local[insert_idx_local - 1]) do
                begin
                    tmp_text_local := head_texts_local[insert_idx_local - 1];
                    head_texts_local[insert_idx_local - 1] :=
                        head_texts_local[insert_idx_local];
                    head_texts_local[insert_idx_local] := tmp_text_local;
                    tmp_score_local := head_scores_local[insert_idx_local - 1];
                    head_scores_local[insert_idx_local - 1] :=
                        head_scores_local[insert_idx_local];
                    head_scores_local[insert_idx_local] := tmp_score_local;
                    Dec(insert_idx_local);
                end;

                if Length(head_texts_local) > c_head_probe_limit_local then
                begin
                    SetLength(head_texts_local, c_head_probe_limit_local);
                    SetLength(head_scores_local, c_head_probe_limit_local);
                end;
            end;
        begin
            Result := False;
            out_text := '';
            out_score := 0;
            SetLength(head_texts_local, 0);
            SetLength(head_scores_local, 0);
            debug_tail_info_local := '';

            if (start_idx < 0) or (start_idx + 2 > High(effective_syllables)) or
                (query_key = '') or (m_dictionary = nil) then
            begin
                Exit;
            end;

            head_key_local := build_query_key_local(start_idx, 2);
            tail_key_local := build_query_key_local(start_idx + 2, 1);
            if (head_key_local = '') or (tail_key_local = '') then
            begin
                Exit;
            end;

            if try_resolve_best_exact_subspan_local(start_idx, 2, resolved_text_local_321,
                resolved_score_local_321, resolved_segments_local_321,
                resolved_path_local_321, resolved_has_anchor_local_321,
                resolved_anchor_units_local_321) and
                (get_candidate_text_unit_count(Trim(resolved_text_local_321)) = 2) and
                is_valid_solver_cjk_phrase_text_local(Trim(resolved_text_local_321), 2) then
            begin
                candidate_score_local := resolved_score_local_321;
                if resolved_has_anchor_local_321 then
                begin
                    Inc(candidate_score_local, resolved_anchor_units_local_321 * 192);
                end;
                if resolved_segments_local_321 > 1 then
                begin
                    Dec(candidate_score_local, (resolved_segments_local_321 - 1) * 96);
                end;
                add_head_option_local(Trim(resolved_text_local_321), candidate_score_local);
            end
            else if m_dictionary.lookup(head_key_local, head_results_local) then
            begin
                for idx_local := 0 to High(head_results_local) do
                begin
                    if idx_local >= c_head_probe_limit_local * 2 then
                    begin
                        Break;
                    end;
                    if Trim(head_results_local[idx_local].comment) <> '' then
                    begin
                        Continue;
                    end;
                    candidate_text_local := Trim(head_results_local[idx_local].text);
                    if (get_candidate_text_unit_count(candidate_text_local) <> 2) or
                        (not is_valid_solver_cjk_phrase_text_local(candidate_text_local, 2)) then
                    begin
                        Continue;
                    end;

                    candidate_score_local := head_results_local[idx_local].score;
                    if head_results_local[idx_local].has_dict_weight and
                        (head_results_local[idx_local].dict_weight > candidate_score_local) then
                    begin
                        candidate_score_local := head_results_local[idx_local].dict_weight;
                    end;
                    Inc(candidate_score_local,
                        get_preferred_query_phrase_bonus_local(head_key_local, candidate_text_local));
                    add_head_option_local(candidate_text_local, candidate_score_local);
                end;
            end;

            if Length(head_texts_local) = 0 then
            begin
                Exit;
            end;

            if not m_dictionary.lookup(tail_key_local, tail_results_local) then
            begin
                Exit;
            end;

            best_tail_text_local := '';
            best_tail_score_local := Low(Integer);
            for idx_local := 0 to High(tail_results_local) do
            begin
                if idx_local >= c_tail_probe_limit_local then
                begin
                    Break;
                end;
                if Trim(tail_results_local[idx_local].comment) <> '' then
                begin
                    Continue;
                end;

                candidate_text_local := Trim(tail_results_local[idx_local].text);
                candidate_units_local := get_candidate_text_unit_count(candidate_text_local);
                if (candidate_units_local <> 1) or
                    (not is_valid_solver_cjk_phrase_text_local(candidate_text_local, 1)) then
                begin
                    Continue;
                end;
                if not match_single_char_candidate_for_syllable(tail_key_local,
                    candidate_text_local, is_preferred_local) then
                begin
                    Continue;
                end;

                for head_option_idx_local := 0 to High(head_texts_local) do
                begin
                    candidate_combined_text_local :=
                        head_texts_local[head_option_idx_local] +
                        candidate_text_local;
                    if has_competing_exact_full_phrase_solver_local(query_key,
                        candidate_combined_text_local) then
                    begin
                        Continue;
                    end;

                    context_bonus_local := m_dictionary.get_context_bonus(
                        head_texts_local[head_option_idx_local], candidate_text_local);
                    prefix_popularity_local := 0;
                    if m_dictionary is TncSqliteDictionary then
                    begin
                        prefix_popularity_local := TncSqliteDictionary(m_dictionary).
                            get_prefix_popularity_hint(
                            candidate_combined_text_local);
                    end;
                    exact_bonus_local := get_exact_query_text_bonus_solver_local(query_key,
                        candidate_combined_text_local);
                    query_bonus_local := get_preferred_query_phrase_bonus_local(query_key,
                        candidate_combined_text_local);
                    if (context_bonus_local <= 0) and (prefix_popularity_local <= 0) and
                        (exact_bonus_local <= 0) then
                    begin
                        if m_config.debug_mode and
                            (Length(debug_tail_info_local) < 256) then
                        begin
                            debug_tail_info_local := debug_tail_info_local + Format(
                                ' [%x c=%d p=%d e=%d b=%d]',
                                [Ord(candidate_text_local[1]), context_bonus_local,
                                prefix_popularity_local, exact_bonus_local,
                                Ord(SameText(candidate_text_local,
                                get_fixed_boundary_single_char_for_solver_local(
                                tail_key_local)))]);
                        end;
                        if SameText(candidate_text_local,
                            get_fixed_boundary_single_char_for_solver_local(
                            tail_key_local)) then
                        begin
                            Continue;
                        end;
                    end;

                    candidate_score_local := tail_results_local[idx_local].score;
                    if tail_results_local[idx_local].has_dict_weight and
                        (tail_results_local[idx_local].dict_weight > candidate_score_local) then
                    begin
                        candidate_score_local := tail_results_local[idx_local].dict_weight;
                    end;
                    Inc(candidate_score_local, context_bonus_local * c_context_scale_local);
                    if prefix_popularity_local > 0 then
                    begin
                        Inc(candidate_score_local,
                            Round(Ln(1.0 + prefix_popularity_local) * 256.0));
                    end;
                    Inc(candidate_score_local, query_bonus_local + exact_bonus_local);
                    if (context_bonus_local <= 0) and (prefix_popularity_local <= 0) and
                        (exact_bonus_local <= 0) then
                    begin
                        Dec(candidate_score_local, 384);
                    end;
                    if is_preferred_local then
                    begin
                        Inc(candidate_score_local, c_preferred_tail_bonus_local);
                    end;
                    if m_config.debug_mode and (Length(debug_tail_info_local) < 512) then
                    begin
                        debug_tail_info_local := debug_tail_info_local + Format(
                            ' [%x s=%d]', [Ord(candidate_text_local[1]),
                            candidate_score_local]);
                    end;

                    candidate_score_local := head_scores_local[head_option_idx_local] +
                        candidate_score_local + c_complete_promote_bonus_local;
                    if not solver_candidate_respects_fixed_boundaries_local(
                        start_idx, 3, candidate_combined_text_local) then
                    begin
                        Continue;
                    end;
                    if candidate_score_local > best_tail_score_local then
                    begin
                        best_tail_score_local := candidate_score_local;
                        best_tail_text_local := candidate_combined_text_local;
                    end;
                end;
            end;

            if best_tail_text_local = '' then
            begin
                if m_config.debug_mode then
                begin
                    m_last_full_path_debug_info := m_last_full_path_debug_info +
                        Format(' t321=[notail head=%s tail=%s dbg=%s]',
                        [head_key_local, tail_key_local, debug_tail_info_local]);
                end;
                Exit;
            end;

            out_text := best_tail_text_local;
            out_score := best_tail_score_local;
            Result := True;
        end;

        function collect_single_char_candidates_local(const pinyin_key: string;
            out out_texts: TArray<string>; out out_scores: TArray<Integer>): Boolean;
        const
            c_single_option_limit = 6;
            c_single_option_probe_limit = 12;
        var
            local_results: TncCandidateList;
            result_idx: Integer;
            candidate_text: string;
            candidate_score: Integer;

            procedure add_option_local(const text_value: string;
                const score_value: Integer);
            var
                option_idx: Integer;
                insert_idx: Integer;
                tmp_text: string;
                tmp_score: Integer;
            begin
                if text_value = '' then
                begin
                    Exit;
                end;
                for option_idx := 0 to High(out_texts) do
                begin
                    if SameText(out_texts[option_idx], text_value) then
                    begin
                        if score_value > out_scores[option_idx] then
                        begin
                            out_scores[option_idx] := score_value;
                        end;
                        Exit;
                    end;
                end;

                insert_idx := Length(out_texts);
                SetLength(out_texts, insert_idx + 1);
                SetLength(out_scores, insert_idx + 1);
                out_texts[insert_idx] := text_value;
                out_scores[insert_idx] := score_value;

                while (insert_idx > 0) and
                    (out_scores[insert_idx] > out_scores[insert_idx - 1]) do
                begin
                    tmp_text := out_texts[insert_idx - 1];
                    out_texts[insert_idx - 1] := out_texts[insert_idx];
                    out_texts[insert_idx] := tmp_text;
                    tmp_score := out_scores[insert_idx - 1];
                    out_scores[insert_idx - 1] := out_scores[insert_idx];
                    out_scores[insert_idx] := tmp_score;
                    Dec(insert_idx);
                end;

                if Length(out_texts) > c_single_option_limit then
                begin
                    SetLength(out_texts, c_single_option_limit);
                    SetLength(out_scores, c_single_option_limit);
                end;
            end;
        begin
            SetLength(out_texts, 0);
            SetLength(out_scores, 0);
            if (m_dictionary = nil) or (pinyin_key = '') then
            begin
                Exit(Length(out_texts) > 0);
            end;
            if not m_dictionary.lookup_exact_full_pinyin(pinyin_key, local_results) then
            begin
                Exit(Length(out_texts) > 0);
            end;

            for result_idx := 0 to High(local_results) do
            begin
                if result_idx >= c_single_option_probe_limit then
                begin
                    Break;
                end;
                if Trim(local_results[result_idx].comment) <> '' then
                begin
                    Continue;
                end;

                candidate_text := Trim(local_results[result_idx].text);
                if (get_candidate_text_unit_count(candidate_text) <> 1) or
                    (not is_valid_solver_cjk_phrase_text_local(candidate_text, 1)) then
                begin
                    Continue;
                end;

                candidate_score := local_results[result_idx].score;
                if local_results[result_idx].has_dict_weight and
                    (local_results[result_idx].dict_weight > candidate_score) then
                begin
                    candidate_score := local_results[result_idx].dict_weight;
                end;
                Inc(candidate_score, get_preferred_query_phrase_bonus_local(
                    pinyin_key, candidate_text));
                Dec(candidate_score,
                    get_context_free_single_char_penalty_solver_local(pinyin_key,
                    candidate_text));
                add_option_local(candidate_text, candidate_score);
            end;

            Result := Length(out_texts) > 0;
        end;

        function try_get_best_two_syllable_contextual_single_char_combo_local(
            const start_idx: Integer; const query_key: string;
            out out_text: string; out out_score: Integer): Boolean;
        const
            c_combo_probe_penalty = 64;
            c_context_scale_local = 4;
        var
            left_key_local: string;
            right_key_local: string;
            left_option_texts_local: TArray<string>;
            left_option_scores_local: TArray<Integer>;
            right_option_texts_local: TArray<string>;
            right_option_scores_local: TArray<Integer>;
            left_idx_local: Integer;
            right_idx_local: Integer;
            combined_text_local: string;
            combined_score_local: Integer;
            context_bonus_local: Integer;
            prefix_popularity_local: Integer;
            query_bonus_local: Integer;
            exact_bonus_local: Integer;
        begin
            Result := False;
            out_text := '';
            out_score := Low(Integer);
            if (start_idx < 0) or (start_idx + 1 > High(effective_syllables)) or
                (query_key = '') or (m_dictionary = nil) then
            begin
                Exit;
            end;

            left_key_local := build_query_key_local(start_idx, 1);
            right_key_local := build_query_key_local(start_idx + 1, 1);
            if (left_key_local = '') or (right_key_local = '') then
            begin
                Exit;
            end;

            if (not collect_single_char_candidates_local(left_key_local,
                left_option_texts_local, left_option_scores_local)) or
                (not collect_single_char_candidates_local(right_key_local,
                right_option_texts_local, right_option_scores_local)) then
            begin
                Exit;
            end;

            for left_idx_local := 0 to High(left_option_texts_local) do
            begin
                for right_idx_local := 0 to High(right_option_texts_local) do
                begin
                    combined_text_local := left_option_texts_local[left_idx_local] +
                        right_option_texts_local[right_idx_local];
                    if not is_valid_solver_cjk_phrase_text_local(combined_text_local, 2) then
                    begin
                        Continue;
                    end;
                    if not solver_candidate_respects_fixed_boundaries_local(
                        start_idx, 2, combined_text_local) then
                    begin
                        Continue;
                    end;

                    context_bonus_local := m_dictionary.get_context_bonus(
                        left_option_texts_local[left_idx_local],
                        right_option_texts_local[right_idx_local]);
                    prefix_popularity_local := 0;
                    if m_dictionary is TncSqliteDictionary then
                    begin
                        prefix_popularity_local := TncSqliteDictionary(m_dictionary).
                            get_prefix_popularity_hint(combined_text_local);
                    end;
                    exact_bonus_local := get_exact_query_text_bonus_solver_local(
                        query_key, combined_text_local);
                    query_bonus_local := get_preferred_query_phrase_bonus_local(
                        query_key, combined_text_local);
                    if (context_bonus_local <= 0) and (prefix_popularity_local <= 0) and
                        (exact_bonus_local <= 0) and
                        SameText(right_option_texts_local[right_idx_local],
                        get_fixed_boundary_single_char_for_solver_local(right_key_local)) then
                    begin
                        Continue;
                    end;

                    combined_score_local := left_option_scores_local[left_idx_local] +
                        right_option_scores_local[right_idx_local] -
                        c_combo_probe_penalty;
                    Inc(combined_score_local, context_bonus_local *
                        c_context_scale_local);
                    if prefix_popularity_local > 0 then
                    begin
                        Inc(combined_score_local,
                            Round(Ln(1.0 + prefix_popularity_local) * 256.0));
                    end;
                    Inc(combined_score_local, exact_bonus_local + query_bonus_local);
                    if (context_bonus_local <= 0) and (prefix_popularity_local <= 0) and
                        (exact_bonus_local <= 0) then
                    begin
                        Dec(combined_score_local, 192);
                    end;

                    if (not Result) or (combined_score_local > out_score) then
                    begin
                        Result := True;
                        out_text := combined_text_local;
                        out_score := combined_score_local;
                    end;
                end;
            end;
        end;

        function collect_two_syllable_contextual_options_local(
            const start_idx: Integer; const query_key: string;
            out out_texts: TArray<string>; out out_scores: TArray<Integer>): Boolean;
        const
            c_option_limit_local = 8;
            c_combo_probe_penalty = 64;
            c_context_scale_local = 4;
        var
            left_key_local: string;
            right_key_local: string;
            left_option_texts_local: TArray<string>;
            left_option_scores_local: TArray<Integer>;
            right_option_texts_local: TArray<string>;
            right_option_scores_local: TArray<Integer>;
            left_idx_local: Integer;
            right_idx_local: Integer;
            combined_text_local: string;
            combined_score_local: Integer;
            context_bonus_local: Integer;
            prefix_popularity_local: Integer;
            query_bonus_local: Integer;
            exact_bonus_local: Integer;

            procedure add_option_local(const text_value: string;
                const score_value: Integer);
            var
                option_idx_local: Integer;
                insert_idx_local: Integer;
                tmp_text_local: string;
                tmp_score_local: Integer;
            begin
                if text_value = '' then
                begin
                    Exit;
                end;
                for option_idx_local := 0 to High(out_texts) do
                begin
                    if SameText(out_texts[option_idx_local], text_value) then
                    begin
                        if score_value > out_scores[option_idx_local] then
                        begin
                            out_scores[option_idx_local] := score_value;
                        end;
                        Exit;
                    end;
                end;

                insert_idx_local := Length(out_texts);
                SetLength(out_texts, insert_idx_local + 1);
                SetLength(out_scores, insert_idx_local + 1);
                out_texts[insert_idx_local] := text_value;
                out_scores[insert_idx_local] := score_value;

                while (insert_idx_local > 0) and
                    (out_scores[insert_idx_local] > out_scores[insert_idx_local - 1]) do
                begin
                    tmp_text_local := out_texts[insert_idx_local - 1];
                    out_texts[insert_idx_local - 1] := out_texts[insert_idx_local];
                    out_texts[insert_idx_local] := tmp_text_local;
                    tmp_score_local := out_scores[insert_idx_local - 1];
                    out_scores[insert_idx_local - 1] := out_scores[insert_idx_local];
                    out_scores[insert_idx_local] := tmp_score_local;
                    Dec(insert_idx_local);
                end;

                if Length(out_texts) > c_option_limit_local then
                begin
                    SetLength(out_texts, c_option_limit_local);
                    SetLength(out_scores, c_option_limit_local);
                end;
            end;
        begin
            Result := False;
            SetLength(out_texts, 0);
            SetLength(out_scores, 0);
            if (start_idx < 0) or (start_idx + 1 > High(effective_syllables)) or
                (query_key = '') or (m_dictionary = nil) then
            begin
                Exit;
            end;

            left_key_local := build_query_key_local(start_idx, 1);
            right_key_local := build_query_key_local(start_idx + 1, 1);
            if (left_key_local = '') or (right_key_local = '') then
            begin
                Exit;
            end;

            if (not collect_single_char_candidates_local(left_key_local,
                left_option_texts_local, left_option_scores_local)) or
                (not collect_single_char_candidates_local(right_key_local,
                right_option_texts_local, right_option_scores_local)) then
            begin
                Exit;
            end;

            for left_idx_local := 0 to High(left_option_texts_local) do
            begin
                for right_idx_local := 0 to High(right_option_texts_local) do
                begin
                    combined_text_local := left_option_texts_local[left_idx_local] +
                        right_option_texts_local[right_idx_local];
                    if not is_valid_solver_cjk_phrase_text_local(combined_text_local, 2) then
                    begin
                        Continue;
                    end;
                    if not solver_candidate_respects_fixed_boundaries_local(
                        start_idx, 2, combined_text_local) then
                    begin
                        Continue;
                    end;

                    context_bonus_local := m_dictionary.get_context_bonus(
                        left_option_texts_local[left_idx_local],
                        right_option_texts_local[right_idx_local]);
                    prefix_popularity_local := 0;
                    if m_dictionary is TncSqliteDictionary then
                    begin
                        prefix_popularity_local := TncSqliteDictionary(m_dictionary).
                            get_prefix_popularity_hint(combined_text_local);
                    end;
                    exact_bonus_local := get_exact_query_text_bonus_solver_local(
                        query_key, combined_text_local);
                    query_bonus_local := get_preferred_query_phrase_bonus_local(
                        query_key, combined_text_local);
                    if (context_bonus_local <= 0) and (prefix_popularity_local <= 0) and
                        (exact_bonus_local <= 0) and
                        SameText(right_option_texts_local[right_idx_local],
                        get_fixed_boundary_single_char_for_solver_local(right_key_local)) then
                    begin
                        Continue;
                    end;

                    combined_score_local := left_option_scores_local[left_idx_local] +
                        right_option_scores_local[right_idx_local] -
                        c_combo_probe_penalty;
                    Inc(combined_score_local, context_bonus_local *
                        c_context_scale_local);
                    if prefix_popularity_local > 0 then
                    begin
                        Inc(combined_score_local,
                            Round(Ln(1.0 + prefix_popularity_local) * 256.0));
                    end;
                    Inc(combined_score_local, exact_bonus_local + query_bonus_local);
                    if (context_bonus_local <= 0) and (prefix_popularity_local <= 0) and
                        (exact_bonus_local <= 0) then
                    begin
                        Dec(combined_score_local, 192);
                    end;

                    add_option_local(combined_text_local, combined_score_local);
                end;
            end;

            Result := Length(out_texts) > 0;
        end;

        function try_get_best_query_key_candidate_local(const query_key: string;
            const expected_syllables: Integer; out out_text: string;
            out out_score: Integer): Boolean;
        var
            cached_state: Integer;
            snapshot_candidates: TncCandidateList;
            snapshot_scores: TArray<Integer>;
            candidate_idx: Integer;
            candidate: TncCandidate;
            candidate_text: string;
            candidate_score: Integer;
            candidate_units: Integer;
            best_complete_text: string;
            best_complete_score: Integer;
            best_partial_text: string;
            best_partial_score: Integer;
            best_partial_comment: string;
            best_split_text: string;
            best_split_score: Integer;
            comment_key: string;
            comment_syllables: TncPinyinParseResult;
            tail_text: string;
            tail_score: Integer;
            combined_text: string;
            combined_score: Integer;
            context_bonus: Integer;
            query_syllables_local: TncPinyinParseResult;
            split_idx: Integer;
            left_key: string;
            right_key: string;
            left_text: string;
            left_score: Integer;
            right_text: string;
            right_score: Integer;
            left_option_texts: TArray<string>;
            left_option_scores: TArray<Integer>;
            right_option_texts: TArray<string>;
            right_option_scores: TArray<Integer>;
            left_option_idx: Integer;
            right_option_idx: Integer;
            left_candidate_text: string;
            left_candidate_score: Integer;
            right_candidate_text: string;
            right_candidate_score: Integer;
            local_idx: Integer;
            infer_score: Integer;
            infer_segments: Integer;
            inferred_path: string;
            aligned_start_idx: Integer;
            aligned_has_anchor: Boolean;
            aligned_anchor_units: Integer;
            allow_nested_engine_local: Boolean;
            aligned_exact_text_local: string;
            aligned_exact_score_local: Integer;
            aligned_two_char_text_local: string;
            aligned_two_char_score_local: Integer;
            aligned_contextual_text_local: string;
            aligned_contextual_score_local: Integer;
            candidate_has_exact_match_local: Boolean;
            best_complete_locked_local: Boolean;

            function try_find_aligned_query_start_local: Boolean;
            var
                query_syllables_match_local: TncPinyinParseResult;
                lookup_syllables_match_local: TncPinyinParseResult;
                start_idx_match_local: Integer;
                unit_idx_match_local: Integer;
                matched_local: Boolean;
            begin
                Result := False;
                aligned_start_idx := -1;
                if (query_key = '') or (not is_full_pinyin_key(query_key)) or
                    (not is_full_pinyin_key(lookup_text)) or
                    (expected_syllables <= 0) or
                    (input_syllable_count < expected_syllables) then
                begin
                    Exit;
                end;

                query_syllables_match_local :=
                    get_effective_compact_pinyin_syllables(query_key);
                if Length(query_syllables_match_local) <> expected_syllables then
                begin
                    Exit;
                end;

                lookup_syllables_match_local :=
                    get_effective_compact_pinyin_syllables(lookup_text);
                if Length(lookup_syllables_match_local) <> input_syllable_count then
                begin
                    Exit;
                end;

                for start_idx_match_local := 0 to
                    input_syllable_count - expected_syllables do
                begin
                    matched_local := True;
                    for unit_idx_match_local := 0 to expected_syllables - 1 do
                    begin
                        if not SameText(normalize_pinyin_text(
                            lookup_syllables_match_local[start_idx_match_local +
                            unit_idx_match_local].text), normalize_pinyin_text(
                            query_syllables_match_local[unit_idx_match_local].text)) then
                        begin
                            matched_local := False;
                            Break;
                        end;
                    end;
                    if matched_local then
                    begin
                        aligned_start_idx := start_idx_match_local;
                        Exit(True);
                    end;
                end;
            end;

            function try_collect_aligned_exact_options_local(
                const option_start_idx_local: Integer;
                const option_query_key_local: string;
                const option_syllables_local: Integer;
                out out_texts_local: TArray<string>;
                out out_scores_local: TArray<Integer>): Boolean;
            var
                local_results_local: TncCandidateList;
                result_idx_local: Integer;
                candidate_text_local: string;
                candidate_units_local: Integer;
                candidate_score_local: Integer;
                insert_idx_local: Integer;
                option_idx_local: Integer;
                option_limit_local: Integer;
                tmp_text_local: string;
                tmp_score_local: Integer;
            begin
                Result := False;
                SetLength(out_texts_local, 0);
                SetLength(out_scores_local, 0);
                if (option_start_idx_local < 0) or (m_dictionary = nil) or
                    (option_query_key_local = '') or (option_syllables_local <= 1) then
                begin
                    Exit;
                end;

                if not m_dictionary.lookup_exact_full_pinyin(
                    option_query_key_local, local_results_local) then
                begin
                    Exit;
                end;

                if option_syllables_local >= 3 then
                begin
                    option_limit_local := 2;
                end
                else
                begin
                    option_limit_local := c_solver_beam_limit;
                end;

                for result_idx_local := 0 to High(local_results_local) do
                begin
                    if result_idx_local >= c_solver_probe_limit * 3 then
                    begin
                        Break;
                    end;
                    if Trim(local_results_local[result_idx_local].comment) <> '' then
                    begin
                        Continue;
                    end;

                    candidate_text_local := Trim(local_results_local[result_idx_local].text);
                    candidate_units_local :=
                        get_candidate_text_unit_count(candidate_text_local);
                    if (candidate_units_local < 2) or
                        (candidate_units_local > option_syllables_local) or
                        (not is_valid_solver_cjk_phrase_text_local(
                        candidate_text_local, candidate_units_local)) then
                    begin
                        Continue;
                    end;
                    if (option_syllables_local >= 4) and
                        (candidate_units_local <> option_syllables_local) then
                    begin
                        Continue;
                    end;
                    if not solver_candidate_respects_fixed_boundaries_local(
                        option_start_idx_local, option_syllables_local,
                        candidate_text_local) then
                    begin
                        Continue;
                    end;

                    candidate_score_local := local_results_local[result_idx_local].score;
                    if local_results_local[result_idx_local].has_dict_weight and
                        (local_results_local[result_idx_local].dict_weight >
                        candidate_score_local) then
                    begin
                        candidate_score_local :=
                            local_results_local[result_idx_local].dict_weight;
                    end;
                    Inc(candidate_score_local,
                        get_preferred_query_phrase_bonus_local(option_query_key_local,
                        candidate_text_local));
                    Inc(candidate_score_local,
                        get_preferred_exact_subspan_bonus_local(option_query_key_local,
                        candidate_text_local));
                    Inc(candidate_score_local,
                        get_exact_query_text_bonus_solver_local(option_query_key_local,
                        candidate_text_local));
                    Dec(candidate_score_local,
                        get_trailing_context_free_single_char_penalty_solver_local(
                        option_query_key_local, candidate_text_local));

                    for option_idx_local := 0 to High(out_texts_local) do
                    begin
                        if SameText(out_texts_local[option_idx_local],
                            candidate_text_local) then
                        begin
                            if candidate_score_local >
                                out_scores_local[option_idx_local] then
                            begin
                                out_scores_local[option_idx_local] :=
                                    candidate_score_local;
                            end;
                            candidate_text_local := '';
                            Break;
                        end;
                    end;
                    if candidate_text_local = '' then
                    begin
                        Continue;
                    end;

                    insert_idx_local := Length(out_texts_local);
                    SetLength(out_texts_local, insert_idx_local + 1);
                    SetLength(out_scores_local, insert_idx_local + 1);
                    out_texts_local[insert_idx_local] := candidate_text_local;
                    out_scores_local[insert_idx_local] := candidate_score_local;

                    while (insert_idx_local > 0) and
                        (out_scores_local[insert_idx_local] >
                        out_scores_local[insert_idx_local - 1]) do
                    begin
                        tmp_text_local := out_texts_local[insert_idx_local - 1];
                        out_texts_local[insert_idx_local - 1] :=
                            out_texts_local[insert_idx_local];
                        out_texts_local[insert_idx_local] := tmp_text_local;
                        tmp_score_local := out_scores_local[insert_idx_local - 1];
                        out_scores_local[insert_idx_local - 1] :=
                            out_scores_local[insert_idx_local];
                        out_scores_local[insert_idx_local] := tmp_score_local;
                        Dec(insert_idx_local);
                    end;

                    if Length(out_texts_local) > option_limit_local then
                    begin
                        SetLength(out_texts_local, option_limit_local);
                        SetLength(out_scores_local, option_limit_local);
                    end;
                end;

                if (option_syllables_local >= 3) and (Length(out_scores_local) > 1) and
                    (out_scores_local[0] >= out_scores_local[1] + 512) then
                begin
                    SetLength(out_texts_local, 1);
                    SetLength(out_scores_local, 1);
                end;

                Result := Length(out_texts_local) > 0;
            end;
        begin
            Result := False;
            out_text := '';
            out_score := 0;
            aligned_exact_text_local := '';
            aligned_exact_score_local := Low(Integer);
            aligned_two_char_text_local := '';
            aligned_two_char_score_local := Low(Integer);
            aligned_contextual_text_local := '';
            aligned_contextual_score_local := Low(Integer);
            best_complete_locked_local := False;
            if (query_key = '') or (not is_full_pinyin_key(query_key)) or
                (expected_syllables <= 0) or
                (expected_syllables > c_solver_max_chunk_syllables) then
            begin
                Exit;
            end;

            if expected_syllables = 1 then
            begin
                Exit(try_get_best_single_char_for_pinyin_key_local(query_key,
                    out_text, out_score));
            end;

            if query_cache_states.TryGetValue(query_key, cached_state) then
            begin
                if cached_state = 1 then
                begin
                    query_cache_texts.TryGetValue(query_key, out_text);
                    query_cache_scores.TryGetValue(query_key, out_score);
                    Exit(out_text <> '');
                end;
                Exit(False);
            end;

            best_complete_text := '';
            best_complete_score := Low(Integer);
            best_partial_text := '';
            best_partial_score := Low(Integer);
            best_partial_comment := '';
            best_split_text := '';
            best_split_score := Low(Integer);

            if try_find_aligned_query_start_local and
                try_resolve_best_exact_subspan_local(aligned_start_idx,
                expected_syllables, aligned_exact_text_local,
                aligned_exact_score_local, infer_segments, inferred_path,
                aligned_has_anchor, aligned_anchor_units) then
            begin
                if solver_candidate_respects_fixed_boundaries_local(
                    aligned_start_idx, expected_syllables, aligned_exact_text_local) then
                begin
                    best_complete_text := aligned_exact_text_local;
                    best_complete_score := aligned_exact_score_local -
                        get_trailing_context_free_single_char_penalty_solver_local(
                        query_key, aligned_exact_text_local);
                    best_complete_locked_local := True;
                end;
            end;
            if (expected_syllables = 2) and (aligned_start_idx >= 0) and
                try_get_best_two_syllable_contextual_single_char_combo_local(
                aligned_start_idx, query_key, aligned_two_char_text_local,
                aligned_two_char_score_local) and
                ((best_complete_text = '') or
                (aligned_two_char_score_local > best_complete_score)) then
            begin
                best_complete_text := aligned_two_char_text_local;
                best_complete_score := aligned_two_char_score_local;
                best_complete_locked_local := True;
            end;
            if (expected_syllables = 3) and (aligned_start_idx >= 0) and
                try_get_best_three_syllable_two_plus_one_candidate_local(
                aligned_start_idx, query_key, aligned_contextual_text_local,
                aligned_contextual_score_local) and
                ((best_complete_text = '') or
                (aligned_contextual_score_local > best_complete_score)) then
            begin
                best_complete_text := aligned_contextual_text_local;
                best_complete_score := aligned_contextual_score_local;
                best_complete_locked_local := True;
            end;

            allow_nested_engine_local := False;
            if allow_nested_engine_local then
            begin
                if query_engine = nil then
                begin
                    query_engine_config := m_config;
                    query_engine_config.debug_mode := False;
                    query_engine_config.max_candidates := 96;
                    query_engine := TncEngine.Create(query_engine_config);
                    query_engine.m_disable_subspan_standalone_oracle :=
                        m_disable_subspan_standalone_oracle + 1;
                end;

                query_cache_states.AddOrSetValue(query_key, 3);
                query_engine.reset;
                query_engine.m_disable_subspan_standalone_oracle :=
                    m_disable_subspan_standalone_oracle + 1;
                query_engine.m_composition_text := query_key;
                query_engine.build_candidates;
                SetLength(snapshot_candidates, Length(query_engine.m_candidates));
                SetLength(snapshot_scores, Length(query_engine.m_candidates));
                for candidate_idx := 0 to High(query_engine.m_candidates) do
                begin
                    snapshot_candidates[candidate_idx] :=
                        query_engine.m_candidates[candidate_idx];
                    snapshot_scores[candidate_idx] := query_engine.get_rank_score(
                        query_engine.m_candidates[candidate_idx]);
                end;

                for candidate_idx := 0 to High(snapshot_candidates) do
                begin
                    if candidate_idx >= c_solver_probe_limit then
                    begin
                        Break;
                    end;

                    candidate := snapshot_candidates[candidate_idx];
                    candidate_text := Trim(candidate.text);
                    if candidate_text = '' then
                    begin
                        Continue;
                    end;

                    candidate_score := snapshot_scores[candidate_idx];
                    candidate_units := get_candidate_text_unit_count(candidate_text);
                    if candidate_units <= 0 then
                    begin
                        Continue;
                    end;

                    if Trim(candidate.comment) = '' then
                    begin
                        if (candidate_units <> expected_syllables) or
                            (not is_valid_solver_cjk_phrase_text_local(
                            candidate_text, expected_syllables)) then
                        begin
                            Continue;
                        end;

                        inferred_path := infer_segment_path_for_query_text_with_score(
                            query_key, candidate_text, infer_score,
                            infer_segments);
                        if inferred_path <> '' then
                        begin
                            Inc(candidate_score, infer_score);
                            Inc(candidate_score, infer_segments * 320);
                        end
                        else if expected_syllables >= 4 then
                        begin
                            Dec(candidate_score, 960);
                        end;
                        Inc(candidate_score,
                            get_preferred_query_phrase_bonus_local(query_key,
                            candidate_text));
                        Inc(candidate_score,
                            get_exact_query_text_bonus_solver_local(query_key,
                            candidate_text));
                        Dec(candidate_score,
                            get_trailing_context_free_single_char_penalty_solver_local(
                            query_key, candidate_text));
                        candidate_has_exact_match_local :=
                            has_exact_query_text_match_solver_local(query_key,
                            candidate_text);
                        if best_complete_locked_local and
                            (expected_syllables <= 3) and
                            (best_complete_text <> '') and
                            (not SameText(candidate_text, best_complete_text)) and
                            (not candidate_has_exact_match_local) then
                        begin
                            Continue;
                        end;

                        if candidate_score > best_complete_score then
                        begin
                            best_complete_text := candidate_text;
                            best_complete_score := candidate_score;
                        end;
                        Continue;
                    end;

                    comment_key := normalize_pinyin_text(candidate.comment);
                    if (comment_key = '') or
                        (not is_full_pinyin_key(comment_key)) then
                    begin
                        Continue;
                    end;

                    comment_syllables :=
                        get_effective_compact_pinyin_syllables(comment_key);
                    if (Length(comment_syllables) = 0) or
                        (candidate_units + Length(comment_syllables) <>
                        expected_syllables) then
                    begin
                        Continue;
                    end;

                    if not try_get_best_query_key_candidate_local(comment_key,
                        Length(comment_syllables), tail_text, tail_score) then
                    begin
                        Continue;
                    end;

                    combined_text := candidate_text + tail_text;
                    if (aligned_start_idx >= 0) and
                        (not solver_candidate_respects_fixed_boundaries_local(
                        aligned_start_idx, expected_syllables, combined_text)) then
                    begin
                        Continue;
                    end;
                    combined_score := candidate_score + tail_score;
                    if m_dictionary <> nil then
                    begin
                        context_bonus := m_dictionary.get_context_bonus(
                            candidate_text, tail_text);
                        Inc(combined_score, context_bonus);
                    end;
                    Inc(combined_score,
                        get_preferred_query_phrase_bonus_local(query_key,
                        combined_text));
                    Inc(combined_score,
                        get_exact_query_text_bonus_solver_local(query_key,
                        combined_text));
                    if is_solver_boundary_tail_local(comment_key) then
                    begin
                        Inc(combined_score, 1024);
                    end;

                    if combined_score > best_partial_score then
                    begin
                        best_partial_text := combined_text;
                        best_partial_score := combined_score;
                        best_partial_comment := comment_key;
                    end;
                end;
            end;

            query_syllables_local := get_effective_compact_pinyin_syllables(query_key);
            if Length(query_syllables_local) = expected_syllables then
            begin
                for split_idx := 1 to expected_syllables - 1 do
                begin
                    left_key := '';
                    for local_idx := 0 to split_idx - 1 do
                    begin
                        left_key := left_key + normalize_pinyin_text(
                            query_syllables_local[local_idx].text);
                    end;

                    right_key := '';
                    for local_idx := split_idx to High(query_syllables_local) do
                    begin
                        right_key := right_key + normalize_pinyin_text(
                            query_syllables_local[local_idx].text);
                    end;

                    if (left_key = '') or (right_key = '') then
                    begin
                        Continue;
                    end;

                    SetLength(left_option_texts, 0);
                    SetLength(left_option_scores, 0);
                    SetLength(right_option_texts, 0);
                    SetLength(right_option_scores, 0);

                    if split_idx = 1 then
                    begin
                        if not collect_single_char_candidates_local(left_key,
                            left_option_texts, left_option_scores) then
                        begin
                            Continue;
                        end;
                    end
                    else if (aligned_start_idx >= 0) and
                        try_collect_aligned_exact_options_local(
                        aligned_start_idx, left_key, split_idx,
                        left_option_texts, left_option_scores) then
                    begin
                    end
                    else if try_get_best_query_key_candidate_local(left_key, split_idx,
                        left_text, left_score) then
                    begin
                        SetLength(left_option_texts, 1);
                        SetLength(left_option_scores, 1);
                        left_option_texts[0] := left_text;
                        left_option_scores[0] := left_score;
                    end
                    else
                    begin
                        Continue;
                    end;

                    if expected_syllables - split_idx = 1 then
                    begin
                        if not collect_single_char_candidates_local(right_key,
                            right_option_texts, right_option_scores) then
                        begin
                            Continue;
                        end;
                    end
                    else if (aligned_start_idx >= 0) and
                        try_collect_aligned_exact_options_local(
                        aligned_start_idx + split_idx, right_key,
                        expected_syllables - split_idx,
                        right_option_texts, right_option_scores) then
                    begin
                    end
                    else if try_get_best_query_key_candidate_local(right_key,
                        expected_syllables - split_idx, right_text, right_score) then
                    begin
                        SetLength(right_option_texts, 1);
                        SetLength(right_option_scores, 1);
                        right_option_texts[0] := right_text;
                        right_option_scores[0] := right_score;
                    end
                    else
                    begin
                        Continue;
                    end;

                    for left_option_idx := 0 to High(left_option_texts) do
                    begin
                        left_candidate_text := left_option_texts[left_option_idx];
                        left_candidate_score := left_option_scores[left_option_idx];
                        for right_option_idx := 0 to High(right_option_texts) do
                        begin
                            right_candidate_text :=
                                right_option_texts[right_option_idx];
                            right_candidate_score :=
                                right_option_scores[right_option_idx];

                            combined_text := left_candidate_text +
                                right_candidate_text;
                            if not is_valid_solver_cjk_phrase_text_local(combined_text,
                                expected_syllables) then
                            begin
                                Continue;
                            end;
                            if (aligned_start_idx >= 0) and
                                (not solver_candidate_respects_fixed_boundaries_local(
                                aligned_start_idx, expected_syllables,
                                combined_text)) then
                            begin
                                Continue;
                            end;

                            if (split_idx = 1) and
                                (get_exact_query_text_bonus_solver_local(query_key,
                                combined_text) = 0) and
                                (not SameText(left_candidate_text,
                                get_fixed_boundary_single_char_for_solver_local(
                                left_key))) then
                            begin
                                Continue;
                            end;

                            combined_score := left_candidate_score +
                                right_candidate_score - 96;
                            Inc(combined_score,
                                get_preferred_query_phrase_bonus_local(query_key,
                                combined_text));
                            Inc(combined_score,
                                get_exact_query_text_bonus_solver_local(query_key,
                                combined_text));
                            if m_dictionary <> nil then
                            begin
                                context_bonus := m_dictionary.get_context_bonus(
                                    left_candidate_text, right_candidate_text);
                                Inc(combined_score, context_bonus);
                            end;

                            inferred_path := infer_segment_path_for_query_text_with_score(
                                query_key, combined_text, infer_score,
                                infer_segments);
                            if inferred_path <> '' then
                            begin
                                Inc(combined_score, infer_score);
                                Inc(combined_score, infer_segments * 320);
                            end;

                            if combined_score > best_split_score then
                            begin
                                best_split_text := combined_text;
                                best_split_score := combined_score;
                            end;
                        end;
                    end;
                end;
            end;

            if best_complete_text <> '' then
            begin
                out_text := best_complete_text;
                out_score := best_complete_score;
                if (best_partial_text <> '') and
                    is_solver_boundary_tail_local(best_partial_comment) and
                    (best_partial_score > best_complete_score + 512) then
                begin
                    out_text := best_partial_text;
                    out_score := best_partial_score;
                end;
            end;

            if (best_split_text <> '') and
                ((out_text = '') or
                (best_split_score > out_score - 128) or
                ((expected_syllables >= 4) and
                (best_split_score + 256 >= out_score))) then
            begin
                out_text := best_split_text;
                out_score := best_split_score;
            end;

            if out_text <> '' then
            begin
                query_cache_states.AddOrSetValue(query_key, 1);
                query_cache_texts.AddOrSetValue(query_key, out_text);
                query_cache_scores.AddOrSetValue(query_key, out_score);
                Exit(True);
            end;

            if best_partial_text <> '' then
            begin
                out_text := best_partial_text;
                out_score := best_partial_score;
                query_cache_states.AddOrSetValue(query_key, 1);
                query_cache_texts.AddOrSetValue(query_key, out_text);
                query_cache_scores.AddOrSetValue(query_key, out_score);
                Exit(True);
            end;

            query_cache_states.AddOrSetValue(query_key, 2);
        end;

        function try_get_best_subquery_candidate_local(const start_idx: Integer;
            const syllable_count_part: Integer; out out_text: string;
            out out_score: Integer): Boolean;
        var
            query_key: string;
            resolved_path: string;
            resolved_score: Integer;
            resolved_segments: Integer;
            resolved_anchor_units: Integer;
            resolved_has_anchor: Boolean;
            resolved_units: Integer;
            preferred_text_local: string;
            preferred_bonus_local: Integer;
            allow_direct_exact_local: Boolean;
            contextual_two_text_local: string;
            contextual_two_score_local: Integer;
            contextual_text_local: string;
            contextual_score_local: Integer;
        begin
            Result := False;
            out_text := '';
            out_score := 0;
            preferred_text_local := '';
            preferred_bonus_local := 0;
            contextual_two_text_local := '';
            contextual_two_score_local := Low(Integer);
            contextual_text_local := '';
            contextual_score_local := Low(Integer);

            if syllable_count_part = 1 then
            begin
                Exit(try_get_exact_single_char_candidate_local(start_idx,
                    out_text, out_score));
            end;

            if syllable_count_part > c_solver_max_chunk_syllables then
            begin
                Exit;
            end;

            query_key := build_query_key_local(start_idx, syllable_count_part);
            if query_key <> '' then
            begin
                try_get_preferred_query_phrase_text_local(query_key,
                    preferred_text_local, preferred_bonus_local);
            end;
            allow_direct_exact_local := (syllable_count_part <= 3) or
                (preferred_bonus_local > 0);

            if allow_direct_exact_local and
                try_resolve_best_exact_subspan_local(start_idx, syllable_count_part,
                out_text, resolved_score, resolved_segments, resolved_path,
                resolved_has_anchor, resolved_anchor_units) then
            begin
                resolved_units := get_candidate_text_unit_count(Trim(out_text));
                if (resolved_units >= 2) and
                    (resolved_units <= syllable_count_part) and
                    is_valid_solver_cjk_phrase_text_local(out_text,
                    resolved_units) then
                begin
                    out_score := resolved_score;
                    if resolved_has_anchor then
                    begin
                        Inc(out_score, resolved_anchor_units * 192);
                    end;
                    if resolved_segments > 1 then
                    begin
                        Dec(out_score, (resolved_segments - 1) * 96);
                    end;
                end;
            end;
            if (syllable_count_part = 2) and
                try_get_best_two_syllable_contextual_single_char_combo_local(
                start_idx, query_key, contextual_two_text_local,
                contextual_two_score_local) and
                ((out_text = '') or (contextual_two_score_local > out_score)) then
            begin
                out_text := contextual_two_text_local;
                out_score := contextual_two_score_local;
            end;
            if (syllable_count_part = 3) and
                try_get_best_three_syllable_two_plus_one_candidate_local(
                start_idx, query_key, contextual_text_local,
                contextual_score_local) and
                ((out_text = '') or (contextual_score_local > out_score)) then
            begin
                out_text := contextual_text_local;
                out_score := contextual_score_local;
            end;
            if out_text <> '' then
            begin
                Exit(True);
            end;

            if (query_key = '') or (not is_full_pinyin_key(query_key)) then
            begin
                Exit;
            end;

            Result := try_get_best_query_key_candidate_local(query_key,
                syllable_count_part, out_text, out_score);
        end;

        function is_solver_beam_option_better_local(
            const left_option: TSubquerySolverBeamOption;
            const right_option: TSubquerySolverBeamOption): Boolean;
        begin
            Result := False;
            if left_option.score > right_option.score then
            begin
                Exit(True);
            end;
            if left_option.score < right_option.score then
            begin
                Exit(False);
            end;
            if left_option.segments < right_option.segments then
            begin
                Exit(True);
            end;
            if left_option.segments > right_option.segments then
            begin
                Exit(False);
            end;
            if (left_option.text <> '') and
                ((right_option.text = '') or
                (CompareText(left_option.text, right_option.text) < 0)) then
            begin
                Exit(True);
            end;
        end;

        procedure sort_and_trim_solver_beam_options_local(
            var options: TSubquerySolverBeamOptionArray; const max_count: Integer);
        var
            option_idx: Integer;
            insert_idx: Integer;
            tmp_option: TSubquerySolverBeamOption;
        begin
            for option_idx := 1 to High(options) do
            begin
                for insert_idx := option_idx downto 1 do
                begin
                    if not is_solver_beam_option_better_local(options[insert_idx],
                        options[insert_idx - 1]) then
                    begin
                        Break;
                    end;
                    tmp_option := options[insert_idx - 1];
                    options[insert_idx - 1] := options[insert_idx];
                    options[insert_idx] := tmp_option;
                end;
            end;

            if (max_count > 0) and (Length(options) > max_count) then
            begin
                SetLength(options, max_count);
            end;
        end;

        procedure add_solver_beam_option_local(
            var options: TSubquerySolverBeamOptionArray;
            const candidate_option: TSubquerySolverBeamOption;
            const max_count: Integer);
        var
            option_idx: Integer;
        begin
            if candidate_option.text = '' then
            begin
                Exit;
            end;

            for option_idx := 0 to High(options) do
            begin
                if SameText(options[option_idx].text, candidate_option.text) then
                begin
                    if is_solver_beam_option_better_local(candidate_option,
                        options[option_idx]) then
                    begin
                        options[option_idx] := candidate_option;
                        sort_and_trim_solver_beam_options_local(options, max_count);
                    end;
                    Exit;
                end;
            end;

            SetLength(options, Length(options) + 1);
            options[High(options)] := candidate_option;
            sort_and_trim_solver_beam_options_local(options, max_count);
        end;

        function collect_exact_query_key_candidates_local(
            const start_idx_local: Integer; const query_key_local: string;
            const max_units_local: Integer;
            out out_texts_local: TArray<string>;
            out out_scores_local: TArray<Integer>): Boolean;
        var
            local_results_local: TncCandidateList;
            result_idx_local: Integer;
            candidate_text_local: string;
            candidate_score_local: Integer;
            candidate_units_local: Integer;
            insert_idx_local: Integer;
            tmp_text_local: string;
            tmp_score_local: Integer;
            option_idx_local: Integer;
            option_limit_local: Integer;
        begin
            Result := False;
            SetLength(out_texts_local, 0);
            SetLength(out_scores_local, 0);
            if (m_dictionary = nil) or (query_key_local = '') then
            begin
                Exit;
            end;

            if not m_dictionary.lookup_exact_full_pinyin(query_key_local,
                local_results_local) then
            begin
                Exit;
            end;

            if max_units_local >= 3 then
            begin
                option_limit_local := 2;
            end
            else
            begin
                option_limit_local := c_solver_beam_limit;
            end;

            for result_idx_local := 0 to High(local_results_local) do
            begin
                if result_idx_local >= c_solver_probe_limit * 3 then
                begin
                    Break;
                end;
                if Trim(local_results_local[result_idx_local].comment) <> '' then
                begin
                    Continue;
                end;

                candidate_text_local := Trim(local_results_local[result_idx_local].text);
                candidate_units_local := get_candidate_text_unit_count(
                    candidate_text_local);
                if (candidate_units_local < 2) or
                    (candidate_units_local > max_units_local) or
                    (not is_valid_solver_cjk_phrase_text_local(
                    candidate_text_local, candidate_units_local)) then
                begin
                    Continue;
                end;
                if (max_units_local >= 4) and
                    (candidate_units_local <> max_units_local) then
                begin
                    Continue;
                end;
                if not solver_candidate_respects_fixed_boundaries_local(
                    start_idx_local, max_units_local, candidate_text_local) then
                begin
                    Continue;
                end;

                candidate_score_local := local_results_local[result_idx_local].score;
                if local_results_local[result_idx_local].has_dict_weight and
                    (local_results_local[result_idx_local].dict_weight >
                    candidate_score_local) then
                begin
                    candidate_score_local :=
                        local_results_local[result_idx_local].dict_weight;
                end;
                Inc(candidate_score_local,
                    get_preferred_query_phrase_bonus_local(query_key_local,
                    candidate_text_local));
                Inc(candidate_score_local,
                    get_preferred_exact_subspan_bonus_local(query_key_local,
                    candidate_text_local));
                Inc(candidate_score_local,
                    get_exact_query_text_bonus_solver_local(query_key_local,
                    candidate_text_local));
                Dec(candidate_score_local,
                    get_trailing_context_free_single_char_penalty_solver_local(
                    query_key_local, candidate_text_local));

                for option_idx_local := 0 to High(out_texts_local) do
                begin
                    if SameText(out_texts_local[option_idx_local], candidate_text_local) then
                    begin
                        if candidate_score_local > out_scores_local[option_idx_local] then
                        begin
                            out_scores_local[option_idx_local] := candidate_score_local;
                        end;
                        candidate_text_local := '';
                        Break;
                    end;
                end;
                if candidate_text_local = '' then
                begin
                    Continue;
                end;

                insert_idx_local := Length(out_texts_local);
                SetLength(out_texts_local, insert_idx_local + 1);
                SetLength(out_scores_local, insert_idx_local + 1);
                out_texts_local[insert_idx_local] := candidate_text_local;
                out_scores_local[insert_idx_local] := candidate_score_local;

                while (insert_idx_local > 0) and
                    (out_scores_local[insert_idx_local] >
                    out_scores_local[insert_idx_local - 1]) do
                begin
                    tmp_text_local := out_texts_local[insert_idx_local - 1];
                    out_texts_local[insert_idx_local - 1] :=
                        out_texts_local[insert_idx_local];
                    out_texts_local[insert_idx_local] := tmp_text_local;
                    tmp_score_local := out_scores_local[insert_idx_local - 1];
                    out_scores_local[insert_idx_local - 1] :=
                        out_scores_local[insert_idx_local];
                    out_scores_local[insert_idx_local] := tmp_score_local;
                    Dec(insert_idx_local);
                end;

                if Length(out_texts_local) > option_limit_local then
                begin
                    SetLength(out_texts_local, option_limit_local);
                    SetLength(out_scores_local, option_limit_local);
                end;
            end;

            if (max_units_local >= 3) and (Length(out_scores_local) > 1) and
                (out_scores_local[0] >= out_scores_local[1] + 512) then
            begin
                SetLength(out_texts_local, 1);
                SetLength(out_scores_local, 1);
            end;

            Result := Length(out_texts_local) > 0;
        end;

        function collect_subquery_candidate_options_local(const start_idx: Integer;
            const syllable_count_part: Integer;
            out out_options: TSubquerySolverBeamOptionArray): Boolean;
        var
            query_key_local: string;
            cached_state_local: Integer;
            cached_options_local: TSubquerySolverBeamOptionArray;
            result_idx_local: Integer;
            candidate_text_local: string;
            candidate_score_local: Integer;
            resolved_path_local: string;
            resolved_score_local: Integer;
            resolved_segments_local: Integer;
            resolved_anchor_units_local: Integer;
            resolved_has_anchor_local: Boolean;
            resolved_units_local: Integer;
            preferred_text_local: string;
            preferred_bonus_local: Integer;
            allow_direct_exact_local: Boolean;
            contextual_two_text_local: string;
            contextual_two_score_local: Integer;
            split_idx_local: Integer;
            left_key_local: string;
            right_key_local: string;
            left_text_local: string;
            right_text_local: string;
            left_score_local: Integer;
            right_score_local: Integer;
            left_option_texts_local: TArray<string>;
            left_option_scores_local: TArray<Integer>;
            right_option_texts_local: TArray<string>;
            right_option_scores_local: TArray<Integer>;
            left_option_idx_local: Integer;
            right_option_idx_local: Integer;
            combined_text_local: string;
            combined_score_local: Integer;
            contextual_text_local: string;
            contextual_score_local: Integer;
            infer_score_local: Integer;
            infer_segments_local: Integer;
            inferred_path_local: string;
            context_bonus_local: Integer;
            option_local: TSubquerySolverBeamOption;
            option_limit_local: Integer;
            nested_candidate_idx_local: Integer;
            nested_candidate_local: TncCandidate;
            nested_candidate_score_local: Integer;
            nested_candidate_units_local: Integer;
        begin
            Result := False;
            SetLength(out_options, 0);
            if syllable_count_part <= 0 then
            begin
                Exit;
            end;
            contextual_text_local := '';
            contextual_score_local := Low(Integer);
            contextual_two_text_local := '';
            contextual_two_score_local := Low(Integer);
            if syllable_count_part = 3 then
            begin
                option_limit_local := c_solver_three_syllable_option_limit;
            end
            else
            begin
                option_limit_local := c_solver_beam_limit;
            end;

            query_key_local := build_query_key_local(start_idx, syllable_count_part);
            if query_key_local = '' then
            begin
                Exit;
            end;

            if query_option_cache_states.TryGetValue(query_key_local,
                cached_state_local) then
            begin
                if cached_state_local = 1 then
                begin
                    if query_option_cache_options.TryGetValue(query_key_local,
                        cached_options_local) then
                    begin
                        out_options := Copy(cached_options_local);
                        Exit(Length(out_options) > 0);
                    end;
                    Exit(False);
                end;
                Exit(False);
            end;

            if syllable_count_part = 1 then
            begin
                if collect_single_char_candidates_local(query_key_local,
                    left_option_texts_local, left_option_scores_local) then
                begin
                    for left_option_idx_local := 0 to High(left_option_texts_local) do
                    begin
                        option_local := Default(TSubquerySolverBeamOption);
                        option_local.text := left_option_texts_local[
                            left_option_idx_local];
                        option_local.path := option_local.text;
                        option_local.first_chunk := option_local.text;
                        option_local.score := left_option_scores_local[
                            left_option_idx_local];
                        option_local.segments := 1;
                        add_solver_beam_option_local(out_options, option_local,
                            option_limit_local);
                    end;
                end;
                if Length(out_options) > 0 then
                begin
                    query_option_cache_states.AddOrSetValue(query_key_local, 1);
                    query_option_cache_options.AddOrSetValue(query_key_local,
                        Copy(out_options));
                    Exit(True);
                end;
                query_option_cache_states.AddOrSetValue(query_key_local, 2);
                Exit(False);
            end;

            if syllable_count_part > c_solver_max_chunk_syllables then
            begin
                Exit;
            end;

            preferred_text_local := '';
            preferred_bonus_local := 0;
            try_get_preferred_query_phrase_text_local(query_key_local,
                preferred_text_local, preferred_bonus_local);
            allow_direct_exact_local := (syllable_count_part <= 3) or
                (preferred_bonus_local > 0);

            if allow_direct_exact_local and
                try_resolve_best_exact_subspan_local(start_idx, syllable_count_part,
                candidate_text_local, resolved_score_local, resolved_segments_local,
                resolved_path_local, resolved_has_anchor_local,
                resolved_anchor_units_local) then
            begin
                resolved_units_local :=
                    get_candidate_text_unit_count(Trim(candidate_text_local));
                if (resolved_units_local >= 2) and
                    (resolved_units_local <= syllable_count_part) and
                    is_valid_solver_cjk_phrase_text_local(candidate_text_local,
                    resolved_units_local) and
                    solver_candidate_respects_fixed_boundaries_local(start_idx,
                    syllable_count_part, candidate_text_local) then
                begin
                    option_local := Default(TSubquerySolverBeamOption);
                    option_local.text := candidate_text_local;
                    option_local.path := candidate_text_local;
                    option_local.first_chunk := candidate_text_local;
                    option_local.score := resolved_score_local;
                    if resolved_has_anchor_local then
                    begin
                        Inc(option_local.score, resolved_anchor_units_local * 192);
                    end;
                    if resolved_segments_local > 1 then
                    begin
                        Dec(option_local.score, (resolved_segments_local - 1) * 96);
                    end;
                    option_local.segments := Max(1, resolved_segments_local);
                    add_solver_beam_option_local(out_options, option_local,
                        option_limit_local);
                end;
            end;
            if (syllable_count_part = 2) and
                collect_two_syllable_contextual_options_local(start_idx,
                query_key_local, left_option_texts_local, left_option_scores_local) then
            begin
                for result_idx_local := 0 to High(left_option_texts_local) do
                begin
                    option_local := Default(TSubquerySolverBeamOption);
                    option_local.text := left_option_texts_local[result_idx_local];
                    option_local.path := option_local.text;
                    option_local.first_chunk := option_local.text;
                    option_local.score := left_option_scores_local[result_idx_local];
                    option_local.segments := 1;
                    add_solver_beam_option_local(out_options, option_local,
                        option_limit_local);
                end;
            end
            else if (syllable_count_part = 2) and
                try_get_best_two_syllable_contextual_single_char_combo_local(
                start_idx, query_key_local, contextual_two_text_local,
                contextual_two_score_local) then
            begin
                option_local := Default(TSubquerySolverBeamOption);
                option_local.text := contextual_two_text_local;
                option_local.path := contextual_two_text_local;
                option_local.first_chunk := contextual_two_text_local;
                option_local.score := contextual_two_score_local;
                option_local.segments := 1;
                add_solver_beam_option_local(out_options, option_local,
                    option_limit_local);
            end;
            if (syllable_count_part = 3) and
                try_get_best_three_syllable_two_plus_one_candidate_local(
                start_idx, query_key_local, contextual_text_local,
                contextual_score_local) then
            begin
                option_local := Default(TSubquerySolverBeamOption);
                option_local.text := contextual_text_local;
                option_local.path := contextual_text_local;
                option_local.first_chunk := contextual_text_local;
                option_local.score := contextual_score_local;
                option_local.segments := 1;
                add_solver_beam_option_local(out_options, option_local,
                    option_limit_local);
            end;

            if collect_exact_query_key_candidates_local(start_idx, query_key_local,
                syllable_count_part, left_option_texts_local,
                left_option_scores_local) then
            begin
                for result_idx_local := 0 to High(left_option_texts_local) do
                begin
                    option_local := Default(TSubquerySolverBeamOption);
                    option_local.text := left_option_texts_local[result_idx_local];
                    option_local.path := option_local.text;
                    option_local.first_chunk := option_local.text;
                    option_local.score := left_option_scores_local[result_idx_local];
                    option_local.segments := 1;
                    add_solver_beam_option_local(out_options, option_local,
                        option_limit_local);
                end;
            end;
            if (syllable_count_part >= 2) and (syllable_count_part <= 3) then
            begin
                if query_engine = nil then
                begin
                    query_engine_config := m_config;
                    query_engine_config.debug_mode := False;
                    query_engine_config.max_candidates := 6;
                    query_engine := TncEngine.Create(query_engine_config);
                    query_engine.m_disable_subspan_standalone_oracle :=
                        m_disable_subspan_standalone_oracle + 1;
                end;

                query_engine.reset;
                query_engine.m_disable_subspan_standalone_oracle :=
                    m_disable_subspan_standalone_oracle + 1;
                query_engine.m_composition_text := query_key_local;
                query_engine.build_candidates;
                for nested_candidate_idx_local := 0 to High(query_engine.m_candidates) do
                begin
                    if nested_candidate_idx_local >= 96 then
                    begin
                        Break;
                    end;
                    nested_candidate_local := query_engine.m_candidates[
                        nested_candidate_idx_local];
                    candidate_text_local := Trim(nested_candidate_local.text);
                    if (Trim(nested_candidate_local.comment) <> '') or
                        (candidate_text_local = '') then
                    begin
                        Continue;
                    end;
                    nested_candidate_units_local := get_candidate_text_unit_count(
                        candidate_text_local);
                    if (nested_candidate_units_local <> syllable_count_part) or
                        (not is_valid_solver_cjk_phrase_text_local(candidate_text_local,
                        syllable_count_part)) or
                        (not solver_candidate_respects_fixed_boundaries_local(
                        start_idx, syllable_count_part, candidate_text_local)) then
                    begin
                        Continue;
                    end;

                    nested_candidate_score_local := query_engine.get_rank_score(
                        nested_candidate_local);
                    Inc(nested_candidate_score_local,
                        get_preferred_query_phrase_bonus_local(
                        query_key_local, candidate_text_local));
                    Inc(nested_candidate_score_local,
                        get_preferred_exact_subspan_bonus_local(
                        query_key_local, candidate_text_local));
                    Inc(nested_candidate_score_local,
                        get_exact_query_text_bonus_solver_local(
                        query_key_local, candidate_text_local));
                    Dec(nested_candidate_score_local,
                        get_trailing_context_free_single_char_penalty_solver_local(
                        query_key_local, candidate_text_local));
                    inferred_path_local :=
                        infer_segment_path_for_query_text_with_score(
                        query_key_local, candidate_text_local,
                        infer_score_local, infer_segments_local);
                    if inferred_path_local <> '' then
                    begin
                        Inc(nested_candidate_score_local, infer_score_local);
                        Inc(nested_candidate_score_local,
                            infer_segments_local * 320);
                    end;
                    option_local := Default(TSubquerySolverBeamOption);
                    option_local.text := candidate_text_local;
                    option_local.path := candidate_text_local;
                    option_local.first_chunk := candidate_text_local;
                    option_local.score := nested_candidate_score_local;
                    option_local.segments := 1;
                    add_solver_beam_option_local(out_options, option_local,
                        option_limit_local);
                end;
            end;

            if try_get_best_query_key_candidate_local(query_key_local,
                syllable_count_part, candidate_text_local, candidate_score_local) then
            begin
                option_local := Default(TSubquerySolverBeamOption);
                option_local.text := candidate_text_local;
                option_local.path := candidate_text_local;
                option_local.first_chunk := candidate_text_local;
                option_local.score := candidate_score_local;
                option_local.segments := 1;
                add_solver_beam_option_local(out_options, option_local,
                    option_limit_local);
            end;

            for split_idx_local := 1 to syllable_count_part - 1 do
            begin
                left_key_local := build_query_key_local(start_idx, split_idx_local);
                right_key_local := build_query_key_local(start_idx + split_idx_local,
                    syllable_count_part - split_idx_local);
                if (left_key_local = '') or (right_key_local = '') then
                begin
                    Continue;
                end;

                SetLength(left_option_texts_local, 0);
                SetLength(left_option_scores_local, 0);
                SetLength(right_option_texts_local, 0);
                SetLength(right_option_scores_local, 0);

                if split_idx_local = 1 then
                begin
                    if not collect_single_char_candidates_local(left_key_local,
                        left_option_texts_local, left_option_scores_local) then
                    begin
                        Continue;
                    end;
                end
                else if collect_exact_query_key_candidates_local(start_idx,
                    left_key_local,
                    split_idx_local, left_option_texts_local,
                    left_option_scores_local) then
                begin
                end
                else if try_get_best_query_key_candidate_local(left_key_local,
                    split_idx_local, left_text_local, left_score_local) then
                begin
                    SetLength(left_option_texts_local, 1);
                    SetLength(left_option_scores_local, 1);
                    left_option_texts_local[0] := left_text_local;
                    left_option_scores_local[0] := left_score_local;
                end
                else
                begin
                    Continue;
                end;

                if syllable_count_part - split_idx_local = 1 then
                begin
                    if not collect_single_char_candidates_local(right_key_local,
                        right_option_texts_local, right_option_scores_local) then
                    begin
                        Continue;
                    end;
                end
                else if collect_exact_query_key_candidates_local(
                    start_idx + split_idx_local, right_key_local,
                    syllable_count_part - split_idx_local, right_option_texts_local,
                    right_option_scores_local) then
                begin
                end
                else if try_get_best_query_key_candidate_local(right_key_local,
                    syllable_count_part - split_idx_local, right_text_local,
                    right_score_local) then
                begin
                    SetLength(right_option_texts_local, 1);
                    SetLength(right_option_scores_local, 1);
                    right_option_texts_local[0] := right_text_local;
                    right_option_scores_local[0] := right_score_local;
                end
                else
                begin
                    Continue;
                end;

                for left_option_idx_local := 0 to High(left_option_texts_local) do
                begin
                    for right_option_idx_local := 0 to High(right_option_texts_local) do
                    begin
                        combined_text_local := left_option_texts_local[
                            left_option_idx_local] + right_option_texts_local[
                            right_option_idx_local];
                        if not is_valid_solver_cjk_phrase_text_local(
                            combined_text_local, syllable_count_part) then
                        begin
                            Continue;
                        end;

                        if (split_idx_local = 1) and
                            (get_exact_query_text_bonus_solver_local(
                            query_key_local, combined_text_local) = 0) and
                            (not SameText(left_option_texts_local[
                            left_option_idx_local],
                            get_fixed_boundary_single_char_for_solver_local(
                            left_key_local))) then
                        begin
                            Continue;
                        end;

                        combined_score_local :=
                            left_option_scores_local[left_option_idx_local] +
                            right_option_scores_local[right_option_idx_local] - 96;
                        Inc(combined_score_local,
                            get_preferred_query_phrase_bonus_local(query_key_local,
                            combined_text_local));
                        Inc(combined_score_local,
                            get_exact_query_text_bonus_solver_local(
                            query_key_local, combined_text_local));
                        if m_dictionary <> nil then
                        begin
                            context_bonus_local := m_dictionary.get_context_bonus(
                                left_option_texts_local[left_option_idx_local],
                                right_option_texts_local[right_option_idx_local]);
                            Inc(combined_score_local, context_bonus_local);
                        end;
                        inferred_path_local :=
                            infer_segment_path_for_query_text_with_score(
                            query_key_local, combined_text_local,
                            infer_score_local, infer_segments_local);
                        if inferred_path_local <> '' then
                        begin
                            Inc(combined_score_local, infer_score_local);
                            Inc(combined_score_local, infer_segments_local * 320);
                        end;

                        option_local := Default(TSubquerySolverBeamOption);
                        option_local.text := combined_text_local;
                        option_local.path := combined_text_local;
                        option_local.first_chunk := combined_text_local;
                        option_local.score := combined_score_local;
                        option_local.segments := 2;
                        add_solver_beam_option_local(out_options, option_local,
                            option_limit_local);
                    end;
                end;
            end;

            Result := Length(out_options) > 0;
            if Result then
            begin
                query_option_cache_states.AddOrSetValue(query_key_local, 1);
                query_option_cache_options.AddOrSetValue(query_key_local,
                    Copy(out_options));
            end
            else
            begin
                query_option_cache_states.AddOrSetValue(query_key_local, 2);
            end;
        end;

        function get_solver_chunk_length_bonus_local(
            const chunk_syllables_local: Integer;
            const chunk_segments_local: Integer): Integer;
        begin
            if chunk_syllables_local <= 0 then
            begin
                Exit(0);
            end;

            if chunk_syllables_local <= 3 then
            begin
                Exit(chunk_syllables_local * chunk_syllables_local *
                    c_solver_length_bonus);
            end;

            Result := (3 * 3 * c_solver_length_bonus) +
                ((chunk_syllables_local - 3) * (c_solver_length_bonus div 2));
            if chunk_segments_local <= 1 then
            begin
                Dec(Result, (chunk_syllables_local - 3) *
                    (c_solver_length_bonus * 2));
            end;
            Result := Max(Result, chunk_syllables_local * 640);
        end;

        procedure maybe_promote_subquery_result_local(const result_text: string;
            const result_score: Integer; const result_segments: Integer;
            const result_path: string);
        var
            promote_existing_index_local: Integer;
            promote_idx_local: Integer;
            promote_top_path_segment_count_local: Integer;
            promote_should_promote_local: Boolean;
            promote_picked_local: TncCandidate;
        begin
            if (Trim(result_text) = '') or
                (get_candidate_text_unit_count(Trim(result_text)) <>
                input_syllable_count) then
            begin
                Exit;
            end;

            promote_existing_index_local := -1;
            for promote_idx_local := 0 to High(candidates) do
            begin
                if (Trim(candidates[promote_idx_local].comment) = '') and
                    SameText(Trim(candidates[promote_idx_local].text),
                    result_text) then
                begin
                    promote_existing_index_local := promote_idx_local;
                    Break;
                end;
            end;

            if promote_existing_index_local = 0 then
            begin
                out_promoted := True;
                Exit;
            end;

            promote_top_path_segment_count_local := get_path_segment_count_local(
                get_segment_path_for_candidate(candidates[0]));
            promote_should_promote_local := False;
            if Trim(candidates[0].comment) <> '' then
            begin
                promote_should_promote_local := True;
            end
            else if get_candidate_text_unit_count(Trim(candidates[0].text)) <>
                input_syllable_count then
            begin
                promote_should_promote_local := True;
            end
            else if (promote_top_path_segment_count_local > 0) and
                (result_segments < promote_top_path_segment_count_local) then
            begin
                promote_should_promote_local := True;
            end
            else if promote_existing_index_local > 0 then
            begin
                promote_should_promote_local := True;
            end
            else if not SameText(Trim(candidates[0].text), result_text) then
            begin
                promote_should_promote_local := True;
            end;

            if not promote_should_promote_local then
            begin
                Exit;
            end;

            if promote_existing_index_local > 0 then
            begin
                promote_picked_local := candidates[promote_existing_index_local];
                promote_picked_local.score := Max(promote_picked_local.score,
                    Max(candidates[0].score + c_solver_promote_bonus,
                    result_score + c_solver_promote_bonus));
                remember_segment_path_for_candidate(promote_picked_local.text,
                    promote_picked_local.comment, result_path,
                    promote_picked_local.score);
            end
            else
            begin
                FillChar(promote_picked_local, SizeOf(promote_picked_local), 0);
                promote_picked_local.text := result_text;
                promote_picked_local.comment := '';
                promote_picked_local.score := Max(candidates[0].score +
                    c_solver_promote_bonus, result_score +
                    c_solver_promote_bonus);
                promote_picked_local.source := cs_rule;
                promote_picked_local.has_dict_weight := False;
                promote_picked_local.dict_weight := 0;
                remember_segment_path_for_candidate(promote_picked_local.text, '',
                    result_path, promote_picked_local.score);
            end;

            if promote_existing_index_local > 0 then
            begin
                for promote_idx_local := promote_existing_index_local downto 1 do
                begin
                    candidates[promote_idx_local] :=
                        candidates[promote_idx_local - 1];
                end;
            end
            else
            begin
                SetLength(candidates, Length(candidates) + 1);
                for promote_idx_local := High(candidates) downto 1 do
                begin
                    candidates[promote_idx_local] :=
                        candidates[promote_idx_local - 1];
                end;
            end;
            candidates[0] := promote_picked_local;
            out_promoted := True;
        end;

        function try_build_strict_exact_window_sentence_candidate_local(
            out out_text: string; out out_score: Integer;
            out out_segments: Integer; out out_path: string): Boolean;
        const
            c_strict_max_chunk_syllables = 6;
            c_strict_single_penalty = 7800;
            c_strict_nonboundary_single_penalty = 4600;
            c_strict_join_penalty = 900;
            c_strict_context_scale = 6;
        var
            strict_states: TStrictExactSentenceStateArray;
            strict_pos: Integer;
            strict_len: Integer;
            strict_next_pos: Integer;
            strict_chunk_text: string;
            strict_chunk_path: string;
            strict_combined_text: string;
            strict_combined_path: string;
            strict_chunk_score: Integer;
            strict_total_score: Integer;
            strict_chunk_segments: Integer;
            strict_total_segments: Integer;
            strict_chunk_anchor_units: Integer;
            strict_total_anchor_units: Integer;
            strict_match_count_local: Integer;
            strict_mismatch_count_local: Integer;
            strict_strong_match_count_local: Integer;
            strict_strong_mismatch_count_local: Integer;
            strict_context_bonus_local: Integer;
            strict_has_anchor_local: Boolean;
            strict_is_single_local: Boolean;
            strict_is_strong_chunk_local: Boolean;
            strict_total_strong_chunks_local: Integer;
            strict_total_single_chunks_local: Integer;
            strict_candidate_better_local: Boolean;
            strict_fixed_text_local: string;

            function get_strict_chunk_bonus_local(
                const local_len: Integer;
                const local_has_anchor: Boolean;
                const local_anchor_units: Integer;
                const local_chunk_score: Integer): Integer;
            begin
                case local_len of
                    1:
                        Result := -c_strict_single_penalty;
                    2:
                        Result := 0;
                    3:
                        Result := 2800;
                    4:
                        Result := 7600;
                    5:
                        Result := 11200;
                    else
                        Result := 13600 + ((local_len - 6) * 1600);
                end;

                if local_has_anchor or (local_anchor_units >= 2) then
                begin
                    Inc(Result, 2200);
                end;

                if (local_len = 2) and (local_chunk_score < 18000) and
                    (not local_has_anchor) then
                begin
                    Dec(Result, 1600);
                end
                else if (local_len >= 4) and (local_chunk_score >= 28000) then
                begin
                    Inc(Result, 1400);
                end;
            end;

            function try_get_strict_chunk_local(const local_pos: Integer;
                const local_len: Integer; out local_text: string;
                out local_score: Integer; out local_segments: Integer;
                out local_path: string; out local_has_anchor: Boolean;
                out local_anchor_units: Integer;
                out local_is_strong_chunk: Boolean;
                out local_is_single: Boolean): Boolean;
            var
                local_query_key: string;
            begin
                Result := False;
                local_text := '';
                local_score := 0;
                local_segments := 1;
                local_path := '';
                local_has_anchor := False;
                local_anchor_units := 0;
                local_is_strong_chunk := False;
                local_is_single := False;

                if local_len <= 0 then
                begin
                    Exit;
                end;

                local_query_key := build_query_key_local(local_pos, local_len);
                if local_query_key = '' then
                begin
                    Exit;
                end;

                if local_len = 1 then
                begin
                    strict_fixed_text_local :=
                        get_fixed_boundary_single_char_for_solver_local(
                        effective_syllables[local_pos].text);
                    if strict_fixed_text_local = '' then
                    begin
                        Exit;
                    end;
                    if not try_get_exact_single_char_candidate_local(local_pos,
                        local_text, local_score) then
                    begin
                        local_text := strict_fixed_text_local;
                        local_score := 1500;
                    end;
                    if not SameText(local_text, strict_fixed_text_local) then
                    begin
                        local_text := strict_fixed_text_local;
                        local_score := Max(local_score, 1500);
                    end;
                    local_has_anchor := True;
                    local_anchor_units := Ord(local_has_anchor);
                    local_is_single := True;
                    if not is_valid_solver_cjk_phrase_text_local(local_text, 1) then
                    begin
                        Exit;
                    end;
                    local_is_strong_chunk := True;
                    local_path := local_text;
                    Exit(True);
                end;

                if not try_resolve_best_exact_subspan_local(local_pos, local_len,
                    local_text, local_score, local_segments, local_path,
                    local_has_anchor, local_anchor_units) then
                begin
                    Exit;
                end;
                if (not is_valid_solver_cjk_phrase_text_local(local_text, local_len)) or
                    (not solver_candidate_respects_fixed_boundaries_local(local_pos,
                    local_len, local_text)) then
                begin
                    Exit;
                end;

                Inc(local_score, get_exact_query_text_bonus_solver_local(
                    local_query_key, local_text));
                local_is_strong_chunk := (local_len >= 3) or local_has_anchor or
                    (local_score >= 22000);
                if local_path = '' then
                begin
                    local_path := local_text;
                end;
                Result := True;
            end;
        begin
            Result := False;
            out_text := '';
            out_score := 0;
            out_segments := 0;
            out_path := '';

            if syllable_count_local < c_solver_min_syllables then
            begin
                Exit;
            end;

            SetLength(strict_states, syllable_count_local + 1);
            strict_states[syllable_count_local].valid := True;
            strict_states[syllable_count_local].score := 0;
            strict_states[syllable_count_local].segments := 0;
            strict_states[syllable_count_local].strong_chunks := 0;
            strict_states[syllable_count_local].single_chunks := 0;
            strict_states[syllable_count_local].anchor_units := 0;
            strict_states[syllable_count_local].text := '';
            strict_states[syllable_count_local].path := '';
            strict_states[syllable_count_local].first_chunk := '';

            for strict_pos := syllable_count_local - 1 downto 0 do
            begin
                strict_states[strict_pos].valid := False;
                strict_states[strict_pos].score := Low(Integer);
                strict_states[strict_pos].segments := MaxInt;
                strict_states[strict_pos].strong_chunks := -1;
                strict_states[strict_pos].single_chunks := MaxInt;
                strict_states[strict_pos].anchor_units := 0;
                strict_states[strict_pos].text := '';
                strict_states[strict_pos].path := '';
                strict_states[strict_pos].first_chunk := '';

                for strict_len := 1 to Min(c_strict_max_chunk_syllables,
                    syllable_count_local - strict_pos) do
                begin
                    strict_next_pos := strict_pos + strict_len;
                    if (strict_next_pos < syllable_count_local) and
                        (not strict_states[strict_next_pos].valid) then
                    begin
                        Continue;
                    end;
                    if not try_get_strict_chunk_local(strict_pos, strict_len,
                        strict_chunk_text, strict_chunk_score,
                        strict_chunk_segments, strict_chunk_path,
                        strict_has_anchor_local, strict_chunk_anchor_units,
                        strict_is_strong_chunk_local, strict_is_single_local) then
                    begin
                        Continue;
                    end;

                    strict_total_score := strict_chunk_score +
                        get_strict_chunk_bonus_local(strict_len,
                        strict_has_anchor_local, strict_chunk_anchor_units,
                        strict_chunk_score);
                    strict_total_segments := strict_chunk_segments;
                    strict_total_strong_chunks_local :=
                        Ord(strict_is_strong_chunk_local);
                    strict_total_single_chunks_local :=
                        Ord(strict_is_single_local);
                    strict_total_anchor_units := strict_chunk_anchor_units;
                    strict_combined_text := strict_chunk_text;
                    strict_combined_path := strict_chunk_path;

                    if strict_next_pos < syllable_count_local then
                    begin
                        Inc(strict_total_score,
                            strict_states[strict_next_pos].score);
                        Inc(strict_total_score, -c_strict_join_penalty);
                        Inc(strict_total_segments,
                            strict_states[strict_next_pos].segments);
                        Inc(strict_total_strong_chunks_local,
                            strict_states[strict_next_pos].strong_chunks);
                        Inc(strict_total_single_chunks_local,
                            strict_states[strict_next_pos].single_chunks);
                        if strict_states[strict_next_pos].anchor_units >
                            strict_total_anchor_units then
                        begin
                            strict_total_anchor_units :=
                                strict_states[strict_next_pos].anchor_units;
                        end;
                        if (m_dictionary <> nil) and
                            (strict_states[strict_next_pos].first_chunk <> '') then
                        begin
                            strict_context_bonus_local :=
                                m_dictionary.get_context_bonus(
                                strict_chunk_text,
                                strict_states[strict_next_pos].first_chunk);
                            Inc(strict_total_score,
                                strict_context_bonus_local *
                                c_strict_context_scale);
                        end;
                        strict_combined_text := strict_chunk_text +
                            strict_states[strict_next_pos].text;
                        if strict_states[strict_next_pos].path <> '' then
                        begin
                            if strict_combined_path <> '' then
                            begin
                                strict_combined_path := strict_combined_path +
                                    c_segment_path_separator +
                                    strict_states[strict_next_pos].path;
                            end
                            else
                            begin
                                strict_combined_path :=
                                    strict_states[strict_next_pos].path;
                            end;
                        end;
                    end;

                    strict_candidate_better_local := False;
                    if strict_total_score > strict_states[strict_pos].score then
                    begin
                        strict_candidate_better_local := True;
                    end
                    else if strict_total_score = strict_states[strict_pos].score then
                    begin
                        if strict_total_strong_chunks_local >
                            strict_states[strict_pos].strong_chunks then
                        begin
                            strict_candidate_better_local := True;
                        end
                        else if strict_total_strong_chunks_local =
                            strict_states[strict_pos].strong_chunks then
                        begin
                            if strict_total_single_chunks_local <
                                strict_states[strict_pos].single_chunks then
                            begin
                                strict_candidate_better_local := True;
                            end
                            else if strict_total_single_chunks_local =
                                strict_states[strict_pos].single_chunks then
                            begin
                                if strict_total_segments <
                                    strict_states[strict_pos].segments then
                                begin
                                    strict_candidate_better_local := True;
                                end
                                else if (strict_total_segments =
                                    strict_states[strict_pos].segments) and
                                    ((strict_states[strict_pos].text = '') or
                                    (CompareText(strict_combined_text,
                                    strict_states[strict_pos].text) < 0)) then
                                begin
                                    strict_candidate_better_local := True;
                                end;
                            end;
                        end;
                    end;

                    if strict_candidate_better_local then
                    begin
                        strict_states[strict_pos].valid := True;
                        strict_states[strict_pos].score := strict_total_score;
                        strict_states[strict_pos].segments := strict_total_segments;
                        strict_states[strict_pos].strong_chunks :=
                            strict_total_strong_chunks_local;
                        strict_states[strict_pos].single_chunks :=
                            strict_total_single_chunks_local;
                        strict_states[strict_pos].anchor_units :=
                            strict_total_anchor_units;
                        strict_states[strict_pos].text := strict_combined_text;
                        strict_states[strict_pos].path := strict_combined_path;
                        strict_states[strict_pos].first_chunk := strict_chunk_text;
                    end;
                end;
            end;

            if (not strict_states[0].valid) or
                (strict_states[0].text = '') or
                (get_candidate_text_unit_count(strict_states[0].text) <>
                input_syllable_count) then
            begin
                Exit;
            end;

            get_exact_window_consistency_stats_local(strict_states[0].text, 2, 5,
                strict_match_count_local, strict_mismatch_count_local,
                strict_strong_match_count_local,
                strict_strong_mismatch_count_local);
            if (strict_strong_mismatch_count_local > 0) or
                (strict_strong_match_count_local <
                Max(2, Min(6, input_syllable_count div 2))) or
                (strict_match_count_local <
                strict_mismatch_count_local + 2) or
                (strict_states[0].strong_chunks <
                Max(2, Min(5, input_syllable_count div 3))) or
                (strict_states[0].single_chunks >
                Max(2, input_syllable_count div 5)) then
            begin
                if m_config.debug_mode then
                begin
                    m_last_full_path_debug_info := m_last_full_path_debug_info +
                        Format(' tssx=[reject text=%s score=%d seg=%d sm=%d ssm=%d mm=%d sc=%d]',
                        [strict_states[0].text, strict_states[0].score,
                        strict_states[0].segments,
                        strict_strong_match_count_local,
                        strict_strong_mismatch_count_local,
                        strict_mismatch_count_local,
                        strict_states[0].single_chunks]);
                end;
                Exit;
            end;

            out_text := strict_states[0].text;
            out_score := strict_states[0].score +
                (strict_strong_match_count_local * 1024) -
                (strict_mismatch_count_local * 128);
            out_segments := strict_states[0].segments;
            out_path := strict_states[0].path;
            if m_config.debug_mode then
            begin
                m_last_full_path_debug_info := m_last_full_path_debug_info +
                    Format(' tssx=[best text=%s score=%d seg=%d sm=%d mm=%d sc=%d]',
                    [out_text, out_score, out_segments,
                    strict_strong_match_count_local,
                    strict_mismatch_count_local,
                    strict_states[0].single_chunks]);
            end;
            Result := True;
        end;

        procedure try_update_beam_from_position_local(const start_idx: Integer);
        var
            chunk_syllables_local: Integer;
            next_idx_local: Integer;
            chunk_options_local: TSubquerySolverBeamOptionArray;
            chunk_option_idx_local: Integer;
            suffix_option_idx_local: Integer;
            chunk_option_local: TSubquerySolverBeamOption;
            suffix_option_local: TSubquerySolverBeamOption;
            candidate_option_local: TSubquerySolverBeamOption;
            context_bonus_local: Integer;
            exact_two_text_local: string;
            exact_two_score_local: Integer;
        begin
            SetLength(best_beam_options[start_idx], 0);
            for chunk_syllables_local := 1 to Min(c_solver_max_chunk_syllables,
                syllable_count_local - start_idx) do
            begin
                next_idx_local := start_idx + chunk_syllables_local;
                if (next_idx_local < syllable_count_local) and
                    (Length(best_beam_options[next_idx_local]) = 0) then
                begin
                    Continue;
                end;

                if not collect_subquery_candidate_options_local(start_idx,
                    chunk_syllables_local, chunk_options_local) then
                begin
                    Continue;
                end;

                for chunk_option_idx_local := 0 to High(chunk_options_local) do
                begin
                    chunk_option_local := chunk_options_local[chunk_option_idx_local];
                    chunk_option_local.first_chunk := chunk_option_local.text;
                    if (chunk_syllables_local = 1) and
                        try_get_top_two_syllable_exact_text_local(start_idx,
                        exact_two_text_local, exact_two_score_local) and
                        (get_first_solver_text_unit_local(exact_two_text_local) <> '') and
                        (not SameText(get_first_solver_text_unit_local(
                        exact_two_text_local), chunk_option_local.text)) then
                    begin
                        Dec(chunk_option_local.score, 12000);
                    end;
                    if (chunk_syllables_local = 1) and
                        try_get_top_two_syllable_exact_text_local(start_idx,
                        exact_two_text_local, exact_two_score_local) and
                        (not SameText(chunk_option_local.text,
                        get_fixed_boundary_single_char_for_solver_local(
                        effective_syllables[start_idx].text))) then
                    begin
                        Dec(chunk_option_local.score, 4096);
                    end;
                    Inc(chunk_option_local.score,
                        get_solver_chunk_length_bonus_local(
                        chunk_syllables_local, chunk_option_local.segments));
                    if chunk_syllables_local >= 3 then
                    begin
                        Inc(chunk_option_local.score, c_solver_anchor_bonus);
                    end;

                    if next_idx_local >= syllable_count_local then
                    begin
                        add_solver_beam_option_local(best_beam_options[start_idx],
                            chunk_option_local, c_solver_beam_limit);
                        Continue;
                    end;

                    for suffix_option_idx_local := 0 to
                        High(best_beam_options[next_idx_local]) do
                    begin
                        suffix_option_local :=
                            best_beam_options[next_idx_local][suffix_option_idx_local];
                        candidate_option_local := Default(TSubquerySolverBeamOption);
                        candidate_option_local.text := chunk_option_local.text +
                            suffix_option_local.text;
                        candidate_option_local.path := chunk_option_local.path;
                        if suffix_option_local.path <> '' then
                        begin
                            if candidate_option_local.path <> '' then
                            begin
                                candidate_option_local.path :=
                                    candidate_option_local.path +
                                    c_segment_path_separator;
                            end;
                            candidate_option_local.path :=
                                candidate_option_local.path +
                                suffix_option_local.path;
                        end;
                        candidate_option_local.first_chunk :=
                            chunk_option_local.first_chunk;
                        candidate_option_local.score := chunk_option_local.score +
                            suffix_option_local.score;
                        candidate_option_local.segments :=
                            chunk_option_local.segments +
                            suffix_option_local.segments;
                        if (m_dictionary <> nil) and
                            (suffix_option_local.first_chunk <> '') then
                        begin
                            context_bonus_local := m_dictionary.get_context_bonus(
                                chunk_option_local.text,
                                suffix_option_local.first_chunk);
                            Inc(candidate_option_local.score, context_bonus_local);
                        end;
                        add_solver_beam_option_local(best_beam_options[start_idx],
                            candidate_option_local, c_solver_beam_limit);
                    end;
                end;
            end;
        end;

        procedure try_update_best_from_position(const start_idx: Integer);
        var
            chunk_syllables: Integer;
            next_idx: Integer;
            chunk_text: string;
            chunk_score: Integer;
            exact_two_text: string;
            exact_two_score: Integer;
            total_score: Integer;
            total_segments: Integer;
            combined_text: string;
            combined_path: string;
            better_candidate: Boolean;
            first_chunk_local: string;
            context_bonus: Integer;
        begin
            for chunk_syllables := 1 to Min(c_solver_max_chunk_syllables,
                syllable_count_local - start_idx) do
            begin
                next_idx := start_idx + chunk_syllables;
                if (next_idx < syllable_count_local) and
                    (best_scores[next_idx] = Low(Integer)) then
                begin
                    Continue;
                end;

                if not try_get_best_subquery_candidate_local(start_idx,
                    chunk_syllables, chunk_text, chunk_score) then
                begin
                    Continue;
                end;

                if (chunk_syllables = 1) and
                    try_get_top_two_syllable_exact_text_local(start_idx,
                    exact_two_text, exact_two_score) and
                    (get_first_solver_text_unit_local(exact_two_text) <> '') and
                    (not SameText(get_first_solver_text_unit_local(exact_two_text),
                    chunk_text)) then
                begin
                    Dec(chunk_score, 12000);
                end;
                if (chunk_syllables = 1) and
                    try_get_top_two_syllable_exact_text_local(start_idx,
                    exact_two_text, exact_two_score) and
                    (not SameText(chunk_text,
                    get_fixed_boundary_single_char_for_solver_local(
                    effective_syllables[start_idx].text))) then
                begin
                    Dec(chunk_score, 4096);
                end;

                total_score := chunk_score +
                    get_solver_chunk_length_bonus_local(chunk_syllables, 1);
                if chunk_syllables >= 3 then
                begin
                    Inc(total_score, c_solver_anchor_bonus);
                end;

                combined_text := chunk_text;
                combined_path := chunk_text;
                total_segments := 1;
                first_chunk_local := chunk_text;

                if next_idx < syllable_count_local then
                begin
                    Inc(total_score, best_scores[next_idx]);
                    if (m_dictionary <> nil) and (best_first_chunks[next_idx] <> '') then
                    begin
                        context_bonus := m_dictionary.get_context_bonus(chunk_text,
                            best_first_chunks[next_idx]);
                        Inc(total_score, context_bonus);
                    end;
                    Inc(total_segments, best_segments[next_idx]);
                    combined_text := combined_text + best_texts[next_idx];
                    if best_paths[next_idx] <> '' then
                    begin
                        combined_path := combined_path + c_segment_path_separator +
                            best_paths[next_idx];
                    end;
                end;

                better_candidate := False;
                if total_score > best_scores[start_idx] then
                begin
                    better_candidate := True;
                end
                else if total_score = best_scores[start_idx] then
                begin
                    if total_segments < best_segments[start_idx] then
                    begin
                        better_candidate := True;
                    end
                    else if (total_segments = best_segments[start_idx]) and
                        ((best_texts[start_idx] = '') or
                        (CompareText(combined_text, best_texts[start_idx]) < 0)) then
                    begin
                        better_candidate := True;
                    end;
                end;

                if better_candidate then
                begin
                    best_scores[start_idx] := total_score;
                    best_segments[start_idx] := total_segments;
                    best_texts[start_idx] := combined_text;
                    best_paths[start_idx] := combined_path;
                    best_first_chunks[start_idx] := first_chunk_local;
                end;
            end;
        end;
    begin
        out_promoted := False;
        if (Length(candidates) = 0) or
            (m_disable_subspan_standalone_oracle > 0) or
            (input_syllable_count < c_solver_min_syllables) or
            (not is_full_pinyin_key(lookup_text)) or
            (m_dictionary = nil) then
        begin
            Exit;
        end;

        effective_syllables := get_effective_compact_pinyin_syllables(lookup_text);
        syllable_count_local := Length(effective_syllables);
        if syllable_count_local <> input_syllable_count then
        begin
            Exit;
        end;

        has_extendable_tail_local :=
            has_extendable_tail_query_local(lookup_text);
        if has_extendable_tail_local and m_config.debug_mode then
        begin
            m_last_full_path_debug_info := m_last_full_path_debug_info +
                ' tss=[extendable_tail]';
        end;

        if try_build_strict_exact_window_sentence_candidate_local(
            strict_solver_text_local, strict_solver_score_local,
            strict_solver_segments_local, strict_solver_path_local) then
        begin
            maybe_promote_subquery_result_local(strict_solver_text_local,
                strict_solver_score_local, strict_solver_segments_local,
                strict_solver_path_local);
            if out_promoted then
            begin
                Exit;
            end;
        end;

        query_cache_states := TDictionary<string, Integer>.Create;
        query_cache_texts := TDictionary<string, string>.Create;
        query_cache_scores := TDictionary<string, Integer>.Create;
        query_option_cache_states := TDictionary<string, Integer>.Create;
        query_option_cache_options :=
            TDictionary<string, TSubquerySolverBeamOptionArray>.Create;
        query_engine := nil;
        try
            SetLength(best_scores, syllable_count_local + 1);
            SetLength(best_segments, syllable_count_local + 1);
            SetLength(best_texts, syllable_count_local + 1);
            SetLength(best_paths, syllable_count_local + 1);
            SetLength(best_first_chunks, syllable_count_local + 1);
            SetLength(best_beam_options, syllable_count_local + 1);

            for idx := 0 to syllable_count_local do
            begin
                best_scores[idx] := Low(Integer);
                best_segments[idx] := MaxInt;
                best_texts[idx] := '';
                best_paths[idx] := '';
                best_first_chunks[idx] := '';
            end;

            best_scores[syllable_count_local] := 0;
            best_segments[syllable_count_local] := 0;
            SetLength(best_beam_options[syllable_count_local], 1);
            best_beam_options[syllable_count_local][0] :=
                Default(TSubquerySolverBeamOption);
            best_beam_options[syllable_count_local][0].score := 0;
            best_beam_options[syllable_count_local][0].segments := 0;

            for idx := syllable_count_local - 1 downto 0 do
            begin
                try_update_best_from_position(idx);
            end;

            if (syllable_count_local <= c_solver_beam_max_syllables) and
                ((best_scores[0] = Low(Integer)) or (best_segments[0] >= 6)) then
            begin
                for idx := syllable_count_local - 1 downto 0 do
                begin
                    try_update_beam_from_position_local(idx);
                end;

                if (Length(best_beam_options[0]) > 0) and
                    (best_beam_options[0][0].text <> '') and
                    (get_candidate_text_unit_count(best_beam_options[0][0].text) =
                    input_syllable_count) and
                    ((best_scores[0] = Low(Integer)) or
                    (best_beam_options[0][0].score > best_scores[0]) or
                    ((best_beam_options[0][0].score + 256 >= best_scores[0]) and
                    (best_beam_options[0][0].segments <= best_segments[0]))) then
                begin
                    best_scores[0] := best_beam_options[0][0].score;
                    best_segments[0] := best_beam_options[0][0].segments;
                    best_texts[0] := best_beam_options[0][0].text;
                    best_paths[0] := best_beam_options[0][0].path;
                    best_first_chunks[0] := best_beam_options[0][0].first_chunk;
                end;
            end;

            if (best_scores[0] = Low(Integer)) or
                (best_texts[0] = '') or
                (get_candidate_text_unit_count(best_texts[0]) <> input_syllable_count) then
            begin
                if m_config.debug_mode then
                begin
                    m_last_full_path_debug_info := m_last_full_path_debug_info +
                        ' tss=[miss]';
                end;
                Exit;
            end;

            if m_config.debug_mode then
            begin
                m_last_full_path_debug_info := m_last_full_path_debug_info +
                    Format(' tss=[best text=%s score=%d seg=%d]',
                    [best_texts[0], best_scores[0], best_segments[0]]);
                if Length(best_beam_options[0]) > 0 then
                begin
                    m_last_full_path_debug_info := m_last_full_path_debug_info +
                        Format(' tbeam=[best text=%s score=%d seg=%d]',
                        [best_beam_options[0][0].text,
                        best_beam_options[0][0].score,
                        best_beam_options[0][0].segments]);
                end;
            end;

            existing_index := -1;
            for idx := 0 to High(candidates) do
            begin
                if (Trim(candidates[idx].comment) = '') and
                    SameText(Trim(candidates[idx].text), best_texts[0]) then
                begin
                    existing_index := idx;
                    Break;
                end;
            end;

            if existing_index = 0 then
            begin
                out_promoted := True;
                Exit;
            end;

            top_path_segment_count := get_path_segment_count_local(
                get_segment_path_for_candidate(candidates[0]));
            should_promote := False;
            if Trim(candidates[0].comment) <> '' then
            begin
                should_promote := True;
            end
            else if get_candidate_text_unit_count(Trim(candidates[0].text)) <>
                input_syllable_count then
            begin
                should_promote := True;
            end
            else if (top_path_segment_count > 0) and
                (best_segments[0] < top_path_segment_count) then
            begin
                should_promote := True;
            end
            else if existing_index > 0 then
            begin
                should_promote := True;
            end
            else if not SameText(Trim(candidates[0].text), best_texts[0]) then
            begin
                should_promote := True;
            end;

            if not should_promote then
            begin
                Exit;
            end;

            if existing_index > 0 then
            begin
                picked := candidates[existing_index];
            end
            else
            begin
                FillChar(picked, SizeOf(picked), 0);
                picked.text := best_texts[0];
                picked.comment := '';
                picked.score := Max(candidates[0].score + c_solver_promote_bonus,
                    best_scores[0] + c_solver_promote_bonus);
                picked.source := cs_rule;
                picked.has_dict_weight := False;
                picked.dict_weight := 0;
                remember_segment_path_for_candidate(picked.text, '',
                    best_paths[0], picked.score);
            end;

            if existing_index > 0 then
            begin
                for idx := existing_index downto 1 do
                begin
                    candidates[idx] := candidates[idx - 1];
                end;
            end
            else
            begin
                SetLength(candidates, Length(candidates) + 1);
                for idx := High(candidates) downto 1 do
                begin
                    candidates[idx] := candidates[idx - 1];
                end;
            end;
            candidates[0] := picked;
            out_promoted := True;
        finally
            query_engine.Free;
            query_option_cache_options.Free;
            query_option_cache_states.Free;
            query_cache_scores.Free;
            query_cache_texts.Free;
            query_cache_states.Free;
        end;
    end;

    procedure ensure_multi_char_partial_precedes_single_char_partial(
        var candidates: TncCandidateList);
    var
        idx: Integer;
        best_index: Integer;
        best_units: Integer;
        best_score: Integer;
        first_single_index: Integer;
        target_index: Integer;
        picked: TncCandidate;
        candidate_units: Integer;

        function is_complete_multi_char_anchor_local(
            const candidate: TncCandidate): Boolean;
        var
            anchor_units: Integer;
        begin
            Result := False;
            if candidate.comment <> '' then
            begin
                Exit;
            end;

            anchor_units := get_candidate_text_unit_count(Trim(candidate.text));
            if anchor_units < 2 then
            begin
                Exit;
            end;

            if candidate.has_dict_weight or (candidate.source = cs_user) then
            begin
                Exit(True);
            end;

            Result := (candidate.source = cs_rule) and
                (not is_runtime_chain_candidate(candidate)) and
                (not is_runtime_common_pattern_candidate(candidate)) and
                (not is_runtime_redup_candidate(candidate));
        end;

        function is_strong_multi_char_partial_local(
            const candidate: TncCandidate): Boolean;
        begin
            Result := (candidate.comment <> '') and
                (get_candidate_text_unit_count(Trim(candidate.text)) >= 2) and
                (candidate.has_dict_weight or (candidate.source = cs_user) or
                ((candidate.source = cs_rule) and
                (not is_runtime_chain_candidate(candidate)) and
                (not is_runtime_common_pattern_candidate(candidate)) and
                (not is_runtime_redup_candidate(candidate))));
        end;
    begin
        if (Length(candidates) <= 1) or (input_syllable_count < 2) then
        begin
            Exit;
        end;

        first_single_index := -1;
        best_index := -1;
        best_units := -1;
        best_score := Low(Integer);
        for idx := 0 to High(candidates) do
        begin
            if (first_single_index < 0) and (candidates[idx].comment <> '') and
                (get_candidate_text_unit_count(Trim(candidates[idx].text)) = 1) then
            begin
                first_single_index := idx;
            end;

            if not is_strong_multi_char_partial_local(candidates[idx]) then
            begin
                Continue;
            end;

            candidate_units := get_candidate_text_unit_count(Trim(candidates[idx].text));
            if (candidate_units > best_units) or
                ((candidate_units = best_units) and (candidates[idx].score > best_score)) then
            begin
                best_index := idx;
                best_units := candidate_units;
                best_score := candidates[idx].score;
            end;
        end;

        if (first_single_index < 0) or (best_index < 0) or (best_index < first_single_index) then
        begin
            Exit;
        end;

        target_index := 0;
        while (target_index <= High(candidates)) and
            is_complete_multi_char_anchor_local(candidates[target_index]) do
        begin
            Inc(target_index);
        end;

        if (target_index > High(candidates)) or (best_index <= target_index) then
        begin
            Exit;
        end;

        picked := candidates[best_index];
        for idx := best_index downto target_index + 1 do
        begin
            candidates[idx] := candidates[idx - 1];
        end;
        candidates[target_index] := picked;
    end;

    function build_exact_leading_prefix_partial_candidates(const query_text: string;
        out out_candidates: TncCandidateList): Boolean; forward;
    function build_raw_leading_prefix_partial_candidates(const query_text: string;
        out out_candidates: TncCandidateList): Boolean; forward;
    function build_lightweight_sentence_candidates(const query_text: string;
        out out_candidates: TncCandidateList): Boolean; forward;

    procedure ensure_rich_head_single_char_partials_visible(
        var candidates: TncCandidateList);
    const
        c_target_single_count = 7;
    var
        target_index: Integer;
        pick_index: Integer;
        picked: TncCandidate;
        moved_count: Integer;
        best_phrase_index: Integer;
        best_phrase_units: Integer;
        best_phrase_score: Integer;
        candidate_units: Integer;
        top_phrase_units: Integer;
        visible_head_single_count: Integer;
        has_visible_secondary_head_partial: Boolean;
        supplemental_candidates: TncCandidateList;
        tail_prefix: string;
        parser: TncPinyinParser;
        raw_syllables: TncPinyinParseResult;
        top_clone: TncCandidate;

        function is_complete_multi_char_candidate_local(
            const candidate: TncCandidate): Boolean;
        begin
            Result := (candidate.comment = '') and
                (get_candidate_text_unit_count(Trim(candidate.text)) >= 2);
        end;

        function is_head_multi_char_partial_local(
            const candidate: TncCandidate): Boolean;
        begin
            Result := (candidate.comment <> '') and
                (get_candidate_text_unit_count(Trim(candidate.text)) >= 2);
        end;

        function is_head_single_char_partial_local(
            const candidate: TncCandidate): Boolean;
        begin
            Result := (candidate.comment <> '') and
                (get_candidate_text_unit_count(Trim(candidate.text)) = 1) and
                (get_effective_compact_pinyin_unit_count(candidate.comment) =
                input_syllable_count - 1);
        end;

        function is_top_anchor_candidate_local(
            const candidate: TncCandidate): Boolean;
        begin
            Result := is_complete_multi_char_candidate_local(candidate) or
                is_head_multi_char_partial_local(candidate);
        end;

        function is_text_prefix_local(const prefix_value: string;
            const full_value: string): Boolean;
        begin
            Result := (prefix_value <> '') and (full_value <> '') and
                (Length(prefix_value) <= Length(full_value)) and
                SameText(Copy(full_value, 1, Length(prefix_value)), prefix_value);
        end;

        function get_raw_query_tail_prefix_local: string;
        begin
            Result := '';
            parser := TncPinyinParser.Create;
            try
                raw_syllables := parser.parse(normalize_pinyin_text(lookup_text));
            finally
                parser.Free;
            end;

            if Length(raw_syllables) <= 0 then
            begin
                Exit;
            end;

            Result := normalize_pinyin_text(raw_syllables[High(raw_syllables)].text);
            if (Result = '') or is_full_pinyin_key(Result) then
            begin
                Result := '';
            end;
        end;

        function has_same_text_tail_partial_local(const text_value: string;
            const comment_value: string): Boolean;
        var
            local_idx: Integer;
        begin
            Result := False;
            if (Trim(text_value) = '') or (Trim(comment_value) = '') then
            begin
                Exit;
            end;

            for local_idx := 0 to High(candidates) do
            begin
                if SameText(Trim(candidates[local_idx].text), Trim(text_value)) and
                    SameText(Trim(candidates[local_idx].comment), Trim(comment_value)) then
                begin
                    Exit(True);
                end;
            end;
        end;

        function has_extendable_full_tail_query_local: Boolean;
        var
            effective_syllables: TncPinyinParseResult;
            local_syllable_count: Integer;
            suffix_ch: Char;
            extended_key: string;
        begin
            Result := False;
            if lookup_text = '' then
            begin
                Exit;
            end;

            effective_syllables := get_effective_compact_pinyin_syllables(lookup_text);
            local_syllable_count := Length(effective_syllables);
            if local_syllable_count < 4 then
            begin
                Exit;
            end;

            for suffix_ch := 'a' to 'z' do
            begin
                extended_key := lookup_text + suffix_ch;
                if get_effective_compact_pinyin_unit_count(extended_key) =
                    local_syllable_count then
                begin
                    Exit(True);
                end;
            end;
        end;

        procedure append_raw_head_prefix_partials_local;
        const
            c_raw_single_limit = 6;
            c_raw_phrase_limit = 3;
        var
            local_prefix_key: string;
            local_tail_comment: string;
            local_results: TncCandidateList;
            local_idx: Integer;
            local_added: Integer;
            local_candidate: TncCandidate;
            local_units: Integer;
        begin
            if Length(raw_syllables) < 2 then
            begin
                Exit;
            end;

            local_prefix_key := normalize_pinyin_text(raw_syllables[0].text);
            local_tail_comment := '';
            for local_idx := 1 to High(raw_syllables) do
            begin
                local_tail_comment := local_tail_comment +
                    normalize_pinyin_text(raw_syllables[local_idx].text);
            end;

            if (m_dictionary <> nil) and (local_prefix_key <> '') and
                (local_tail_comment <> '') and
                m_dictionary.lookup(local_prefix_key, local_results) then
            begin
                local_added := 0;
                for local_idx := 0 to High(local_results) do
                begin
                    if local_added >= c_raw_single_limit then
                    begin
                        Break;
                    end;

                    if Trim(local_results[local_idx].comment) <> '' then
                    begin
                        Continue;
                    end;

                    local_units := get_candidate_text_unit_count(
                        Trim(local_results[local_idx].text));
                    if local_units <> 1 then
                    begin
                        Continue;
                    end;

                    if has_same_text_tail_partial_local(local_results[local_idx].text,
                        local_tail_comment) then
                    begin
                        Continue;
                    end;

                    local_candidate := local_results[local_idx];
                    local_candidate.comment := local_tail_comment;
                    Inc(local_candidate.score, 420);
                    SetLength(candidates, Length(candidates) + 1);
                    candidates[High(candidates)] := local_candidate;
                    Inc(local_added);
                end;
            end;

            if Length(raw_syllables) < 3 then
            begin
                Exit;
            end;

            local_prefix_key := normalize_pinyin_text(raw_syllables[0].text) +
                normalize_pinyin_text(raw_syllables[1].text);
            local_tail_comment := '';
            for local_idx := 2 to High(raw_syllables) do
            begin
                local_tail_comment := local_tail_comment +
                    normalize_pinyin_text(raw_syllables[local_idx].text);
            end;

            if (m_dictionary <> nil) and (local_prefix_key <> '') and
                (local_tail_comment <> '') and
                m_dictionary.lookup(local_prefix_key, local_results) then
            begin
                local_added := 0;
                for local_idx := 0 to High(local_results) do
                begin
                    if local_added >= c_raw_phrase_limit then
                    begin
                        Break;
                    end;

                    if Trim(local_results[local_idx].comment) <> '' then
                    begin
                        Continue;
                    end;

                    local_units := get_candidate_text_unit_count(
                        Trim(local_results[local_idx].text));
                    if local_units < 2 then
                    begin
                        Continue;
                    end;

                    if has_same_text_tail_partial_local(local_results[local_idx].text,
                        local_tail_comment) then
                    begin
                        Continue;
                    end;

                    local_candidate := local_results[local_idx];
                    local_candidate.comment := local_tail_comment;
                    Inc(local_candidate.score, 640);
                    SetLength(candidates, Length(candidates) + 1);
                    candidates[High(candidates)] := local_candidate;
                    Inc(local_added);
                end;
            end;
        end;

        function has_exact_full_multi_char_phrase_local(
            const pinyin_key: string): Boolean;
        var
            local_results: TncCandidateList;
            local_idx: Integer;
        begin
            Result := False;
            if (m_dictionary = nil) or (Trim(pinyin_key) = '') or
                (not m_dictionary.lookup_exact_full_pinyin(pinyin_key, local_results)) then
            begin
                Exit;
            end;

            for local_idx := 0 to High(local_results) do
            begin
                if (Trim(local_results[local_idx].comment) = '') and
                    (get_candidate_text_unit_count(Trim(local_results[local_idx].text)) >= 2) then
                begin
                    Exit(True);
                end;
            end;
        end;

        procedure append_extendable_full_tail_partial_local;
        var
            head_query_text: string;
            local_tail_comment: string;
            local_idx: Integer;
            head_candidates: TncCandidateList;
            best_head_idx: Integer;
            local_candidate: TncCandidate;
        begin
            if Length(raw_syllables) < 2 then
            begin
                Exit;
            end;
            if tail_prefix <> '' then
            begin
                Exit;
            end;
            if not has_extendable_full_tail_query_local then
            begin
                Exit;
            end;
            if has_exact_full_multi_char_phrase_local(lookup_text) then
            begin
                Exit;
            end;

            head_query_text := '';
            for local_idx := 0 to High(raw_syllables) - 1 do
            begin
                head_query_text := head_query_text +
                    normalize_pinyin_text(raw_syllables[local_idx].text);
            end;
            local_tail_comment := normalize_pinyin_text(
                raw_syllables[High(raw_syllables)].text);
            if (head_query_text = '') or (local_tail_comment = '') then
            begin
                Exit;
            end;

            if not build_lightweight_sentence_candidates(head_query_text, head_candidates) then
            begin
                Exit;
            end;

            best_head_idx := -1;
            for local_idx := 0 to High(head_candidates) do
            begin
                if (Trim(head_candidates[local_idx].comment) = '') and
                    (get_candidate_text_unit_count(Trim(head_candidates[local_idx].text)) >= 2) then
                begin
                    best_head_idx := local_idx;
                    Break;
                end;
            end;
            if best_head_idx < 0 then
            begin
                Exit;
            end;

            if has_same_text_tail_partial_local(head_candidates[best_head_idx].text,
                local_tail_comment) then
            begin
                Exit;
            end;

            local_candidate := head_candidates[best_head_idx];
            local_candidate.comment := local_tail_comment;
            Inc(local_candidate.score, 260);
            SetLength(candidates, Length(candidates) + 1);
            for local_idx := High(candidates) downto 1 do
            begin
                candidates[local_idx] := candidates[local_idx - 1];
            end;
            candidates[0] := local_candidate;
        end;

        procedure append_raw_exact_prefix_partial_local;
        const
            c_weak_exact_prefix_anchor_weight = 300;
        var
            prefix_count: Integer;
            local_idx: Integer;
            insert_idx: Integer;
            head_key: string;
            tail_comment_local: string;
            local_results: TncCandidateList;
            local_candidate: TncCandidate;
            local_weight: Integer;
        begin
            if Length(raw_syllables) < 3 then
            begin
                Exit;
            end;

            if (tail_prefix = '') and has_exact_full_multi_char_phrase_local(lookup_text) then
            begin
                Exit;
            end;

            for prefix_count := High(raw_syllables) downto 2 do
            begin
                head_key := '';
                for local_idx := 0 to prefix_count - 1 do
                begin
                    head_key := head_key + normalize_pinyin_text(raw_syllables[local_idx].text);
                end;

                tail_comment_local := '';
                for local_idx := prefix_count to High(raw_syllables) do
                begin
                    tail_comment_local := tail_comment_local +
                        normalize_pinyin_text(raw_syllables[local_idx].text);
                end;

                if (head_key = '') or (tail_comment_local = '') then
                begin
                    Continue;
                end;
                if (m_dictionary = nil) or
                    (not m_dictionary.lookup_exact_full_pinyin(head_key, local_results)) then
                begin
                    Continue;
                end;

                for local_idx := 0 to High(local_results) do
                begin
                    if (Trim(local_results[local_idx].comment) <> '') or
                        (get_candidate_text_unit_count(Trim(local_results[local_idx].text)) < 2) then
                    begin
                        Continue;
                    end;

                    if has_same_text_tail_partial_local(local_results[local_idx].text,
                        tail_comment_local) then
                    begin
                        Break;
                    end;

                    local_candidate := local_results[local_idx];
                    local_weight := local_candidate.score;
                    if local_candidate.has_dict_weight and
                        (local_candidate.dict_weight > local_weight) then
                    begin
                        local_weight := local_candidate.dict_weight;
                    end;
                    if (local_candidate.source <> cs_user) and
                        (local_weight < c_weak_exact_prefix_anchor_weight) then
                    begin
                        Continue;
                    end;
                    local_candidate.comment := tail_comment_local;
                    Inc(local_candidate.score, 960 + (prefix_count * 80));
                    SetLength(candidates, Length(candidates) + 1);
                    for insert_idx := High(candidates) downto 1 do
                    begin
                        candidates[insert_idx] := candidates[insert_idx - 1];
                    end;
                    candidates[0] := local_candidate;
                    Exit;
                end;
            end;
        end;
    begin
        if (Length(candidates) = 0) or (input_syllable_count < 3) then
        begin
            Exit;
        end;

        if not is_top_anchor_candidate_local(candidates[0]) then
        begin
            Exit;
        end;

        visible_head_single_count := 0;
        has_visible_secondary_head_partial := False;
        for pick_index := 1 to Min(High(candidates), c_target_single_count + 1) do
        begin
            if is_head_multi_char_partial_local(candidates[pick_index]) then
            begin
                has_visible_secondary_head_partial := True;
            end;
            if is_head_single_char_partial_local(candidates[pick_index]) then
            begin
                Inc(visible_head_single_count);
            end;
        end;

        if ((not has_visible_secondary_head_partial) or
            (visible_head_single_count < 3)) and
            build_exact_leading_prefix_partial_candidates(lookup_text,
            supplemental_candidates) then
        begin
            candidates := merge_candidate_lists(candidates, supplemental_candidates, 0);
        end;
        if (visible_head_single_count < 3) and
            build_raw_leading_prefix_partial_candidates(lookup_text,
            supplemental_candidates) then
        begin
            candidates := merge_candidate_lists(candidates, supplemental_candidates, 0);
        end;

        tail_prefix := get_raw_query_tail_prefix_local;
        if ((not has_visible_secondary_head_partial) or
            (visible_head_single_count < 3)) and (tail_prefix <> '') then
        begin
            append_raw_head_prefix_partials_local;
        end;
        append_raw_exact_prefix_partial_local;
        append_extendable_full_tail_partial_local;

        if (tail_prefix <> '') and is_complete_multi_char_candidate_local(candidates[0]) and
            (get_candidate_text_unit_count(Trim(candidates[0].text)) >= 2) and
            (not has_same_text_tail_partial_local(candidates[0].text, tail_prefix)) then
        begin
            top_clone := candidates[0];
            top_clone.comment := tail_prefix;
            Inc(top_clone.score, 240);
            SetLength(candidates, Length(candidates) + 1);
            for pick_index := High(candidates) downto 1 do
            begin
                candidates[pick_index] := candidates[pick_index - 1];
            end;
            candidates[0] := top_clone;
        end;

        best_phrase_index := -1;
        best_phrase_units := -1;
        best_phrase_score := Low(Integer);
        for pick_index := 1 to High(candidates) do
        begin
            if not is_head_multi_char_partial_local(candidates[pick_index]) then
            begin
                Continue;
            end;

            candidate_units := get_candidate_text_unit_count(Trim(candidates[pick_index].text));
            if (candidate_units > best_phrase_units) or
                ((candidate_units = best_phrase_units) and
                (candidates[pick_index].score > best_phrase_score)) then
            begin
                best_phrase_index := pick_index;
                best_phrase_units := candidate_units;
                best_phrase_score := candidates[pick_index].score;
            end;
        end;

        if best_phrase_index > 1 then
        begin
            picked := candidates[best_phrase_index];
            while best_phrase_index > 1 do
            begin
                candidates[best_phrase_index] := candidates[best_phrase_index - 1];
                Dec(best_phrase_index);
            end;
            candidates[1] := picked;
            best_phrase_index := 1;
        end;

        if (best_phrase_index > 0) and (tail_prefix <> '') and
            is_complete_multi_char_candidate_local(candidates[0]) then
        begin
            top_phrase_units := get_candidate_text_unit_count(Trim(candidates[0].text));
            if (best_phrase_units >= top_phrase_units - 1) and
                is_text_prefix_local(Trim(candidates[best_phrase_index].text),
                Trim(candidates[0].text)) then
            begin
                picked := candidates[best_phrase_index];
                while best_phrase_index > 0 do
                begin
                    candidates[best_phrase_index] := candidates[best_phrase_index - 1];
                    Dec(best_phrase_index);
                end;
                candidates[0] := picked;
            end;
        end;

        if (best_phrase_index > 0) and (Trim(candidates[0].comment) <> '') then
        begin
            top_phrase_units := get_candidate_text_unit_count(Trim(candidates[0].text));
            if best_phrase_units > top_phrase_units then
            begin
                picked := candidates[best_phrase_index];
                while best_phrase_index > 0 do
                begin
                    candidates[best_phrase_index] := candidates[best_phrase_index - 1];
                    Dec(best_phrase_index);
                end;
                candidates[0] := picked;
            end;
        end;

        moved_count := 0;
        for target_index := 2 to Min(High(candidates), c_target_single_count + 1) do
        begin
            if is_head_single_char_partial_local(candidates[target_index]) then
            begin
                Inc(moved_count);
                Continue;
            end;

            pick_index := target_index + 1;
            while pick_index <= High(candidates) do
            begin
                if is_head_single_char_partial_local(candidates[pick_index]) then
                begin
                    Break;
                end;
                Inc(pick_index);
            end;

            if (pick_index < 0) or (pick_index > High(candidates)) or
                (not is_head_single_char_partial_local(candidates[pick_index])) then
            begin
                Break;
            end;

            picked := candidates[pick_index];
            while pick_index > target_index do
            begin
                candidates[pick_index] := candidates[pick_index - 1];
                Dec(pick_index);
            end;
            candidates[target_index] := picked;
            Inc(moved_count);
        end;

        if moved_count = 0 then
        begin
            Exit;
        end;
    end;

    function is_lightweight_sentence_complete_candidate_for_visibility(
        const candidate: TncCandidate): Boolean;
    var
        candidate_text_units: Integer;
        encoded_path: string;
        path_segment_count: Integer;
    begin
        Result := False;
        if (candidate.comment <> '') or candidate.has_dict_weight or
            (candidate.source = cs_user) or (input_syllable_count < 5) then
        begin
            Exit;
        end;

        candidate_text_units := get_candidate_text_unit_count(Trim(candidate.text));
        if candidate_text_units < 4 then
        begin
            Exit;
        end;

        encoded_path := get_segment_path_for_candidate(candidate);
        path_segment_count := get_encoded_path_segment_count_local(encoded_path);
        if path_segment_count < 2 then
        begin
            Exit;
        end;

        Result := get_candidate_segment_path_score_hint(candidate) > Low(Integer);
    end;

    procedure ensure_best_lightweight_sentence_candidate_visible(var candidates: TncCandidateList);
    const
        c_lightweight_segment_tiebreak_margin = 160;
    var
        best_index: Integer;
        best_score_hint: Integer;
        top_score_hint: Integer;
        best_segment_count: Integer;
        top_segment_count: Integer;
        best_candidate_score: Integer;
        top_candidate_score: Integer;
        best_visibility_adjustment: Integer;
        top_visibility_adjustment: Integer;
        idx: Integer;
        picked: TncCandidate;
        visibility_syllables: TncPinyinParseResult;

