function signed_log1p(const value: Integer): Double;
begin
    if value < 0 then
    begin
        Result := -Ln(1.0 + Abs(value));
    end
    else
    begin
        Result := Ln(1.0 + value);
    end;
end;

function character_id(const value: Char): Integer;
var
    low_idx: Integer;
    high_idx: Integer;
    mid_idx: Integer;
    codepoint: Word;
begin
    Result := 1;
    codepoint := Ord(value);
    low_idx := 0;
    high_idx := c_vocabulary_entries - 1;
    while low_idx <= high_idx do
    begin
        mid_idx := low_idx + ((high_idx - low_idx) div 2);
        if c_vocabulary_codepoints[mid_idx] = codepoint then
        begin
            Exit(c_vocabulary_ids[mid_idx]);
        end;
        if c_vocabulary_codepoints[mid_idx] < codepoint then
        begin
            low_idx := mid_idx + 1;
        end
        else
        begin
            high_idx := mid_idx - 1;
        end;
    end;
end;

function short_context_residual_score(const context_text: string;
    const candidate_text: string; const base_rank: Integer;
    const char_lm_score: Integer; const dict_weight: Integer;
    const display_score: Integer; const is_baseline: Boolean;
    const lm_delta_from_baseline: Integer;
    const weight_delta_from_baseline: Integer;
    const lm_delta_from_best: Integer; const is_lm_best: Boolean;
    const candidate_count: Integer; const context_length: Integer;
    const text_length: Integer): Double;
var
    input_values: array[0..c_input_units - 1] of Double;
    hidden_values: array[0..c_hidden_units - 1] of Double;
    context_start: Integer;
    context_count: Integer;
    context_position: Integer;
    candidate_position: Integer;
    embedding_idx: Integer;
    character_idx: Integer;
    input_idx: Integer;
    hidden_idx: Integer;
    feature_idx: Integer;
    value: Double;
begin
    input_values[0] := base_rank;
    input_values[1] := char_lm_score;
    input_values[2] := Ln(1.0 + Max(0, dict_weight));
    input_values[3] := Ln(1.0 + Max(0, display_score));
    if is_baseline then input_values[4] := 1.0 else input_values[4] := 0.0;
    input_values[5] := lm_delta_from_baseline;
    input_values[6] := signed_log1p(weight_delta_from_baseline);
    input_values[7] := lm_delta_from_best;
    if is_lm_best then input_values[8] := 1.0 else input_values[8] := 0.0;
    input_values[9] := candidate_count;
    input_values[10] := Ln(1.0 + Max(0, context_length));
    input_values[11] := text_length;
    for feature_idx := 0 to c_feature_count - 1 do
    begin
        input_values[feature_idx] :=
            (input_values[feature_idx] - c_feature_mean[feature_idx]) /
            c_feature_scale[feature_idx];
    end;

    context_count := Min(c_context_positions, Length(context_text));
    context_start := Length(context_text) - context_count + 1;
    input_idx := c_feature_count;
    for context_position := 0 to c_context_positions - 1 do
    begin
        character_idx := 0;
        if context_position >= c_context_positions - context_count then
        begin
            character_idx := character_id(context_text[context_start +
                context_position - (c_context_positions - context_count)]);
        end;
        for embedding_idx := 0 to c_embedding_units - 1 do
        begin
            input_values[input_idx] := c_context_embeddings[
                character_idx * c_embedding_units + embedding_idx];
            Inc(input_idx);
        end;
    end;
    for candidate_position := 1 to c_candidate_positions do
    begin
        character_idx := 0;
        if candidate_position <= Length(candidate_text) then
        begin
            character_idx := character_id(candidate_text[candidate_position]);
        end;
        for embedding_idx := 0 to c_embedding_units - 1 do
        begin
            input_values[input_idx] := c_candidate_embeddings[
                character_idx * c_embedding_units + embedding_idx];
            Inc(input_idx);
        end;
    end;

    for hidden_idx := 0 to c_hidden_units - 1 do
    begin
        value := c_hidden_bias[hidden_idx];
        for input_idx := 0 to c_input_units - 1 do
        begin
            value := value + c_input_weights[
                hidden_idx * c_input_units + input_idx] * input_values[input_idx];
        end;
        hidden_values[hidden_idx] := Tanh(value);
    end;
    Result := c_output_bias;
    for hidden_idx := 0 to c_hidden_units - 1 do
    begin
        Result := Result + c_output_weights[hidden_idx] * hidden_values[hidden_idx];
    end;
end;

